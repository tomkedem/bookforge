{
  "platform": "Yuval",
  "version": "1.0.0",
  "description": "Digital reading platform for Hebrew and English with mobile-first design - Technical book edition optimized for code readability and diagram clarity",
  "book": {
    "title": {
      "he": "סיכום שיעור שני - Machine Learning",
      "en": "Machine Learning Lesson 2 - Summary"
    },
    "genre": "Technical/Educational",
    "topic": "Machine Learning - Core Concepts",
    "chapters": 29,
    "special_content": ["code_blocks", "diagrams", "mathematical_notation"]
  },
  "colors": {
    "primary": {
      "main": "#1a1a1a",
      "light": "#4a4a4a",
      "lighter": "#888888",
      "lightest": "#bbbbbb"
    },
    "secondary": {
      "main": "#ffffff",
      "light": "#fafaf8",
      "lighter": "#f5f3ef"
    },
    "neutral": {
      "background": "#ffffff",
      "surface": "#fafaf8",
      "surface_alt": "#f5f3ef",
      "text_primary": "#1a1a1a",
      "text_secondary": "#4a4a4a",
      "text_tertiary": "#888888",
      "text_muted": "#bbbbbb",
      "border_subtle": "#f0ede8",
      "border_normal": "#e0ddd8",
      "border_strong": "#c8c4bc",
      "divider": "#e8e5e0"
    },
    "technical": {
      "code_bg": "#fafaf8",
      "code_border": "#e0ddd8",
      "code_text": "#1a1a1a",
      "inline_code_bg": "#f5f3ef",
      "diagram_border": "#c8c4bc"
    }
  },
  "typography": {
    "fontFamily": {
      "heading": "'Frank Ruhl Libre', Georgia, serif",
      "body": "'Heebo', system-ui, sans-serif",
      "code": "'JetBrains Mono', 'Fira Code', 'Courier New', monospace",
      "technical": "'Inter', system-ui, sans-serif"
    },
    "sizes": {
      "h1": {"size": "56px", "line_height": 1.1, "weight": 900},
      "h2": {"size": "36px", "line_height": 1.2, "weight": 700},
      "h3": {"size": "24px", "line_height": 1.3, "weight": 600},
      "h4": {"size": "20px", "line_height": 1.4, "weight": 500},
      "body_large": {"size": "18px", "line_height": 1.9, "weight": 300},
      "body_normal": {"size": "16px", "line_height": 1.8, "weight": 300},
      "body_small": {"size": "14px", "line_height": 1.7, "weight": 300},
      "code_inline": {"size": "15px", "weight": 400},
      "code_block": {"size": "14px", "line_height": 1.6, "weight": 400},
      "caption": {"size": "13px", "line_height": 1.5, "weight": 400},
      "quote": {"size": "20px", "line_height": 1.7, "weight": 300}
    }
  },
  "spacing": {
    "mobile": {
      "padding_x": "20px",
      "padding_y": "16px",
      "gap_section": "56px",
      "gap_paragraph": "24px",
      "gap_code_block": "32px",
      "gap_diagram": "40px"
    },
    "tablet": {
      "padding_x": "40px",
      "padding_y": "24px",
      "gap_section": "72px",
      "gap_paragraph": "28px",
      "gap_code_block": "40px",
      "gap_diagram": "48px"
    },
    "desktop": {
      "padding_x": "64px",
      "padding_y": "32px",
      "gap_section": "88px",
      "gap_paragraph": "32px",
      "gap_code_block": "48px",
      "gap_diagram": "56px"
    }
  },
  "components": {
    "book_card": {
      "background": "neutral_surface",
      "padding": "40px",
      "thumbnail_height": "180px",
      "title_size": "24px",
      "title_weight": 700,
      "subtitle_size": "16px",
      "description_size": "14px",
      "border": "1px solid #e0ddd8"
    },
    "reading_page": {
      "max_width": "680px",
      "paragraph_size": "16px",
      "paragraph_line_height": 1.8,
      "heading_size": "36px",
      "blockquote_border": "right",
      "blockquote_size": "20px",
      "blockquote_padding": "24px 28px"
    },
    "code_block": {
      "background": "#fafaf8",
      "border": "1px solid #e0ddd8",
      "border_radius": "8px",
      "padding": "20px",
      "font_size": "14px",
      "line_height": 1.6,
      "overflow": "auto",
      "tab_size": 2,
      "rtl_override": "ltr",
      "mobile_scroll": "horizontal"
    },
    "inline_code": {
      "background": "#f5f3ef",
      "padding": "2px 6px",
      "border_radius": "3px",
      "font_size": "15px",
      "color": "#1a1a1a"
    },
    "diagram": {
      "max_width": "100%",
      "border": "1px solid #c8c4bc",
      "border_radius": "4px",
      "padding": "16px",
      "background": "#ffffff",
      "caption_size": "13px",
      "caption_color": "#4a4a4a",
      "caption_align": "center",
      "mobile_scroll": "horizontal_if_needed"
    },
    "language_toggle": {
      "border_radius": "24px",
      "padding": "4px",
      "button_padding": "4px 14px",
      "background": "#f5f3ef"
    },
    "header": {
      "position": "sticky",
      "height": "64px",
      "background": "rgba(255, 255, 255, 0.96)",
      "backdrop_filter": "blur(16px)",
      "border_bottom": "1px solid #e8e5e0"
    },
    "table_of_contents": {
      "font_size": "15px",
      "line_height": 1.6,
      "padding": "12px 16px",
      "active_border": "3px solid #1a1a1a",
      "hover_background": "#fafaf8"
    },
    "list": {
      "item_spacing": "12px",
      "indent": "24px",
      "marker_color": "#4a4a4a"
    }
  },
  "breakpoints": {
    "mobile": "< 640px",
    "tablet": "640px - 1024px",
    "desktop": "> 1024px"
  },
  "rtl": {
    "languages": ["Hebrew"],
    "direction": "rtl",
    "text_align": "right",
    "exceptions": ["code", "diagrams", "mathematical_notation"]
  },
  "ltr": {
    "languages": ["English"],
    "direction": "ltr",
    "text_align": "left",
    "forced_elements": ["code", "pre", "code_block", "formula"]
  },
  "features": {
    "reading_progress": {
      "description": "User continues reading from exact position on any device",
      "display": "progress_bar_under_header",
      "color": "#1a1a1a",
      "height": "3px"
    },
    "share_quote": {
      "description": "Highlight text to create shareable quote image",
      "output_format": "PNG",
      "include_context": true
    },
    "multi_language": {
      "enabled": true,
      "languages": ["Hebrew", "English"],
      "toggle_location": "header_right",
      "sync_position": true
    },
    "code_copy": {
      "enabled": true,
      "button_position": "top_right",
      "feedback": "tooltip"
    },
    "diagram_zoom": {
      "enabled": true,
      "trigger": "tap_or_click",
      "overlay_background": "rgba(255, 255, 255, 0.95)"
    }
  },
  "accessibility": {
    "contrast_ratio": "WCAG AA minimum (4.5:1 for normal text, 3:1 for large text)",
    "focus_outline": "2px solid #1a1a1a",
    "focus_offset": "2px",
    "skip_links": true,
    "aria_labels": "comprehensive",
    "keyboard_navigation": "full_support"
  },
  "rules": {
    "color_palette": "Black, white, gray only - clean technical aesthetic",
    "max_colors": 2,
    "forbidden": ["blue", "green", "red", "orange", "gradients_except_overlays"],
    "required_fonts": [
      "Frank Ruhl Libre for headings",
      "Heebo for body text",
      "JetBrains Mono for code"
    ],
    "code_formatting": "Always LTR, horizontal scroll on mobile, clear indentation",
    "diagram_handling": "Ensure visibility on small screens, provide zoom capability",
    "spacing_principle": "Extra whitespace between sections for technical content clarity",
    "mobile_first": "Design for 360px width first, then scale up"
  },
  "technical_notes": {
    "code_syntax_highlighting": "Use simple black/gray highlighting to maintain B&W aesthetic",
    "diagram_formats": "Support SVG for scalability, PNG for raster images",
    "mathematical_notation": "Use Unicode or simple ASCII art where possible, consider MathJax if complex formulas present",
    "tables": "Stack on mobile, side-scroll on overflow, clear headers",
    "footnotes": "Display inline on mobile, sidebar on desktop if space allows",
    "performance": "Lazy load images and diagrams, prioritize above-fold content"
  }
}
