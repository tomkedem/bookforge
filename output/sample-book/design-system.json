{
  "platform": "Yuval",
  "version": "1.0.0",
  "description": "Digital reading platform for Hebrew and English with mobile-first design",
  "colors": {
    "primary": {
      "main": "#1a1a1a",
      "light": "#4a4a4a",
      "lighter": "#888888",
      "lightest": "#bbbbbb"
    },
    "secondary": {
      "main": "#ffffff",
      "light": "#fafaf8",
      "lighter": "#f5f3ef"
    },
    "neutral": {
      "background": "#ffffff",
      "surface": "#fafaf8",
      "surface_alt": "#f5f3ef",
      "text_primary": "#1a1a1a",
      "text_secondary": "#4a4a4a",
      "text_tertiary": "#888888",
      "text_muted": "#bbbbbb",
      "border_subtle": "#f0ede8",
      "border_normal": "#e0ddd8",
      "border_strong": "#c8c4bc",
      "divider": "#e8e5e0"
    }
  },
  "typography": {
    "fontFamily": {
      "heading": "'Frank Ruhl Libre', Georgia, serif",
      "body": "'Heebo', system-ui, sans-serif",
      "code": "'JetBrains Mono', 'Fira Code', monospace"
    },
    "sizes": {
      "h1": {"size": "64px", "line_height": 1.05, "weight": 900},
      "h2": {"size": "40px", "line_height": 1.1, "weight": 700},
      "h3": {"size": "26px", "line_height": 1.3, "weight": 400},
      "body_large": {"size": "18px", "line_height": 1.9, "weight": 300},
      "body_normal": {"size": "15px", "line_height": 1.7, "weight": 300},
      "quote": {"size": "22px", "line_height": 1.6, "weight": 300}
    }
  },
  "spacing": {
    "mobile": {
      "padding_x": "24px",
      "padding_y": "16px",
      "gap_section": "48px"
    },
    "tablet": {
      "padding_x": "40px",
      "padding_y": "24px",
      "gap_section": "56px"
    },
    "desktop": {
      "padding_x": "64px",
      "padding_y": "32px",
      "gap_section": "72px"
    }
  },
  "components": {
    "book_card": {
      "background": "dominant_color_overlay",
      "padding": "44px",
      "thumbnail_height": "200px",
      "title_size": "26px",
      "title_weight": 700,
      "description_size": "14px"
    },
    "reading_page": {
      "max_width": "620px",
      "paragraph_size": "18px",
      "paragraph_line_height": 1.9,
      "heading_size": "48px",
      "blockquote_border": "right",
      "blockquote_size": "22px"
    },
    "language_toggle": {
      "border_radius": "24px",
      "padding": "4px",
      "button_padding": "4px 14px"
    },
    "header": {
      "position": "sticky",
      "height": "68px",
      "background": "rgba(255, 255, 255, 0.95)",
      "backdrop_filter": "blur(12px)"
    }
  },
  "breakpoints": {
    "mobile": "< 640px",
    "tablet": "640px - 1024px",
    "desktop": "> 1024px"
  },
  "rtl": {
    "languages": ["Hebrew"],
    "direction": "rtl",
    "text_align": "right"
  },
  "ltr": {
    "languages": ["English", "Code"],
    "direction": "ltr",
    "text_align": "left"
  },
  "features": {
    "reading_progress": {
      "description": "User continues reading from exact position on any device",
      "display": "progress_bar_under_header"
    },
    "share_quote": {
      "description": "Highlight text to create shareable quote image",
      "output_format": "PNG"
    },
    "multi_language": {
      "enabled": true,
      "languages": ["Hebrew", "English"],
      "toggle_location": "header_right"
    }
  },
  "rules": {
    "color_palette": "Black, white, gray only",
    "max_colors": 2,
    "forbidden": ["blue", "green", "red", "orange", "gradients_except_overlays"],
    "required_fonts": ["Frank Ruhl Libre for headings", "Heebo for body"],
    "accessibility": "WCAG AA minimum contrast"
  }
}
