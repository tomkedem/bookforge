---
interface Props {
  bookId: string;
  chapterIndex: number;
  totalChapters: number;
}

const { bookId, chapterIndex, totalChapters } = Astro.props;
---

<div id="reading-progress-bar" class="fixed top-0 right-0 left-0 h-1 bg-gray-100 z-50" role="progressbar" aria-valuemin={0} aria-valuemax={100} aria-valuenow={0}>
  <div id="reading-progress-fill" class="h-full bg-blue-600 transition-all duration-150 ease-out w-0"></div>
</div>

<script define:vars={{ bookId, chapterIndex, totalChapters }}>
  const COOKIE_KEY = `yuval-progress-${bookId}`;

  function saveProgress(scrollPosition: number) {
    const data = { chapter: chapterIndex, scrollPosition };
    localStorage.setItem(COOKIE_KEY, JSON.stringify(data));
  }

  function updateBar() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0;

    const fill = document.getElementById('reading-progress-fill');
    const bar = document.getElementById('reading-progress-bar');
    if (fill) fill.style.width = `${pct}%`;
    if (bar) bar.setAttribute('aria-valuenow', String(Math.round(pct)));

    saveProgress(scrollTop);
  }

  // Offer to restore previous scroll position — ask user first (WCAG 2.3)
  const saved = localStorage.getItem(COOKIE_KEY);
  if (saved) {
    try {
      const { chapter, scrollPosition } = JSON.parse(saved);
      if (chapter === chapterIndex && scrollPosition > 100) {
        const banner = document.createElement('div');
        banner.id = 'resume-banner';
        banner.setAttribute('role', 'alert');
        banner.className = 'fixed bottom-4 right-4 z-50 bg-gray-900 text-white text-sm px-4 py-3 rounded-lg shadow-lg flex items-center gap-3';
        banner.innerHTML = `
          <span>המשך מהמקום שעצרת?</span>
          <button id="resume-yes" class="underline font-medium">המשך</button>
          <button id="resume-no" class="text-gray-400 hover:text-white">×</button>
        `;
        document.body.appendChild(banner);
        document.getElementById('resume-yes')?.addEventListener('click', () => {
          window.scrollTo({ top: scrollPosition, behavior: 'smooth' });
          banner.remove();
        });
        document.getElementById('resume-no')?.addEventListener('click', () => banner.remove());
      }
    } catch {}
  }

  window.addEventListener('scroll', updateBar, { passive: true });
  updateBar();
</script>
