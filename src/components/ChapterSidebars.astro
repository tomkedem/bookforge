---
import type { Language, Chapter } from '../types/index';
import { LANGUAGES } from '../utils/language';

interface Props {
  chapters: Chapter[];
  currentChapterId: number;
  bookSlug: string;
  language?: Language;
}

const { chapters, currentChapterId, bookSlug, language = LANGUAGES.EN } = Astro.props;
const isRtl = language === LANGUAGES.HE;
---

<div class="sidebars-container" transition:persist="sidebars">
  <!-- Mobile TOC toggle button -->
  <button
    id="mobile-toc-toggle"
    class="mobile-toc-btn"
    aria-label={language === LANGUAGES.HE ? 'פתח ניווט' : 'Open navigation'}
    aria-expanded="false"
  >
    <span class="mobile-toc-btn-glow"></span>
    <span class="mobile-toc-btn-ring"></span>
    <svg class="mobile-toc-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>

  <!-- Mobile overlay -->
  <div id="mobile-sidebar-overlay" class="mobile-overlay"></div>

  <!-- Mobile combined drawer (outline + TOC) -->
  <div id="mobile-drawer" class="mobile-drawer">
    <!-- Tab buttons -->
    <div class="mobile-drawer-tabs" role="tablist">
      <button class="mobile-tab active" data-tab="outline" role="tab" aria-selected="true" aria-controls="mobile-outline-panel">
        <span data-i18n="sidebar.inChapter">In This Chapter</span>
      </button>
      <button class="mobile-tab" data-tab="chapters" role="tab" aria-selected="false" aria-controls="mobile-chapters-panel">
        <span data-i18n="sidebar.chapters">Chapters</span>
      </button>
    </div>
    <!-- Outline panel -->
    <div class="mobile-panel active" id="mobile-outline-panel" role="tabpanel">
      <nav id="mobile-chapter-outline" class="outline-list">
        <ul></ul>
      </nav>
    </div>
    <!-- Chapters panel -->
    <div class="mobile-panel" id="mobile-chapters-panel" role="tabpanel">
      <nav class="toc-list">
        <ul>
          {chapters.map((chapter) => (
            <li
              class:list={[
                'toc-item',
                chapter.id === currentChapterId && 'toc-item-active',
              ]}
            >
              <a
                href={`/read/${bookSlug}/${chapter.id}`}
                class:list={[
                  'toc-link',
                  'mobile-toc-link',
                  chapter.id === currentChapterId && 'toc-link-active',
                ]}
              >
                <span class="toc-number">
                  {String(chapter.id).padStart(2, '0')}
                </span>
                <span class="toc-chapter-title">
                  <span data-he={chapter.title_he} data-en={chapter.title_en} data-es={chapter.title_es || chapter.title_en}>
                    {language === LANGUAGES.HE ? chapter.title_he : language === 'es' ? (chapter.title_es || chapter.title_en) : chapter.title_en}
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>

  <!-- Right Sidebar: Table of Contents (כל הפרקים) -->
  <aside
    class:list={[
      'toc-sidebar',
      'toc-sidebar-right',
      isRtl && 'toc-sidebar-rtl',
    ]}
    id="toc-sidebar"
    data-rtl={isRtl}
    aria-label={language === LANGUAGES.HE ? 'תוכן עניינים' : language === 'es' ? 'Tabla de Contenidos' : 'Table of Contents'}
  >
    <h3 class="toc-title">
      <span data-i18n="sidebar.chapters">Chapters</span>
    </h3>
    <nav class="toc-list">
      <ul>
        {chapters.map((chapter) => (
          <li
            class:list={[
              'toc-item',
              chapter.id === currentChapterId && 'toc-item-active',
            ]}
            data-chapter-id={chapter.id}
          >
            <a
              href={`/read/${bookSlug}/${chapter.id}`}
              class:list={[
                'toc-link',
                chapter.id === currentChapterId && 'toc-link-active',
              ]}
              aria-current={chapter.id === currentChapterId ? 'page' : undefined}
              data-chapter-id={chapter.id}
            >
              <span class="toc-number">
                {String(chapter.id).padStart(2, '0')}
              </span>
              <span class="toc-chapter-title">
                <span data-he={chapter.title_he} data-en={chapter.title_en} data-es={chapter.title_es || chapter.title_en}>
                  {language === LANGUAGES.HE
                    ? chapter.title_he
                    : language === 'es'
                      ? (chapter.title_es || chapter.title_en)
                      : chapter.title_en}
                </span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>

  <!-- Left Sidebar: Chapter Outline (headings של הפרק) -->
  <aside
    class:list={[
      'outline-sidebar',
      'outline-sidebar-left',
      isRtl && 'outline-sidebar-rtl',
    ]}
    id="outline-sidebar"
    data-rtl={isRtl}
    aria-label={language === LANGUAGES.HE ? 'מתוכן הפרק' : language === 'es' ? 'Esquema del Capítulo' : 'Chapter Outline'}
  >
    <h3 class="outline-title">
      <span data-i18n="sidebar.inChapter">In This Chapter</span>
    </h3>
    <nav id="chapter-outline" class="outline-list">
      <ul>
        {/* Outline will be populated by JavaScript from h2/h3 tags */}
      </ul>
    </nav>
  </aside>
</div>

<style>
  .sidebars-container {
    position: relative;
    width: 100%;
  }

  /* TOC Sidebar — LEFT in English, RIGHT in Hebrew */
  .toc-sidebar {
    position: fixed;
    top: 68px;
    left: 0;
    right: auto;
    width: 320px;
    height: calc(100vh - 68px);
    background: var(--yuval-surface);
    border-right: 1px solid var(--yuval-border);
    border-left: none;
    padding: 24px 16px;
    overflow-y: auto;
    z-index: 30;
    font-size: 13px;
    line-height: 1.4;
  }

  .toc-sidebar-rtl {
    left: auto;
    right: 0;
    border-right: none;
    border-left: 1px solid var(--yuval-border);
  }

  .toc-title {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: var(--yuval-text-muted);
    text-transform: uppercase;
    margin-bottom: 16px;
    padding: 0 4px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .toc-title::before {
    content: '';
    width: 16px;
    height: 2px;
    background: linear-gradient(to right, #c9a227, transparent);
    border-radius: 1px;
  }

  :global(.dark) .toc-title::before {
    background: linear-gradient(to right, #8b7355, transparent);
  }

  .toc-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .toc-item {
    position: relative;
    margin-bottom: 0;
    border-radius: 10px;
    overflow: hidden;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .toc-item:hover {
    transform: translateX(-2px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .toc-sidebar-rtl .toc-item:hover {
    transform: translateX(2px);
  }

  .toc-item-active {
    background: linear-gradient(135deg, 
      rgba(201, 162, 39, 0.12) 0%,
      rgba(201, 162, 39, 0.06) 100%
    );
    box-shadow: 
      0 2px 12px rgba(201, 162, 39, 0.15),
      inset 0 0 0 1px rgba(201, 162, 39, 0.25);
  }

  .toc-item-active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(to bottom, #e8c547, #c9a227, #a8852a);
    border-radius: 0 3px 3px 0;
  }

  .toc-sidebar-rtl .toc-item-active::before {
    left: auto;
    right: 0;
    border-radius: 3px 0 0 3px;
  }

  /* Reading indicator dot for active chapter */
  .toc-item-active::after {
    content: '';
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 8px;
    height: 8px;
    background: #c9a227;
    border-radius: 50%;
    animation: reading-pulse 2s ease-in-out infinite;
    box-shadow: 0 0 8px rgba(201, 162, 39, 0.6);
  }

  .toc-sidebar-rtl .toc-item-active::after {
    right: auto;
    left: 12px;
  }

  @keyframes reading-pulse {
    0%, 100% { 
      opacity: 1; 
      transform: translateY(-50%) scale(1);
    }
    50% { 
      opacity: 0.6; 
      transform: translateY(-50%) scale(0.85);
    }
  }

  :global(.dark) .toc-item-active {
    background: linear-gradient(135deg, 
      rgba(139, 115, 85, 0.18) 0%,
      rgba(139, 115, 85, 0.08) 100%
    );
    box-shadow: 
      0 2px 12px rgba(139, 115, 85, 0.2),
      inset 0 0 0 1px rgba(139, 115, 85, 0.3);
  }

  :global(.dark) .toc-item-active::before {
    background: linear-gradient(to bottom, #a8956d, #8b7355, #6d5a42);
  }

  :global(.dark) .toc-item-active::after {
    background: #a8956d;
    box-shadow: 0 0 8px rgba(168, 149, 109, 0.6);
  }

  .toc-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    color: var(--yuval-text-tertiary);
    text-decoration: none;
    transition: all 0.2s ease;
    border-radius: 10px;
  }

  .toc-link:hover {
    color: var(--yuval-text);
    background: rgba(0, 0, 0, 0.03);
  }

  :global(.dark) .toc-link:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .toc-link-active {
    color: var(--yuval-text);
    font-weight: 600;
    padding-right: 28px; /* Space for reading dot */
  }

  .toc-sidebar-rtl .toc-link-active {
    padding-right: 12px;
    padding-left: 28px;
  }

  .toc-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: var(--yuval-bg-secondary);
    border-radius: 6px;
    color: var(--yuval-text-muted);
    font-size: 11px;
    font-weight: 600;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .toc-item-active .toc-number {
    background: linear-gradient(135deg, #c9a227, #a8852a);
    color: #fff;
    box-shadow: 0 2px 6px rgba(201, 162, 39, 0.35);
  }

  :global(.dark) .toc-item-active .toc-number {
    background: linear-gradient(135deg, #8b7355, #6d5a42);
    box-shadow: 0 2px 6px rgba(139, 115, 85, 0.4);
  }

  .toc-link:hover .toc-number {
    transform: scale(1.05);
  }

  .toc-chapter-title {
    flex: 1;
    font-size: 12.5px;
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .toc-item-active .toc-chapter-title {
    color: var(--yuval-chapter-title);
  }

  /* Completed chapter styling */
  .toc-item-completed .toc-number {
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: #fff;
    box-shadow: 0 2px 6px rgba(34, 197, 94, 0.3);
  }

  :global(.dark) .toc-item-completed .toc-number {
    background: linear-gradient(135deg, #4ade80, #22c55e);
    box-shadow: 0 2px 6px rgba(74, 222, 128, 0.35);
  }

  /* Completed chapter checkmark */
  .toc-item-completed .toc-link {
    display: flex;
    align-items: center;
  }

  .chapter-complete-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.15), rgba(34, 197, 94, 0.05));
    border-radius: 50%;
    color: #22c55e;
    font-weight: 700;
    font-size: 11px;
    margin-inline-start: auto;
    flex-shrink: 0;
  }

  :global(.dark) .chapter-complete-check {
    background: linear-gradient(135deg, rgba(74, 222, 128, 0.2), rgba(74, 222, 128, 0.08));
    color: #4ade80;
  }

  /* Progress bar under chapter */
  .toc-progress-bar {
    position: absolute;
    bottom: 0;
    left: 12px;
    right: 12px;
    height: 2px;
    background: var(--yuval-border);
    border-radius: 1px;
    overflow: hidden;
    opacity: 0.6;
  }

  .toc-progress-fill {
    height: 100%;
    background: linear-gradient(to right, #c9a227, #e8c547);
    border-radius: 1px;
    transition: width 0.3s ease;
  }

  :global(.dark) .toc-progress-fill {
    background: linear-gradient(to right, #8b7355, #a8956d);
  }

  /* Outline Sidebar — RIGHT in English, LEFT in Hebrew */
  .outline-sidebar {
    position: fixed;
    top: 68px;
    right: 0;
    left: auto;
    width: 320px;
    height: calc(100vh - 68px);
    background: var(--yuval-surface);
    border-left: 1px solid var(--yuval-border);
    border-right: none;
    padding: 24px 16px;
    overflow-y: auto;
    z-index: 30;
    font-size: 13px;
    line-height: 1.5;
  }

  .outline-sidebar-rtl {
    right: auto;
    left: 0;
    border-left: none;
    border-right: 1px solid var(--yuval-border);
  }

  .outline-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--yuval-text-muted);
    text-transform: uppercase;
    margin-bottom: 16px;
    padding: 0;
  }

  .outline-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .outline-list li {
    margin-bottom: 0;
    border-bottom: 1px solid var(--yuval-toc-item-border);
  }

  .outline-list a {
    display: block;
    padding: 8px 0;
    color: var(--yuval-text-tertiary);
    text-decoration: none;
    font-size: 12px;
    word-break: break-word;
    transition: color 0.2s;
  }

  .outline-list a:hover {
    color: var(--yuval-text);
  }

  /* Indentation for nested headings */
  .outline-list li[data-level="h3"] a {
    padding-left: 12px;
    padding-right: 0;
  }

  .outline-list li[data-level="h3"].outline-sidebar-rtl a {
    padding-left: 0;
    padding-right: 12px;
  }

  /* ── Smooth transition for immersive mode ── */
  .toc-sidebar {
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.35s ease;
  }
  .outline-sidebar {
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.35s ease;
  }

  /* ── Immersive mode: sidebars slide off screen ── */
  :global(body.reading-immersive) .toc-sidebar:not(.toc-sidebar-rtl) {
    transform: translateX(-100%);
    pointer-events: none;
  }
  :global(body.reading-immersive) .toc-sidebar-rtl {
    transform: translateX(100%);
    pointer-events: none;
  }
  :global(body.reading-immersive) .outline-sidebar:not(.outline-sidebar-rtl) {
    transform: translateX(100%);
    pointer-events: none;
  }
  :global(body.reading-immersive) .outline-sidebar-rtl {
    transform: translateX(-100%);
    pointer-events: none;
  }

  /* ── Peek on hover at screen edges ── */
  :global(body.reading-immersive) .toc-sidebar:not(.toc-sidebar-rtl):hover,
  :global(body.reading-immersive) .toc-sidebar-rtl:hover,
  :global(body.reading-immersive) .outline-sidebar:not(.outline-sidebar-rtl):hover,
  :global(body.reading-immersive) .outline-sidebar-rtl:hover {
    transform: translateX(0);
    pointer-events: auto;
    opacity: 1;
  }

  /* ── Edge peek trigger zones ── */
  .toc-sidebar::before,
  .outline-sidebar::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 16px;
    z-index: 1;
  }
  .toc-sidebar:not(.toc-sidebar-rtl)::before { right: -16px; }
  .toc-sidebar-rtl::before { left: -16px; }
  .outline-sidebar:not(.outline-sidebar-rtl)::before { left: -16px; }
  .outline-sidebar-rtl::before { right: -16px; }

  /* Scrollbar styling */
  .toc-sidebar::-webkit-scrollbar,
  .outline-sidebar::-webkit-scrollbar {
    width: 4px;
  }

  .toc-sidebar::-webkit-scrollbar-track,
  .outline-sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .toc-sidebar::-webkit-scrollbar-thumb,
  .outline-sidebar::-webkit-scrollbar-thumb {
    background: #e0ddd8;
    border-radius: 2px;
  }

  .toc-sidebar::-webkit-scrollbar-thumb:hover,
  .outline-sidebar::-webkit-scrollbar-thumb:hover {
    background: #c8c4bc;
  }

  /* Mobile: hide sidebars on small screens */
  @media (max-width: 1023px) {
    .toc-sidebar,
    .outline-sidebar {
      display: none;
    }
  }

  /* Mobile drawer (combined outline+chapters) */
  .mobile-drawer {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    max-height: 70vh;
    background: var(--yuval-surface);
    z-index: 60;
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.15);
    overflow: hidden;
    flex-direction: column;
  }

  .mobile-drawer.open {
    display: flex;
    animation: slideUp 0.25s ease-out;
  }

  .mobile-drawer-tabs {
    display: flex;
    border-bottom: 1px solid var(--yuval-border);
    flex-shrink: 0;
  }

  .mobile-tab {
    flex: 1;
    padding: 12px 8px;
    font-size: 13px;
    font-weight: 500;
    color: var(--yuval-text-tertiary);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }

  .mobile-tab.active {
    color: var(--yuval-text);
    border-bottom-color: var(--yuval-toc-active);
  }

  .mobile-panel {
    display: none;
    overflow-y: auto;
    padding: 12px 16px;
    flex: 1;
  }

  .mobile-panel.active {
    display: block;
  }

  .mobile-toc-btn {
    display: none;
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 50;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #8b5cf6, #a78bfa);
    color: #ffffff;
    border: none;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 4px 15px rgba(99, 102, 241, 0.4),
      0 8px 30px rgba(139, 92, 246, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s;
    overflow: visible;
  }

  .mobile-toc-btn:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow:
      0 8px 25px rgba(99, 102, 241, 0.5),
      0 12px 40px rgba(139, 92, 246, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }

  .mobile-toc-btn:active {
    transform: scale(0.92);
    box-shadow:
      0 2px 8px rgba(99, 102, 241, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
  }

  .mobile-toc-btn-glow {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, #6366f1, #a78bfa, #c4b5fd, #6366f1);
    opacity: 0.5;
    filter: blur(8px);
    animation: btnGlowSpin 4s linear infinite;
    z-index: -1;
  }

  .mobile-toc-btn-ring {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 2px solid rgba(139, 92, 246, 0.3);
    animation: btnRingPulse 2.5s ease-in-out infinite;
    pointer-events: none;
  }

  .mobile-toc-icon {
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.2));
  }

  @keyframes btnGlowSpin {
    to { transform: rotate(360deg); }
  }

  @keyframes btnRingPulse {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.15); opacity: 0; }
  }

  @media (max-width: 1023px) {
    .mobile-toc-btn {
      display: flex;
    }
  }

  :global(.dark) .mobile-toc-btn {
    background: linear-gradient(135deg, #7c3aed, #6366f1, #818cf8);
    box-shadow:
      0 4px 15px rgba(124, 58, 237, 0.45),
      0 8px 30px rgba(99, 102, 241, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  :global(.dark) .mobile-toc-btn:hover {
    box-shadow:
      0 8px 25px rgba(124, 58, 237, 0.55),
      0 12px 40px rgba(99, 102, 241, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
  }

  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 55;
  }

  .mobile-overlay.active {
    display: block;
  }

  @keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }

  /* Adjust main content when sidebars visible */
  :global(.reading-page-with-sidebars) {
    margin-left: 260px;
    margin-right: 260px;
  }

  :global(.reading-page-with-sidebars[dir='rtl']) {
    margin-left: 260px;
    margin-right: 260px;
  }
</style>

<script>
  /**
   * Get the current active language from URL or localStorage
   */
  function getCurrentLang(): string {
    const urlParams = new URLSearchParams(window.location.search);
    return urlParams.get('lang') || localStorage.getItem('yuval_language') || 'en';
  }

  /**
   * Get the current chapter ID from the URL
   */
  function getCurrentChapterId(): number | null {
    const match = window.location.pathname.match(/\/read\/[^/]+\/(\d+)/);
    return match ? parseInt(match[1], 10) : null;
  }

  /**
   * Update the active chapter highlighting in TOC based on current URL.
   * Called after navigation when using transition:persist.
   */
  function updateActiveChapter() {
    const currentId = getCurrentChapterId();
    if (currentId === null) return;

    // Update desktop TOC
    document.querySelectorAll('.toc-item').forEach(item => {
      const chapterId = parseInt((item as HTMLElement).dataset.chapterId || '0', 10);
      const link = item.querySelector('.toc-link');
      
      if (chapterId === currentId) {
        item.classList.add('toc-item-active');
        link?.classList.add('toc-link-active');
        link?.setAttribute('aria-current', 'page');
      } else {
        item.classList.remove('toc-item-active');
        link?.classList.remove('toc-link-active');
        link?.removeAttribute('aria-current');
      }
    });

    // Update mobile TOC
    document.querySelectorAll('.mobile-toc-link').forEach(link => {
      const href = link.getAttribute('href') || '';
      const match = href.match(/\/read\/[^/]+\/(\d+)/);
      const chapterId = match ? parseInt(match[1], 10) : 0;
      
      const item = link.closest('.toc-item');
      if (chapterId === currentId) {
        item?.classList.add('toc-item-active');
        link.classList.add('toc-link-active');
      } else {
        item?.classList.remove('toc-item-active');
        link.classList.remove('toc-link-active');
      }
    });
  }

  /**
   * Load chapter content via fetch without full page navigation.
   * INSTANT swap - no animation, no scroll visible.
   */
  async function loadChapterContent(url: string): Promise<void> {
    const container = document.getElementById('chapter-container');
    const header = document.getElementById('chapter-header');

    if (!container) { window.location.href = url; return; }

    // Fade out only the content — sidebars and header stay put
    container.style.transition = 'opacity 0.1s ease';
    container.style.opacity = '0';

    try {
      const response = await fetch(url);
      if (!response.ok) throw new Error('Failed to fetch chapter');

      const html = await response.text();
      const doc = new DOMParser().parseFromString(html, 'text/html');

      const newContainer = doc.getElementById('chapter-container');
      const newHeader = doc.getElementById('chapter-header');

      // Scroll to top while content is transparent
      window.scrollTo({ top: 0, behavior: 'instant' });

      // Swap content
      if (newContainer) {
        container.innerHTML = newContainer.innerHTML;
        container.dataset.chapterId = newContainer.dataset.chapterId || '';
        container.dataset.book = newContainer.dataset.book || '';
      }
      if (newHeader && header) {
        header.innerHTML = newHeader.innerHTML;
      }

      // Apply language, update URL and TOC
      applyLanguageVisibility(getCurrentLang());
      history.pushState({}, '', url);
      updateActiveChapter();
      buildChapterOutline();

      // Notify other scripts that new chapter content is in the DOM
      window.dispatchEvent(new CustomEvent('chapter-content-swapped'));

      // Fade content back in
      container.style.opacity = '1';

    } catch (error) {
      console.error('Error loading chapter:', error);
      container.style.opacity = '1';
      window.location.href = url;
    }
  }

  /**
   * Apply language visibility to content divs
   */
  function applyLanguageVisibility(lang: string) {
    document.querySelectorAll('[data-lang]').forEach(el => {
      const elLang = (el as HTMLElement).dataset.lang;
      if (elLang === lang) {
        el.classList.remove('hidden');
        el.classList.add('visible');
      } else {
        el.classList.add('hidden');
        el.classList.remove('visible');
      }
    });
  }

  // Expose for keyboard navigation and other modules
  (window as any).yuvalLoadChapter = loadChapterContent;

  /**
   * TOC navigation — uses fetch to load content without page navigation.
   */
  function initTocNavigation() {
    // Must target the desktop sidebar specifically — there are multiple .toc-list
    // elements in the DOM (mobile drawer + desktop sidebar) and querySelector
    // returns the first one (mobile), leaving desktop links without a handler.
    const tocSidebar = document.getElementById('toc-sidebar');
    if (!tocSidebar || tocSidebar.dataset.navInit === 'true') return;
    tocSidebar.dataset.navInit = 'true';

    tocSidebar.addEventListener('click', async (e) => {
      const target = (e.target as HTMLElement).closest('a.toc-link') as HTMLAnchorElement | null;
      if (!target) return;

      e.preventDefault();

      // No ?lang= needed - language determined by toggle position
      const url = target.getAttribute('href')?.split('?')[0] || '';

      await loadChapterContent(url);
    });
  }

  // Handle browser back/forward buttons
  window.addEventListener('popstate', async () => {
    await loadChapterContent(window.location.href);
  });

  /**
   * Update sidebar text based on current language
   */
  function updateSidebarText(lang: string) {
    // data-i18n elements (sidebar titles) are handled by applyLanguageToPage().
    // Only dynamic content (chapter titles from MD) needs manual update here.
    document.querySelectorAll('.toc-chapter-title span[data-he]').forEach((span) => {
      const heText = span.getAttribute('data-he');
      const enText = span.getAttribute('data-en');
      const esText = span.getAttribute('data-es');
      if (lang === 'he') {
        span.textContent = heText;
      } else if (lang === 'es') {
        span.textContent = esText || enText;
      } else {
        span.textContent = enText;
      }
    });
  }

  /**
   * Build chapter outline from h2/h3 headings
   * Searches for headings in the chapter content divs
   */
  function buildChapterOutline() {
    const outline = document.getElementById('chapter-outline');
    if (!outline) return;

    // Clear existing outline
    const ul = outline.querySelector('ul');
    if (ul) {
      ul.innerHTML = '';
    }

    // Find the chapter container
    const container = document.getElementById('chapter-container');
    if (!container) return;

    // Find visible content div by data-lang attribute
    const heDiv = container.querySelector('[data-lang="he"]');
    const enDiv = container.querySelector('[data-lang="en"]');

    let contentDiv = null;
    if (heDiv && window.getComputedStyle(heDiv).display !== 'none') {
      contentDiv = heDiv;
    } else if (enDiv && window.getComputedStyle(enDiv).display !== 'none') {
      contentDiv = enDiv;
    }

    if (!contentDiv) return;

    // Get all h2 and h3 elements from the content
    const headings = Array.from(contentDiv.querySelectorAll('h2, h3'));

    if (headings.length === 0) {
      // If no headings found, show message
      const li = document.createElement('li');
      li.style.color = '#cccccc';
      li.style.fontSize = '12px';
      li.textContent = 'No sections found';
      if (ul) ul.appendChild(li);
      return;
    }

    headings.forEach((heading, index) => {
      const level = heading.tagName.toLowerCase();
      const text = heading.textContent?.trim() || `Section ${index + 1}`;
      const id = `section-${index}`;

      // Add id to heading
      heading.id = id;

      // Create outline item
      const li = document.createElement('li');
      li.setAttribute('data-level', level);

      const link = document.createElement('a');
      link.href = `#${id}`;
      link.textContent = text;
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(id);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      li.appendChild(link);
      if (ul) ul.appendChild(li);
    });
  }

  /**
   * TOC links no longer need ?lang= - language is determined by toggle position
   */
  function updateTocLinks(lang: string) {
    // Links are now clean URLs without ?lang= parameter
    // Language is determined solely by the toggle position in localStorage
  }

  /**
   * Swap sidebar positions based on language:
   *  EN: TOC left, Outline right
   *  HE: TOC right, Outline left
   */
  function updateSidebarPositions(lang: string) {
    const toc = document.getElementById('toc-sidebar');
    const outline = document.getElementById('outline-sidebar');
    if (!toc || !outline) return;

    if (lang === 'he') {
      toc.classList.add('toc-sidebar-rtl');
      outline.classList.add('outline-sidebar-rtl');
    } else {
      toc.classList.remove('toc-sidebar-rtl');
      outline.classList.remove('outline-sidebar-rtl');
    }
  }

  /**
   * Initialize sidebars on page load and when language changes
   */
  function initializeSidebars(lang?: string) {
    // Language determined only from localStorage (toggle position)
    if (!lang) {
      lang = localStorage.getItem('yuval_language') || 'en';
    }

    // Update text
    updateSidebarText(lang);

    // Update TOC link hrefs
    updateTocLinks(lang);

    // Swap sidebar positions
    updateSidebarPositions(lang);

    // Initialize click navigation
    initTocNavigation();

    // Update active chapter highlighting (for transition:persist)
    updateActiveChapter();

    // Wait for content to render, then build outline
    setTimeout(() => {
      buildChapterOutline();
    }, 150);
  }

  // Initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initializeSidebars();
    });
  } else {
    initializeSidebars();
  }

  // ── TOC progress indicators ────────────────────────────────────────────────
  function updateTocProgress(currentChapterPct?: number) {
    const bookEl = document.getElementById('chapter-container');
    const book = bookEl?.dataset.book || '';
    const currentChapterId = bookEl?.dataset.chapterId || '';
    if (!book) return;

    // Get completed chapters list
    let completedChapters: string[] = [];
    try {
      completedChapters = JSON.parse(localStorage.getItem(`yuval_ch_complete_${book}`) || '[]');
    } catch { /* ignore */ }

    document.querySelectorAll<HTMLElement>('#toc-sidebar li[data-chapter-id]').forEach(li => {
      const chId = li.dataset.chapterId;
      if (!chId) return;

      // Remove old indicator
      li.querySelector('.toc-progress-bar-wrap')?.remove();

      let pct = 0;
      let done = false;

      // Check if chapter is completed
      if (completedChapters.includes(chId) || completedChapters.includes(String(chId))) {
        pct = 100;
        done = true;
      } else if (chId === currentChapterId && currentChapterPct !== undefined) {
        // Use real-time percentage for current chapter
        pct = currentChapterPct;
        done = pct >= 100;
      } else {
        // Find saved progress percentage for this chapter
        for (let i = 0; i < localStorage.length; i++) {
          const k = localStorage.key(i);
          if (!k?.includes(`_${book}_ch${chId}`)) continue;
          try {
            const d = JSON.parse(localStorage.getItem(k) || '{}');
            if (d.percentage !== undefined && d.percentage > pct) {
              pct = d.percentage;
            } else if (d.scrollPosition && d.scrollPosition > 50) {
              // Fallback: estimate from scroll position (assume ~2500px page height)
              const estimated = Math.min(95, Math.round((d.scrollPosition / 2500) * 100));
              if (estimated > pct) pct = estimated;
            }
          } catch { /* skip */ }
        }
      }

      if (pct < 3) return; // Don't show bar for minimal progress

      // Thin progress bar under the chapter title link
      const bar = document.createElement('div');
      bar.className = 'toc-progress-bar-wrap';
      bar.style.cssText = `
        position:absolute; bottom:0; left:8px; right:8px; height:2px;
        border-radius:99px;
        background:var(--yuval-border,#e5e7eb);
        overflow:hidden;
      `;
      const fill = document.createElement('div');
      fill.style.cssText = `
        height:100%; width:${pct}%; border-radius:99px;
        background:${done ? '#22c55e' : '#6366f1'};
        transition:width 0.6s ease;
      `;
      bar.appendChild(fill);

      // li needs relative positioning
      li.style.position = 'relative';
      li.appendChild(bar);
    });
  }

  // Call on init and after chapter swaps
  setTimeout(updateTocProgress, 200);
  window.addEventListener('chapter-content-swapped', () => setTimeout(updateTocProgress, 400));
  
  // Update current chapter progress in real-time on scroll
  let scrollTimeout: ReturnType<typeof setTimeout>;
  window.addEventListener('scroll', () => {
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      const container = document.getElementById('chapter-container');
      if (!container) return;
      const containerTop = container.offsetTop;
      const containerHeight = container.offsetHeight;
      const scrollable = containerHeight - window.innerHeight;
      if (scrollable <= 0) {
        updateTocProgress(100);
        return;
      }
      const scrolledInto = window.scrollY - containerTop;
      const pct = scrolledInto <= 0 ? 0 : Math.min(100, Math.round((scrolledInto / scrollable) * 100));
      updateTocProgress(pct);
    }, 100);
  }, { passive: true });
  
  // Update when chapter is completed
  window.addEventListener('chapter-completed', () => {
    setTimeout(() => updateTocProgress(100), 100);
  });

  // Update when language changes
  window.addEventListener('language-changed', (e: any) => {
    const lang = e.detail?.language || 'en';
    updateSidebarText(lang);
    updateTocLinks(lang);
    updateSidebarPositions(lang);
    setTimeout(() => {
      buildChapterOutline();
    }, 150);
  });

  // Also update on Astro navigation
  document.addEventListener('astro:after-swap', () => {
    initializeSidebars();
    drawerInitialized = false;
    initMobileToc();
  });

  /**
   * Build outline for mobile drawer from visible chapter headings
   */
  function buildMobileOutline() {
    const mobileOutline = document.getElementById('mobile-chapter-outline');
    if (!mobileOutline) return;
    const ul = mobileOutline.querySelector('ul');
    if (!ul) return;
    ul.innerHTML = '';

    const container = document.getElementById('chapter-container');
    if (!container) return;

    const heDiv = container.querySelector('[data-lang="he"]');
    const enDiv = container.querySelector('[data-lang="en"]');
    let contentDiv: Element | null = null;
    if (heDiv && window.getComputedStyle(heDiv).display !== 'none') contentDiv = heDiv;
    else if (enDiv && window.getComputedStyle(enDiv).display !== 'none') contentDiv = enDiv;
    if (!contentDiv) return;

    const headings = Array.from(contentDiv.querySelectorAll('h2, h3'));
    if (headings.length === 0) {
      const li = document.createElement('li');
      li.style.color = '#ccc';
      li.style.fontSize = '12px';
      const lang = getCurrentLang();
      li.textContent = lang === 'he' ? 'לא נמצאו סעיפים' : lang === 'es' ? 'No se encontraron secciones' : 'No sections found';
      ul.appendChild(li);
      return;
    }

    headings.forEach((heading, i) => {
      const level = heading.tagName.toLowerCase();
      const text = heading.textContent?.trim() || `Section ${i + 1}`;
      const id = heading.id || `section-${i}`;
      if (!heading.id) heading.id = id;

      const li = document.createElement('li');
      li.setAttribute('data-level', level);
      const link = document.createElement('a');
      link.href = `#${id}`;
      link.textContent = text;
      link.addEventListener('click', (e) => {
        e.preventDefault();
        closeDrawer();
        const target = document.getElementById(id);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      li.appendChild(link);
      ul.appendChild(li);
    });
  }

  /**
   * Mobile drawer with tabs: outline + chapters
   */
  let drawerInitialized = false;

  function closeDrawer() {
    const drawer = document.getElementById('mobile-drawer');
    const overlay = document.getElementById('mobile-sidebar-overlay');
    const btn = document.getElementById('mobile-toc-toggle');
    drawer?.classList.remove('open');
    overlay?.classList.remove('active');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  function initMobileToc() {
    if (drawerInitialized) return;

    const btn = document.getElementById('mobile-toc-toggle');
    const overlay = document.getElementById('mobile-sidebar-overlay');
    const drawer = document.getElementById('mobile-drawer');
    if (!btn || !overlay || !drawer) return;

    drawerInitialized = true;

    function openDrawer() {
      buildMobileOutline();
      drawer!.classList.add('open');
      overlay!.classList.add('active');
      btn!.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    btn.addEventListener('click', () => {
      const isOpen = drawer!.classList.contains('open');
      isOpen ? closeDrawer() : openDrawer();
    });

    overlay.addEventListener('click', closeDrawer);

    // Tab switching
    drawer.querySelectorAll('.mobile-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.tab;
        drawer!.querySelectorAll('.mobile-tab').forEach(t => t.classList.remove('active'));
        drawer!.querySelectorAll('.mobile-panel').forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        const panel = target === 'outline'
          ? document.getElementById('mobile-outline-panel')
          : document.getElementById('mobile-chapters-panel');
        panel?.classList.add('active');
      });
    });

    // Handle chapter link clicks with fetch-based loading
    drawer.querySelectorAll('a.mobile-toc-link').forEach(link => {
      link.addEventListener('click', async (e) => {
        e.preventDefault();
        closeDrawer();
        
        // No ?lang= needed - language determined by toggle position
        const url = (link as HTMLAnchorElement).getAttribute('href')?.split('?')[0] || '';

        await loadChapterContent(url);
      });
    });
  }

  // Init mobile TOC on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileToc);
  } else {
    initMobileToc();
  }

  // Update mobile drawer on language change
  window.addEventListener('language-changed', () => {
    // Links no longer need ?lang= - language is determined by toggle position
    const drawer = document.getElementById('mobile-drawer');
    if (drawer && drawer.classList.contains('open')) buildMobileOutline();
  });

  /**
   * Immersive reading mode — hide chrome when scrolling down, restore on scroll up.
   * Only active on reading pages (where this component is loaded).
   */
  (function initImmersiveMode() {
    const SCROLL_DOWN_THRESHOLD = 80;  // px scrolled before activating
    const SCROLL_UP_SNAP = 30;         // px scrolled up before restoring
    let lastScrollY = 0;
    let ticking = false;
    let immersiveActive = false;

    function setImmersive(active: boolean) {
      if (active === immersiveActive) return;
      immersiveActive = active;
      document.body.classList.toggle('reading-immersive', active);
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const currentY = window.scrollY;

        if (currentY < SCROLL_DOWN_THRESHOLD) {
          // Near top — always show everything
          setImmersive(false);
        } else if (currentY > lastScrollY + 5) {
          // Scrolling down
          setImmersive(true);
        } else if (lastScrollY - currentY > SCROLL_UP_SNAP) {
          // Scrolled up enough
          setImmersive(false);
        }

        lastScrollY = currentY;
        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });

    // Reset on chapter navigation
    window.addEventListener('popstate', () => setImmersive(false));
  })();
</script>
