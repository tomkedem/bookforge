---
import type { Language } from '../types/index';
import { getLanguageDirection } from '../utils/language';

interface Props {
  wordCount: number;
  readingTimeMinutes: number;
  sections: number;
  language: Language;
}

const { wordCount, readingTimeMinutes, sections, language } = Astro.props;
const isHe = language === 'he';

const labels = {
  words: isHe ? 'מילים' : 'words',
  readTime: isHe ? 'דקות קריאה' : 'min read',
  sections: isHe ? 'סעיפים' : 'sections',
};

const formattedCount = wordCount.toLocaleString(isHe ? 'he-IL' : 'en-US');
---

<div class="chapter-meta" data-dir={isHe ? 'rtl' : 'ltr'}>
  <span class="meta-item" id={`reading-time-meta-${language}`}>
    <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9"/>
      <path d="M12 7v5l3.5 2"/>
      <circle cx="12" cy="12" r="0.5" fill="currentColor" stroke="none"/>
    </svg>
    <span class="reading-time-value" data-total-minutes={readingTimeMinutes}>{readingTimeMinutes} {labels.readTime}</span>
  </span>

  <span class="meta-dot" aria-hidden="true">·</span>

  <span class="meta-item">
    <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19v16H6.5a2.5 2.5 0 0 0 0 5H19"/>
      <path d="M8 7h6M8 11h4"/>
    </svg>
    {formattedCount} {labels.words}
  </span>

  <span class="meta-dot" aria-hidden="true">·</span>

  <span class="meta-item">
    <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="18" height="18" rx="3"/>
      <path d="M3 9h18M9 3v18"/>
    </svg>
    {sections} {labels.sections}
  </span>
</div>

<style>
  .chapter-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    color: var(--yuval-meta-text);
    font-size: 0.8125rem;
    margin-bottom: 2rem;
    padding: 0.625rem 1rem;
    background: var(--yuval-meta-bg);
    border-radius: 0;
    border: 1px solid var(--yuval-meta-border);
    transition: color 0.3s, background 0.3s, border-color 0.3s;
  }

  .chapter-meta[data-dir="rtl"] {
    direction: rtl;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .meta-icon {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    opacity: 1;
    color: var(--yuval-chapter-title);
  }

  .meta-dot {
    color: var(--yuval-meta-dot);
    font-size: 1.1rem;
    line-height: 1;
    user-select: none;
  }
</style>
