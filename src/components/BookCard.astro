---
interface Props {
  slug: string;
  title_he: string;
  title_en: string;
  description_he: string;
  description_en: string;
  coverImage: string;
  dominantColor?: string;
  class?: string;
}

const {
  slug,
  title_he,
  title_en,
  description_he,
  description_en,
  coverImage,
  dominantColor = '#1a1a1a',
  class: className,
} = Astro.props;

const bookUrl = `/books/${slug}`;
---

<article
  class:list={[
    'group',
    'relative',
    'overflow-hidden',
    'rounded-2xl',
    'bg-yuval-surface',
    'card-float',
    className,
  ]}
>
  <!-- Thumbnail container with dominant color overlay -->
  <div
    class="relative h-48 overflow-hidden bg-contain bg-center bg-no-repeat"
    style={`background-image: url('${coverImage}'); background-color: var(--yuval-surface);`}
  >
    <!-- Dominant color overlay -->
    <div
      class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-20"
      style={`background-color: ${dominantColor};`}
    />

    <!-- Focus overlay for accessibility -->
    <div
      class="absolute inset-0 opacity-0 transition-opacity duration-200 group-focus-within:opacity-10"
      style="background-color: rgba(0, 0, 0, 1);"
    />
  </div>

  <!-- Content -->
  <div class="p-4 sm:p-6 space-y-2 sm:space-y-3">
    <h3
      class="font-heading font-bold text-lg sm:text-2xl leading-tight text-yuval-text group-hover:text-yuval-text-secondary transition-colors duration-200"
      data-he={title_he}
      data-en={title_en}
    >
      {title_en}
    </h3>

    <p
      class="text-sm text-yuval-text-secondary leading-relaxed line-clamp-3"
      data-he={description_he}
      data-en={description_en}
    >
      {description_en}
    </p>

    <!-- Read button -->
    <a
      href={bookUrl}
      class="inline-block mt-4 px-4 py-2 font-body font-medium text-sm rounded-md bg-yuval-accent text-yuval-accent-text hover:bg-yuval-accent-hover transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yuval-highlight book-card-link"
      data-base-url={bookUrl}
      data-he="קרא עכשיו"
      data-en="Read Now"
    >
      Read Now
    </a>
  </div>
</article>

<script>
  function updateBookCardLinks() {
    const lang = localStorage.getItem('yuval_language') || 'en';
    document.querySelectorAll<HTMLAnchorElement>('.book-card-link').forEach(link => {
      const base = link.dataset.baseUrl || link.getAttribute('href') || '';
      link.href = lang === 'he' ? `${base}?lang=he` : base;
    });
  }
  updateBookCardLinks();
  window.addEventListener('language-changed', updateBookCardLinks);
</script>
