---
interface Props {
  book: {
    name: string;
    title: string;
    chapters: number;
    cover?: string | null;
  };
}

const { book } = Astro.props;
---

<a href={`/book/${book.name}/`} class="book-card">
  {book.cover && (
    <img src={book.cover} alt={book.title} class="book-cover" />
  )}
  {!book.cover && (
    <div class="book-cover-placeholder">
      <div class="placeholder-text">No Cover</div>
    </div>
  )}
  <div class="book-info">
    <h3 data-he={book.title} data-en={book.title}>{book.title}</h3>
    <p data-he={`${book.chapters} פרקים`} data-en={`${book.chapters} Chapters`}>
      {book.chapters} chapters
    </p>
  </div>
</a>

<style>
  .book-card {
    border: 1px solid #ddd;
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    display: block;
  }

  .book-card:hover {
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
  }

  .book-cover {
    width: 100%;
    height: 300px;
    object-fit: cover;
    background: #f5f5f5;
  }

  .book-cover-placeholder {
    width: 100%;
    height: 300px;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid #ddd;
  }

  .placeholder-text {
    color: #999;
    font-size: 14px;
  }

  .book-info {
    padding: 16px;
  }

  .book-info h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .book-info p {
    color: #666;
    font-size: 14px;
  }
</style>
