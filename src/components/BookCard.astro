---
import { SUPPORTED_LANGUAGES, DEFAULT_LANGUAGE } from '../utils/language';

interface Props {
  slug: string;
  titles: Record<string, string>;        // { he: '...', en: '...', fr: '...' }
  subtitles?: Record<string, string>;
  descriptions?: Record<string, string>;
  coverImage: string;
  dominantColor?: string;
  category?: string;
  class?: string;
  // Legacy props for backward compatibility
  title_he?: string;
  title_en?: string;
  title_es?: string;
  subtitle_he?: string;
  subtitle_en?: string;
  subtitle_es?: string;
  description_he?: string;
  description_en?: string;
  description_es?: string;
}

const {
  slug,
  titles = {},
  subtitles = {},
  descriptions = {},
  coverImage,
  dominantColor = '#888888',
  category = 'General',
  class: className,
  // Merge legacy props into titles/subtitles/descriptions
  title_he,
  title_en,
  title_es,
  subtitle_he,
  subtitle_en,
  subtitle_es,
  description_he,
  description_en,
  description_es,
} = Astro.props;

// Build unified records from both new and legacy props
const allTitles = { ...titles };
if (title_he) allTitles['he'] = title_he;
if (title_en) allTitles['en'] = title_en;
if (title_es) allTitles['es'] = title_es;

const allSubtitles = { ...subtitles };
if (subtitle_he) allSubtitles['he'] = subtitle_he;
if (subtitle_en) allSubtitles['en'] = subtitle_en;
if (subtitle_es) allSubtitles['es'] = subtitle_es;

const allDescriptions = { ...descriptions };
if (description_he) allDescriptions['he'] = description_he;
if (description_en) allDescriptions['en'] = description_en;
if (description_es) allDescriptions['es'] = description_es;

// Get display values (default language fallback)
const displayTitle = allTitles[DEFAULT_LANGUAGE] || allTitles['en'] || Object.values(allTitles)[0] || '';
const displaySubtitle = allSubtitles[DEFAULT_LANGUAGE] || allSubtitles['en'] || Object.values(allSubtitles)[0] || '';
const displayDescription = allDescriptions[DEFAULT_LANGUAGE] || allDescriptions['en'] || Object.values(allDescriptions)[0] || '';

// Generate data attributes for all supported languages
const titleAttrs = Object.fromEntries(
  SUPPORTED_LANGUAGES.map(l => [`data-${l.code}`, allTitles[l.code] || displayTitle])
);
const subtitleAttrs = Object.fromEntries(
  SUPPORTED_LANGUAGES.map(l => [`data-${l.code}`, allSubtitles[l.code] || displaySubtitle])
);
const descAttrs = Object.fromEntries(
  SUPPORTED_LANGUAGES.map(l => [`data-${l.code}`, allDescriptions[l.code] || displayDescription])
);

const hasSubtitle = Object.values(allSubtitles).some(v => v);
const bookUrl = `/books/${slug}`;
---

<article
  class:list={['book-card', 'group', 'relative', 'overflow-hidden', 'rounded-2xl', 'bg-yuval-surface', className]}
  data-book-category={category}
  data-book-slug={slug}
  style={`--card-glow: ${dominantColor};`}
>
  <!-- Cover image — clean, no overlay -->
  <div class="card-cover relative h-28 overflow-hidden">
    <img
      src={coverImage}
      alt=""
      class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-103"
      loading="lazy"
      decoding="async"
      onerror="this.style.display='none'"
    />
    <!-- Reading progress bar — shown client-side if book was started -->
    <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-black/10">
      <div class="card-progress-fill h-full bg-yuval-accent w-0 transition-all duration-500" data-slug={slug}></div>
    </div>
  </div>

  <!-- Content -->
  <div class="p-3 sm:p-4 space-y-1.5">
    <!-- Category + continue reading row -->
    <div class="flex items-center justify-between gap-2">
      <span class="card-badge">{category}</span>
      <span class="card-continue hidden text-xs text-yuval-text-muted" data-slug={slug}>
        <span data-he="המשך" data-en="Continue" data-es="Continuar">Continue</span>
        <span class="card-continue-chapter font-medium"></span>
      </span>
    </div>

    <h3
      class="font-heading font-semibold text-sm sm:text-base leading-snug text-yuval-text"
      {...titleAttrs}
    >
      {displayTitle}
    </h3>

    {hasSubtitle && (
      <p
        class="text-xs text-yuval-text-muted italic leading-tight -mt-0.5"
        {...subtitleAttrs}
      >
        {displaySubtitle}
      </p>
    )}

    <p
      class="text-xs text-yuval-text-secondary leading-relaxed line-clamp-2"
      {...descAttrs}
    >
      {displayDescription}
    </p>

    <!-- Read link — minimal, text only -->
    <a
      href={bookUrl}
      class="card-link inline-flex items-center gap-1 pt-1 text-xs font-medium text-yuval-text-secondary hover:text-yuval-text transition-colors duration-150 book-card-link"
      data-base-url={bookUrl}
      data-he="קרא עכשיו ←"
      data-en="Read →"
      data-es="Leer →"
    >
      Read →
    </a>
  </div>
</article>

<style>
  /* ── Card base ── */
  .book-card {
    border: 1px solid var(--yuval-border);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.3s ease,
                border-color 0.3s ease;
    will-change: transform;
  }

  /* ── Ambient glow on hover using dominant color ── */
  .book-card:hover {
    transform: translateY(-6px);
    border-color: transparent;
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--card-glow) 25%, transparent),
      0 8px 24px -4px color-mix(in srgb, var(--card-glow) 30%, transparent),
      0 24px 48px -8px color-mix(in srgb, var(--card-glow) 20%, transparent),
      0 2px 8px rgba(0,0,0,0.12);
  }

  /* Fallback for browsers without color-mix */
  @supports not (color: color-mix(in srgb, red 50%, blue)) {
    .book-card:hover {
      box-shadow:
        0 8px 24px -4px rgba(0,0,0,0.18),
        0 24px 48px -8px rgba(0,0,0,0.12);
    }
  }

  /* ── Cover image fallback background ── */
  .card-cover {
    background: linear-gradient(135deg, var(--yuval-bg-secondary) 0%, var(--yuval-border) 100%);
  }

  /* ── Category badge ── */
  .card-badge {
    color: var(--yuval-text-muted);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>

<script>
  function initBookCards() {
    const lang = localStorage.getItem('yuval_language') || 'en';

    // Update links to include language
    document.querySelectorAll<HTMLAnchorElement>('.book-card-link').forEach(link => {
      const base = link.dataset.baseUrl || link.getAttribute('href') || '';
      link.href = lang === 'he' ? `${base}?lang=he` : lang === 'es' ? `${base}?lang=es` : base;
    });

    // Show reading progress on cards
    document.querySelectorAll<HTMLElement>('.book-card[data-book-slug]').forEach(card => {
      const slug = card.dataset.bookSlug;
      if (!slug) return;

      // Find all reading progress keys for this book
      const prefix = `yuval_reading_progress_${slug}_ch`;
      let lastChapter = 0;
      let hasProgress = false;

      for (let i = 0; i < localStorage.length; i++) {
        const key = localStorage.key(i);
        if (key && key.includes(prefix)) {
          try {
            const data = JSON.parse(localStorage.getItem(key) || '{}');
            if (data.scrollPosition > 50) {
              hasProgress = true;
              if (data.chapterId > lastChapter) lastChapter = data.chapterId;
            }
          } catch { /* skip */ }
        }
      }

      if (hasProgress) {
        // Show "Continue reading" badge
        const badge = card.querySelector<HTMLElement>('.card-continue[data-slug="' + slug + '"]');
        const chapterSpan = card.querySelector<HTMLElement>('.card-continue-chapter');
        if (badge) badge.classList.remove('hidden');
        if (chapterSpan) chapterSpan.textContent = ` · Ch. ${lastChapter}`;

        // Animate progress bar (chapter number as rough proxy)
        const fill = card.querySelector<HTMLElement>('.card-progress-fill[data-slug="' + slug + '"]');
        if (fill) {
          // Use lastChapter as a fraction of likely total (rough visual only)
          const pct = Math.min(95, lastChapter * 15);
          requestAnimationFrame(() => { fill.style.width = `${pct}%`; });
        }
      }
    });
  }

  initBookCards();
  window.addEventListener('language-changed', initBookCards);
  document.addEventListener('astro:after-swap', initBookCards);
</script>
