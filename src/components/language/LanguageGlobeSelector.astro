---
/**
 * LanguageGlobeSelector — circular language trigger.
 *
 * Step-2 visual surface for the language switcher. Renders as a perfect
 * 44×44 circle: a conic gold/silver "ring" outside, deep-space radial
 * gradient inside, with a small SVG globe (no continents yet, parallels
 * + meridians + a soft specular highlight). On click it opens a small
 * native-label menu; behavior mirrors the legacy LanguageSelector so
 * existing listeners keep working unchanged.
 *
 * Inputs (from Step-1 data flow — never re-derived inside the component):
 *   activeLanguage      — the language currently rendered by the page.
 *   availableLanguages  — the context's resolved list (platform OR book
 *                         OR course OR chapter, decided upstream).
 *
 * The component does NOT fall back to SUPPORTED_LANGUAGES — if a parent
 * passes a 2-language array, only those 2 appear. That's the contract
 * established in Step 1.
 */

import type { Language } from '../../types/index';
import { getLanguageMeta, getLanguageDirection } from '../../utils/language';

interface Props {
  activeLanguage: Language;
  availableLanguages: Language[];
  class?: string;
  /** Force-disable the menu (e.g. while parent is mid-redirect). The
   *  single-language case is handled automatically via availableLanguages. */
  disabled?: boolean;
}

const {
  activeLanguage,
  availableLanguages,
  class: className,
  disabled = false,
} = Astro.props;

const options = availableLanguages.map((code) => {
  const meta = getLanguageMeta(code);
  return {
    code,
    label: meta.label,
    labelEn: meta.labelEn,
    dir: meta.dir,
    flag: meta.flag ?? '🌐',
  };
});

/**
 * Step-3 arc/orbit layout.
 *
 * Each option carries a CSS-pixel translateY offset (`arcY`) and a
 * tiny beam rotation (`beamRot`, degrees) so that pills sit on an
 * implied cosine arc above the globe and the connection-beam under
 * each pill leans gently toward the globe center. Both values are
 * SSR-computed from the resolved option count, no JS runtime cost.
 *
 *   - arcY: a cosine curve in screen-Y. t = (i - center) / center
 *           runs from -1 (left edge) through 0 (apex) to +1 (right
 *           edge). y(t) = -APEX · cos(t · π/2) lifts the apex up by
 *           APEX_LIFT_PX and lets the edges sit at the baseline.
 *           Smooth across odd / even counts and degrades to zero
 *           when there are fewer than three options (a 2-pill row
 *           would have no meaningful apex).
 *
 *   - beamRot: linear with t, capped at ±BEAM_TILT_DEG. Edge pills'
 *              connection beams tilt slightly toward the globe; the
 *              middle pill's stays vertical. The text on every pill
 *              is not rotated — only the ::after beam is.
 *
 * Both values are written to inline-style CSS variables on each
 * button so a media query can attenuate them on tablet / disable
 * them on mobile without touching the JS.
 */
const activeMeta = getLanguageMeta(activeLanguage);
const isRtl = getLanguageDirection(activeLanguage) === 'rtl';

const N = options.length;
// Step 3.5 — arc depth lifted from 22 → 44 px (desktop). The old
// value was correct but invisible at a glance; doubling brings the
// arc into the spec's 36-48 px band where the curve actually reads
// as an orbit instead of three pills with a tiny stagger. Tablet
// inherits this via the existing --lgs-arc-scale (0.55) → ~24 px,
// inside the spec's 18-28 band. Mobile keeps the flat fallback.
const APEX_LIFT_PX = 44;
// Beam tilt scaled up alongside the arc (8 → 12 deg). The wider
// vertical spread between apex and edge pills makes a stronger
// horizontal-distance feel, and the steeper beam tilt sells the
// "edge pills point inward toward the globe" cue.
const BEAM_TILT_DEG = 12;
const center = N > 1 ? (N - 1) / 2 : 0;
// QA fix — RTL flips the flex row's visual order (LTR [he, en, es]
// → RTL [es, en, he]). The arcY is symmetric so it doesn't need
// flipping (apex stays in the visual middle). But beamRot is
// linear in `t` and uses source index — in RTL, the leftmost
// VISUAL pill is the rightmost SOURCE pill, so the beam tilts
// in the wrong direction (away from the globe instead of toward
// it). Multiplying the beam rotation by -1 on RTL pages restores
// the "edge pills point inward toward the globe center" cue.
const beamRotSign = isRtl ? -1 : 1;

const optionsWithArc = options.map((option, i) => {
  let arcY = 0;
  let beamRot = 0;
  if (N >= 3 && center > 0) {
    const t = (i - center) / center; // [-1, +1]
    arcY = -Math.round(APEX_LIFT_PX * Math.cos((t * Math.PI) / 2) * 10) / 10;
    beamRot = -Math.round(BEAM_TILT_DEG * t * beamRotSign * 10) / 10;
  }
  return { ...option, arcY, beamRot };
});
const onlyOne = options.length <= 1;
const triggerDisabled = disabled || onlyOne;

const triggerAriaLabel = onlyOne
  ? `Only one language available: ${activeMeta.labelEn}`
  : `Change language. Current: ${activeMeta.labelEn}`;

/**
 * Per-language focus points used to rotate the 3D Earth on overlay
 * open. The map is intentionally small and additive — adding a new
 * platform language adds an entry here and nothing else. A code
 * missing from the map opens the globe at lat=0/lng=0 (no special
 * rotation), which is a safe degraded-but-functional state.
 *
 * Rules of thumb when adding entries:
 *   - Use the country/region most commonly associated with the
 *     language for the platform's audience, not the most populous.
 *   - Stay in the front hemisphere of the initial camera; extreme
 *     latitudes feel disorienting before the user touches the globe.
 */
/**
 * Each language defines TWO geographic points:
 *   - The outer entry { lat, lng, label } is the CAMERA FOCUS — the
 *     coordinate the Earth rotates so that it faces the viewer when
 *     the language is active. Tuned for a beautiful composition
 *     (slightly north / centered on the region as a whole), not for
 *     precise country-pin accuracy.
 *   - The optional inner `hotspot` is the MARKER coordinate — the
 *     exact lat/lng where the gold dot is projected to land. When
 *     omitted, the marker falls back to the camera focus point.
 *
 * Hebrew is the only language that currently needs the split:
 *   - Camera at 32.2°N, 35.2°E centers the Eastern Mediterranean
 *     in the viewport.
 *   - Marker at 31.5°N, 34.8°E sits on the Israeli coastline near
 *     Ashkelon, snapping the dot off the open sea and onto land.
 * English and Spanish reuse a single point for both purposes — the
 * North America center and central Spain already land on land at
 * the projection scale.
 */
const LANGUAGE_FOCUS: Record<
  string,
  {
    lat: number;
    lng: number;
    label: string;
    hotspot?: { lat: number; lng: number; label: string };
  }
> = {
  he: {
    lat: 32.2,
    lng: 35.2,
    label: 'Eastern Mediterranean',
    // Israel marker target — explicit user-supplied coordinate.
    // Iteration history:
    //   1) 31.8, 35.2 — initial single point. Landed in the sea NW
    //                   of Israel.
    //   2) 31.5, 34.8 — first dedicated hotspot. User: still slightly
    //                   too high / NW; asked for finer tuning.
    //   3) 31.78, 35.22 (Jerusalem) — INCORRECT direction: this moved
    //                   the marker north-east when it needed to keep
    //                   moving south-east. Reverted.
    //   4) 31.5, 34.8 (this entry) — user re-supplied the original
    //                   precise suggestion. Locking it in here as the
    //                   authoritative coordinate. ~1.6 px south and
    //                   2.4 px west of the Jerusalem attempt on the
    //                   600 px stage, which is the direction the user
    //                   asked for.
    hotspot: { lat: 31.5, lng: 34.8, label: 'Israel' },
  },
  en: { lat: 39.8, lng: -98.6, label: 'North America / United States' },
  es: { lat: 40.4, lng: -3.7, label: 'Spain / Iberian Peninsula' },
};

const focusByCode = JSON.stringify(
  Object.fromEntries(options.map((o) => [o.code, LANGUAGE_FOCUS[o.code] ?? null]))
);
---

<div
  class:list={['lgs-root', className]}
  data-current={activeLanguage}
  data-rtl={isRtl}
>
  <button
    type="button"
    class="lgs-trigger"
    aria-haspopup={onlyOne ? 'false' : 'listbox'}
    aria-expanded="false"
    aria-disabled={triggerDisabled ? 'true' : 'false'}
    aria-label={triggerAriaLabel}
    title={onlyOne ? `Only one language available: ${activeMeta.labelEn}` : undefined}
    data-tooltip={onlyOne ? undefined : 'Change language'}
    data-i18n-tooltip={onlyOne ? undefined : 'header.languageTooltip'}
    data-only-one={onlyOne ? 'true' : 'false'}
  >
    <span class="lgs-disc" aria-hidden="true">
      {/* Earth visual driven by the same /assets/globe/earth-day-2k.webp
          texture the cinematic overlay uses. Implemented as a styled
          div with background-image so the header pays no Three.js or
          WebGL cost — at 42 px we don't need a 3D sphere, just a
          well-cropped slice of the equirectangular Blue Marble map.
          Atmospheric rim and specular highlight are added by
          ::before / ::after in CSS. The crop is shifted per active
          language via .lgs-root[data-current="<lang>"] selectors, so
          when Hebrew is active the disc shows the Israel / Eastern
          Mediterranean region — visually consistent with where the
          big cinematic globe will land when it launches. */}
      <span class="lgs-globe" aria-hidden="true"></span>
    </span>
  </button>


</div>

{!onlyOne && (
  <div
    class="lgs-overlay"
    role="dialog"
    aria-modal="true"
    aria-label="Choose language"
    data-open="false"
    data-initial-language={activeLanguage}
    data-language-focus={focusByCode}
    hidden
  >
    {/* Backdrop. Click outside the stage closes without changing
        language. data-lgs-close marks any element that should trigger
        the close handler — keeps the JS tiny. */}
    <div class="lgs-overlay-backdrop" data-lgs-close="true" aria-hidden="true"></div>

    {/* Cinematic stage: language row above, 3D Earth canvas below.
        Sized to viewport via vh/vw so the stage stays centered on
        any screen without absolute pixel math. */}
    <div class="lgs-overlay-stage">
      <ul
        class="lgs-overlay-row"
        role="listbox"
        aria-label="Available languages"
      >
        {/* Step 3.5 — visible orbit path.
            A single thin SVG curve traced beneath the pills so the
            "orbit" cue is no longer only implied by per-pill
            translateY. The path is a quadratic Bezier shaped to
            line up with the bottoms of the pills as they sit on
            the arc: endpoints at the baseline (edge pills' bottom),
            apex above (apex pill's bottom). Pure stroke — no fill,
            no node markers in the SVG. Edge fades are handled by a
            CSS mask-image so the path can stay a simple solid
            stroke. Hidden under prefers-reduced-motion would be
            wrong (this is layout, not motion) — but hidden on
            mobile via display: none, where the row falls back to
            a compact flat layout. */}
        <svg
          class="lgs-overlay-orbit"
          aria-hidden="true"
          viewBox="0 0 1000 100"
          preserveAspectRatio="none"
          focusable="false"
        >
          <path
            d="M 0 100 Q 500 0 1000 100"
            fill="none"
            stroke="rgba(244, 226, 170, 0.32)"
            stroke-width="1.1"
            stroke-linecap="round"
            vector-effect="non-scaling-stroke"
          />
        </svg>
        {optionsWithArc.map((option) => (
          <li class="lgs-overlay-item">
            <button
              type="button"
              class:list={['lgs-overlay-option', option.code === activeLanguage && 'is-active']}
              data-language={option.code}
              data-dir={option.dir}
              role="option"
              aria-selected={option.code === activeLanguage}
              aria-label={option.labelEn}
              style={`--lgs-arc-y: ${option.arcY}px; --lgs-beam-rot: ${option.beamRot}deg;`}
            >
              <span class="lgs-overlay-flag" aria-hidden="true">{option.flag}</span>
              <span class="lgs-overlay-native">{option.label}</span>
              <span class="lgs-overlay-en">{option.labelEn}</span>
              {option.code === activeLanguage && (
                <span class="lgs-overlay-check" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                  </svg>
                </span>
              )}
            </button>
          </li>
        ))}
      </ul>

      {/* Mount point for the Three.js canvas. The 3D module appends
          a <canvas> here on first overlay open. The empty inner div
          gives the canvas a stable container with explicit pixel size
          set by ResizeObserver in the module.

          The .lgs-hotspot child is the Step-2 geographic-region cue.
          It sits at the dead center of the stage (50%/50%), which is
          where the rotated Earth presents the active focus point.
          The host adds .is-visible after a hover/focus rotation, and
          removes it on manual drag / overlay close so it can never
          stay stranded on a mis-oriented globe. The dot itself is
          pure CSS — no SVG asset, no canvas write, no shader change. */}
      <div class="lgs-overlay-earth" data-earth-stage="true" aria-hidden="true">
        {/* Step-4 selection-ceremony label. Sits absolutely above
            the canvas, hidden by default. Text content is set by
            the host at click time as "Native · Region" (e.g.,
            "עברית · Israel"), then a fade-in/out runs during the
            ~700 ms ceremony window. Empty when idle. */}
        <div class="lgs-overlay-confirm-label" aria-hidden="true"></div>
        {/* Two-layer hotspot: the outer element handles geographic
            positioning via a transform translate driven by CSS
            variables (--lgs-hx / --lgs-hy), which the host's
            projection rAF updates each frame. The inner .dot
            handles the pulse keyframe (scale animation). Splitting
            transforms across two elements keeps the position
            uncontested by the pulse, otherwise the keyframe's
            transform: scale() would overwrite the translate and
            yank the marker back to (0, 0). */}
        <span class="lgs-hotspot" aria-hidden="true">
          <span class="lgs-hotspot-dot"></span>
        </span>
      </div>
    </div>
  </div>
)}

<style>
  .lgs-root {
    position: relative;
    display: inline-block;
    line-height: 0;
  }

  /* ── Trigger: perfect 46×46 circle. The visible gold/silver ring is
       the 2px gap between this element (conic gradient) and the inner
       .lgs-disc; the disc resolves to 42px, leaving the globe SVG room
       to occupy ~75% of the inner disc diameter (within the 72–78%
       target band) without overpowering the ring. */
  .lgs-trigger {
    width: 46px;
    height: 46px;
    min-width: 46px;
    min-height: 46px;
    border-radius: 50%;
    padding: 0;
    border: none;
    cursor: pointer;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* Two layered backgrounds:
       (1) An upper-rim highlight — a faint cool-cream radial parked at
           the top of the disc. This is the only "light from above" cue
           on the ring; it gives the metal a soft bevel without any
           literal gloss reflection. Sits ON TOP of the conic so it
           lifts whichever stop currently lies along the upper arc.
       (2) Softened gold/silver conic. Versus the previous palette
           (saturated #c9a227 and near-white #f0e3b0 / #e8eaee), the
           lightness range is compressed and saturations are pulled
           down so the metal reads as brushed champagne/pewter rather
           than polished jewelry. Same hue rotation (gold → champagne
           → silver → deep taupe → gold → warm-silver) so the
           multi-toned identity survives. */
    background:
      radial-gradient(
        ellipse 80% 55% at 50% 0%,
        rgba(255, 250, 235, 0.22) 0%,
        rgba(255, 250, 235, 0) 48%
      ),
      conic-gradient(
        from 210deg,
        #a89060 0deg,
        #c8b890 60deg,
        #afb2b8 130deg,
        #7e6f5c 200deg,
        #b39872 270deg,
        #c1bdb4 320deg,
        #a89060 360deg
      );
    /* Outer shadow trimmed: drop softer + tighter, gold halo removed
       from the resting state. The ring should ground the disc, not
       glow on its own. Hover/focus restore a touch of warmth. */
    box-shadow:
      0 2px 5px rgba(0, 0, 0, 0.32),
      0 1px 2px rgba(0, 0, 0, 0.18);
    transition:
      transform 220ms var(--ease-emphasized, cubic-bezier(0.2, 0.7, 0.2, 1)),
      box-shadow 220ms var(--ease-emphasized, cubic-bezier(0.2, 0.7, 0.2, 1));
  }

  .lgs-trigger:hover {
    transform: translateY(-1px);
    box-shadow:
      0 4px 10px rgba(0, 0, 0, 0.38),
      0 1px 3px rgba(0, 0, 0, 0.20),
      0 0 14px rgba(201, 169, 110, 0.16);
  }

  .lgs-trigger:focus-visible {
    outline: none;
    box-shadow:
      0 0 0 3px rgba(232, 197, 71, 0.40),
      0 4px 10px rgba(0, 0, 0, 0.35);
  }

  .lgs-trigger[aria-disabled="true"] {
    cursor: default;
  }

  .lgs-trigger[aria-disabled="true"]:hover {
    transform: none;
  }

  /* Inner space disc — sits 2px inside the conic ring. Polished in
     the mini-globe pass to feel more refined and less "heavy":
       • Outer perimeter softened from pitch #000000 to #060912 (a
         very dark cool blue). The ring around the globe still reads
         as "space" but doesn't punch a visible black hole at the
         disc's edge, which made the frame compete with the planet
         for attention.
       • Inset shadows toned down (0.55 → 0.38 on the top dark; cool
         bottom bounce lifted slightly to 0.13). The "recessed inside
         the ring" cue stays, but quieter — same role, less weight. */
  .lgs-disc {
    position: absolute;
    inset: 2px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 42%,
      #131c30 0%,
      #0a1020 60%,
      #060912 100%
    );
    box-shadow:
      inset 0 1.5px 2.5px rgba(0, 0, 0, 0.38),
      inset 0 -1px 2px rgba(70, 100, 150, 0.13);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    pointer-events: none;
  }

  /* ── Small header Earth (mini-globe treatment) ───────────────────
     A 32×32 globe centered inside the 42×42 disc — ~76% of the
     inner circle, leaving a ~5 px dark-space ring on each side
     where the disc's own radial gradient shows through. That ring
     is the "premium frame": instead of a raw circular photo crop
     filling the disc, the globe reads as a celestial body floating
     in space, with the gold/silver outer ring framing the whole
     composition.

     Sizing math (image is 2048×1024, equal scale at equator —
     5.69 source px per degree on both axes):
       scale s = 32 / (5.69 × 50) ≈ 0.1125
       background-size = 2048 × s, 1024 × s ≈ 230 × 115
     The 50° crop (wider than the previous 40° on a 42 px globe)
     is deliberate at mini scale: a recognizable hemisphere reads
     as a planet, whereas a zoomed-in patch reads as a postcard.
     Per-language background-position centers each language's
     focus region in the visible disc.

     The image is treated for mini-scale readability with three
     CSS techniques layered together:
       • A filter chain (saturate / brightness / contrast) lifts
         mid-tones and clarifies ocean/land separation that
         otherwise turn muddy at 32 px.
       • Three layered inset shadows give the photo a curved-
         sphere feel: a soft all-edge vignette, a directional
         terminator at the lower-right, and a warm highlight at
         the upper-left — matching the cinematic Earth's sun
         direction so the small globe reads as the same object
         lit the same way.
       • Pseudo-elements add an atmospheric cyan rim just inside
         the silhouette and a specular highlight in the upper-
         left quadrant. */
  .lgs-globe {
    position: relative;
    /* Polished from 32 → 34 px (~+6%, inside the requested 5–8%
       window). At 34 px the globe is ~81% of the 42 px disc, with
       a thin ~4 px breathing ring of disc gradient on every side.
       Bigger planet, smaller frame, same premium 1:1 button. */
    width: 34px;
    height: 34px;
    display: block;
    border-radius: 50%;
    background-image: url('/assets/globe/earth-day-2k.webp');
    background-repeat: no-repeat;
    /* Background-size for a 50° equirectangular crop at 34 px:
         scale = 34 / (5.69 × 50) ≈ 0.1195
         → 2048 × 0.1195 ≈ 245 wide, 1024 × 0.1195 ≈ 122 tall */
    background-size: 245px 122px;
    /* Background-position composed via calc() from two pairs of
       CSS custom properties:
         --lgs-base-x / --lgs-base-y — language-specific focus
           region. Set by the .lgs-root[data-current="<lang>"]
           selectors below so each language has a stable default
           that says "this is your part of the planet."
         --lgs-px / --lgs-py — pointer-hover parallax offsets.
           Default 0. Updated by the trigger's pointermove handler
           (JS, mouse-only) within a ±12 / ±8 px window so the
           globe gently tilts toward the cursor. Reset to 0 on
           pointerleave / pointercancel / blur — so the globe
           always returns to its language-default position.
       Keyboard focus, touch, pen, and prefers-reduced-motion all
       skip the parallax update path, which means those users see
       the stable language default at all times. */
    --lgs-base-x: -105px;
    --lgs-base-y: -44px;
    --lgs-px: 0px;
    --lgs-py: 0px;
    background-position-x: calc(var(--lgs-base-x) + var(--lgs-px));
    background-position-y: calc(var(--lgs-base-y) + var(--lgs-py));
    /* Mini-scale color correction — slightly stronger than the
       previous tuning. The small globe sits next to the Theme
       selector at ~16 px on-screen visual mass; a touch more
       saturation + brightness keeps it from reading as a darker
       neighbour. Filter also lightly amplifies the atmospheric
       ::before and specular ::after below; values are tuned so
       both stay restrained, never neon. */
    filter: saturate(1.32) brightness(1.14) contrast(1.08);
    /* Three layered inset shadows model the lit-sphere depth:
         1. Soft all-edge vignette — silhouette curves away from
            the viewer. Slightly lifted (0.25 → 0.22) since the
            larger globe needs less darkening to feel round.
         2. Directional terminator: lower-right darkening matches
            the cinematic Earth's sun direction (upper-left).
         3. Warm highlight — bumped from 0.16 → 0.20 alpha and
            offset 2.5 px (was 2) so the upper-left lift is now
            clearly perceptible at 34 px but still restrained.
            This is the requested "subtle 3D highlight." */
    box-shadow:
      inset 0 0 4px rgba(0, 0, 0, 0.22),
      inset -2.5px -2.5px 5px rgba(0, 0, 0, 0.30),
      inset 2.5px 2.5px 4.5px rgba(255, 248, 230, 0.20);
    /* Single transition timing handles both flows that change
       the background position: a language switch (a jump of tens
       of px on one or both axes), and pointer-hover parallax (a
       gentle drift of up to ±12 px). 220 ms ease-out makes the
       language change feel deliberate without being lazy, and the
       parallax follow feel like a gravitational pull toward the
       cursor rather than a jittery snap on every pointermove. */
    transition:
      background-position-x 220ms cubic-bezier(0.2, 0.7, 0.2, 1),
      background-position-y 220ms cubic-bezier(0.2, 0.7, 0.2, 1),
      opacity 200ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  /* Atmospheric cyan rim removed at the 34 px header size. The
     cyan halo drew the eye as a separate crescent on the LEFT
     side of the globe where the Earth texture happens to show
     dark Atlantic ocean — the cyan band stood out against the
     dark ocean and read as "a leftover circle not attached to
     anything." On other sides where the texture shows brighter
     land (Africa, Europe) the rim blended in fine, but the left
     side was a perception bug.
     The silhouette is still clearly defined by the box-shadow
     stack on .lgs-globe (edge vignette + directional terminator
     + warm upper-left highlight) — enough sphere cue at this
     scale. The cinematic Earth's atmosphere shader on the big
     globe stays untouched; at 600 px the rim earns its place. */

  /* Specular highlight — soft warm-white pool at the upper-left
     quadrant. Softened from the previous pass: peak alpha 0.44
     → 0.34, and slightly enlarged (26% → 30%) so the light pool
     reads as a gentle gradient rather than a glossy dot. Mirrors
     the cinematic Earth's lit-from-upper-left direction. */
  .lgs-globe::after {
    content: '';
    position: absolute;
    top: 13%;
    left: 19%;
    width: 30%;
    height: 30%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 40% 40%,
      rgba(255, 252, 235, 0.34) 0%,
      rgba(255, 255, 255, 0.15) 38%,
      rgba(255, 255, 255, 0.04) 72%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* ── Per-language background position ─────────────────────────────
     Each entry sets the language's stable focus region as a base
     pair of CSS custom properties. The pointer-hover parallax adds
     ±12 px on top of these values; when the cursor leaves, the
     parallax resets to 0 and the globe returns to exactly this
     position. Values recomputed for the 34 px globe at the 50°
     equirectangular crop:
       source_x  = ((lng + 180) / 360) × 2048
       source_y  = ((90 - lat) / 180) × 1024
       display_x = source_x × 0.1195
       display_y = source_y × 0.1195
       bg-pos    = (17 - display_x, 17 - display_y)
     Stay in lockstep with LANGUAGE_FOCUS in the component frontmatter. */
  .lgs-root[data-current="he"] .lgs-globe {
    /* Israel / Eastern Mediterranean — lat 32, lng 35 */
    --lgs-base-x: -129px;
    --lgs-base-y: -22px;
  }
  .lgs-root[data-current="en"] .lgs-globe {
    /* North America — lat 40, lng -100 */
    --lgs-base-x: -37px;
    --lgs-base-y: -17px;
  }
  .lgs-root[data-current="es"] .lgs-globe {
    /* Spain / Iberian Peninsula — lat 40, lng -3 */
    --lgs-base-x: -103px;
    --lgs-base-y: -17px;
  }

  /* Header globe is hidden whenever the cinematic overlay is "out" —
     during launch, while open, and during return. The class is added
     by JS at the start of openOverlay and removed at the end of
     closeOverlay (after the return animation completes), so the
     small Earth fades out as the big Earth launches and fades back
     in only after the big Earth has fully returned to the trigger. */
  .lgs-trigger.is-launched-out .lgs-globe {
    opacity: 0;
  }

  /* ── Pre-launch CHARGE phase ────────────────────────────────────
     A short (~220 ms) energy-gather pulse on the trigger right
     before the cinematic globe detaches. Visual ingredients are
     intentionally restrained:
       • a tiny vertical lift (-1 px, then back) — physical "wind up"
       • a warm gold halo ring that brightens then fades — "charge"
       • a faint warm tint inside the disc — light gathering at core
     No saturated neon, no scale pop. Pure preparation. The class is
     added/removed by JS so the keyframes only run for the actual
     charge window — the trigger never plays this on idle hover.
     During this animation the JS still has `is-launched-out` OFF,
     so the small globe is visible — the user sees the artifact
     charging before it leaves. */
  .lgs-trigger.is-charging {
    animation: lgs-charge-pulse 220ms cubic-bezier(0.4, 0, 0.6, 1) both;
  }
  @keyframes lgs-charge-pulse {
    0% {
      transform: translateY(0);
      box-shadow:
        0 2px 5px rgba(0, 0, 0, 0.32),
        0 1px 2px rgba(0, 0, 0, 0.18);
    }
    60% {
      transform: translateY(-1px);
      box-shadow:
        0 3px 8px rgba(0, 0, 0, 0.38),
        0 1px 2px rgba(0, 0, 0, 0.20),
        0 0 18px rgba(232, 197, 71, 0.42),
        0 0 6px rgba(255, 230, 160, 0.30);
    }
    100% {
      transform: translateY(0);
      box-shadow:
        0 2px 6px rgba(0, 0, 0, 0.34),
        0 1px 2px rgba(0, 0, 0, 0.20),
        0 0 10px rgba(232, 197, 71, 0.18);
    }
  }

  /* ── Return DOCKING phase ───────────────────────────────────────
     A brief (~240 ms) scale-pop on the trigger that fires the
     moment the big Earth lands back into the header. The keyframe
     starts at scale(0.92) so the trigger "receives" the planet
     with a small inhale, then overshoots to 1.05 and settles at 1.0
     via a slight-bounce easing. Pairs with the cross-fade timer in
     runReturnFlight (is-launched-out drops slightly BEFORE this
     class is added), so the small globe is already opacity-rising
     into the scaling trigger — together they read as "the artifact
     re-materializes in the header" rather than "globe shrinks,
     small globe pops up". */
  .lgs-trigger.is-docking {
    animation: lgs-dock-pop 240ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes lgs-dock-pop {
    0% {
      transform: scale(0.92);
    }
    60% {
      transform: scale(1.05);
    }
    100% {
      transform: scale(1);
    }
  }

  /* Lock background scroll while the overlay is open. Applied to
     <html> from JS (toggle a class) so it lifts even on routes whose
     <body> uses overflow-driven layout. The overlay itself is fixed
     so locking scroll doesn't shift the dialog. */
  :global(html.lgs-overlay-open),
  :global(html.lgs-overlay-open body) {
    overflow: hidden;
  }

  /* ── Cinematic overlay ───────────────────────────────────────────
     A full-viewport modal that dims the page and centers the 3D
     Earth + the language row. The whole thing is fixed-position so
     it floats above any page chrome (sidebars, sticky header, etc.)
     without needing a portal — Astro doesn't have one anyway.

     Visibility model:
       - The element starts with the `hidden` HTML attribute set so
         AT users don't encounter it before opening.
       - On open, JS clears `hidden` and sets data-open="true" in the
         next frame, which triggers the CSS transitions to fade the
         backdrop and lift the stage.
       - On close, JS sets data-open="false" → CSS transitions out;
         after the transition completes, JS re-applies `hidden`.

     The 3D canvas inside is created lazily on first open by the
     interactive-earth-3d module and then re-used across subsequent
     opens (only paused / resumed). Full disposal happens on Astro
     view transitions and on page unload, never on a normal close. */
  .lgs-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .lgs-overlay[data-open="true"] {
    pointer-events: auto;
  }

  /* Force the [hidden] HTML attribute to actually hide the overlay.
     Without this rule, the .lgs-overlay rule above (display: flex)
     beats the UA stylesheet's [hidden] { display: none } at the same
     specificity (both 0,1,0) because component CSS loads later. The
     symptom was that overlay.setAttribute('hidden', '') was inert and
     the centered Earth stayed on screen after the return flight
     completed in the resume-after-language-change path. Bumping
     specificity to 0,2,0 via [hidden] guarantees the close actually
     hides. */
  .lgs-overlay[hidden] {
    display: none;
  }

  .lgs-overlay-backdrop {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      rgba(8, 10, 18, 0.78) 0%,
      rgba(2, 3, 8, 0.92) 70%
    );
    backdrop-filter: blur(12px) saturate(120%);
    -webkit-backdrop-filter: blur(12px) saturate(120%);
    opacity: 0;
    transition: opacity 260ms var(--ease-emphasized, cubic-bezier(0.2, 0.7, 0.2, 1));
  }

  .lgs-overlay[data-open="true"] .lgs-overlay-backdrop {
    opacity: 1;
  }

  .lgs-overlay-stage {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(20px, 3.5vh, 36px);
    padding: clamp(16px, 4vh, 36px);
    /* Widened from 720 → 880 to give the larger Earth stage (now up
       to 600 px) elbow room and to keep the language row flowing on
       a single line at common desktop widths. The vw cap keeps
       narrower viewports unaffected. */
    width: min(880px, 94vw);
    /* The stage container has no own animation. Children animate
       independently:
         - .lgs-overlay-earth: WAAPI flight on open/close (driven by JS)
         - .lgs-overlay-row: opacity + translate transition gated by
           the .is-revealed class (revealed only after the earth lands).
       The backdrop's fade-in still runs from CSS on data-open. */
  }

  /* ── Language row (above the globe) ─────────────────────────────
     Compact horizontal pills. Native label is the primary text;
     English label is a subtitle that wraps under in narrower row
     widths. Active state stacks four non-color cues: gold border,
     gold glow, gradient background, checkmark — plus aria-selected
     and font-weight. */
  .lgs-overlay-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-end;
    gap: clamp(8px, 1.5vw, 14px);
    /* Step 3.5 — position context for the SVG orbit + visible
       headroom above the row's natural box so the apex pill (lifted
       up to 44 px above baseline on desktop) and the orbit path
       arc both have room without overlapping the stage's top
       padding. The row's intrinsic flex height stays the same;
       the headroom is created with an outset before the SVG. */
    position: relative;
    /* Hidden on render. Revealed by JS once the launch animation
       lands, via the .is-revealed class. On close JS removes the
       class first, waits for the fade-out, then runs the return
       animation on the earth. */
    opacity: 0;
    transform: translateY(-8px);
    transition:
      opacity 240ms var(--ease-emphasized, cubic-bezier(0.2, 0.7, 0.2, 1)),
      transform 240ms var(--ease-emphasized, cubic-bezier(0.2, 0.7, 0.2, 1));
    pointer-events: none;
  }

  .lgs-overlay-row.is-revealed {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* ── Visible orbit path (Step 3.5) ───────────────────────────────
     A thin gold-tinted SVG curve sitting behind the pills,
     extending above the row's natural box so its apex sits at the
     same Y as the apex pill's bottom edge. Two visual treatments
     stack to keep it premium and restrained:
       • CSS mask-image fades the path's left/right ends so the
         curve dissolves into the stage rather than terminating in
         a hard endpoint.
       • A drop-shadow filter gives the stroke a 4 px gold glow so
         the line reads as luminous chrome, not a printed border.
     The path coordinates are tuned to align with APEX_LIFT_PX = 44
     desktop (matched to the frontmatter constant). Tablet shrinks
     the upward extension via a media query; mobile hides it. */
  .lgs-overlay-orbit {
    position: absolute;
    left: 0;
    right: 0;
    /* Start 52 px above the row's content edge so the curve's
       apex (at viewBox Y = 50, midcurve) lands within ~4 px of
       the apex pill's bottom for typical pill heights. */
    top: -52px;
    bottom: 0;
    width: 100%;
    height: auto;
    pointer-events: none;
    /* Soft horizontal fade — the path "emerges from space" on
       both sides instead of stopping abruptly. */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      rgba(0, 0, 0, 0.6) 14%,
      #000 30%,
      #000 70%,
      rgba(0, 0, 0, 0.6) 86%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      rgba(0, 0, 0, 0.6) 14%,
      #000 30%,
      #000 70%,
      rgba(0, 0, 0, 0.6) 86%,
      transparent 100%
    );
    /* Gold glow on the stroke. drop-shadow on the SVG element
       blurs the rendered path, giving the line a soft halo. Tuned
       low enough that it never reads as neon. */
    filter: drop-shadow(0 0 4px rgba(232, 197, 71, 0.32));
  }

  /* Tablet — shallower orbit (pairs with the 0.55 arc-scale). */
  @media (max-width: 768px) {
    .lgs-overlay-orbit {
      top: -28px;
    }
  }
  /* Mobile — orbit removed entirely so the compact flat row reads
     as a clean list (no path beneath two stacked pills). The
     per-pill arc-y is already disabled at this breakpoint. */
  @media (max-width: 480px) {
    .lgs-overlay-orbit {
      display: none;
    }
  }

  .lgs-overlay-item {
    display: contents;
  }

  /* ── Language option pill ────────────────────────────────────────
     Goal of this revision: read as floating glass chrome over the
     cinematic Earth stage, not as a raised button. Idle pills wear
     a silvery warm-white hairline so the active state's gold can
     stand out without saturating the whole row. Charcoal-glass
     background sits over a stronger backdrop blur (14 px) so the
     planet behind the row peeks through softened, lifting the row
     visually closer to the Earth's atmosphere band.

     Active state stacks SIX non-color cues, exceeding the "more
     than color alone" accessibility requirement:
       1. Gold hairline border (warm, not saturated)
       2. Inner top-highlight in pale gold
       3. Concentrated gold halo (smaller radius than before)
       4. Stronger font weight on the native label
       5. Gold check chip in the corner
       6. Thin vertical light beam below the pill, pointing at
          the globe (see ::after rule) — a subtle cinematic
          connection cue, not a UI border. */
  .lgs-overlay-option {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 9px 16px;
    /* Silvery warm-white hairline. Idle pills no longer claim any
       gold — gold is the active state's signature. */
    border: 1px solid rgba(255, 240, 220, 0.07);
    border-radius: 999px;
    /* Top-light sheen on warm charcoal glass. The linear-gradient
       layer gives the pill a faint bevel from above; the solid
       layer below is the actual tinted glass. */
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0) 60%),
      rgba(18, 16, 22, 0.40);
    color: var(--yuval-text-secondary, #c4b8a8);
    font-family: var(--font-heading, inherit);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.15;
    cursor: pointer;
    /* Stronger backdrop blur + a touch of saturation read as real
       atmospheric glass rather than a flat tinted rectangle. */
    backdrop-filter: blur(14px) saturate(118%);
    -webkit-backdrop-filter: blur(14px) saturate(118%);
    /* Inner top highlight + soft drop. No outer halo on idle —
       a glow on every pill would compete with the active one. */
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 6px 18px rgba(0, 0, 0, 0.32);
    /* ── Step-3 arc/orbit positioning ──────────────────────────
       Each pill's inline style sets --lgs-arc-y (px) computed in
       the frontmatter from a cosine curve over the option count.
       --lgs-arc-scale gates the arc strength per viewport:
         desktop: 1   — full arc
         tablet:  0.55 — gentle dip
         mobile:  0   — flat fallback (a curved row would crowd a
                        narrow viewport's vertical budget)
       The text inside the pill is NOT rotated — only the pill's
       vertical position is offset, so labels stay horizontal and
       readable per the spec's accessibility constraint. */
    --lgs-arc-scale: 1;
    transform: translateY(calc(var(--lgs-arc-y, 0px) * var(--lgs-arc-scale)));
    /* Step 3.5 — pills paint above the SVG orbit path. The row is
       position: relative which forms a stacking context; explicit
       z-index keeps the pill chrome (and active node + beam) over
       the orbit line. */
    z-index: 1;
    transition:
      background 220ms var(--ease-standard, ease),
      border-color 220ms var(--ease-standard, ease),
      color 220ms var(--ease-standard, ease),
      box-shadow 220ms var(--ease-standard, ease),
      transform 220ms var(--ease-emphasized, cubic-bezier(0.2, 0.7, 0.2, 1));
  }

  .lgs-overlay-option:hover {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0) 60%),
      rgba(28, 24, 30, 0.55);
    /* Hover hint shifts the hairline a touch warmer toward gold,
       but stays clearly below the active state's saturation so the
       row never has two "selected-looking" pills at once. */
    border-color: rgba(232, 197, 71, 0.22);
    color: var(--yuval-text, #f0e6d0);
    /* Hover combines the arc offset with a 1 px lift so the pill
       still feels like it's reacting to the cursor — but never
       breaks out of its arc position. Layout stays stable: the
       pill below the cursor doesn't push neighbours. */
    transform: translateY(
      calc(var(--lgs-arc-y, 0px) * var(--lgs-arc-scale) - 1px)
    );
  }

  .lgs-overlay-option:focus-visible {
    /* Keyboard focus: refined gold ring sitting outside the pill so
       it stays visible against both glass and the dark backdrop.
       Same warm gold as the brand; offset so it never overlaps
       the pill's own border-radius rounding. */
    outline: 2px solid rgba(232, 197, 71, 0.7);
    outline-offset: 3px;
  }

  .lgs-overlay-option.is-active {
    /* Active state: subtle gold tint over the charcoal glass, NOT
       a saturated yellow button. The gradient peaks at ~10%
       opacity at the top and fades to neutral by the lower half,
       so the pill reads as "lit from above by a small gold key
       light" rather than "filled with paint." */
    background:
      linear-gradient(180deg, rgba(232, 197, 71, 0.11), rgba(232, 197, 71, 0) 65%),
      rgba(18, 16, 22, 0.55);
    border-color: rgba(232, 197, 71, 0.42);
    color: var(--yuval-text, #f0e6d0);
    font-weight: 600;
    /* Refined gold halo on the arc orbit. The inner ring (10 px /
       0.20 alpha) keeps the previous tight kiss-of-light; a
       second softer outer halo (22 px / 0.10) extends the warm
       presence just enough to read as "the selected pill is
       gently illuminated" against the dark stage — without
       turning into a button-shaped lamp. The drop-shadow stack
       is unchanged so the pill still sits over the glass at the
       same depth. */
    box-shadow:
      inset 0 1px 0 rgba(255, 230, 160, 0.12),
      0 0 10px rgba(232, 197, 71, 0.20),
      0 0 22px rgba(232, 197, 71, 0.10),
      0 6px 18px rgba(0, 0, 0, 0.40);
  }
  /* Hover on the active pill preserves the gold-glow signature.
     The base hover rule recalculates background/border for the
     hover state; without this override the active pill would
     temporarily lose its gold tint while hovered. */
  .lgs-overlay-option.is-active:hover {
    background:
      linear-gradient(180deg, rgba(232, 197, 71, 0.13), rgba(232, 197, 71, 0) 65%),
      rgba(28, 24, 30, 0.60);
    border-color: rgba(232, 197, 71, 0.50);
  }

  /* ── Active orbital node (Step 3.5) ─────────────────────────────
     A small gold dot anchored to the active pill's bottom edge —
     visually sitting ON the orbit path. The node + the visible
     SVG orbit together communicate "the selected language is
     a fixed point on the orbit," far stronger than the previous
     state which relied only on glow. Sized small (9 px) so it
     reads as a refined orbital anchor, not a marker on a map.

     The node is positioned via the pill's own coordinate system
     (position: relative on .lgs-overlay-option), so when the
     apex pill is lifted up by --lgs-arc-y, the node moves with
     it and continues to land on the orbit curve at that X. */
  .lgs-overlay-option.is-active::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 100%;
    transform: translate(-50%, -50%);
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(255, 245, 200, 0.95) 0%,
      rgba(232, 197, 71, 0.85) 32%,
      rgba(232, 197, 71, 0.30) 60%,
      rgba(232, 197, 71, 0) 100%
    );
    box-shadow:
      0 0 6px rgba(232, 197, 71, 0.50),
      0 0 14px rgba(232, 197, 71, 0.22);
    pointer-events: none;
    z-index: 2;
  }

  /* Connecting cue — a thin gold light beam dropping from the
     active pill toward the globe.

     Step 3.5 update: the active beam now reads as the selected
     orbital node's energy line — taller (24-40 px clamped) and
     starting just BELOW the node so it appears to emit from the
     node toward the globe. Hover/focus on non-active pills keeps
     the previous short (8-14 px) variant so the active state's
     beam stays visually dominant.

     The beam leans toward the globe center via --lgs-beam-rot
     (degrees, set inline per-pill from the same position-index
     math that drives the arc). Edge pills' beams tilt inward;
     the apex stays vertical. transform-origin: top center pivots
     the BOTTOM of the beam toward the globe, not the top. */
  .lgs-overlay-option.is-active::after {
    content: '';
    position: absolute;
    left: 50%;
    /* Below the orbital node — calc spaces the beam start just
       past the node's bottom (the node is centered on top: 100%
       and is 9 px tall, so its bottom is at top: 100% + 4.5 px). */
    top: calc(100% + 7px);
    width: 1px;
    height: clamp(24px, 5vh, 40px);
    transform-origin: top center;
    transform: translateX(-50%) rotate(
      calc(var(--lgs-beam-rot, 0deg) * var(--lgs-arc-scale, 1))
    );
    background: linear-gradient(
      to bottom,
      rgba(255, 245, 200, 0.65) 0%,
      rgba(232, 197, 71, 0.42) 18%,
      rgba(232, 197, 71, 0.18) 55%,
      rgba(232, 197, 71, 0) 100%
    );
    /* Soft glow on the beam so it reads as energy in motion,
       not a UI border. Same restraint as the orbit path. */
    box-shadow: 0 0 5px rgba(232, 197, 71, 0.22);
    pointer-events: none;
  }

  /* ── Step 4 selection ceremony ──────────────────────────────────
     Three coordinated short pulses + a temporary label, fired the
     moment a language is clicked and held for the ceremony window
     (~700 ms) before the existing close / navigation flow runs.

     Visual budget — every element has a single, contained one-shot
     animation that returns to the resting state at 100 %, so when
     the .is-confirming class is removed (commit() / Escape /
     teardown), the keyframe ends cleanly without a snap-back.

       • Active pill — gold ring expansion (::before keyframe)
       • Active beam — brightness pulse (::after filter only)
       • Hotspot — single larger ring pulse (.dot keyframe)
       • Label — fade-in to "Native · Region", fade-out at end
       • Other pills — dimmed + pointer-events: none (lock cue)

     The cinematic launch / return choreography (Step 1) and the
     geographic-focus animation (Step 2) are not touched — the
     ceremony runs ON TOP of those, with the rotation finishing
     under it. */

  /* Active orbital node — confirm ring. The resting node (::before)
     keeps its scale 1; this ceremony animation lifts it briefly to
     scale 1.4 with a brighter, larger gold halo. transform retains
     the existing translate(-50%, -50%) anchor, so the ring expands
     from the same center point that sits on the orbit curve. */
  .lgs-overlay-option.is-active.is-confirming::before {
    animation: lgs-node-confirm 640ms cubic-bezier(0.34, 1.4, 0.64, 1);
  }
  @keyframes lgs-node-confirm {
    0% {
      transform: translate(-50%, -50%) scale(1);
      box-shadow:
        0 0 6px rgba(232, 197, 71, 0.50),
        0 0 14px rgba(232, 197, 71, 0.22);
    }
    45% {
      transform: translate(-50%, -50%) scale(1.40);
      box-shadow:
        0 0 14px rgba(232, 197, 71, 0.62),
        0 0 30px rgba(232, 197, 71, 0.32),
        0 0 56px rgba(232, 197, 71, 0.14);
    }
    100% {
      transform: translate(-50%, -50%) scale(1);
      box-shadow:
        0 0 6px rgba(232, 197, 71, 0.50),
        0 0 14px rgba(232, 197, 71, 0.22);
    }
  }

  /* Active beam — brightness pulse. The beam already has a transform
     (translateX(-50%) rotate(...)); we don't touch transform here,
     only the filter, so the rotation logic from Step 3.5 is
     preserved exactly. */
  .lgs-overlay-option.is-active.is-confirming::after {
    animation: lgs-beam-confirm 640ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes lgs-beam-confirm {
    0%   { filter: brightness(1) drop-shadow(0 0 0 rgba(232, 197, 71, 0)); }
    45%  { filter: brightness(1.55) drop-shadow(0 0 6px rgba(232, 197, 71, 0.55)); }
    100% { filter: brightness(1) drop-shadow(0 0 0 rgba(232, 197, 71, 0)); }
  }

  /* Hotspot — confirm pulse. Overrides the resting infinite pulse
     while .is-confirming is on the .lgs-hotspot. Slightly larger
     amplitude than the resting pulse (1.45 vs 1.18) and a one-shot
     duration so it reads as a deliberate confirmation, not a
     louder version of the rest cue. The CSS-vars driven translate
     on the parent (.lgs-hotspot) is NOT touched by this animation
     — the dot is a CHILD and only its scale animates here. */
  .lgs-hotspot.is-confirming.is-visible .lgs-hotspot-dot {
    animation: lgs-hotspot-confirm 640ms cubic-bezier(0.34, 1.4, 0.64, 1);
  }
  @keyframes lgs-hotspot-confirm {
    0% {
      transform: scale(1);
      box-shadow:
        0 0 6px rgba(255, 220, 130, 0.55),
        0 0 14px rgba(232, 197, 71, 0.28),
        0 0 28px rgba(232, 197, 71, 0.12);
    }
    45% {
      transform: scale(1.45);
      box-shadow:
        0 0 12px rgba(255, 230, 160, 0.70),
        0 0 26px rgba(232, 197, 71, 0.32),
        0 0 50px rgba(232, 197, 71, 0.16);
    }
    100% {
      transform: scale(1);
      box-shadow:
        0 0 6px rgba(255, 220, 130, 0.55),
        0 0 14px rgba(232, 197, 71, 0.28),
        0 0 28px rgba(232, 197, 71, 0.12);
    }
  }

  /* Temporary "Native · Region" label, sits just above the canvas
     in the gap between the row and the globe. Default opacity 0;
     fades in when JS adds .is-visible and writes the textContent.

     direction: ltr forces a consistent "Native · Region" reading
     regardless of the host page's RTL/LTR — Hebrew users see
     "עברית · Israel" with the bullet between native and region,
     same as English / Spanish users. */
  .lgs-overlay-confirm-label {
    position: absolute;
    left: 50%;
    top: -10px;
    transform: translate(-50%, -100%);
    direction: ltr;
    font-family: var(--font-heading, inherit);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(244, 226, 170, 0.82);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition:
      opacity 220ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 260ms cubic-bezier(0.34, 1.2, 0.64, 1);
    z-index: 3;
    /* Faint gold glow so the small caps read as luminous, not
       printed. Restrained — same magnitude as the orbit path. */
    text-shadow:
      0 0 6px rgba(232, 197, 71, 0.25),
      0 0 14px rgba(232, 197, 71, 0.10);
  }
  .lgs-overlay-confirm-label.is-visible {
    opacity: 1;
    /* Tiny upward lift on appear so it doesn't pop in flat. */
    transform: translate(-50%, calc(-100% - 4px));
  }

  /* Lock cue on the row: while a ceremony is in flight, the
     non-selected pills dim and become non-interactive. The
     selected pill stays fully opaque and keeps its hover-cursor.
     Pointer-events: none on the others is the actual lock — the
     ceremonyInFlight JS guard catches any race that would have
     reached the click handler. */
  .lgs-overlay-row.is-ceremony-locked .lgs-overlay-option:not(.is-confirming) {
    pointer-events: none;
    opacity: 0.55;
    transition: opacity 220ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lgs-overlay-flag {
    /* Reduced from 16 → 14 so the flag accents the language label
       rather than competing with it. Kept at line-height: 1 so the
       emoji's natural baseline doesn't shift the pill's vertical
       rhythm. */
    font-size: 14px;
    line-height: 1;
    /* Tiny opacity reduction so flags don't punch through the
       muted glass row — they should sit in the pill, not on top. */
    opacity: 0.88;
  }

  .lgs-overlay-native {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .lgs-overlay-en {
    font-size: 11px;
    color: var(--yuval-text-tertiary, #9a8e7c);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-inline-start: 2px;
  }

  .lgs-overlay-option.is-active .lgs-overlay-native {
    /* Active label gets a small additional weight bump on top of
       the pill's overall 600. Belt-and-braces with the gold tint
       and check chip — different reader populations rely on
       different cues. */
    font-weight: 600;
  }

  .lgs-overlay-option.is-active .lgs-overlay-en {
    color: var(--yuval-text-secondary, #c4b8a8);
  }

  .lgs-overlay-check {
    /* Slightly smaller (14 vs 16) and a more refined gold gradient
       with a faint inner highlight so the chip reads as enameled
       rather than printed. Border-radius stays 50% (a coin). */
    width: 14px;
    height: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background:
      linear-gradient(135deg, #f1d063 0%, #c9a227 65%, #a88718 100%);
    color: #1a1410;
    box-shadow:
      inset 0 1px 0 rgba(255, 245, 200, 0.45),
      0 0 6px rgba(232, 197, 71, 0.30);
    flex-shrink: 0;
    margin-inline-start: 2px;
  }

  .lgs-overlay-check svg {
    width: 9px;
    height: 9px;
  }

  /* ── 3D Earth stage ─────────────────────────────────────────────
     Square viewport on desktop, capped to viewport height/width on
     small screens so the canvas always fits inside the overlay
     without clipping or overflowing. Three.js mounts a <canvas>
     directly inside this element on first open. */
  .lgs-overlay-earth {
    position: relative;
    /* Desktop default: cinematic 600 px target, with vw / vh
       constraints to keep the globe within the viewport on narrower
       or shorter screens. The renderer is sized via refit() to
       whatever this CSS resolves to — never CSS-scaled — so the
       drawing buffer always matches the visible pixel count. */
    width: min(600px, 78vw, 68vh);
    aspect-ratio: 1 / 1;
    /* Keeps the rAF/render contained so the rest of the page can
       paint independently. */
    contain: layout paint;
  }

  .lgs-overlay-earth canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }

  /* Preflight state — kills the "duplicate Earth" flash that
     happened between the moment Three.js mounted its canvas
     (full-size, centered, immediately renderable) and the moment
     runLaunchFlight pinned the stage to the trigger via inline
     transform. visibility: hidden was chosen over display: none on
     purpose: display:none zeroes out getBoundingClientRect, which
     would break the FLIP geometry that the flight relies on.
     The class is removed SYNCHRONOUSLY by runLaunchFlight in the
     same JS turn as the inline transform is applied, so the
     stage's first painted frame is at the trigger position — not
     at the natural centered position. Reduced-motion / bypass
     branches remove it directly (no flight, stage paints centered
     because that IS the final state). */
  .lgs-overlay-earth.is-preflight {
    visibility: hidden;
  }

  /* ── Geographic hotspot ──────────────────────────────────────────
     A small light point that marks the language's region on the
     planet. Geographically accurate: the host's per-frame rAF
     calls handle.projectLatLng(lat, lng) and writes the resulting
     CSS pixels into --lgs-hx / --lgs-hy on the outer element. The
     outer element positions via transform translate; the inner
     .lgs-hotspot-dot owns the visual + pulse so the keyframe's
     transform: scale() can't fight the position transform.

     The host also toggles .is-visible based on the frontFacing
     flag returned by projectLatLng — when the target region
     rotates past the silhouette into the back hemisphere, the
     hotspot fades out rather than smearing across the limb. */
  .lgs-hotspot {
    position: absolute;
    /* The transform's reference point IS (left: 0, top: 0) — the
       container's top-left. We translate by raw pixel values
       computed in JS (relative to the container's top-left, exactly
       what projectLatLng returns). The default off-screen position
       keeps the marker invisible until the first projection write. */
    left: 0;
    top: 0;
    width: 0;
    height: 0;
    transform: translate(var(--lgs-hx, -9999px), var(--lgs-hy, -9999px));
    pointer-events: none;
    opacity: 0;
    transition: opacity 360ms cubic-bezier(0.4, 0, 0.6, 1);
    /* Above the canvas (siblings inside .lgs-overlay-earth). */
    z-index: 2;
    /* `will-change: transform` hints the compositor to keep the
       hotspot on its own layer so per-frame transform writes
       don't force a full repaint of the canvas behind it. */
    will-change: transform;
  }

  .lgs-hotspot.is-visible {
    opacity: 1;
  }

  /* Inner dot — the actual visual. Centered on the parent's
     translate origin via the negative left/top so (0, 0) on the
     parent equals the dot's center. Pulse animates here so the
     parent's transform stays clean. */
  .lgs-hotspot-dot {
    position: absolute;
    left: -5px;
    top: -5px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(255, 248, 220, 0.95) 0%,
      rgba(255, 220, 130, 0.85) 28%,
      rgba(232, 197, 71, 0.55) 55%,
      rgba(232, 197, 71, 0) 100%
    );
    box-shadow:
      0 0 6px rgba(255, 220, 130, 0.55),
      0 0 14px rgba(232, 197, 71, 0.28),
      0 0 28px rgba(232, 197, 71, 0.12);
  }

  .lgs-hotspot.is-visible .lgs-hotspot-dot {
    animation: lgs-hotspot-pulse 2400ms cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes lgs-hotspot-pulse {
    0%, 100% {
      transform: scale(1);
      box-shadow:
        0 0 6px rgba(255, 220, 130, 0.55),
        0 0 14px rgba(232, 197, 71, 0.28),
        0 0 28px rgba(232, 197, 71, 0.12);
    }
    50% {
      transform: scale(1.18);
      box-shadow:
        0 0 9px rgba(255, 220, 130, 0.62),
        0 0 22px rgba(232, 197, 71, 0.22),
        0 0 38px rgba(232, 197, 71, 0.10);
    }
  }

  /* ── Hover connection cue ────────────────────────────────────────
     A subtler twin of the .is-active::after beam, painted while a
     non-active pill is hovered or keyboard-focused. The active
     pill's cue is gold and slightly taller; this hover variant is
     paler and the same short length so the row never has two
     equally-loud connectors at once. Hidden by default; the row
     reveals on .is-revealed so this cue only appears once the
     language row itself is interactive. */
  .lgs-overlay-option:not(.is-active):hover::after,
  .lgs-overlay-option:not(.is-active):focus-visible::after {
    content: '';
    position: absolute;
    left: 50%;
    top: calc(100% + 2px);
    width: 1px;
    height: clamp(8px, 1.4vh, 14px);
    transform-origin: top center;
    /* Hover/focus beam carries the same orbital tilt as the active
       beam — keeps the cue visually consistent across states. */
    transform: translateX(-50%) rotate(
      calc(var(--lgs-beam-rot, 0deg) * var(--lgs-arc-scale, 1))
    );
    background: linear-gradient(
      to bottom,
      rgba(244, 226, 170, 0.32) 0%,
      rgba(244, 226, 170, 0.10) 55%,
      rgba(244, 226, 170, 0) 100%
    );
    pointer-events: none;
  }

  /* Tablet — language row often wraps onto two lines, which eats
     vertical room. Slightly tighter cap than desktop and a stricter
     vh constraint keep the globe from pushing the row off screen.

     The arc is softened (55 %) on tablet rather than disabled —
     the row still has horizontal room for a gentle curve and the
     orbital cue stays legible. */
  @media (max-width: 768px) {
    .lgs-overlay-earth {
      width: min(520px, 84vw, 64vh);
    }
    .lgs-overlay-option {
      --lgs-arc-scale: 0.55;
    }
  }

  @media (max-width: 480px) {
    .lgs-overlay-stage {
      width: 96vw;
      gap: 16px;
      padding: 12px;
    }
    .lgs-overlay-option {
      padding: 8px 12px;
      gap: 8px;
      /* Mobile fallback — the arc collapses to a flat row. A tall
         arc on a narrow viewport pushes the apex into the stage
         padding and crowds the globe; a flat row keeps reading
         priorities (label first, geographic linkage second) intact.
         Hover lift and active glow still play; only the per-pill
         vertical stagger is dropped. */
      --lgs-arc-scale: 0;
    }
    /* Mobile — without a visible orbit there's nothing for the
       node to anchor to, and a tall energy beam reads as a stray
       stick. Hide the node; shrink the active beam back to the
       short hover-style cue so the "selected pill points at the
       globe" relationship still exists but isn't theatrical. */
    .lgs-overlay-option.is-active::before {
      display: none;
    }
    .lgs-overlay-option.is-active::after {
      top: calc(100% + 2px);
      height: clamp(8px, 1.4vh, 14px);
      box-shadow: none;
    }
    .lgs-overlay-native {
      font-size: 13px;
    }
    .lgs-overlay-en {
      display: none;
    }
    .lgs-overlay-earth {
      /* Phone — slightly more generous than the prior 80vw / 60vh,
         since the rest of the overlay is dimmed and the Earth is the
         hero. Still leaves margin in landscape and on short
         viewports. */
      width: min(86vw, 62vh);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lgs-trigger {
      transition: none !important;
    }
    .lgs-trigger:hover {
      transform: none;
    }
    /* Cinematic launch/return choreography (Step 1) — disabled
       entirely under reduced motion. The JS path also short-
       circuits the charge + dock + curved-flight keyframes,
       belt-and-braces. The simple opacity cross-fade between the
       small globe and big stage still works without any of these. */
    .lgs-trigger.is-charging,
    .lgs-trigger.is-docking {
      animation: none !important;
    }
    /* Geographic hotspot (Step 2) — keep the dot visible but stop
       it pulsing under reduced motion. Opacity transition is
       preserved so the show/hide still feels intentional rather
       than abrupt. The host's JS path swaps animateFocusLatLng for
       the snap focusLatLng under the same media query, so the
       globe itself never tweens. The pulse now lives on the inner
       .lgs-hotspot-dot — disabling it there. */
    .lgs-hotspot {
      transition: opacity 200ms cubic-bezier(0.2, 0.7, 0.2, 1) !important;
    }
    .lgs-hotspot .lgs-hotspot-dot,
    .lgs-hotspot.is-visible .lgs-hotspot-dot {
      animation: none !important;
    }
    /* Step 4 — selection ceremony pulses disabled under reduced
       motion. The JS path also shortens ceremonyMs to ~80 ms so the
       commit fires almost immediately; the label still shows and
       the .is-confirming class is still applied (preserves the
       "selected state" cue), they just don't animate. */
    .lgs-overlay-option.is-active.is-confirming::before,
    .lgs-overlay-option.is-active.is-confirming::after,
    .lgs-hotspot.is-confirming.is-visible .lgs-hotspot-dot {
      animation: none !important;
    }
    .lgs-overlay-confirm-label {
      transition: none !important;
    }
    /* Reduced-motion: snap the language change instead of panning,
       and ignore pointer-hover parallax (the JS handler also
       short-circuits under this media query — belt + braces).
       Opacity transition is preserved so the launched-out
       cross-fade with the cinematic Earth still works. */
    .lgs-globe {
      transition: opacity 200ms cubic-bezier(0.2, 0.7, 0.2, 1) !important;
    }
    .lgs-overlay-backdrop,
    .lgs-overlay-stage,
    .lgs-overlay-option {
      transition: none !important;
    }
    /* Reduced motion: drop the 1 px hover lift but PRESERVE the
       arc-y baseline so hovering a pill doesn't make it jump from
       its orbit position to flat-row level. The arc itself is
       layout, not motion — the spec's "no animation" rule applies
       to the transition between states, not the static position. */
    .lgs-overlay-option:hover {
      transform: translateY(
        calc(var(--lgs-arc-y, 0px) * var(--lgs-arc-scale))
      );
    }
  }
</style>

<script>
  import type { InteractiveEarthHandle, FocusPoint } from '../../scripts/interactive-earth-3d';

  // Single shared Earth instance per page. We keep the canvas alive
  // across open/close so reopening is instant and no second canvas is
  // ever created (per the spec's "do not create duplicate canvases"
  // rule). True teardown happens only on view transitions / unload.
  let earthHandle: InteractiveEarthHandle | null = null;
  let earthLoading: Promise<InteractiveEarthHandle | null> | null = null;
  let lastFocusedBeforeOpen: HTMLElement | null = null;

  // ── Animation state machine ────────────────────────────────────
  // The launch and return animations cover ~500ms and ~480ms. During
  // those windows, additional opens, closes, and language picks must
  // be ignored — otherwise we get duplicate animations, half-flown
  // globes, and language switches firing while the user can't see
  // what they picked. The state guard makes every transition explicit:
  //
  //   closed   → open click   → launching → launch ends → open
  //   open     → close click  → returning → return ends → closed
  //   open     → language pick → returning (with pendingLanguageChange)
  //   any      → astro:before-swap → closed (forced reset on teardown)
  type AnimationState = 'closed' | 'launching' | 'open' | 'returning';
  let state: AnimationState = 'closed';

  // When set, the close path will trigger this language change AFTER
  // the return animation completes (rather than at click time). This
  // is what lets the user see the small globe land back in the header
  // before the page reloads / re-renders for the new language.
  let pendingLanguageChange: string | null = null;

  // The single in-flight WAAPI handle, so we can cancel it cleanly on
  // teardown even if state still says 'launching' or 'returning'.
  let activeAnimation: Animation | null = null;

  // Pending setTimeout IDs for the Step-1 choreography (charge hold,
  // cross-fade timer, docking timers). Tracked centrally so destroy /
  // teardown can clear every pending phase without leaving a dangling
  // class change that fires after the user has navigated away.
  const transientTimers = new Set<number>();

  function setTransientTimeout(fn: () => void, ms: number): number {
    const id = window.setTimeout(() => {
      transientTimers.delete(id);
      fn();
    }, ms);
    transientTimers.add(id);
    return id;
  }

  function clearTransientTimer(id: number): void {
    window.clearTimeout(id);
    transientTimers.delete(id);
  }

  function clearAllTransientTimers(): void {
    transientTimers.forEach((id) => window.clearTimeout(id));
    transientTimers.clear();
  }

  function stripTransientClasses(trigger: HTMLElement): void {
    trigger.classList.remove('is-charging', 'is-docking');
  }

  // ── Step 2 — geographic-focus runtime state ─────────────────────
  //   focusIntentTimer  — pending hover-intent debounce (set by
  //                       scheduleFocus, cleared by cancelPendingFocus
  //                       or by the next scheduleFocus call).
  //   dragCooldownUntil — performance.now() timestamp; while
  //                       now < this, hover/focus rotations are
  //                       suppressed so we don't undo the user's
  //                       manual drag.
  //   currentFocusCode  — the language code we last rotated to. Used
  //                       to skip no-op rotations on re-hover and to
  //                       decide whether a selection click needs to
  //                       run a rotation at all.
  let focusIntentTimer: number | null = null;
  let dragCooldownUntil = 0;
  let currentFocusCode: string | null = null;

  function cancelPendingFocus(): void {
    if (focusIntentTimer !== null) {
      window.clearTimeout(focusIntentTimer);
      focusIntentTimer = null;
    }
  }

  // ── Geographic-hotspot projection tracker ───────────────────────
  // The hotspot is positioned by projecting the active focus point's
  // lat/lng through the Earth's camera every frame, NOT by assuming
  // the rotation has brought the region to the stage center. That
  // assumption was wrong: even when focusLatLng is correct, idle
  // rotation, in-flight focus animations, and manual drag all move
  // the region away from center, and the marker has to follow.
  //
  // A single rAF loop runs while a focus is tracked; it stops on
  // teardown / overlay close / no-active-focus. The loop calls
  // earthHandle.projectLatLng() which uses the same UV→3D formula
  // as the SphereGeometry, so the projected pixel is exactly the
  // surface location the texture renders for that lat/lng.
  let hotspotRafId: number | null = null;
  let hotspotTrackingFocus: FocusPoint | null = null;
  let hotspotTrackingCode: string | null = null;
  let hotspotEl: HTMLElement | null = null;
  // Diagnostic guard — log Hebrew's projection ONCE per page-load
  // so the user (and future debug sessions) can confirm the
  // hotspot lands on Israel without spamming the console every
  // frame. Reset by destroyEarth so a view transition that
  // recreates the page can re-log.
  let hotspotDiagnosticLoggedFor: string | null = null;

  function stopHotspotTracking(removeClass = true): void {
    if (hotspotRafId !== null) {
      cancelAnimationFrame(hotspotRafId);
      hotspotRafId = null;
    }
    hotspotTrackingFocus = null;
    hotspotTrackingCode = null;
    if (hotspotEl && removeClass) {
      hotspotEl.classList.remove('is-visible');
    }
    hotspotEl = null;
  }

  function startHotspotTracking(
    stage: HTMLElement | null,
    code: string,
    focus: FocusPoint,
  ): void {
    if (!stage) return;
    const hotspotElement = stage.querySelector<HTMLElement>('.lgs-hotspot');
    if (!hotspotElement) return;

    // The focus arg flows in from the language-focus map and at
    // runtime is a LanguageFocusEntry (which extends FocusPoint).
    // hotspotPointFor extracts the explicit marker target if one is
    // declared, otherwise returns the camera focus point. This is
    // the ONLY place the split matters — focusLatLng /
    // animateFocusLatLng above keep using the camera focus point,
    // preserving the existing composition.
    const markerPoint = hotspotPointFor(focus as LanguageFocusEntry);
    hotspotTrackingFocus = markerPoint;
    hotspotTrackingCode = code;
    hotspotEl = hotspotElement;

    // Already running — the closure reads hotspotTrackingFocus
    // fresh each frame, so updating it above is enough to switch
    // languages without restarting the rAF.
    if (hotspotRafId !== null) return;

    const frame = () => {
      hotspotRafId = null;
      const focusNow = hotspotTrackingFocus;
      const codeNow = hotspotTrackingCode;
      const el = hotspotEl;
      const handle = earthHandle;
      if (!focusNow || !el || !handle) {
        if (el) el.classList.remove('is-visible');
        return;
      }
      const proj = handle.projectLatLng(focusNow.lat, focusNow.lng);
      if (!proj) {
        el.classList.remove('is-visible');
        return;
      }
      el.style.setProperty('--lgs-hx', `${proj.x.toFixed(2)}px`);
      el.style.setProperty('--lgs-hy', `${proj.y.toFixed(2)}px`);
      el.classList.toggle('is-visible', proj.frontFacing);

      // One-shot diagnostic: per-language. Gated behind isLgsDebug()
      // so production builds stay quiet — set window.__lgsDebug = true
      // in DevTools to re-enable for hotspot-projection verification.
      if (
        isLgsDebug() &&
        hotspotDiagnosticLoggedFor !== codeNow &&
        codeNow !== null
      ) {
        hotspotDiagnosticLoggedFor = codeNow;
        console.info('[LanguageGlobeSelector] hotspot projection', {
          code: codeNow,
          lat: focusNow.lat,
          lng: focusNow.lng,
          label: focusNow.label,
          projectedX: Number(proj.x.toFixed(2)),
          projectedY: Number(proj.y.toFixed(2)),
          visible: proj.frontFacing,
        });
      }

      hotspotRafId = requestAnimationFrame(frame);
    };
    hotspotRafId = requestAnimationFrame(frame);
  }

  /**
   * Run a focus rotation immediately (no debounce). Used both by
   * scheduleFocus (after the hover-intent delay) and by the
   * selection click flow (which doesn't want any delay before
   * starting the land-and-commit ceremony). Returns the rotation
   * duration so the caller can wait for it to finish.
   *
   *   - Reduced motion: snaps via focusLatLng instead of animating.
   *   - Drag cooldown: caller is expected to have checked
   *     dragCooldownUntil; this function does NOT re-check, so the
   *     selection path can always reach the target even within
   *     the cooldown window.
   *   - No-op when the requested code is already current AND the
   *     rotation isn't being forced — saves a redundant animation
   *     pass on repeated hovers of the same pill.
   */
  function runFocusNow(
    handle: InteractiveEarthHandle,
    stage: HTMLElement | null,
    code: string,
    focus: FocusPoint,
    forceRun: boolean,
  ): number {
    if (!forceRun && currentFocusCode === code) {
      // Already on target; just make sure the hotspot's projection
      // tracker is following this point (no-op if it already is).
      startHotspotTracking(stage, code, focus);
      return 0;
    }
    currentFocusCode = code;
    if (isReducedMotion()) {
      handle.focusLatLng(focus.lat, focus.lng);
      startHotspotTracking(stage, code, focus);
      return 0;
    }
    handle.animateFocusLatLng(focus.lat, focus.lng, FOCUS_HOVER_MS);
    startHotspotTracking(stage, code, focus);
    return FOCUS_HOVER_MS;
  }

  // ── Step 4 — selection ceremony state ──────────────────────────
  // Module-level (not per-root closure) so:
  //   1. finalizeOverlayClose can reset the lock if the user
  //      presses Escape or clicks the backdrop mid-ceremony.
  //   2. destroyEarth can reset the lock during a view-transition
  //      that aborts the ceremony before commit fires.
  //   3. Only one ceremony at a time across all selector instances
  //      on the page (typically one in the header — the lock is
  //      effectively per-page-load).
  let ceremonyInFlight = false;
  let confirmingBtn: HTMLElement | null = null;
  let confirmingHotspot: HTMLElement | null = null;
  let confirmingRow: HTMLElement | null = null;
  let confirmingLabel: HTMLElement | null = null;

  /**
   * Begin the visual ceremony. Adds .is-confirming to the active
   * pill, the hotspot, and the language row (for the dim/lock
   * effect); writes the "Native · Region" label and fades it in.
   * Idempotent: a second call without endSelectionCeremony in
   * between cleans up the previous tracked elements first.
   */
  function startSelectionCeremony(
    btn: HTMLElement,
    focus: LanguageFocusEntry | null,
    stage: HTMLElement | null,
  ): void {
    // Defensive — clean any stragglers from a previous ceremony
    // that ended in an unusual path (e.g. cancelled mid-flight).
    endSelectionCeremony();

    btn.classList.add('is-confirming');
    confirmingBtn = btn;

    const row = btn.closest<HTMLElement>('.lgs-overlay-row');
    if (row) {
      row.classList.add('is-ceremony-locked');
      confirmingRow = row;
    }

    if (stage) {
      const hotspot = stage.querySelector<HTMLElement>('.lgs-hotspot');
      if (hotspot) {
        hotspot.classList.add('is-confirming');
        confirmingHotspot = hotspot;
      }

      const labelEl = stage.querySelector<HTMLElement>('.lgs-overlay-confirm-label');
      if (labelEl && focus) {
        const native = btn.querySelector<HTMLElement>('.lgs-overlay-native')?.textContent ?? '';
        // Prefer the explicit hotspot region label when defined
        // (he → "Israel"); fall back to the camera focus label's
        // first segment so en / es get the short region name
        // ("North America", "Spain") instead of the longer
        // composition label ("North America / United States").
        const fullRegion = focus.hotspot?.label ?? focus.label ?? '';
        const region = fullRegion.split('/')[0].trim();
        const text = native && region ? `${native} · ${region}` : (native || region || '');
        labelEl.textContent = text;
        // rAF lets the textContent change paint before the
        // fade-in transition runs, so the label transitions in
        // with its final text — not with the previous ceremony's.
        requestAnimationFrame(() => {
          if (confirmingLabel === labelEl || !confirmingLabel) {
            labelEl.classList.add('is-visible');
          }
        });
        confirmingLabel = labelEl;
      }
    }
  }

  /** End the visual ceremony. Idempotent. Always safe to call
   *  multiple times — the second call is a no-op. */
  function endSelectionCeremony(): void {
    if (confirmingBtn) {
      confirmingBtn.classList.remove('is-confirming');
      confirmingBtn = null;
    }
    if (confirmingHotspot) {
      confirmingHotspot.classList.remove('is-confirming');
      confirmingHotspot = null;
    }
    if (confirmingRow) {
      confirmingRow.classList.remove('is-ceremony-locked');
      confirmingRow = null;
    }
    if (confirmingLabel) {
      confirmingLabel.classList.remove('is-visible');
      // textContent kept so a re-open mid-ceremony briefly shows
      // the previous label until the next ceremony overwrites it
      // — far better UX than a blank flash. The opacity transition
      // takes the visible state out within 220 ms anyway.
      confirmingLabel = null;
    }
  }

  /** Schedule a focus rotation after the hover-intent debounce.
   *  Cancels any earlier pending intent so a fast cursor sweep
   *  across the row only commits to the option the cursor actually
   *  settles on. */
  function scheduleFocus(
    handle: InteractiveEarthHandle,
    stage: HTMLElement | null,
    code: string,
    focus: FocusPoint,
  ): void {
    cancelPendingFocus();
    // Respect the post-drag cooldown — the user just took manual
    // control, don't yank the globe back out from under them.
    if (performance.now() < dragCooldownUntil) return;
    focusIntentTimer = window.setTimeout(() => {
      focusIntentTimer = null;
      // Re-check the cooldown at fire time — a fast drag-then-hover
      // can update dragCooldownUntil between schedule and fire.
      if (performance.now() < dragCooldownUntil) return;
      runFocusNow(handle, stage, code, focus, false);
    }, FOCUS_INTENT_MS);
  }

  // True while the post-navigation resume orchestrator is running.
  // Guards against duplicate resume runs that could happen if Astro
  // re-fires page-load / after-swap on the same document (rare on a
  // hard reload, but cheap insurance). The state machine also blocks
  // duplicates via `state !== 'closed'`, but a dedicated boolean
  // keeps the intent obvious at every call site.
  let resumeInProgress = false;

  // Extended FocusPoint shape carried by the data-language-focus
  // attribute. The optional `hotspot` carries the marker-target
  // coordinate when the camera composition needs to differ from the
  // precise country location (currently only Hebrew, where the
  // camera centers the Eastern Mediterranean for a nicer composition
  // and the marker pins Israel proper). FocusPoint from the Earth
  // module is left unchanged — it only sees lat/lng for rotation.
  interface LanguageFocusEntry extends FocusPoint {
    hotspot?: FocusPoint;
  }
  type LanguageFocusMap = Record<string, LanguageFocusEntry | null>;

  /**
   * Return the point to project for the hotspot marker.
   *   - If the entry has an explicit `hotspot`, use that.
   *   - Otherwise fall back to the camera focus point — preserves
   *     the existing English / Spanish behavior unchanged.
   */
  function hotspotPointFor(entry: LanguageFocusEntry): FocusPoint {
    return entry.hotspot ?? entry;
  }

  // Step-1 choreography phase durations.
  //   CHARGE: how long the "preparing to launch" pulse on the
  //           trigger holds. Short enough to not delay the open
  //           (under the 250 ms perception threshold for "instant")
  //           but long enough that even a cached Earth load shows
  //           the user a visible charge before the flight begins.
  //   DOCK:   how long the "globe lands in the header" scale-pop
  //           runs. Anchored to land its 60 % overshoot peak right
  //           as the return-flight WAAPI hits its final frame.
  //   DOCK_LEAD_MS: how many ms BEFORE the return flight ends
  //                 we add the is-docking class. The keyframe peaks
  //                 at 60 % (~144 ms), so DOCK_LEAD_MS ≈ 144 lines
  //                 the peak up with the flight's last frame.
  const CHARGE_DURATION_MS = 220;
  const DOCK_DURATION_MS = 240;
  const DOCK_LEAD_MS = 150;
  // Launch duration raised from 540 → 880 ms. The previous value
  // felt like a fast pop: the globe was already centered and full-
  // size before the user had time to track the motion. 880 ms sits
  // inside the spec's 850-1050 ms band — long enough for the
  // gradual scale ramp to read, short enough not to feel like a
  // wait. Return duration (RETURN_DURATION_MS, 760 ms) is left
  // untouched per the user's "return looks good" feedback.
  const LAUNCH_DURATION_MS = 880;
  // Step 2 — geographic linkage timings.
  //   FOCUS_HOVER_MS: rotation duration on hover/focus. Centered in
  //                   the requested 550–800 ms band; long enough to
  //                   read as a deliberate camera move, short enough
  //                   to keep up with arrow-key list navigation.
  //   FOCUS_INTENT_MS: hover-intent debounce. Quick mouse-overs (the
  //                    user scanning the row) should not chain three
  //                    rotations in a row — this guard waits for the
  //                    cursor to settle on a single option first.
  //   DRAG_COOLDOWN_MS: how long after a manual drag ends we keep
  //                     suppressing hover/focus rotations. Long enough
  //                     that the user perceives "I just took control"
  //                     as a stable state, short enough that returning
  //                     focus to the row feels responsive again.
  //   SELECTION_LAND_MS: post-click ceremony — minimum time the
  //                      selection's focus rotation gets to land
  //                      before the close / navigation flow begins.
  const FOCUS_HOVER_MS = 650;
  const FOCUS_INTENT_MS = 90;
  const DRAG_COOLDOWN_MS = 1800;
  // Step 4 — selection-ceremony timings.
  //   SELECTION_PULSE_MS: minimum ceremony duration. The CSS keyframes
  //     run 640 ms; the commit fires at 700 ms so the pulses complete
  //     cleanly before the row fades and the return flight begins.
  //   POST_ROTATION_BUFFER_MS: extra pause AFTER rotation lands so
  //     the user perceives the rotation has stopped before things
  //     start moving again. Combined with rotationDur this stays
  //     inside the spec's 650-950 ms ceremony budget for cold rotations.
  //   REDUCED_MOTION_CEREMONY_MS: short hold so the lock + label
  //     paint at least once before commit, but quickly enough to
  //     feel snappy under prefers-reduced-motion.
  const SELECTION_PULSE_MS = 700;
  const POST_ROTATION_BUFFER_MS = 140;
  const REDUCED_MOTION_CEREMONY_MS = 90;
  // Return flight slowed from 460 → 760 ms. The previous value
  // felt rushed — the globe finished its descent before the eye
  // had time to track it. 760 ms is still well inside the
  // "feels responsive" budget (under 1 s) but gives the motion a
  // pleasant, settling cadence — closer to the launch's 540 ms
  // expand pacing. The cross-fade-with-the-small-header-globe
  // math in runReturnFlight uses (RETURN_DURATION_MS - 220), so
  // increasing the duration here automatically gives the cross-
  // fade a longer overlap (220 ms of "both globes co-present at
  // the trigger"), which makes the handoff feel even smoother.
  const RETURN_DURATION_MS = 760;
  const FLIGHT_EASING = 'cubic-bezier(0.32, 0.72, 0.18, 1)';
  // Dedicated launch easing — slower start, smoother arrival.
  // FLIGHT_EASING (above) is an aggressive ease-out: starts fast,
  // overshoots, settles late. Reads correctly for the RETURN flight
  // (where the user expects a quick exit toward the header), but
  // for the LAUNCH it made the globe feel like a pop instead of a
  // gradual rise out of the trigger. This curve starts gently
  // (0.50, 0.05) and arrives smoothly (0.30, 1), no late-stage
  // snap. Combined with the deliberately spaced keyframes in
  // runLaunchFlight, this gives the "slow detach, controlled
  // travel, late expansion" cadence the spec asks for. The
  // return path keeps FLIGHT_EASING — only launch changes here.
  const LAUNCH_EASING = 'cubic-bezier(0.50, 0.05, 0.30, 1.00)';
  // Time the language row needs to fade out before we start the
  // return flight — must be ≥ the row's CSS transition duration so
  // the row is visually gone when the globe begins shrinking back.
  const ROW_FADEOUT_MS = 200;

  function isReducedMotion(): boolean {
    return typeof window !== 'undefined'
      && typeof window.matchMedia === 'function'
      && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  }

  /**
   * Debug-mode gate for diagnostic console output. Off by default.
   * Set `window.__lgsDebug = true` in DevTools to enable verbose
   * logs (refit diagnostic on open, hotspot projection sample per
   * language). Error/warn output is always emitted — only the
   * info-level logs are gated.
   */
  function isLgsDebug(): boolean {
    return typeof window !== 'undefined'
      && (window as unknown as { __lgsDebug?: boolean }).__lgsDebug === true;
  }

  function nextFrame(): Promise<void> {
    return new Promise((resolve) => requestAnimationFrame(() => resolve()));
  }

  function wait(ms: number): Promise<void> {
    return new Promise((resolve) => window.setTimeout(resolve, ms));
  }

  function readFocusMap(overlay: HTMLElement): LanguageFocusMap {
    const raw = overlay.dataset.languageFocus;
    if (!raw) return {};
    try {
      return JSON.parse(raw) as LanguageFocusMap;
    } catch {
      return {};
    }
  }

  async function ensureEarth(stage: HTMLElement, focus: FocusPoint | null): Promise<InteractiveEarthHandle | null> {
    if (earthHandle) return earthHandle;
    if (earthLoading) return earthLoading;
    earthLoading = import('../../scripts/interactive-earth-3d')
      .then(({ createInteractiveEarth }) =>
        createInteractiveEarth(stage, { initialFocus: focus })
      )
      .then((handle) => {
        earthHandle = handle;
        earthLoading = null;
        return handle;
      })
      .catch((err) => {
        // We swallow the error after logging because the overlay's
        // language list is the actual functional UI — the 3D globe is
        // visual decoration. A WebGL-context failure on a niche device
        // shouldn't break language switching.
        console.warn('[LanguageGlobeSelector] 3D Earth failed to initialize:', err);
        earthLoading = null;
        return null;
      });
    return earthLoading;
  }

  function destroyEarth(): void {
    if (activeAnimation) {
      activeAnimation.cancel();
      activeAnimation = null;
    }
    // Clear any pending Step-1 phase timers (charge hold, cross-fade,
    // docking class add/remove) so a teardown mid-flight can't leave a
    // setTimeout firing after the page has navigated away.
    clearAllTransientTimers();
    // Step-2 — cancel pending hover-intent debounce, drop the hotspot
    // class from every stage on the page, reset focus tracking. Same
    // intent as clearAllTransientTimers: no dangling effects after
    // teardown.
    cancelPendingFocus();
    // Stop the projection rAF AND clear is-visible from every
    // hotspot on the page (covers the case where multiple
    // LanguageGlobeSelector instances were mounted). stopHotspotTracking
    // only touches the currently-tracked element; the manual loop
    // catches stragglers.
    stopHotspotTracking();
    document.querySelectorAll<HTMLElement>('.lgs-hotspot')
      .forEach((el) => el.classList.remove('is-visible'));
    // Strip preflight from every stage on the page — covers a
    // teardown during the preflight window (between unhide and
    // runLaunchFlight) so the next open isn't stuck with the stage
    // class set on a different Earth handle.
    document.querySelectorAll<HTMLElement>('.lgs-overlay-earth')
      .forEach((el) => el.classList.remove('is-preflight'));
    hotspotDiagnosticLoggedFor = null;
    currentFocusCode = null;
    dragCooldownUntil = 0;
    // Step 4 — any in-flight ceremony must end here so a teardown
    // mid-ceremony doesn't strand the is-confirming classes or the
    // ceremony lock. Idempotent — safe even if no ceremony was
    // running.
    endSelectionCeremony();
    ceremonyInFlight = false;
    // Strip Step-1 transient classes from every trigger on the page —
    // a teardown right after a click would otherwise leave is-charging
    // or is-docking stuck on the trigger until the next interaction.
    document.querySelectorAll<HTMLElement>('.lgs-trigger').forEach(stripTransientClasses);
    if (earthHandle) {
      earthHandle.destroy();
      earthHandle = null;
    }
    earthLoading = null;
    state = 'closed';
    pendingLanguageChange = null;
  }

  // ── /library navigation handoff (pre-navigation half) ───────────
  // Library uses the hard-reload branch of triggerLanguageChange
  // (window.location.href = ?lang=xx). The default flow runs the
  // return flight BEFORE that navigation, so users see the
  // cinematic close finish and then watch the fresh page paint with
  // RTL/LTR + content-width jumps. The handoff inverts the order:
  //
  //   1. On /library, the option-click handler skips close() and
  //      navigates immediately with the overlay still painted —
  //      this step.
  //   2. On the new page, a follow-up step will detect the
  //      sessionStorage record below, re-open the overlay at the
  //      already-centered state (no launch flight), and run the
  //      return flight there once the language layout has settled.
  //
  // The split lives entirely inside this component. No language
  // event surface changes, no Header.astro changes, no /library
  // page changes.
  const TRANSITION_KEY = 'yuval_lgs_transition';

  interface TransitionRecord {
    targetLang: string;
    fromUrl: '/library';
    startedAt: number;
    expectedReturn: boolean;
  }

  function isLibraryHardReloadTransition(): boolean {
    // Strictly /library only in this rollout phase. Chapter pages
    // already swap client-side via #chapter-container — no jump
    // problem to solve. Other reload-based pages aren't in scope
    // yet; we'll widen the gate path-by-path once the resume half
    // is in place and proven.
    if (window.location.pathname !== '/library') return false;
    // Defensive: if /library ever gains a #chapter-container (it
    // doesn't today), don't engage the navigation handoff — the
    // client-side branch would handle it without a reload.
    if (document.getElementById('chapter-container')) return false;
    return true;
  }

  function persistTransition(targetLang: string): void {
    try {
      const record: TransitionRecord = {
        targetLang,
        fromUrl: '/library',
        startedAt: Date.now(),
        expectedReturn: true,
      };
      sessionStorage.setItem(TRANSITION_KEY, JSON.stringify(record));
    } catch {
      // Storage quota / privacy mode / disabled storage — silently
      // swallow. If the record can't be written, the resume step on
      // the new page simply sees no transition and we degrade to
      // today's behavior. localStorage and the URL change still
      // happen below, so the language switch itself is not blocked.
    }
  }

  function clearTransitionRecord(): void {
    try {
      sessionStorage.removeItem(TRANSITION_KEY);
    } catch {
      // Same defensive swallow as persistTransition.
    }
  }

  function triggerLanguageChange(lang: string): void {
    // Step-1 invariant: localStorage is written ONLY on user selection,
    // never on render-time fallbacks.
    localStorage.setItem('yuval_language', lang);

    // Mirror the legacy LanguageSelector dual-mode behavior:
    // chapter pages pre-render every translation and switch
    // client-side via Header.astro's `language-selector-change` →
    // `language-changed` bridge. Other pages re-render per-language
    // server-side, so a full reload with ?lang=xx is the only safe
    // way to swap content. Either way the existing event surface
    // and storage keys stay 100% unchanged.
    const supportsClientSwitch = !!document.getElementById('chapter-container');
    if (supportsClientSwitch) {
      window.dispatchEvent(
        new CustomEvent('language-selector-change', {
          detail: { language: lang },
          bubbles: true,
        })
      );
    } else {
      const url = new URL(window.location.href);
      url.searchParams.set('lang', lang);
      window.location.href = url.toString();
    }
  }

  /**
   * Compute the FLIP transform that places the stage element so it
   * visually aligns with the trigger element (same center, same
   * width). Returns the inverted transform — when applied to the
   * stage, the stage appears at the trigger's position and size; an
   * animation back to identity then "flies" it to its natural place.
   */
  function flipTransformFromTrigger(stage: HTMLElement, trigger: HTMLElement): string {
    const tr = trigger.getBoundingClientRect();
    const sr = stage.getBoundingClientRect();
    if (sr.width === 0 || sr.height === 0) {
      // Element not laid out yet — no useful transform we can compute.
      return 'none';
    }
    const dx = (tr.left + tr.width / 2) - (sr.left + sr.width / 2);
    const dy = (tr.top + tr.height / 2) - (sr.top + sr.height / 2);
    const scale = tr.width / sr.width;
    return `translate(${dx.toFixed(2)}px, ${dy.toFixed(2)}px) scale(${scale.toFixed(4)})`;
  }

  /**
   * Run the launch flight from `trigger` rect → stage's natural rect.
   *
   * Step-1 choreography (charge → detach → travel → expand → arrive → settle):
   *   - `charge` and `detach` are handled by the caller (openOverlay)
   *     via the .is-charging / .is-launched-out classes, not here.
   *   - `travel` follows a soft arc instead of a straight FLIP
   *     interpolation. A mid keyframe is injected at offset 0.55 with
   *     an upward lift bias (relative to the linear path) so the
   *     planet appears to ascend, not just shrink-up. The bias is
   *     bounded so very short flights don't get an exaggerated bow.
   *   - `expand` reuses the same WAAPI run — the scale grows from
   *     ~headerSize → ~full as the path advances.
   *   - `arrive` lands the planet at identity transform.
   *   - `settle` is baked into the keyframes as a tiny scale(1.022)
   *     overshoot at offset 0.86, returning to identity at 1.0. No
   *     extra class or timer — once the WAAPI finishes, the planet
   *     is at its natural state with no leftover transform.
   *
   * The stage is pinned to the trigger SYNCHRONOUSLY before the
   * animation starts so the first paint doesn't flash at full size.
   */
  async function runLaunchFlight(stage: HTMLElement, trigger: HTMLElement): Promise<void> {
    const startTransform = flipTransformFromTrigger(stage, trigger);
    if (startTransform === 'none') return;

    // FLIP geometry — the stage starts pinned at (dx, dy) scaled to
    // the trigger's width, and animates toward identity (translate
    // 0, 0; scale 1). All intermediate keyframes are computed from
    // these three numbers via a small helper, so the launch pacing
    // (position progress vs scale progress at each time point) is
    // expressed explicitly rather than inferred from a single easing
    // curve — the launch wants slow scale early, faster late.
    const tr = trigger.getBoundingClientRect();
    const sr = stage.getBoundingClientRect();
    const dx = (tr.left + tr.width / 2) - (sr.left + sr.width / 2);
    const dy = (tr.top + tr.height / 2) - (sr.top + sr.height / 2);
    const scale = tr.width / sr.width;
    // Arc bow on the path — applied only at the mid keyframe so the
    // travel reads as a soft rise (planet ascends ABOVE the straight
    // line at midway, then descends into center). Bounded to [-44,
    // -14] so very short flights can't bow harder than long ones.
    const arcLift = Math.max(-44, Math.min(-14, dy * 0.10));

    /**
     * Build an intermediate transform for the launch keyframe.
     *
     * @param positionProgress 0 = at trigger, 1 = at center
     * @param scaleProgress    0 = at trigger size, 1 = full size
     * @param extraY           additional y bias for arc bow
     *
     * The two progress axes are decoupled on purpose: at each
     * keyframe we set both independently to express "the globe is
     * physically 45 % of the way to center but only 32 % of the
     * way through its growth" — the visual that makes the late
     * expansion feel cinematic instead of linear.
     */
    const buildTransform = (
      positionProgress: number,
      scaleProgress: number,
      extraY = 0,
    ): string => {
      const x = dx * (1 - positionProgress);
      const y = dy * (1 - positionProgress) + extraY;
      const s = scale + (1 - scale) * scaleProgress;
      return `translate(${x.toFixed(2)}px, ${y.toFixed(2)}px) scale(${s.toFixed(4)})`;
    };

    // Pin the stage at the trigger position SYNCHRONOUSLY so the next
    // paint shows it small at the trigger, not full-size in the center.
    // Start opacity 0.40 (down from 0.55) so the planet emerges more
    // gradually from the charging trigger — the longer flight duration
    // gives the fade-in time to be felt without lingering.
    stage.style.transform = startTransform;
    stage.style.opacity = '0.40';
    // Remove the preflight (visibility: hidden) class ATOMICALLY with
    // the transform pin. Until this point the stage has been hidden
    // since openOverlay applied is-preflight before unhiding the
    // overlay — preventing the canvas from painting at its natural
    // centered position during ensureEarth + chargeRemaining. The
    // first frame the stage paints will be at the trigger position,
    // with opacity 0.40 — the launch animation's start state.
    stage.classList.remove('is-preflight');
    // Force a reflow so the browser commits the start state before
    // we begin the animation. Without this, some browsers collapse
    // the start frame and the canvas snaps to natural size.
    void stage.offsetWidth;

    // ── Launch keyframes (Step-LAUNCH refinement) ──────────────────
    // Six samples along the flight, each independently controlling
    // position-along-path (pp) and scale-along-growth (sp). The
    // decoupling is what makes the launch feel premium: at 50 % of
    // the time the planet has covered 45 % of the distance but only
    // grown to 32 % of full size, so the late phase delivers a
    // visible expansion into center instead of the old "already
    // full-size at 60 % of the time" pop.
    //
    //   offset  pp     sp     opacity   description
    //   0.00    0.00   0.00   0.40      pinned at the trigger
    //   0.20    0.10   0.05   0.65      small slow detach
    //   0.50    0.45   0.32   0.92      mid travel, growth pulled back
    //   0.78    0.85   0.85   1.00      close to center, late expansion
    //   0.92    1.00   1.022  1.00      tiny overshoot at arrival
    //   1.00    1.00   1.000  1.00      settled at full size
    //
    // The mid keyframe also receives `arcLift` for the soft upward
    // bow on the path — same effect as before, kept at this single
    // keyframe so the geometry remains identical to the previous
    // version (only timing/scale ramp changes).
    const k20 = buildTransform(0.10, 0.05);
    const k50 = buildTransform(0.45, 0.32, arcLift);
    const k78 = buildTransform(0.85, 0.85);

    const anim = stage.animate(
      [
        { transform: startTransform, opacity: 0.40, offset: 0 },
        { transform: k20, opacity: 0.65, offset: 0.20 },
        { transform: k50, opacity: 0.92, offset: 0.50 },
        { transform: k78, opacity: 1.00, offset: 0.78 },
        { transform: 'translate(0px, 0px) scale(1.022)', opacity: 1, offset: 0.92 },
        { transform: 'none', opacity: 1, offset: 1 },
      ],
      { duration: LAUNCH_DURATION_MS, easing: LAUNCH_EASING, fill: 'forwards' }
    );
    activeAnimation = anim;
    try {
      await anim.finished;
    } catch {
      // Cancelled (e.g. teardown). Bail without touching state — the
      // teardown path resets state already.
      return;
    }
    activeAnimation = null;
    // Commit to the natural state and clear inline so the element is
    // back to its CSS-only state with no leftover transform.
    stage.style.transform = '';
    stage.style.opacity = '';
    anim.cancel();
  }

  /**
   * Run the return flight from the stage's natural rect → `trigger` rect.
   *
   * Two pieces of jitter-prevention are baked into this function so
   * the end of the flight feels like a single smooth landing instead
   * of "globe arrives, blinks, small globe appears":
   *
   *   • Opacity animates 1 → 0 (not 1 → 0.85), so the big stage is
   *     fully transparent by the time it reaches the trigger.
   *     Without this, the small globe would be hidden behind a 0.85-
   *     opaque big stage right at the moment the cross-fade should
   *     hand off, producing the visible "blink" the user reported.
   *   • is-launched-out is removed mid-flight (220 ms before flight
   *     end) so the small header globe's existing 200 ms opacity
   *     transition reaches full visibility right as the big stage
   *     finishes fading out. True cross-fade — no empty frame at
   *     the trigger between the two globes.
   *   • visibility: hidden is set on the stage BEFORE anim.cancel()
   *     so the inevitable snap-back-to-center (which happens when
   *     the WAAPI forward-fill is removed) can never be painted.
   *     The previous order canceled first, then hid — which was
   *     racing the compositor.
   */
  async function runReturnFlight(stage: HTMLElement, trigger: HTMLElement): Promise<void> {
    const endTransform = flipTransformFromTrigger(stage, trigger);
    if (endTransform === 'none') return;

    // Symmetric arc to the launch: a tiny pre-descent rise (the
    // planet "winds up" before departing), then a curved travel
    // through a mid keyframe lifted above the linear path, then
    // the final landing at the trigger. The same arcLift math as
    // runLaunchFlight is used so the launch and return read as
    // mirrored cinematic arcs rather than two unrelated motions.
    const tr = trigger.getBoundingClientRect();
    const sr = stage.getBoundingClientRect();
    const dx = (tr.left + tr.width / 2) - (sr.left + sr.width / 2);
    const dy = (tr.top + tr.height / 2) - (sr.top + sr.height / 2);
    const scale = tr.width / sr.width;
    const midDx = dx * 0.5;
    const midDy = dy * 0.5;
    const midScale = scale + (1 - scale) * 0.55;
    const arcLift = Math.max(-44, Math.min(-14, dy * 0.10));
    const midTransform =
      `translate(${midDx.toFixed(2)}px, ${(midDy + arcLift).toFixed(2)}px) scale(${midScale.toFixed(4)})`;

    const anim = stage.animate(
      [
        { transform: 'none', opacity: 1, offset: 0 },
        // Wind-up: a tiny scale(1.012) inhale before the descent.
        // No translate — the planet stays at center, just breathes.
        { transform: 'translate(0px, 0px) scale(1.012)', opacity: 0.98, offset: 0.12 },
        { transform: midTransform, opacity: 0.70, offset: 0.55 },
        { transform: endTransform, opacity: 0, offset: 1 },
      ],
      { duration: RETURN_DURATION_MS, easing: FLIGHT_EASING, fill: 'forwards' }
    );
    activeAnimation = anim;

    // Cross-fade the small header globe back in during the last
    // ~220 ms of the return flight. The .lgs-globe CSS has a 200 ms
    // opacity transition; removing is-launched-out at this point
    // means the small globe is at full opacity right as the big
    // stage finishes fading to 0 — the two motions complete on the
    // same frame, eliminating the empty-trigger flicker.
    const crossfadeDelay = Math.max(0, RETURN_DURATION_MS - 220);
    const crossfadeTimer = setTransientTimeout(() => {
      trigger.classList.remove('is-launched-out');
    }, crossfadeDelay);

    // Docking pop — a scale(0.92 → 1.05 → 1.0) flourish on the
    // trigger as the big Earth arrives. Anchored to peak (60 % of
    // 240 ms ≈ 144 ms in) right as the WAAPI hits its final frame:
    //   pop_start  = RETURN_DURATION_MS - DOCK_LEAD_MS
    //   pop_peak   = pop_start + 0.6 * DOCK_DURATION_MS ≈ flight end
    //   pop_remove = pop_start + DOCK_DURATION_MS (a beat later)
    // The class is removed AFTER the animation completes so the
    // keyframe's `both` fill-mode can't strand the trigger at the
    // last-frame transform (which is scale(1) — harmless even if
    // it does, but cleaner this way).
    const dockStartDelay = Math.max(0, RETURN_DURATION_MS - DOCK_LEAD_MS);
    const dockStartTimer = setTransientTimeout(() => {
      trigger.classList.add('is-docking');
    }, dockStartDelay);
    const dockEndTimer = setTransientTimeout(() => {
      trigger.classList.remove('is-docking');
    }, dockStartDelay + DOCK_DURATION_MS);

    try {
      await anim.finished;
    } catch {
      // Animation cancelled (teardown). Clear the deferred class
      // changes so they can't fire on a globe that's already gone.
      clearTransientTimer(crossfadeTimer);
      clearTransientTimer(dockStartTimer);
      clearTransientTimer(dockEndTimer);
      trigger.classList.remove('is-docking');
      activeAnimation = null;
      return;
    }
    // Belt-and-braces: if the animation finished faster than the
    // crossfade timer (shouldn't, but cheap to clear), kill it.
    // dockEndTimer is intentionally NOT cleared — it removes the
    // class ~90 ms after this point so the dock pop has time to
    // play its tail. finalizeOverlayClose / destroyEarth will
    // catch it if anything goes sideways.
    clearTransientTimer(crossfadeTimer);

    // Hide the stage SYNCHRONOUSLY before canceling the animation.
    // anim.cancel() removes the forward-fill and snaps the stage
    // back to its natural centered position; without this hide-
    // before-cancel order, that snap-back can be painted for a
    // single frame at the end of the return flight — the jitter
    // the user reported as "ריצוד על המסך".
    stage.style.visibility = 'hidden';
    activeAnimation = null;
    anim.cancel();
    // Clear any leftover inline styles. Reset is-launched-out
    // already happened above; finalizeOverlayClose calling it
    // again is an idempotent no-op.
    stage.style.transform = '';
    stage.style.opacity = '';
  }

  async function openOverlay(_root: HTMLElement, overlay: HTMLElement, trigger: HTMLButtonElement): Promise<void> {
    // Guard: ignore re-opens while launching/open/returning.
    if (state !== 'closed') return;
    state = 'launching';

    lastFocusedBeforeOpen = (document.activeElement as HTMLElement) ?? trigger;

    // Safety: if a previous return's dock pop is still queued or
    // playing (state was 'closed' but dockEndTimer hadn't fired yet),
    // strip the class + drop its pending timers so the keyframe can
    // restart cleanly with the new charge anim. Rapid re-open path.
    clearAllTransientTimers();
    stripTransientClasses(trigger);
    // Step 2 — fresh-open hygiene. Any pending hover-intent timer
    // from the previous open should not fire against the new Earth
    // handle. The drag cooldown is also reset so the user always
    // gets the initial-focus rotation, even if the previous session
    // ended mid-drag.
    cancelPendingFocus();
    dragCooldownUntil = 0;
    currentFocusCode = null;
    // Step 4 — clear any leftover ceremony state. Important when a
    // previous ceremony was cancelled without committing (e.g. the
    // user pressed Escape during the ~700 ms pulse window). Without
    // this, the next open would block all option clicks.
    endSelectionCeremony();
    ceremonyInFlight = false;

    const reducedMotion = isReducedMotion();

    // ── Phase 1: CHARGE ───────────────────────────────────────────
    // Briefly play a "preparing to launch" pulse on the trigger
    // WHILE the small globe is still visible. The class is removed
    // before the detach so the keyframe's final state can't fight
    // the trigger's normal CSS. Skipped under reduced motion. The
    // hold runs in parallel with the rest of the open prep below
    // (rAF + ensureEarth), which keeps the perceived latency the
    // same as before — the user doesn't pay for the cinematic.
    const chargeStartedAt = performance.now();
    if (!reducedMotion) {
      trigger.classList.add('is-charging');
    }

    // ── Preflight stage hiding ─────────────────────────────────────
    // Apply BEFORE the overlay is unhidden, so the moment the
    // backdrop fades in, the 3D Earth stage is already
    // visibility:hidden. ensureEarth below will mount the canvas
    // and Three.js will start rendering, but no frame paints to
    // the user until runLaunchFlight clears this class atomically
    // with its inline-transform pin. Reduced-motion / bypass
    // branches further down remove the class directly (no flight,
    // so the centered final state is the desired state).
    // Belt-and-braces: applying it BEFORE `overlay.removeAttribute`
    // guarantees the class is present on the very first frame the
    // overlay's children can paint into.
    const preflightStage = overlay.querySelector<HTMLElement>('.lgs-overlay-earth');
    if (preflightStage) {
      preflightStage.classList.add('is-preflight');
    }

    overlay.removeAttribute('hidden');
    // rAF lets the browser apply `hidden=false` styles before we flip
    // data-open, so the backdrop transition actually runs instead of
    // snapping to fully opaque.
    await nextFrame();
    overlay.dataset.open = 'true';
    trigger.setAttribute('aria-expanded', 'true');
    document.documentElement.classList.add('lgs-overlay-open');

    const stage = overlay.querySelector<HTMLElement>('.lgs-overlay-earth');
    const row = overlay.querySelector<HTMLElement>('.lgs-overlay-row');

    // Lazy-init the 3D Earth on first open. Subsequent opens reuse
    // the existing canvas — we just resume idle rotation.
    let handle: InteractiveEarthHandle | null = null;
    if (stage) {
      const focusMap = readFocusMap(overlay);
      const initialLang = overlay.dataset.initialLanguage || '';
      const initialFocus = focusMap[initialLang] ?? null;
      handle = await ensureEarth(stage, initialFocus);
      if (handle) {
        // Re-apply per-language focus on EVERY open, not just the
        // first construction. The cached handle keeps its previous
        // rotation across close/reopen, and idle rotation drifts
        // the planet ~3.4°/sec eastward between opens — so even
        // when the SSR-set initial focus is correct, Israel rotates
        // out of view within seconds of the page loading. Snapping
        // the focus back here guarantees the user always sees the
        // region the active language calls home (Israel for Hebrew,
        // the UK for English, Spain for Spanish) at the moment the
        // launch flight lands.
        if (initialFocus && initialLang) {
          handle.focusLatLng(initialFocus.lat, initialFocus.lng);
          // Step 2 — remember which language the globe currently
          // shows so hover/focus rotations can no-op when the user
          // hovers the active option. Start the projection tracker
          // so the hotspot lands on the real geographic point
          // (Israel for he, central US for en, central Spain for es)
          // and follows idle rotation / drag automatically.
          currentFocusCode = initialLang;
          startHotspotTracking(stage, initialLang, initialFocus);
        }
        handle.setIdleRotation(true);
      }
    }

    // If we were torn down mid-init, abort cleanly.
    if (state !== 'launching') {
      // Defensive: strip the charge class so a teardown mid-init
      // can't leave the keyframe stuck visually. Also clear the
      // preflight class so a follow-up open / resume isn't stuck
      // with an invisible stage. (finalizeOverlayClose covers the
      // explicit-close case; this catches the in-between window.)
      trigger.classList.remove('is-charging');
      if (preflightStage) preflightStage.classList.remove('is-preflight');
      return;
    }

    // Diagnostic bypass: setting `window.__lgsBypassFlight = true`
    // before clicking the trigger skips the WAAPI launch flight and
    // opens the overlay directly at its final centered size. Used to
    // confirm whether the FLIP / compositor path is the source of
    // perceived softness on the Earth canvas. Has no effect in
    // production unless the flag is explicitly set in DevTools.
    const bypassFlight = (window as unknown as { __lgsBypassFlight?: boolean }).__lgsBypassFlight === true;

    if (stage) {
      if (reducedMotion || bypassFlight) {
        // Reduced motion (or the diagnostic bypass): no flight, no
        // cinematic. Detach immediately (small globe fades via its
        // 200 ms opacity transition), reveal the row alongside the
        // backdrop fade-in. The charge class was never added under
        // reduced motion, so nothing to remove.
        // Drop the preflight class so the centered Earth becomes
        // visible immediately — without a flight there's nothing
        // else to coordinate with.
        stage.classList.remove('is-preflight');
        trigger.classList.add('is-launched-out');
        if (row) row.classList.add('is-revealed');
      } else {
        // ── Phase 2: DETACH ───────────────────────────────────────
        // Hold the charge for the remaining CHARGE_DURATION_MS so
        // the pulse plays to completion even when ensureEarth
        // resolves in <16 ms (cached load). Then strip is-charging,
        // add is-launched-out (small globe begins its 200 ms fade),
        // and start the flight on the same frame — the user sees
        // a clean "charge → small globe fades, big globe flies"
        // handoff with no visual gap.
        const chargeElapsed = performance.now() - chargeStartedAt;
        const chargeRemaining = CHARGE_DURATION_MS - chargeElapsed;
        if (chargeRemaining > 0) {
          await wait(chargeRemaining);
          if (state !== 'launching') {
            trigger.classList.remove('is-charging');
            stage.classList.remove('is-preflight');
            return;
          }
        }
        trigger.classList.remove('is-charging');
        trigger.classList.add('is-launched-out');

        // ── Phases 3–6: TRAVEL → EXPAND → ARRIVE → SETTLE ────────
        // All baked into runLaunchFlight's 4-keyframe WAAPI run:
        // curved travel through the mid keyframe, scale expansion
        // alongside the path, arrival at identity, and a tiny
        // overshoot-and-return settle in the last 14 % of the run.
        await runLaunchFlight(stage, trigger);
        // If we got cancelled mid-flight, bail.
        if (state !== 'launching') return;
        if (row) row.classList.add('is-revealed');
      }
    }

    // Refit the renderer once the stage is at its final centered
    // size. This is the actual fix for the "blurry Earth after
    // launch" symptom: a WAAPI flight that animates a parent
    // transform from a small scale to identity can leave the
    // composited layer rasterized at the smallest size, which then
    // gets GPU-upscaled. refit() resizes the WebGL drawing buffer
    // to the current layout and forces a fresh render frame, which
    // invalidates the cached layer and gives us a sharp planet.
    if (handle && stage) {
      const diag = handle.refit();
      // refit() always runs (it has functional side-effects: resizes
      // the renderer + forces a fresh frame). Only the diagnostic
      // log is gated, behind window.__lgsDebug. Set the flag in
      // DevTools to inspect post-launch DPR / drawing-buffer state.
      if (isLgsDebug()) {
        const stageStyle = window.getComputedStyle(stage);
        const canvasStyle = window.getComputedStyle(handle.canvas);
        console.info('[interactive-earth-3d] DIAG refit after open', {
          ...diag,
          bypassFlight,
          stageTransform: stageStyle.transform,
          stageFilter: stageStyle.filter,
          canvasFilter: canvasStyle.filter,
          canvasImageRendering: canvasStyle.imageRendering,
        });
      }
    }

    // Defensive: in case any branch above failed to clear is-charging
    // (e.g. stage was null and the inner if-block was skipped), strip
    // it now. is-launched-out is set inside the flight branches
    // already; we don't force it here so a no-stage degraded state
    // doesn't hide the small globe behind nothing.
    trigger.classList.remove('is-charging');

    state = 'open';

    // Move focus to the active language option so keyboard users can
    // commit / cancel without an extra Tab.
    const active = overlay.querySelector<HTMLButtonElement>('.lgs-overlay-option.is-active')
      ?? overlay.querySelector<HTMLButtonElement>('.lgs-overlay-option');
    if (active) active.focus();
  }

  /**
   * Shared overlay-close cleanup used by both the normal closeOverlay
   * path and the resume-after-language-change path. Keeping the two
   * paths funneled through one function prevents drift like the
   * resume-cleanup bug where the centered Earth stayed on screen.
   *
   * Sequence:
   *   1. Hide the stage SYNCHRONOUSLY via visibility:hidden. This is
   *      the key fix for the "Earth remains visible" bug:
   *        - runReturnFlight ends with anim.cancel() + inline-style
   *          clear, which snaps the stage back from "small at trigger"
   *          to its natural CSS centered position. Without an
   *          immediate hide, the user sees the Earth pop back to
   *          center for the entire 320 ms backdrop-fade window.
   *        - visibility:hidden takes effect before the next paint, so
   *          the snap-back is never visible.
   *      Layout space is preserved (the backdrop's overlap doesn't
   *      shift) and the canvas continues to exist for cleanup.
   *   2. Flip overlay state (data-open, aria-busy, html scroll lock,
   *      header globe, language row) so the small SVG re-appears and
   *      the backdrop's CSS opacity transition begins.
   *   3. Pause the Earth rAF loop — no need to keep rendering an
   *      invisible canvas.
   *   4. After 320 ms (enough for the 260 ms backdrop fade to finish),
   *      set the `hidden` attribute so the overlay is completely out
   *      of the layout tree. The .lgs-overlay[hidden] CSS rule added
   *      in this fix ensures the attribute actually applies. Also
   *      reset the stage's inline styles so the next open starts
   *      clean.
   *   5. Set state machine back to 'closed'.
   *
   * Does NOT handle focus restoration or pending language changes —
   * those are concerns of the calling path and stay there.
   */
  function finalizeOverlayClose(
    overlay: HTMLElement,
    trigger: HTMLButtonElement,
    stage: HTMLElement | null,
  ): void {
    // 1. Stage invisible immediately — kills the snap-back-to-center
    //    artifact and the "large Earth lingers" bug in one stroke.
    if (stage) {
      stage.style.visibility = 'hidden';
      // Belt-and-braces: also clear the preflight class. The current
      // close path is most often reached AFTER a successful flight
      // (runLaunchFlight removed it already) — but if a close
      // races a never-completed launch, this removal guarantees the
      // next open isn't stuck with the class set.
      stage.classList.remove('is-preflight');
      // Step 2 — stop the projection rAF + drop is-visible so the
      // CSS pulse keyframe stops running on an offscreen element.
      stopHotspotTracking();
    }
    // Step 2 — drop any pending hover-intent debounce and reset the
    // drag cooldown / focus tracker so the next open starts clean.
    cancelPendingFocus();
    if (earthHandle) earthHandle.cancelFocusAnimation();
    dragCooldownUntil = 0;
    currentFocusCode = null;
    // Step 4 — close path (including Escape / backdrop click during
    // a selection ceremony) must release the ceremony lock and
    // clear the .is-confirming classes / dim cue from the row, so
    // a re-open isn't stuck with stale ceremony state. The
    // pending commit() (if any) will still fire from its
    // setTransientTimeout, but its `if (state !== 'open') return`
    // guard makes it a no-op past this point. Reduces every
    // close-mid-ceremony scenario to the same clean shutdown.
    endSelectionCeremony();
    ceremonyInFlight = false;

    // 2. Overlay state flip — starts the backdrop fade transition.
    overlay.dataset.open = 'false';
    overlay.removeAttribute('aria-busy');
    trigger.setAttribute('aria-expanded', 'false');
    document.documentElement.classList.remove('lgs-overlay-open');
    trigger.classList.remove('is-launched-out');
    // is-docking is intentionally NOT stripped here — it was added
    // ~150 ms before the flight ended (DOCK_LEAD_MS) and its 240 ms
    // keyframe still has ~90 ms left to play. The pending dockEndTimer
    // (queued in runReturnFlight via setTransientTimeout) removes the
    // class once the pop has finished its overshoot tail. Stripping it
    // here would cut the cinematic finish short. The is-charging class
    // is never present at this point (always removed before launch).
    // openOverlay's safety strip catches both on a rapid re-open.

    // Defensive: the language row should already be faded at this
    // point (closeOverlay fades it first; runResume never reveals
    // it on the resume side). Removing the class again is
    // idempotent and guarantees no stale revealed state.
    const row = overlay.querySelector<HTMLElement>('.lgs-overlay-row');
    if (row) row.classList.remove('is-revealed');

    // 3. Pause Earth rAF — no point rendering an invisible canvas.
    if (earthHandle) earthHandle.setIdleRotation(false);

    // 4. Hide the overlay completely once the backdrop has finished
    //    its CSS fade. Re-check data-open inside the timer so a
    //    user-initiated re-open in the meantime is not stomped.
    //    Reset inline visibility and any leftover transform/opacity
    //    on the stage so the next open begins from a clean canvas.
    window.setTimeout(() => {
      if (overlay.dataset.open === 'false') {
        overlay.setAttribute('hidden', '');
        if (stage) {
          stage.style.visibility = '';
          stage.style.transform = '';
          stage.style.opacity = '';
        }
      }
    }, 320);

    // 5. State machine reset.
    state = 'closed';
  }

  async function closeOverlay(overlay: HTMLElement, trigger: HTMLButtonElement): Promise<void> {
    // Guard: only close from the open state. Calls during launching
    // or returning are ignored — we never strand the user mid-flight.
    if (state !== 'open') return;
    state = 'returning';

    const stage = overlay.querySelector<HTMLElement>('.lgs-overlay-earth');
    const row = overlay.querySelector<HTMLElement>('.lgs-overlay-row');

    // 1. Fade language row out first.
    if (row) row.classList.remove('is-revealed');

    if (stage) {
      if (isReducedMotion()) {
        // Reduced motion: skip the flight. Just close the overlay.
      } else {
        // 2. Wait for the row to fade out before starting the flight,
        //    so the user sees a clean "row vanishes → globe departs"
        //    sequence rather than both happening together.
        await wait(ROW_FADEOUT_MS);
        if (state !== 'returning') return;
        await runReturnFlight(stage, trigger);
        if (state !== 'returning') return;
      }
    }

    // 3. Tear down overlay state via the shared finalize helper —
    //    same cleanup the resume path uses, so the two paths can't
    //    drift apart. finalize hides the stage synchronously and
    //    schedules the overlay's `hidden` attribute for after the
    //    backdrop fade.
    finalizeOverlayClose(overlay, trigger, stage);

    // 4. Restore focus to whoever held it before the overlay opened
    //    (the trigger if that element is gone). This is specific to
    //    the normal close — the resume path comes from a fresh page
    //    where lastFocusedBeforeOpen is null and just focuses the
    //    new trigger.
    //    `focusVisible: false` tells the browser NOT to apply
    //    :focus-visible to this programmatic focus. Without it,
    //    Chromium treats a .focus() that fires hundreds of ms after
    //    the originating mouse click as keyboard-like and shows the
    //    focus ring + the data-tooltip — appearing as a "ghost
    //    tooltip" over the header after the return animation
    //    completes. Mouse users get focus restored quietly;
    //    keyboard users still see :focus-visible the moment they
    //    Tab or arrow-key away and back.
    if (lastFocusedBeforeOpen && document.contains(lastFocusedBeforeOpen)) {
      lastFocusedBeforeOpen.focus({ focusVisible: false } as unknown as FocusOptions);
    } else {
      trigger.focus({ focusVisible: false } as unknown as FocusOptions);
    }
    lastFocusedBeforeOpen = null;

    // 5. If a language was selected, fire the existing change path
    //    AFTER the globe has fully returned. The reload (or in-page
    //    swap on chapter pages) happens after the user has visually
    //    seen the close complete, which feels much more deliberate
    //    than starting the language change at click time.
    if (pendingLanguageChange) {
      const lang = pendingLanguageChange;
      pendingLanguageChange = null;
      triggerLanguageChange(lang);
    }
  }

  // ── /library navigation handoff (resume half) ────────────────────
  // Runs once per page init after initGlobeSelectors wires its
  // event handlers. Reads the sessionStorage record persisted by
  // the pre-navigation half on the previous page; if valid, resumes
  // the overlay at its fully-open visual state (skipping the launch
  // flight, since the user has already mentally "left" the previous
  // page) and runs the return flight to the new header trigger
  // once the new layout has settled. Always clears the record on
  // exit so a stale flag can't replay on an unrelated reload.
  async function resumeTransitionIfNeeded(): Promise<void> {
    if (resumeInProgress) return;

    // ── 1. Read ──────────────────────────────────────────────
    let raw: string | null = null;
    try {
      raw = sessionStorage.getItem(TRANSITION_KEY);
    } catch {
      return;
    }
    if (!raw) return;

    // ── 2. Parse ─────────────────────────────────────────────
    let record: unknown = null;
    try {
      record = JSON.parse(raw);
    } catch {
      clearTransitionRecord();
      return;
    }

    // ── 3. Validate every field. Any failure clears + exits ──
    // Strict on /library + freshness so a stale flag from an
    // unrelated reload (e.g. user pressed F5 ten minutes later)
    // can never trigger a phantom overlay.
    const r = record as Partial<TransitionRecord> | null;
    if (
      !r ||
      typeof r !== 'object' ||
      r.fromUrl !== '/library' ||
      r.expectedReturn !== true ||
      typeof r.startedAt !== 'number' ||
      typeof r.targetLang !== 'string'
    ) {
      clearTransitionRecord();
      return;
    }
    const elapsed = Date.now() - r.startedAt;
    // ≥0 guards against future-dated records (clock skew, replay).
    // ≤5000 is the freshness window: a real navigation commits in
    // ~50–500 ms; 5 s gives a generous slow-network ceiling but
    // is too short for a stale F5.
    if (elapsed < 0 || elapsed > 5000) {
      clearTransitionRecord();
      return;
    }
    if (window.location.pathname !== '/library') {
      clearTransitionRecord();
      return;
    }

    // ── 4. Find the DOM ──────────────────────────────────────
    const root = document.querySelector<HTMLElement>('.lgs-root');
    const trigger = root?.querySelector<HTMLButtonElement>('.lgs-trigger') ?? null;
    const overlay = (root?.nextElementSibling as HTMLElement | null) ?? null;
    if (
      !root ||
      !trigger ||
      !overlay ||
      !overlay.classList.contains('lgs-overlay')
    ) {
      // Single-language case (no overlay rendered) or DOM not yet
      // ready. Drop the record either way — leaving it around
      // would cause a future page-load to spurious-resume.
      clearTransitionRecord();
      return;
    }

    // ── 5. Don't fight an in-progress open ───────────────────
    if (state !== 'closed') {
      clearTransitionRecord();
      return;
    }

    // ── 6. Run, with hard failure safety ─────────────────────
    resumeInProgress = true;
    try {
      await runResume(overlay, trigger);
    } catch (err) {
      console.warn('[LanguageGlobeSelector] Resume failed:', err);
      // Emergency restore: under no circumstances leave the user
      // staring at a stuck overlay, a locked scroll, or a missing
      // header globe. Idempotent — these calls are safe even if
      // the failure happened before they were originally applied.
      try {
        overlay.removeAttribute('aria-busy');
        overlay.dataset.open = 'false';
        overlay.setAttribute('hidden', '');
        trigger.classList.remove('is-launched-out');
        trigger.setAttribute('aria-expanded', 'false');
        document.documentElement.classList.remove('lgs-overlay-open');
        if (earthHandle) earthHandle.setIdleRotation(false);
        state = 'closed';
      } catch {
        // If even the recovery throws, there's nothing useful we
        // can do programmatically. The user can still reload.
      }
    }
    clearTransitionRecord();
    resumeInProgress = false;
  }

  /**
   * Worker for the resume orchestrator. Reproduces the visual state
   * the previous page held at the moment of navigation — overlay
   * open, backdrop dimmed, big Earth centered, language row faded —
   * waits for the new page's layout to settle, then runs the
   * existing return flight to whatever rect the new header trigger
   * occupies. Throws on Earth-init failure; the wrapper handles
   * emergency cleanup.
   */
  async function runResume(overlay: HTMLElement, trigger: HTMLButtonElement): Promise<void> {
    state = 'returning';

    // 1. Hide the small header SVG via the existing "launched-out"
    //    class so only the big centered Earth is visible while the
    //    overlay is up. The new page renders the small globe
    //    visible by default — this class flip masks the swap.
    trigger.classList.add('is-launched-out');
    trigger.setAttribute('aria-expanded', 'true');

    // 2. Reveal overlay in the fully-open visual state. No launch
    //    flight: the user already mentally "left" the previous
    //    page; reanimating from the trigger would feel wrong and
    //    waste their attention right when the new page is settling.
    overlay.removeAttribute('hidden');
    await nextFrame();
    overlay.dataset.open = 'true';
    overlay.setAttribute('aria-busy', 'true');
    document.documentElement.classList.add('lgs-overlay-open');

    // 3. Build the Earth using the same ensureEarth path as the
    //    normal open flow. The language row stays HIDDEN — the
    //    previous page already faded it on click; popping it back
    //    on the new page would feel like a hiccup.
    const stage = overlay.querySelector<HTMLElement>('.lgs-overlay-earth');
    if (stage) {
      // Defensive: resume path INTENTIONALLY shows the stage at its
      // centered final state (the previous page already paid the
      // launch flight). If a prior open left is-preflight lingering
      // for any reason, strip it so the centered Earth paints.
      stage.classList.remove('is-preflight');
    }
    let handle: InteractiveEarthHandle | null = null;
    if (stage) {
      const focusMap = readFocusMap(overlay);
      const initialLang = overlay.dataset.initialLanguage || '';
      const initialFocus = focusMap[initialLang] ?? null;
      handle = await ensureEarth(stage, initialFocus);
      if (handle) {
        // Always re-apply focus on resume — mirrors the same call
        // we make on a normal open so the user sees the correct
        // region (Israel for he, UK for en, etc.) at the moment
        // the overlay paints.
        if (initialFocus && initialLang) {
          handle.focusLatLng(initialFocus.lat, initialFocus.lng);
          // Step 2 — same focus tracking as the normal open path;
          // the resume path is just an open whose launch flight
          // was already paid for by the previous page.
          currentFocusCode = initialLang;
          startHotspotTracking(stage, initialLang, initialFocus);
        }
        handle.setIdleRotation(true);
      }
    }

    // 4. If Earth init failed, fall back to a quick clean close
    //    without the return flight. Better to drop the user into
    //    the new page cleanly than leave the overlay stuck. Same
    //    shared finalize call as the success path uses, so this
    //    branch can't drift either.
    if (!stage || !handle) {
      finalizeOverlayClose(overlay, trigger, stage ?? null);
      return;
    }

    // 5. Wait for layout stability before reading the new header
    //    trigger's rect. Two animation frames let the new layout
    //    settle (RTL/LTR flip, content widths, header padding).
    //    document.fonts.ready handles late typography settling;
    //    the 250 ms race keeps us from stalling on slow font CDNs.
    await nextFrame();
    await nextFrame();
    try {
      if (document.fonts && document.fonts.ready) {
        await Promise.race([
          document.fonts.ready,
          new Promise<void>((resolve) => window.setTimeout(resolve, 250)),
        ]);
      }
    } catch {
      // fonts.ready can reject on edge browsers; treat as no-op.
    }

    // 6. Refit the renderer to whatever the new page's stage has
    //    resolved to. RTL might shift the stage container by a
    //    few px; ResizeObserver may not have caught a sub-pixel
    //    rounding diff during the navigation. Belt + braces.
    handle.refit();

    // 7. Return flight to the new page's header trigger. The
    //    FLIP reads live getBoundingClientRect() values, so a
    //    header trigger that moved across the screen due to
    //    RTL/LTR is handled automatically — the globe flies to
    //    whichever side the new layout placed the trigger on.
    if (!isReducedMotion()) {
      try {
        await runReturnFlight(stage, trigger);
      } catch {
        // Animation cancelled (teardown, repeat interrupt). The
        // cleanup below still runs.
      }
    }

    // 8. Standard close cleanup via the shared finalize helper.
    //    Same call closeOverlay uses, so the resume path and the
    //    normal path can't drift apart. finalize hides the stage
    //    synchronously to kill the snap-back-to-center symptom,
    //    schedules the overlay's `hidden` attribute for after the
    //    backdrop fade, and resets state to 'closed'.
    finalizeOverlayClose(overlay, trigger, stage);

    // Focus the new page's trigger — the previous page's
    // lastFocusedBeforeOpen reference was destroyed at navigation,
    // so falling through to the trigger is the safest restoration.
    // `focusVisible: false` suppresses the focus-ring + data-tooltip
    // that would otherwise appear after the return flight in
    // Chromium (it treats focus() fired hundreds of ms after the
    // originating click as keyboard-like). See the matching
    // comment in closeOverlay above.
    trigger.focus({ focusVisible: false } as unknown as FocusOptions);
  }

  function initGlobeSelectors(): void {
    const roots = document.querySelectorAll<HTMLElement>('.lgs-root');

    roots.forEach((root) => {
      if (root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      const trigger = root.querySelector<HTMLButtonElement>('.lgs-trigger');
      if (!trigger) return;

      const onlyOne = trigger.dataset.onlyOne === 'true';
      if (onlyOne) {
        // Single-language: the button stays visible (so header layout
        // doesn't shift between contexts) but it never opens anything.
        // The title attribute already carries the explanation.
        trigger.addEventListener('click', (e) => e.preventDefault());
        return;
      }

      // The overlay was rendered as a SIBLING of .lgs-root (not a
      // child) so its position:fixed isn't pinned to the header's
      // stacking context. Find it via the next-sibling lookup that
      // Astro guarantees: each LanguageGlobeSelector instance emits
      // exactly one .lgs-root followed by its .lgs-overlay (when the
      // language count > 1).
      const overlay = root.nextElementSibling as HTMLElement | null;
      if (!overlay || !overlay.classList.contains('lgs-overlay')) return;

      const open = () => {
        // Defer the async open so the click handler returns quickly.
        void openOverlay(root, overlay, trigger);
      };
      const close = () => {
        void closeOverlay(overlay, trigger);
      };

      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        // Only react when fully open or fully closed. Mid-animation
        // clicks are deliberately ignored — the cinematic flight is
        // short enough that this feels intentional, not unresponsive.
        if (state === 'open') {
          close();
        } else if (state === 'closed') {
          open();
        }
      });

      trigger.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          if (state === 'open') {
            close();
          } else if (state === 'closed') {
            open();
          }
        }
      });

      // ── Pointer-hover parallax ─────────────────────────────────
      // Gentle "globe tilts toward the cursor" effect, mouse-only.
      // The .lgs-globe CSS uses calc(--lgs-base-* + --lgs-p*) for
      // its background-position; this handler writes --lgs-px and
      // --lgs-py within ±12 / ±8 px based on where the cursor sits
      // inside the 46 px trigger. Coefficients are negative so the
      // visible region of the globe shifts toward the cursor (the
      // surface near the cursor "comes forward"), matching the
      // 3D card-tilt parallax convention.
      //
      // Skipped under prefers-reduced-motion. Skipped for non-mouse
      // pointer types (touch, pen) — those don't have a meaningful
      // "hover before commit" phase and triggering parallax on a
      // tap would shift the globe right when the user is about to
      // click. Keyboard focus keeps the language default at all
      // times. Reset to 0 on pointerleave / pointercancel / blur so
      // the globe always returns to its language-default region.
      const globe = trigger.querySelector<HTMLElement>('.lgs-globe');
      const reducedMotion =
        typeof window.matchMedia === 'function' &&
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (globe && !reducedMotion) {
        const PARALLAX_X = 12; // px
        const PARALLAX_Y = 8;  // px (smaller — latitude shift is more visually sensitive)

        trigger.addEventListener('pointermove', (e: PointerEvent) => {
          if (e.pointerType !== 'mouse') return;
          const rect = trigger.getBoundingClientRect();
          if (rect.width === 0 || rect.height === 0) return;
          // Normalize to -1..+1 across the trigger box.
          const nx = ((e.clientX - rect.left) / rect.width) * 2 - 1;
          const ny = ((e.clientY - rect.top) / rect.height) * 2 - 1;
          // Clamp in case a fast pointer move lands the event
          // slightly outside the rect.
          const cx = Math.max(-1, Math.min(1, nx));
          const cy = Math.max(-1, Math.min(1, ny));
          // Negative coefficient = visible region shifts toward
          // the cursor (the side near the cursor rotates forward).
          const px = -cx * PARALLAX_X;
          const py = -cy * PARALLAX_Y;
          globe.style.setProperty('--lgs-px', `${px.toFixed(1)}px`);
          globe.style.setProperty('--lgs-py', `${py.toFixed(1)}px`);
        });

        const resetParallax = () => {
          globe.style.setProperty('--lgs-px', '0px');
          globe.style.setProperty('--lgs-py', '0px');
        };
        trigger.addEventListener('pointerleave', resetParallax);
        trigger.addEventListener('pointercancel', resetParallax);
        trigger.addEventListener('blur', resetParallax);
      }

      // Click anywhere marked data-lgs-close (the backdrop) closes
      // without changing language. The stage's option buttons handle
      // their own clicks; the empty stage area is non-interactive.
      overlay.addEventListener('click', (e: Event) => {
        const target = e.target as HTMLElement;
        if (target.closest('[data-lgs-close="true"]')) {
          close();
        }
      });

      const optionButtons = overlay.querySelectorAll<HTMLButtonElement>('.lgs-overlay-option');

      // ── Step 2 — geographic-focus wiring ──────────────────────────
      // Read the per-language focus map once (stable for the page
      // lifetime). The map is set by the .astro frontmatter via
      // data-language-focus on the overlay; missing entries yield
      // null and the no-op short-circuit in handleOptionPreview takes
      // over — so a language without a registered focus simply skips
      // its rotation rather than throwing.
      const stepTwoFocusMap = readFocusMap(overlay);

      const previewLanguageOnGlobe = (btn: HTMLButtonElement): void => {
        if (state !== 'open') return;
        // QA fix — don't fight the ceremony's rotation. The
        // is-ceremony-locked row already blocks POINTER hover via
        // pointer-events: none on non-confirming pills, but Tab /
        // ArrowKey navigation can still move keyboard FOCUS to a
        // dimmed pill, which would fire this listener and yank the
        // globe toward the focused (but not selected) region in
        // the middle of the selection ceremony's rotation. This
        // guard pins the rotation to the user's actual selection.
        if (ceremonyInFlight) return;
        const code = btn.dataset.language;
        if (!code) return;
        const focus = stepTwoFocusMap[code];
        if (!focus || !earthHandle) return;
        const stage = overlay.querySelector<HTMLElement>('.lgs-overlay-earth');
        scheduleFocus(earthHandle, stage, code, focus);
      };

      optionButtons.forEach((btn) => {
        // Mouse hover — pointerenter only. Pointermove fires on every
        // sub-pixel motion and would spam scheduleFocus; pointerenter
        // fires once per option entry. Pen/touch get NO hover-driven
        // rotation: they have no meaningful "hover before commit"
        // phase, and rotating on first touch would yank the globe
        // right as the user is about to click.
        btn.addEventListener('pointerenter', (e: PointerEvent) => {
          if (e.pointerType && e.pointerType !== 'mouse') return;
          previewLanguageOnGlobe(btn);
        });
        // Keyboard focus — fires on Tab and on arrow-key navigation
        // (the existing ArrowRight/Down handler calls .focus()), so
        // keyboard users get the same geographic linkage as mouse
        // users for free.
        btn.addEventListener('focus', () => {
          previewLanguageOnGlobe(btn);
        });
      });

      // ── Step 2 — manual drag cooldown ─────────────────────────────
      // The Earth module's canvas is appended inside .lgs-overlay-earth
      // at first overlay open. We attach listeners on the STAGE so
      // they survive even before the canvas exists (event bubbling
      // catches pointer events on the canvas once it's mounted).
      // pointerdown: kill any in-flight hover/focus rotation +
      //              pending debounce. The hotspot is NOT hidden:
      //              the projection rAF tracks the real geographic
      //              coordinate, so as the user drags the planet,
      //              the marker follows its region across the
      //              surface and auto-hides via projectLatLng's
      //              frontFacing flag when the region passes behind
      //              the silhouette.
      // pointerup / cancel: start the cooldown clock. Hover/focus
      //              rotations remain suppressed for DRAG_COOLDOWN_MS
      //              so the user's manual orientation is respected.
      const stepTwoStage = overlay.querySelector<HTMLElement>('.lgs-overlay-earth');
      if (stepTwoStage) {
        stepTwoStage.addEventListener('pointerdown', (e: PointerEvent) => {
          // Only treat canvas-targeted pointerdowns as drags. The
          // hotspot has pointer-events: none so it can't be a target,
          // but a defensive check costs nothing.
          if ((e.target as HTMLElement).tagName !== 'CANVAS') return;
          cancelPendingFocus();
          if (earthHandle) earthHandle.cancelFocusAnimation();
          // Stamp the cooldown immediately too — between pointerdown
          // and pointerup, hover events on the row are also suppressed
          // (the user is mid-drag, not previewing). pointerup will
          // re-stamp with a fresh window.
          dragCooldownUntil = performance.now() + DRAG_COOLDOWN_MS;
        });
        const stampCooldown = () => {
          dragCooldownUntil = performance.now() + DRAG_COOLDOWN_MS;
        };
        stepTwoStage.addEventListener('pointerup', stampCooldown);
        stepTwoStage.addEventListener('pointercancel', stampCooldown);
      }

      optionButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          // Block language picks during launch/return — the row is
          // either invisible or fading out, so a click during those
          // states would be a misclick we don't want to honor.
          if (state !== 'open') return;
          // Step-4 lock — ceremonyInFlight is module-level so
          // finalizeOverlayClose / destroyEarth can release it.
          // Multiple rapid clicks (even across pills) hit this
          // guard until the current ceremony finishes or aborts.
          if (ceremonyInFlight) return;

          const lang = btn.dataset.language;
          if (!lang) return;

          ceremonyInFlight = true;

          // Step 4 — full selection ceremony. Three coordinated
          // visual events fire NOW (synchronous so the user sees
          // immediate feedback on click); the existing language
          // transition flow runs after the ceremony window.
          //
          //   1. Lock — ceremonyInFlight blocks further clicks;
          //              startSelectionCeremony dims the other pills
          //              and disables their pointer events.
          //   2. Pulses — gold ring on the orbital node, brightness
          //              pulse on the energy beam, larger pulse on
          //              the projected hotspot (Israel / N.America /
          //              Spain) — all single-shot CSS keyframes.
          //   3. Label — "Native · Region" fades in above the canvas
          //              ("עברית · Israel" / "English · North America" /
          //              "Español · Spain").
          //
          // The rotation (Step 2) runs alongside the visuals; commit
          // fires when both have settled.
          const focus = stepTwoFocusMap[lang];
          const reducedMotion = isReducedMotion();
          // Cancel any debounce so the ceremony rotation starts
          // immediately (no FOCUS_INTENT_MS lag on the user's
          // deliberate click). force=true so even a re-click on
          // the same region re-pulses the hotspot.
          cancelPendingFocus();

          // Visuals first, so they paint on the same frame as the
          // click — the user gets immediate feedback even before
          // the rotation begins.
          startSelectionCeremony(btn, focus, stepTwoStage ?? null);

          let rotationDur = 0;
          if (focus && earthHandle) {
            rotationDur = runFocusNow(
              earthHandle,
              stepTwoStage ?? null,
              lang,
              focus,
              true,
            );
          }
          // Ceremony window:
          //   • reduced motion: ~90 ms — paints the lock + label
          //     once, then commits. No long pulse, no glow travel.
          //   • full motion: max(rotation + 140 ms buffer, 700 ms).
          //     The 700 ms floor lets the keyframes (640 ms each)
          //     complete before close starts; the rotation + buffer
          //     handles cold rotations (650 ms tween) cleanly.
          //     Stays inside the 650-950 ms spec budget for every
          //     combination of rotation distance / cache state.
          const ceremonyMs = reducedMotion
            ? REDUCED_MOTION_CEREMONY_MS
            : Math.max(SELECTION_PULSE_MS, rotationDur + POST_ROTATION_BUFFER_MS);

          // Commit closure — wraps the existing branch logic so the
          // post-ceremony code path stays identical to today's. The
          // language-logic surface (localStorage, sessionStorage,
          // events, URL) is untouched; only the TIMING of these
          // writes shifts by ceremonyMs.
          const commit = () => {
            // Always release the ceremony lock + clear the .is-confirming
            // visuals first. If state has moved off 'open' (Escape
            // pressed during the ceremony delay, or a teardown),
            // finalizeOverlayClose has already cleared them — the
            // calls are idempotent, so a double-cleanup is safe.
            // After the bail-out below, a future re-open will see a
            // clean slate.
            ceremonyInFlight = false;
            endSelectionCeremony();
            if (state !== 'open') return;

            if (isLibraryHardReloadTransition()) {
              const row = overlay.querySelector<HTMLElement>('.lgs-overlay-row');
              if (row) row.classList.remove('is-revealed');
              overlay.setAttribute('aria-busy', 'true');

              localStorage.setItem('yuval_language', lang);
              persistTransition(lang);

              const url = new URL(window.location.href);
              url.searchParams.set('lang', lang);
              window.location.href = url.toString();
              return;
            }

            // Default flow (chapter pages, every other reload-based
            // page): unchanged from today. Defer the language change
            // to closeOverlay so the return flight runs first.
            pendingLanguageChange = lang;
            close();
          };

          if (ceremonyMs <= 0) {
            commit();
          } else {
            // Use a transient-tracked timeout so a teardown during
            // the ceremony (astro:before-swap, beforeunload) cancels
            // the commit cleanly. Otherwise we'd risk writing
            // localStorage and navigating after the page has begun
            // tearing down. setTransientTimeout is the same tracked
            // timer used by Step-1 dock pop — destroyEarth /
            // clearAllTransientTimers catch it.
            //
            // The /library hard-reload handoff (sessionStorage
            // 'yuval_lgs_transition' record) is identical to today's:
            // commit() runs the same writes, in the same order,
            // hitting the same code path. We just delayed it by
            // ≤ 650 ms to let the selection ceremony land.
            setTransientTimeout(commit, ceremonyMs);
          }
        });
      });

      // Keyboard: Escape always closes. Arrow keys move focus among
      // language options.
      overlay.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') {
          e.preventDefault();
          close();
          return;
        }
        if (state !== 'open') return; // arrow keys are no-ops mid-flight
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          const focused = document.activeElement as HTMLButtonElement;
          const list = Array.from(optionButtons);
          const idx = list.indexOf(focused);
          if (idx >= 0 && idx < list.length - 1) {
            e.preventDefault();
            list[idx + 1].focus();
          }
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          const focused = document.activeElement as HTMLButtonElement;
          const list = Array.from(optionButtons);
          const idx = list.indexOf(focused);
          if (idx > 0) {
            e.preventDefault();
            list[idx - 1].focus();
          }
        }
      });
    });

    // After the per-root wiring is in place, check whether this
    // page-load is the receiving side of a /library navigation
    // handoff (see TRANSITION_KEY / persistTransition above). If
    // so, resumeTransitionIfNeeded re-opens the overlay at its
    // centered open state, waits for layout, and runs the return
    // flight to the new page's header trigger. Fire-and-forget —
    // the function self-guards against duplicate runs.
    void resumeTransitionIfNeeded();
  }

  // Visual sync: when ANY selector (legacy or globe) changes the
  // language, every globe instance updates its active option marker
  // without a remount. Reads the same canonical events the legacy
  // selector emits — language-changed, language-ui-sync — so
  // co-existence with the legacy selector during rollout is safe.
  function syncToLang(lang: string): void {
    document.querySelectorAll<HTMLElement>('.lgs-root').forEach((root) => {
      if (root.dataset.current === lang) return;
      root.dataset.current = lang;
    });
    document.querySelectorAll<HTMLButtonElement>('.lgs-overlay-option').forEach((opt) => {
      const isActive = opt.dataset.language === lang;
      opt.classList.toggle('is-active', isActive);
      opt.setAttribute('aria-selected', String(isActive));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGlobeSelectors);
  } else {
    initGlobeSelectors();
  }
  document.addEventListener('astro:page-load', initGlobeSelectors);
  document.addEventListener('astro:after-swap', initGlobeSelectors);

  // Full Three.js teardown on view transitions and full unloads. This
  // is the ONLY place the canvas + GPU resources get disposed; every
  // other close just pauses the rAF loop so re-open is instant.
  document.addEventListener('astro:before-swap', destroyEarth);
  window.addEventListener('beforeunload', destroyEarth);

  window.addEventListener('language-changed', (e: Event) => {
    const lang = (e as CustomEvent<{ language: string }>).detail?.language;
    if (lang) syncToLang(lang);
  });
  window.addEventListener('language-ui-sync', (e: Event) => {
    const lang = (e as CustomEvent<{ language: string }>).detail?.language;
    if (lang) syncToLang(lang);
  });
</script>
