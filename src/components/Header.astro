  :global([dir="rtl"]) .quote-text {
    font-family: 'David Libre', 'Spectral', Georgia, serif;
    font-style: normal;
    font-weight: 500;
    letter-spacing: 0;
  }

  /* Parent stays at full opacity — children handle the animation. */

  :global(.dark) .quote-text {
    color: #d4c4a8;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  }

  @media (min-width: 768px) {
    .quote-text {
      font-size: calc(1.22rem * var(--quote-scale, 1));
    }
  }

  @media (min-width: 1024px) {
    .quote-container {
      max-width: 800px;
    }
    .quote-text {
      font-size: calc(1.38rem * var(--quote-scale, 1));
    }
  }

