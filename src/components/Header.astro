---
import type { Language } from '../types/index';
import LanguageToggle from './LanguageToggle.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  language?: Language;
  showLanguageToggle?: boolean;
  class?: string;
}

const { language = 'en', showLanguageToggle = true, class: className } =
  Astro.props;
---

<header
  id="site-header"
  class:list={[
    'yuval-header',
    'sticky',
    'top-0',
    'z-50',
    'w-full',
    className,
  ]}
>
  <!-- Animated light reflection -->
  <div class="header-shine"></div>
  
  <!-- Inner glow layer -->
  <div class="header-glow"></div>
  
  <!-- Skip to content link for keyboard users -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:top-2 focus:left-2 focus:px-4 focus:py-2 focus:bg-yuval-accent focus:text-yuval-accent-text focus:rounded-md focus:text-sm focus:font-medium"
  >
    {language === 'he' ? 'דלג לתוכן' : 'Skip to content'}
  </a>
  <div
    class:list={[
      'header-inner',
      'flex',
      'items-center',
      'justify-between',
      'h-16',
      'px-4',
      'sm:px-6',
      'lg:px-8',
      language === 'he' && 'flex-row-reverse',
    ]}
  >
    <!-- Logo / Brand -->
    <a
      href="/"
      class="yuval-logo"
      data-he="Yuval"
      data-en="Yuval"
      aria-label={language === 'he' ? 'Yuval — עמוד הבית' : 'Yuval — Home'}
    >
      <span class="logo-icon">Y</span>
      <span class="logo-text">uval</span>
      <span class="logo-sparkle"></span>
    </a>

    <!-- Controls: Theme + Language -->
    <div class:list={['flex', 'items-center', 'gap-3', language === 'he' && 'flex-row-reverse']}>
      <ThemeToggle />
      {showLanguageToggle && <LanguageToggle currentLanguage={language} />}
    </div>
  </div>
  
  <!-- Premium bottom border -->
  <div class="header-border"></div>
</header>

<style>
  .yuval-header {
    background: 
      linear-gradient(180deg, 
        rgba(255,255,255,0.97) 0%, 
        rgba(252,252,254,0.95) 50%,
        rgba(248,249,252,0.92) 100%
      );
    backdrop-filter: blur(24px) saturate(200%);
    -webkit-backdrop-filter: blur(24px) saturate(200%);
    overflow: hidden;
  }

  :global(.dark) .yuval-header {
    background: 
      linear-gradient(180deg, 
        rgba(12,12,16,0.98) 0%, 
        rgba(8,8,12,0.96) 50%,
        rgba(4,4,8,0.94) 100%
      );
  }

  /* Animated light reflection */
  .header-shine {
    position: absolute;
    top: 0;
    left: -150%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255,255,255,0.15) 45%,
      rgba(255,255,255,0.3) 50%,
      rgba(255,255,255,0.15) 55%,
      transparent 60%
    );
    animation: headerShine 8s ease-in-out infinite;
    pointer-events: none;
  }

  :global(.dark) .header-shine {
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255,255,255,0.03) 45%,
      rgba(255,255,255,0.08) 50%,
      rgba(255,255,255,0.03) 55%,
      transparent 60%
    );
  }

  @keyframes headerShine {
    0%, 100% { left: -150%; }
    50% { left: 150%; }
  }

  /* Subtle inner glow at top */
  .header-glow {
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255,255,255,0.8),
      transparent
    );
    pointer-events: none;
  }

  :global(.dark) .header-glow {
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255,255,255,0.15),
      transparent
    );
  }

  /* Premium bottom border - thin gold line */
  .header-border {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(180,160,120,0.2) 10%,
      rgba(212,175,55,0.5) 30%,
      rgba(255,215,0,0.6) 50%,
      rgba(212,175,55,0.5) 70%,
      rgba(180,160,120,0.2) 90%,
      transparent 100%
    );
  }

  :global(.dark) .header-border {
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(120,100,70,0.3) 10%,
      rgba(180,150,60,0.5) 30%,
      rgba(212,175,55,0.7) 50%,
      rgba(180,150,60,0.5) 70%,
      rgba(120,100,70,0.3) 90%,
      transparent 100%
    );
  }

  /* Shadow beneath header */
  .yuval-header::after {
    content: '';
    position: absolute;
    bottom: -20px;
    left: 5%;
    right: 5%;
    height: 20px;
    background: radial-gradient(
      ellipse at center,
      rgba(0,0,0,0.08) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  :global(.dark) .yuval-header::after {
    background: radial-gradient(
      ellipse at center,
      rgba(0,0,0,0.25) 0%,
      transparent 70%
    );
  }

  .header-inner {
    position: relative;
    z-index: 1;
  }

  /* ═══ LOGO STYLING ═══ */
  .yuval-logo {
    position: relative;
    display: flex;
    align-items: baseline;
    text-decoration: none;
    outline: none;
    padding: 8px 16px;
    border-radius: 12px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .yuval-logo:hover {
    background: rgba(212,175,55,0.08);
  }

  :global(.dark) .yuval-logo:hover {
    background: rgba(212,175,55,0.12);
  }

  /* First letter - special treatment */
  .logo-icon {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2.2rem;
    font-weight: 700;
    font-style: italic;
    background: linear-gradient(
      135deg,
      #1a1a2e 0%,
      #2d2d44 30%,
      #1a1a2e 60%,
      #0d0d1a 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-right: -2px;
    transition: all 0.4s ease;
  }

  :global(.dark) .logo-icon {
    background: linear-gradient(
      135deg,
      #f8f8fc 0%,
      #d4d4dc 30%,
      #f8f8fc 60%,
      #ffffff 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
  }

  .logo-text {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    background: linear-gradient(
      135deg,
      #2d2d44 0%,
      #1a1a2e 50%,
      #2d2d44 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: all 0.4s ease;
  }

  :global(.dark) .logo-text {
    background: linear-gradient(
      135deg,
      #e8e8f0 0%,
      #c8c8d4 50%,
      #e8e8f0 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
  }

  /* Sparkle effect */
  .logo-sparkle {
    position: absolute;
    top: 8px;
    right: 12px;
    width: 6px;
    height: 6px;
    background: radial-gradient(
      circle,
      rgba(212,175,55,0.9) 0%,
      rgba(255,215,0,0.6) 40%,
      transparent 70%
    );
    border-radius: 50%;
    opacity: 0;
    transform: scale(0);
    transition: all 0.3s ease;
  }

  .yuval-logo:hover .logo-sparkle {
    opacity: 1;
    transform: scale(1);
    animation: sparkle 1.5s ease-in-out infinite;
  }

  @keyframes sparkle {
    0%, 100% { 
      opacity: 0.6;
      transform: scale(1);
    }
    50% { 
      opacity: 1;
      transform: scale(1.3);
    }
  }

  /* Hover effects */
  .yuval-logo:hover .logo-icon {
    background: linear-gradient(
      135deg,
      #8b7355 0%,
      #d4af37 30%,
      #ffd700 50%,
      #d4af37 70%,
      #8b7355 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    filter: drop-shadow(0 0 12px rgba(212,175,55,0.4));
  }

  .yuval-logo:hover .logo-text {
    background: linear-gradient(
      135deg,
      #8b7355 0%,
      #b8986a 30%,
      #d4af37 50%,
      #b8986a 70%,
      #8b7355 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    filter: drop-shadow(0 0 8px rgba(212,175,55,0.3));
  }

  :global(.dark) .yuval-logo:hover .logo-icon,
  :global(.dark) .yuval-logo:hover .logo-text {
    filter: drop-shadow(0 0 16px rgba(255,215,0,0.5));
  }

  .yuval-logo:focus-visible {
    outline: 2px solid rgba(212,175,55,0.6);
    outline-offset: 4px;
  }

  @media (min-width: 640px) {
    .logo-icon {
      font-size: 2.6rem;
    }
    .logo-text {
      font-size: 2.1rem;
      letter-spacing: 0.1em;
    }
  }
</style>
