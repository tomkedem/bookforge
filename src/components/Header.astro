  /* ═════════════════════════════════════════════════════════════
     READING MODE — calm, contextual header
     Active when ReadingLayout adds body.reading-mode. The header
     stops competing with content: thinner strip, no gradient, soft
     blur, and a low resting opacity that lifts to full on hover or
     keyboard focus so the language switch / theme toggle stay
     reachable without friction.
     ═════════════════════════════════════════════════════════════ */
  /* Reading-mode header bg is flattened to the shell surface so the
     platform header, the chapter top strip, the unified right TOC,
     and the LeftSidebar dock all share one identical color — no
     gradient, no tonal drift. The previous gradient (#faf8f5 →
     #f5f3f0 light / #1a1a1f → #141418 dark) read as a slightly
     different cream/charcoal than the shell, breaking the "single
     surface" illusion. */
  :global(body.reading-mode) .yuval-header {
    /* Shell surface — parchment cream (--bg-shell: #F3EEE0), same as
       the LeftSidebar dock, right TOC, status bar, and body gutter,
       so the entire reading shell reads as one continuous parchment
       surface. backdrop-filter removed: bg is opaque, and the blur
       was causing color drift from content scrolling underneath.
       box-shadow removed: the 1-2px shadow band below the header
       was rendering as a visible thin gap between the platform header
       and the chapter top strip. With both surfaces sharing the same
       color and the chapter strip docking flush via --reading-sticky-top,
       the seam is conveyed by the ::before gold hairline alone. */
    background: #F3EEE0;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: none;
    transition: background-color 220ms var(--ease-standard);
  }

  :global(.dark body.reading-mode) .yuval-header {
    background: var(--yuval-surface, #1a1a1a);
    box-shadow: none;
  }

  /* Drop the cosmic top-edge highlight in reading mode — the parchment
     shell needs its own hairline divider, which the cosmic surface no
     longer provides. The base `.yuval-header::before` rule was removed
     to make /library blend into its cosmic background; here we
     reinstate it as a soft sepia hairline so the parchment header
     still reads as separated from the chapter strip below. */
  :global(body.reading-mode) .yuval-header::after { display: none; }
  :global(body.reading-mode) .yuval-header::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(201, 169, 110, 0.22);
    pointer-events: none;
    z-index: 3;
  }
  :global(.dark body.reading-mode) .yuval-header::before {
    background: rgba(139, 115, 85, 0.28);
  }

  /* Compact strip — ~52px vs the default 64px. */
  :global(body.reading-mode) .header-inner {
    height: 52px;
    transition: height 220ms var(--ease-standard);
  }

  /* Slightly soften logo + trailing controls — quiet, not invisible.
     Restored to full on header hover / keyboard focus. */
  :global(body.reading-mode) .yuval-logo,
  :global(body.reading-mode) .header-inner > div:last-child {
    opacity: 0.85;
    transition: opacity 220ms var(--ease-standard);
  }

  :global(body.reading-mode) .yuval-header:hover .yuval-logo,
  :global(body.reading-mode) .yuval-header:hover .header-inner > div:last-child,
  :global(body.reading-mode) .yuval-header:focus-within .yuval-logo,
  :global(body.reading-mode) .yuval-header:focus-within .header-inner > div:last-child {
    opacity: 1;
  }

  /* Quote softens — lighter weight, a touch smaller, generous tracking,
     no text-shadow. The quote stays — it just whispers instead of speaks. */
  :global(body.reading-mode) .quote-text {
    font-size: calc(0.96rem * var(--quote-scale, 1));
    font-weight: 300;
    opacity: 0.85;
    letter-spacing: 0.025em;
    text-shadow: none;
  }

  :global([dir="rtl"] body.reading-mode) .quote-text {
    font-weight: 400;
  }

  @media (min-width: 768px) {
    :global(body.reading-mode) .quote-text {
      font-size: calc(1.06rem * var(--quote-scale, 1));
    }
  }

  @media (min-width: 1024px) {
    :global(body.reading-mode) .quote-text {
      font-size: calc(1.18rem * var(--quote-scale, 1));
    }
  }

  :global(body.reading-mode) .quote-author {
    opacity: 0.75;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
  }

  @media (min-width: 768px) {
    :global(body.reading-mode) .quote-author {
      font-size: 0.76rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(body.reading-mode) .yuval-header,
    :global(body.reading-mode) .header-inner,
    :global(body.reading-mode) .yuval-logo,
    :global(body.reading-mode) .header-inner > div:last-child {
      transition: none !important;
    }
  }
</style>

<script>
  import { QUOTES_BY_LANGUAGE } from '../i18n/quotes';
  import { SOURCE_LANGUAGE } from '../utils/language';

  function getCurrentLanguage() {
    return localStorage.getItem('yuval_language') || SOURCE_LANGUAGE;
  }

  function getQuotesForLanguage(lang: string) {
    return QUOTES_BY_LANGUAGE[lang as keyof typeof QUOTES_BY_LANGUAGE] || QUOTES_BY_LANGUAGE[SOURCE_LANGUAGE];
  }

  function getHeaderAriaLabel(lang: string) {
    const label = lang === 'he' ? 'עמוד הבית' : 'Home';
    return `Yuval - ${label}`;
  }

  let lastQuoteIndex = -1;
  let quoteShowCount = 0;
  let currentFontIndex = -1;

  const QUOTES_PER_FONT = 3;

  type FontChoice = { family: string; style: string; weight: string; scale?: number };

  const FONT_POOLS: Record<string, FontChoice[]> = {
    he: [
      { family: "'David Libre', Georgia, serif", style: 'normal', weight: '500' },
      { family: "'Frank Ruhl Libre', Georgia, serif", style: 'normal', weight: '400' },
      { family: "'Bellefair', Georgia, serif", style: 'normal', weight: '400', scale: 1.05 },
      { family: "'Noto Serif Hebrew', Georgia, serif", style: 'normal', weight: '500' },
      { family: "'Noto Rashi Hebrew', 'David Libre', Georgia, serif", style: 'normal', weight: '500', scale: 1.1 },
    ],
    en: [
      { family: "'Spectral', Georgia, serif", style: 'italic', weight: '400' },
      { family: "'IM Fell English', Georgia, serif", style: 'italic', weight: '400', scale: 1.02 },
      { family: "'Old Standard TT', Georgia, serif", style: 'italic', weight: '400' },
      { family: "'Cardo', Georgia, serif", style: 'italic', weight: '400' },
      { family: "'Cinzel', Georgia, serif", style: 'normal', weight: '500', scale: 0.88 },
      { family: "'UnifrakturMaguntia', serif", style: 'normal', weight: '400', scale: 1.1 },
    ],
  };
  FONT_POOLS.es = FONT_POOLS.en;

  function pickFont(lang: string): FontChoice {
    const pool = FONT_POOLS[lang] || FONT_POOLS.en;
    if (quoteShowCount % QUOTES_PER_FONT === 0) {
      currentFontIndex = (currentFontIndex + 1);
    }
    return pool[((currentFontIndex % pool.length) + pool.length) % pool.length];
  }

  // Picks a random entry direction for the next quote appearance and
  // applies it to the parent as CSS variables. The keyframe reads
  // these to translate each word from that direction toward (0,0).
  type EntryDirection = { x: string; y: string };
  const ENTRY_DIRECTIONS: EntryDirection[] = [
    { x: '0px', y: '14px' },    // from below
    { x: '0px', y: '-14px' },   // from above
    { x: '14px', y: '0px' },    // from right
    { x: '-14px', y: '0px' },   // from left
    { x: '10px', y: '10px' },   // from bottom-right
    { x: '-10px', y: '10px' },  // from bottom-left
    { x: '10px', y: '-10px' },  // from top-right
    { x: '-10px', y: '-10px' }, // from top-left
  ];
  let lastEntryDirIndex = -1;

  function pickEntryDirection(): EntryDirection {
    let i: number;
    do {
      i = Math.floor(Math.random() * ENTRY_DIRECTIONS.length);
    } while (i === lastEntryDirIndex && ENTRY_DIRECTIONS.length > 1);
    lastEntryDirIndex = i;
    return ENTRY_DIRECTIONS[i];
  }

  function applyEntryDirection(el: HTMLElement | null, dir: EntryDirection) {
    if (!el) return;
    el.style.setProperty('--qw-from-x', dir.x);
    el.style.setProperty('--qw-from-y', dir.y);
  }

  // Splits text into per-word spans with --i indices so CSS can stagger
  // each word's opacity/blur/translate transition for a cinematic reveal.
  function setStaggeredText(el: HTMLElement, text: string) {
    el.textContent = '';
    if (!text) return;
    const words = text.split(/\s+/).filter(Boolean);
    words.forEach((word, i) => {
      const span = document.createElement('span');
      span.className = 'qw';
      span.style.setProperty('--i', String(i));
      span.textContent = word;
      el.appendChild(span);
      if (i < words.length - 1) {
        el.appendChild(document.createTextNode(' '));
      }
    });
  }

  function applyFontToEl(el: HTMLElement | null, font: FontChoice) {
    if (!el) return;
    el.style.fontFamily = font.family;
    el.style.fontStyle = font.style;
    el.style.fontWeight = font.weight;
    if (font.scale) {
      el.style.setProperty('--quote-scale', String(font.scale));
    } else {
      el.style.removeProperty('--quote-scale');
    }
  }

  const GENERIC_AUTHORS = new Set(['Original', 'מקורי', 'Original.', 'Anonymous']);

  function normalizeQuote(raw: unknown): { text: string; author: string } {
    if (typeof raw === 'string') {
      return { text: raw, author: '' };
    }
    if (raw && typeof raw === 'object') {
      const obj = raw as { text?: string; author?: string };
      const author = obj.author && !GENERIC_AUTHORS.has(obj.author) ? obj.author : '';
      return { text: obj.text ?? '', author };
    }
    return { text: '', author: '' };
  }

  function showQuote() {
    const quoteEl = document.getElementById('header-quote');
    const authorEl = document.getElementById('header-quote-author');
    const mobileQuote = document.getElementById('mobile-quote');
    const mobileAuthor = document.getElementById('mobile-quote-author');
    const mobileBar = document.getElementById('mobile-quote-bar');
    const mobileTrack = document.getElementById('mobile-quote-track');
    const logoLink = document.getElementById('site-logo-link');

    const lang = getCurrentLanguage();
    const quotes = getQuotesForLanguage(lang);

    if (!quotes.length) return;

    let newIndex;
    do {
      newIndex = Math.floor(Math.random() * quotes.length);
    } while (newIndex === lastQuoteIndex && quotes.length > 1);

    lastQuoteIndex = newIndex;

    const { text, author } = normalizeQuote(quotes[newIndex]);
    const quoteWithMarks = `"${text}"`;
    const isRtl = document.documentElement.dir === 'rtl';

    const font = pickFont(lang);
    quoteShowCount++;

    if (logoLink) {
      logoLink.setAttribute('aria-label', getHeaderAriaLabel(lang));
    }

    if (quoteEl) {
      quoteEl.classList.add('fade-out');
      if (authorEl) authorEl.classList.add('fade-out');
      // One direction per cycle — quote and author share it so the
      // pair feels like a single unit blowing in from the same place.
      const entryDir = pickEntryDirection();
      setTimeout(() => {
        // Removing fade-out + replacing children in the same synchronous
        // block lets the browser apply the default :not(.fade-out) rule
        // to the fresh spans, which triggers the fade-in-up keyframe
        // animation from frame one. No paint-cycle juggling needed.
        applyEntryDirection(quoteEl, entryDir);
        quoteEl.classList.remove('fade-out');
        setStaggeredText(quoteEl, quoteWithMarks);
        quoteEl.dir = isRtl ? 'rtl' : 'ltr';
        applyFontToEl(quoteEl, font);
        if (authorEl) {
          applyEntryDirection(authorEl, entryDir);
          authorEl.classList.remove('fade-out');
          setStaggeredText(authorEl, author);
          authorEl.dir = isRtl ? 'rtl' : 'ltr';
        }
      }, 600);
    }

    if (mobileBar) {
      if (isRtl) {
        mobileBar.classList.add('rtl');
      } else {
        mobileBar.classList.remove('rtl');
      }
    }

    if (mobileQuote) mobileQuote.textContent = quoteWithMarks;
    if (mobileAuthor) mobileAuthor.textContent = author;

    applyFontToEl(mobileQuote as HTMLElement | null, font);

    if (mobileTrack) {
      mobileTrack.classList.remove('is-animating');
      void mobileTrack.offsetWidth;
      mobileTrack.classList.add('is-animating');
    }
  }

  function initHeaderQuotes() {
    if (window.__yuvalHeaderQuotesInitialized) {
      showQuote();
      return;
    }

    window.__yuvalHeaderQuotesInitialized = true;

    showQuote();
    window.__yuvalHeaderQuotesInterval = window.setInterval(showQuote, 12500);

    window.addEventListener('language-changed', showQuote);
    document.addEventListener('astro:page-load', showQuote);
  }

  // Bridge language-selector-change to language-changed for compatibility
  window.addEventListener('language-selector-change', (e: Event) => {
    const customEvent = e as CustomEvent<{ language: string }>;
    if (customEvent.detail?.language) {
      const lang = customEvent.detail.language;

      // Update localStorage first
      localStorage.setItem('yuval_language', lang);

      window.dispatchEvent(
        new CustomEvent('language-changed', {
          detail: { language: lang },
          bubbles: true,
        })
      );
    }
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeaderQuotes, { once: true });
  } else {
    initHeaderQuotes();
  }
</script>
