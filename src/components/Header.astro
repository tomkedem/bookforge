---
import type { Language } from '../types/index';
import LanguageToggle from './LanguageToggle.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  language?: Language;
  showLanguageToggle?: boolean;
  class?: string;
}

const { language = 'en', showLanguageToggle = true, class: className } =
  Astro.props;
---

<header
  class:list={[
    'sticky',
    'top-0',
    'z-50',
    'w-full',
    'border-b',
    'border-yuval-border',
    'backdrop-blur-md',
    'transition-colors',
    'duration-300',
    className,
  ]}
  style="background-color: var(--yuval-header-bg)"
>
  <div
    class:list={[
      'flex',
      'items-center',
      'justify-between',
      'h-16',
      'px-4',
      'sm:px-6',
      'lg:px-8',
      language === 'he' && 'flex-row-reverse',
    ]}
  >
    <!-- Logo / Brand -->
    <a
      href="/"
      class="font-heading font-bold text-xl sm:text-2xl text-yuval-text hover:text-yuval-text-secondary transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yuval-highlight"
      data-he="Yuval"
      data-en="Yuval"
    >
      Yuval
    </a>

    <!-- Controls: Theme + Language -->
    <div class:list={['flex', 'items-center', 'gap-3', language === 'he' && 'flex-row-reverse']}>
      <ThemeToggle />
      {showLanguageToggle && <LanguageToggle currentLanguage={language} />}
    </div>
  </div>
</header>
