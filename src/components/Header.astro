---
import type { Language } from '../types/index';
import LanguageSelector from './LanguageSelector.astro';
import LanguageGlobeSelector from './language/LanguageGlobeSelector.astro';
import ThemeToggle from './ThemeToggle.astro';
import { SOURCE_LANGUAGE, SUPPORTED_LANGUAGES, getLanguageDirection, getLanguageMeta } from '../utils/language';
import { t } from '../i18n';

interface Props {
  language?: Language;
  availableLanguages?: Language[];
  showLanguageToggle?: boolean;
  /**
   * Renders the rotating literary quote (desktop strip + mobile bar).
   * Defaults to `true` to preserve existing behaviour on every existing
   * route. /library opts out so the dashboard reads as a focused product
   * surface, not a content page.
   */
  showQuote?: boolean;
  /**
   * Step-2 rollout switch. When true, the new circular
   * LanguageGlobeSelector is rendered instead of the legacy
   * LanguageSelector. Defaults to `false` so every existing route
   * keeps its current selector until explicitly opted in. The two
   * selectors share the same events and storage keys, so co-existence
   * across pages is safe.
   */
  useGlobeLanguageSelector?: boolean;
  class?: string;
}

const {
  language = SOURCE_LANGUAGE,
  availableLanguages,
  showLanguageToggle = true,
  showQuote = true,
  useGlobeLanguageSelector = false,
  class: className
} = Astro.props;

// Always ensure we have languages - fall back to all supported languages
const effectiveLanguages = (availableLanguages && availableLanguages.length > 0)
  ? availableLanguages
  : SUPPORTED_LANGUAGES.map(l => l.code as Language);

const isRtl = getLanguageDirection(language) === 'rtl';

const searchPlaceholder = t('header.searchPlaceholder', language);
const searchAriaLabel = t('header.searchAriaLabel', language);
---

<header
  id="site-header"
  class:list={[
    'yuval-header',
    'sticky',
    'top-0',
    'z-50',
    'w-full',
    className,
  ]}
>
  <a
    href="#main-content"
    id="skip-to-content-link"
    class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:top-2 focus:left-2 focus:px-4 focus:py-2 focus:bg-yuval-accent focus:text-yuval-accent-text focus:rounded-md focus:text-sm focus:font-medium"
  >
    <span data-i18n="header.skipToContent">Skip to content</span>
  </a>

  <div
    class:list={[
      'header-inner',
      'flex',
      'items-center',
      'justify-between',
      'px-4',
      'sm:px-6',
      'lg:px-8',
      isRtl && 'flex-row-reverse',
    ]}
  >
    <a
      href="/"
      id="site-logo-link"
      class="yuval-logo"
      aria-label="Yuval"
    >
      <span class="logo-mark" aria-hidden="true">
        <svg viewBox="0 0 40 32" xmlns="http://www.w3.org/2000/svg" focusable="false">
          <defs>
            <linearGradient id="yvl-book-stroke" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#7A5A22" />
              <stop offset="35%" stop-color="#D8BE75" />
              <stop offset="60%" stop-color="#F3DE9B" />
              <stop offset="100%" stop-color="#B8903E" />
            </linearGradient>
            <linearGradient id="yvl-book-page" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" stop-color="rgba(243, 222, 155, 0.18)" />
              <stop offset="100%" stop-color="rgba(184, 144, 62, 0.04)" />
            </linearGradient>
            <radialGradient id="yvl-book-glow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="rgba(243, 222, 155, 0.55)" />
              <stop offset="60%" stop-color="rgba(216, 190, 117, 0.18)" />
              <stop offset="100%" stop-color="rgba(216, 190, 117, 0)" />
            </radialGradient>
          </defs>

          <!-- Soft warm glow behind the book -->
          <circle cx="20" cy="16" r="15" fill="url(#yvl-book-glow)" />

          <!-- Spine highlight -->
          <line x1="20" y1="6" x2="20" y2="28" stroke="url(#yvl-book-stroke)" stroke-width="0.6" stroke-linecap="round" opacity="0.55" />

          <!-- Left page (filled with subtle holographic gradient) -->
          <path
            d="M20 7.5 C 16 6, 11 5.6, 6.5 6.5 L 6.5 25 C 11 24.1, 16 24.5, 20 26 Z"
            fill="url(#yvl-book-page)"
            stroke="url(#yvl-book-stroke)"
            stroke-width="0.9"
            stroke-linejoin="round"
          />
          <!-- Right page -->
          <path
            d="M20 7.5 C 24 6, 29 5.6, 33.5 6.5 L 33.5 25 C 29 24.1, 24 24.5, 20 26 Z"
            fill="url(#yvl-book-page)"
            stroke="url(#yvl-book-stroke)"
            stroke-width="0.9"
            stroke-linejoin="round"
          />

          <!-- Thin holographic text lines on the left page -->
          <line x1="9" y1="11" x2="17.5" y2="10.4" stroke="url(#yvl-book-stroke)" stroke-width="0.4" stroke-linecap="round" opacity="0.7" />
          <line x1="9" y1="13.5" x2="17.5" y2="13" stroke="url(#yvl-book-stroke)" stroke-width="0.4" stroke-linecap="round" opacity="0.55" />
          <line x1="9" y1="16" x2="16" y2="15.6" stroke="url(#yvl-book-stroke)" stroke-width="0.4" stroke-linecap="round" opacity="0.4" />
          <line x1="9" y1="18.5" x2="17.5" y2="18.1" stroke="url(#yvl-book-stroke)" stroke-width="0.4" stroke-linecap="round" opacity="0.55" />
          <line x1="9" y1="21" x2="15" y2="20.7" stroke="url(#yvl-book-stroke)" stroke-width="0.4" stroke-linecap="round" opacity="0.35" />

          <!-- Thin holographic text lines on the right page -->
          <line x1="22.5" y1="10.4" x2="31" y2="11" stroke="url(#yvl-book-stroke)" stroke-width="0.4" stroke-linecap="round" opacity="0.7" />
          <line x1="22.5" y1="13" x2="31" y2="13.5" stroke="url(#yvl-book-stroke)" stroke-width="0.4" stroke-linecap="round" opacity="0.55" />
          <line x1="24" y1="15.6" x2="31" y2="16" stroke="url(#yvl-book-stroke)" stroke-width="0.4" stroke-linecap="round" opacity="0.4" />
          <line x1="22.5" y1="18.1" x2="31" y2="18.5" stroke="url(#yvl-book-stroke)" stroke-width="0.4" stroke-linecap="round" opacity="0.55" />
          <line x1="25" y1="20.7" x2="31" y2="21" stroke="url(#yvl-book-stroke)" stroke-width="0.4" stroke-linecap="round" opacity="0.35" />

          <!-- Tiny knowledge particles drifting up from the open spread -->
          <circle cx="14" cy="4.5" r="0.5" fill="#F3DE9B" opacity="0.85" />
          <circle cx="20" cy="3" r="0.55" fill="#F3DE9B" opacity="0.95" />
          <circle cx="26.5" cy="4.2" r="0.45" fill="#D8BE75" opacity="0.75" />
          <circle cx="23" cy="5.5" r="0.3" fill="#F3DE9B" opacity="0.6" />
          <circle cx="17" cy="5.8" r="0.3" fill="#D8BE75" opacity="0.55" />
        </svg>
      </span>
      <span class="logo-word">Yuval</span>
    </a>

    <div class="header-search" data-rtl={isRtl ? 'true' : 'false'}>
      <label class="header-search-field">
        <span class="header-search-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" focusable="false">
            <circle cx="9" cy="9" r="6.2" fill="none" stroke="currentColor" stroke-width="1.4" />
            <line x1="13.6" y1="13.6" x2="17.2" y2="17.2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </svg>
        </span>
        <input
          id="yuval-header-search"
          type="search"
          autocomplete="off"
          spellcheck="false"
          class="header-search-input"
          placeholder={searchPlaceholder}
          aria-label={searchAriaLabel}
          dir={isRtl ? 'rtl' : 'ltr'}
        />
      </label>
    </div>

    <div class:list={['header-controls-rail', 'flex', 'items-center', isRtl && 'flex-row-reverse']}>
      {/* Source order is [Language, Theme] so the physical layout in
          BOTH LTR and RTL is: Language on the inline-start side of this
          group, Theme pinned at the far edge (physical right in LTR;
          also physical right in RTL because the parent header-inner
          uses `flex-row-reverse` to keep this controls group on the
          page's inline-end side). The visual reading is always
          [Language Globe] [Theme] with Theme at the far right. */}
      {showLanguageToggle && (
        useGlobeLanguageSelector ? (
          <LanguageGlobeSelector
            activeLanguage={language}
            availableLanguages={effectiveLanguages}
          />
        ) : (
          <LanguageSelector
            languages={effectiveLanguages}
            current={language}
          />
        )
      )}
      <ThemeToggle />
    </div>
  </div>
</header>

{showQuote && (
  <div class="mobile-quote-bar sm:hidden" id="mobile-quote-bar">
    <div class="mobile-quote-track" id="mobile-quote-track">
      <span class="mobile-quote-text" id="mobile-quote"></span>
      <span class="mobile-quote-author-inline" id="mobile-quote-author"></span>
    </div>
  </div>
)}

<script is:inline>
  /* Trigger the one-time gold shimmer on the Yuval wordmark.
     Adds .is-mounted to .yuval-logo on initial load AND on every
     Astro view transition, then removes it after 1.8 s so the
     shimmer animation runs once. Hover-driven shimmer is pure CSS
     (`.yuval-logo:hover` selectors) — no JS needed for that. */
  (function () {
    function fireShimmer() {
      document.querySelectorAll('.yuval-logo').forEach(function (el) {
        el.classList.remove('is-mounted');
        // force reflow so the animation restarts on each navigation
        void el.offsetWidth;
        el.classList.add('is-mounted');
        setTimeout(function () { el.classList.remove('is-mounted'); }, 1800);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fireShimmer, { once: true });
    } else {
      fireShimmer();
    }
    document.addEventListener('astro:page-load', fireShimmer);
  })();
</script>

<script is:inline>
  /* ── Mobile search reveal-on-interaction ─────────────────────────
     Pairs with the `body.header-search-revealed` CSS override inside
     the @media (max-width: 767px) block of this component. On mobile
     widths only, the search row is collapsed by default and reveals
     while the user is moving a finger / mouse on the page or has the
     search input focused. After ~1.8s of no pointer activity (and no
     focus) the class is removed and the row smoothly collapses.

     Listeners are attached to `document`, not `window`, so a single
     handler covers the whole screen — "any position" per the spec.
     They survive Astro view transitions because the document object
     persists across them; the window-level init flag prevents double
     binding when this script is re-evaluated after a transition. */
  (function () {
    if (window.__yuvalSearchRevealInitialized) return;
    window.__yuvalSearchRevealInitialized = true;

    var HIDE_AFTER_MS = 1800;
    var mediaQuery = window.matchMedia('(max-width: 767px)');
    var hideTimer = null;
    var inputFocused = false;

    function isMobile() { return mediaQuery.matches; }

    function clearHideTimer() {
      if (hideTimer !== null) {
        window.clearTimeout(hideTimer);
        hideTimer = null;
      }
    }

    function scheduleHide() {
      clearHideTimer();
      if (inputFocused) return;
      hideTimer = window.setTimeout(function () {
        document.body.classList.remove('header-search-revealed');
        hideTimer = null;
      }, HIDE_AFTER_MS);
    }

    function reveal() {
      if (!isMobile()) {
        // If the viewport grew past mobile (e.g. rotation), drop the
        // reveal class so nothing lingers in the tablet/desktop layout.
        document.body.classList.remove('header-search-revealed');
        clearHideTimer();
        return;
      }
      document.body.classList.add('header-search-revealed');
      scheduleHide();
    }

    document.addEventListener('pointermove', reveal, { passive: true, capture: true });
    document.addEventListener('touchstart', reveal, { passive: true, capture: true });

    // Keep the row open while the input is being typed into; resume
    // the hide timer once focus leaves.
    document.addEventListener('focusin', function (e) {
      var t = e.target;
      if (t && t.id === 'yuval-header-search') {
        inputFocused = true;
        clearHideTimer();
        if (isMobile()) document.body.classList.add('header-search-revealed');
      }
    });
    document.addEventListener('focusout', function (e) {
      var t = e.target;
      if (t && t.id === 'yuval-header-search') {
        inputFocused = false;
        scheduleHide();
      }
    });

    // If the viewport crosses the mobile boundary while the reveal
    // class is set, clean up so desktop never inherits the state.
    function onMediaChange() {
      if (!mediaQuery.matches) {
        document.body.classList.remove('header-search-revealed');
        clearHideTimer();
      }
    }
    if (typeof mediaQuery.addEventListener === 'function') {
      mediaQuery.addEventListener('change', onMediaChange);
    } else if (typeof mediaQuery.addListener === 'function') {
      // Safari < 14 fallback.
      mediaQuery.addListener(onMediaChange);
    }
  })();
</script>

<style>
  /* ── Cosmic glass surface ─────────────────────────────────────
     The Yuval header is a deep-space control layer: layered
     midnight-navy base + a faint warm gold halo behind the brand
     (inline-start) + a faint cool blue halo behind the search.
     The same look applies in both light and dark mode — Yuval is a
     dark-shell product even when the rest of the page is parchment.
     Reading mode flattens this back to the cream shell via the
     `:global(body.reading-mode) .yuval-header` overrides further down. */
  .yuval-header {
    /* Default sticky pin to the viewport top — content flows under
       it on scroll. The Astro-scoped class outranks the Tailwind
       `sticky top-0` utility, so this declaration restores the
       pin explicitly; without it a stray `position: relative` here
       silently disables scroll-pinning. Desktop keeps this sticky
       behaviour. Mobile (<1024px) escalates to `position: fixed`
       further down to eliminate a 1-2px scrolling gap that appeared
       above the header on Chrome / Edge mobile emulation profiles
       and on iOS Safari with the URL-bar morph. `background-clip:
       border-box` (explicit) guarantees the header surface paints
       through its full padding area — including the safe-area
       inset above — so no scroll content can appear through the
       top edge. `padding-top: env(safe-area-inset-top, 0px)`
       extends the header into the iOS notch (paired with
       `viewport-fit=cover` in the viewport meta); on devices
       without a notch the inset resolves to 0. `isolation: isolate`
       establishes a local stacking context for the cosmic
       gradients and star specks. */
    position: sticky;
    top: 0;
    padding-top: env(safe-area-inset-top, 0px);
    background-clip: border-box;
    isolation: isolate;
    /* Layered cosmic surface — five stacked layers, painted bottom-up:
         (5) edge vignette  – deep navy at the corners pulls the eye
                              toward the center, gives the panel a
                              "framed window" quality.
         (4) gold halo      – warm glow behind the inline-start brand
                              area; matches the wordmark's gold without
                              competing with it.
         (3) blue halo      – cooler glow behind the centered search,
                              positions the search visually as the
                              "knowledge gateway" focal point.
         (2) navy gradient  – top-to-bottom darkening gives the surface
                              dimension instead of a flat fill.
         (1) abyss base     – the deepest navy, only visible at the
                              corners where the vignette wins.
       Order in the `background:` shorthand is top-down, so the
       gradients here render in this sequence. */
    /* Cosmic blend — the header surface is now tonally matched to the
       page background (`.library-root` is #00010d, sampled from the
       galaxy core image). The linear gradient darkens top→bottom so
       the bottom edge dissolves into the page below, with no seam.
       Cool depth comes from a single muted blue beam under the search
       and two faint indigo lifts at the inline edges — no atmospheric
       wash, no separator line, no drop shadow. */
    background:
      radial-gradient(
        80% 200% at 50% 70%,
        rgba(90, 140, 255, 0.14) 0%,
        rgba(53, 109, 216, 0.08) 22%,
        rgba(53, 109, 216, 0.03) 42%,
        transparent 65%
      ),
      radial-gradient(
        70% 180% at 100% 50%,
        rgba(53, 75, 160, 0.09) 0%,
        rgba(0, 1, 13, 0) 60%
      ),
      radial-gradient(
        70% 180% at 0% 50%,
        rgba(36, 60, 130, 0.06) 0%,
        rgba(0, 1, 13, 0) 60%
      ),
      radial-gradient(
        160% 220% at 50% 50%,
        transparent 0%,
        transparent 50%,
        rgba(0, 0, 0, 0.65) 100%
      ),
      /* Linear base now starts deeper and lands on the page color
         exactly. Top stop dropped from #050A18 to #020610, mid from
         #02071A to #00050F, floor stays at #00010d so the header
         dissolves into .library-root's #00010d at the bottom. */
      linear-gradient(180deg, #020610 0%, #00050F 55%, #00010d 100%),
      #00010d;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.03) inset,
      0 -1px 0 rgba(0, 0, 0, 0.30) inset;
  }

  /* Top edge — barely-there glass texture. The previous "specular
     highlight" reading too clearly as a defined edge of a panel.
     Now it's a whisper across the upper third, faint enough that
     the eye doesn't lock onto a horizontal line. Just enough to
     keep the surface from reading as flat black. */
  .yuval-header::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(170, 195, 255, 0.10) 30%,
      rgba(220, 230, 255, 0.16) 50%,
      rgba(170, 195, 255, 0.10) 70%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 3;
  }

  /* Bottom divider intentionally removed — the header now blends
     directly into the page below via the matched #00010d floor of
     the surface gradient. No `::before` rule. */

  /* Faint star specks layered over the surface — pure CSS, no images.
     A constellation of 10 tiny radial gradients at varied sizes and
     opacities. The result reads as ambient particle dust around the
     brand and search without competing for attention. */
  .yuval-header > .header-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    /* Cool-only constellation — whites and pale blues. The previous
       pass scattered warm gold dots across the surface, which read
       as gold haze; ambient particles are now strictly cool so the
       header background stays disciplined. */
    background-image:
      radial-gradient(1.1px 1.1px at 8%  32%, rgba(255, 255, 255, 0.65), transparent 60%),
      radial-gradient(0.9px 0.9px at 16% 78%, rgba(200, 220, 255, 0.50), transparent 60%),
      radial-gradient(1.3px 1.3px at 24% 24%, rgba(220, 230, 255, 0.55), transparent 60%),
      radial-gradient(0.9px 0.9px at 33% 64%, rgba(255, 255, 255, 0.45), transparent 60%),
      radial-gradient(1.0px 1.0px at 44% 18%, rgba(200, 220, 255, 0.50), transparent 60%),
      radial-gradient(1.2px 1.2px at 56% 72%, rgba(255, 255, 255, 0.55), transparent 60%),
      radial-gradient(1.4px 1.4px at 67% 30%, rgba(220, 230, 255, 0.55), transparent 60%),
      radial-gradient(0.9px 0.9px at 76% 80%, rgba(200, 220, 255, 0.45), transparent 60%),
      radial-gradient(1.5px 1.5px at 86% 46%, rgba(220, 230, 255, 0.55), transparent 60%),
      radial-gradient(1.0px 1.0px at 94% 28%, rgba(255, 255, 255, 0.45), transparent 60%);
    background-repeat: no-repeat;
    opacity: 0.85;
    z-index: 0;
  }

  :global(.dark) .yuval-header {
    background:
      radial-gradient(
        80% 200% at 50% 70%,
        rgba(90, 140, 255, 0.15) 0%,
        rgba(53, 109, 216, 0.09) 22%,
        rgba(53, 109, 216, 0.04) 42%,
        transparent 65%
      ),
      radial-gradient(
        70% 180% at 100% 50%,
        rgba(53, 75, 160, 0.10) 0%,
        rgba(0, 1, 13, 0) 60%
      ),
      radial-gradient(
        70% 180% at 0% 50%,
        rgba(36, 60, 130, 0.07) 0%,
        rgba(0, 1, 13, 0) 60%
      ),
      radial-gradient(
        160% 220% at 50% 50%,
        transparent 0%,
        transparent 50%,
        rgba(0, 0, 0, 0.75) 100%
      ),
      linear-gradient(180deg, #020610 0%, #00040E 55%, #00010d 100%),
      #00010d;
  }

  .header-inner {
    position: relative;
    z-index: 1;
    height: 72px;
  }

  @media (max-width: 767px) {
    .header-inner {
      height: auto;
      min-height: 64px;
    }
  }

  /* ── Mobile (<1024px): escalate from sticky → fixed ───────────────
        Sticky was leaving a 1-2px gap above the header on Chrome /
        Edge mobile emulation and on iOS Safari URL-bar morph. Fixed
        eliminates that class of bug — the element is anchored to the
        viewport edge directly, never participates in scroll layout,
        so nothing can paint between the viewport top and the
        header's top edge. Page content is pushed below the header
        via a mobile-only `padding-top` on `<main id="main-content">`
        (see the :global rule below) equal to header height +
        safe-area inset, so existing layouts continue to start below
        the fixed header instead of sliding behind it. Desktop
        (≥1024px) is unaffected and keeps the original sticky.
        Inline pin to physical edges is intentional — the header is
        full-width and direction-agnostic. */
  @media (max-width: 1023px) {
    .yuval-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
    }

    /* Compensate the global `<main>` content area for the fixed
       header that's no longer in flow. The offset = the on-mobile
       header height (`min-height: 64px` on .header-inner) plus the
       iOS safe-area inset (~44px on notched iPhones, 0 elsewhere).
       Scoped to mobile via this query, so desktop's flow is
       untouched. Targeted via :global() because `main#main-content`
       lives in BaseLayout, outside this component's scope. */
    :global(main#main-content) {
      padding-top: calc(64px + env(safe-area-inset-top, 0px));
    }
  }

  /* ── Card-aware controls anchor ────────────────────────────────
     From the breakpoint where the ContinueLearningCard becomes
     visible (≥768px) downward, the cosmic dashboard treats the
     header controls and the floating card as one visual grid: the
     card sits at `inset-inline-start: 20px` (physical right in RTL),
     so we override Tailwind's `sm:px-6` / `lg:px-8` on the controls
     side (always physical right — see comment on .header-inner
     parent flex) and pin the rail's outer right edge to that same
     20 px viewport inset. The logo / brand side keeps its original
     Tailwind padding for visual breathing room around the wordmark. */
  @media (min-width: 768px) {
    .header-inner {
      padding-right: 20px !important;
    }
  }

  .yuval-logo {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    padding: 8px 16px;
    border-radius: 16px;
    transition: background-color 300ms var(--ease-standard),
                box-shadow 300ms var(--ease-standard);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  /* Tight warm halo — concentrated on the logo, falls off fast so it
     does NOT bleed into the surrounding header surface. The halo is
     a small breath that hugs the brand, not an atmospheric wash. */
  .yuval-logo::before {
    content: '';
    position: absolute;
    inset: -2px -4px;
    background: radial-gradient(
      55% 70% at 50% 50%,
      rgba(243, 222, 155, 0.06) 0%,
      rgba(216, 190, 117, 0.02) 35%,
      transparent 65%
    );
    border-radius: 18px;
    pointer-events: none;
    z-index: -1;
  }

  :global([dir="rtl"]) .yuval-logo {
    flex-direction: row-reverse;
  }

  .yuval-logo:hover {
    background: rgba(216, 190, 117, 0.06);
    box-shadow: 0 0 24px -4px rgba(243, 222, 155, 0.18);
  }

  :global(.dark) .yuval-logo:hover {
    background: rgba(216, 190, 117, 0.07);
  }

  /* ── Open-book holographic mark ─────────────────────────────── */
  .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 34px;
    flex-shrink: 0;
    /* Tight luminous rim + grounding shadow only. The outer warm halo
       is intentionally small so the gold doesn't bleed into the
       surrounding header surface. */
    filter:
      drop-shadow(0 0 1px rgba(255, 250, 230, 0.55))
      drop-shadow(0 0 4px rgba(243, 222, 155, 0.32))
      drop-shadow(0 2px 3px rgba(0, 0, 0, 0.65));
    transition: filter 320ms var(--ease-standard),
                transform 320ms var(--ease-standard);
  }

  .logo-mark svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .yuval-logo:hover .logo-mark {
    filter:
      drop-shadow(0 0 1px rgba(255, 250, 230, 0.75))
      drop-shadow(0 0 7px rgba(243, 222, 155, 0.48))
      drop-shadow(0 2px 3px rgba(0, 0, 0, 0.65));
    transform: translateY(-1px);
  }

  @media (min-width: 640px) {
    .logo-mark {
      width: 54px;
      height: 44px;
    }
  }

  /* ── Yuval wordmark — engraved metallic gold ─────────────────
     Two-layer background: an animated cream sweep stripe over a
     refined seven-stop gold bevel. The bevel runs deep umber → warm
     bronze → mid gold → cream specular peak at 50 % → mid gold →
     warm bronze → deep umber, so the glyph looks like polished
     metal rather than flat color. The stacked drop-shadows give it
     bevelled depth (highlight above, shadow below) plus a soft
     warm halo so it reads as part of the cosmic surface. */
  .logo-word {
    font-family: 'Cinzel', 'Trajan Pro', 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    line-height: 1;
    color: #F3DE9B;
    /* Higher-contrast metallic bevel: the dark stops are deeper and the
       cream specular peak is a pure cream-white, so the gold reads as
       polished gold leaf rather than a quiet bronze. */
    background:
      linear-gradient(
        105deg,
        transparent 32%,
        rgba(255, 252, 235, 1.0) 50%,
        transparent 68%
      ),
      linear-gradient(
        140deg,
        #3A2708 0%,
        #6E4F18 12%,
        #B8903E 28%,
        #F3DE9B 44%,
        #FFFAE6 50%,
        #F3DE9B 56%,
        #B8903E 72%,
        #6E4F18 88%,
        #3A2708 100%
      );
    background-size: 220% 100%, 100% 100%;
    background-position: -110% 0%, 0% 0%;
    background-repeat: no-repeat, no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    /* Engraved bevel: cream highlight above + dark line below + a
       small grounding shadow. The warm halo is intentionally tight
       so the gold stays on the glyph itself. */
    filter:
      drop-shadow(0 1px 0 rgba(255, 250, 220, 0.70))
      drop-shadow(0 -1px 0 rgba(0, 0, 0, 0.75))
      drop-shadow(0 2px 5px rgba(0, 0, 0, 0.65))
      drop-shadow(0 0 5px rgba(243, 222, 155, 0.22));
    transition: letter-spacing 300ms var(--ease-standard),
                filter 300ms var(--ease-standard);
  }

  @media (min-width: 640px) {
    .logo-word {
      font-size: 2.2rem;
      letter-spacing: 0.20em;
    }
  }

  /* Page-load + hover shimmer — reused keyframe targets the new
     wordmark span. The first background layer (cream stripe) animates
     while the base bevel stays put. */
  .yuval-logo.is-mounted .logo-word {
    animation: yuval-shimmer-sweep 1.4s cubic-bezier(0.4, 0, 0.2, 1) 0.30s 1 backwards;
  }

  .yuval-logo:hover .logo-word {
    animation: yuval-shimmer-sweep 1.0s cubic-bezier(0.4, 0, 0.2, 1) 1;
    filter:
      drop-shadow(0 1px 0 rgba(255, 248, 220, 0.80))
      drop-shadow(0 -1px 0 rgba(0, 0, 0, 0.75))
      drop-shadow(0 2px 5px rgba(0, 0, 0, 0.65))
      drop-shadow(0 0 8px rgba(243, 222, 155, 0.32));
  }

  @media (prefers-reduced-motion: reduce) {
    .yuval-logo .logo-word {
      animation: none !important;
    }
  }

  /* ── Integrated header search bar ─────────────────────────────
     Wide pill embedded in the cosmic surface. Dark glass with a
     thin midnight-blue border that lifts on focus. The container
     flex-grows to fill the space between the brand and the right
     controls so the bar reads as part of the header rather than a
     dropped-in widget. */
  .header-search {
    flex: 1 1 auto;
    display: none;
    align-items: center;
    justify-content: center;
    min-width: 0;
    /* Asymmetric padding establishes the rhythm:
         brand →  24px  → search → 32px → controls
       The wider gap before the controls visually pairs the search
       with the brand area and pushes the controls a touch further
       to the inline-end edge so they read as their own zone. */
    padding-inline-start: 24px;
    padding-inline-end: 32px;
    position: relative;
    z-index: 1;
  }

  /* Strong scoped cool halo behind the search — visible at viewport
     scale, not just on close inspection. Positions the search as the
     primary focal point of the header. */
  .header-search::before {
    content: '';
    position: absolute;
    inset: -16px 8px;
    background: radial-gradient(
      60% 130% at 50% 55%,
      rgba(53, 109, 216, 0.32) 0%,
      rgba(36, 74, 143, 0.18) 30%,
      rgba(36, 74, 143, 0.08) 55%,
      transparent 78%
    );
    border-radius: 9999px;
    pointer-events: none;
    z-index: -1;
  }

  @media (min-width: 768px) {
    .header-search {
      display: flex;
    }
  }

  .header-search-field {
    display: flex;
    align-items: center;
    gap: 14px;
    width: 100%;
    max-width: 640px;
    height: 46px;
    padding: 0 22px;
    border-radius: 9999px;
    /* Deeper, more embedded fill — closer to the cosmic floor color
       so the search reads as a recess in the surface rather than a
       lifted glass capsule. */
    background:
      linear-gradient(
        180deg,
        rgba(7, 16, 38, 0.86) 0%,
        rgba(2, 6, 16, 0.96) 55%,
        rgba(0, 1, 8, 0.99) 100%
      );
    /* Border softened: thinner alpha, still cool blue. */
    border: 1.5px solid rgba(90, 140, 255, 0.38);
    box-shadow:
      inset 0 1px 0 rgba(200, 215, 255, 0.12),
      inset 0 -1px 0 rgba(0, 0, 0, 0.65),
      inset 0 0 22px rgba(53, 109, 216, 0.22),
      0 1px 0 rgba(0, 0, 0, 0.55),
      0 0 0 0 rgba(53, 109, 216, 0),
      0 0 16px rgba(53, 109, 216, 0.10),
      0 3px 10px rgba(0, 0, 0, 0.40);
    transition:
      border-color 240ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1)),
      box-shadow 240ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1)),
      background 240ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1));
    cursor: text;
  }

  .header-search-field:hover {
    border-color: rgba(120, 165, 255, 0.55);
    box-shadow:
      inset 0 1px 0 rgba(200, 215, 255, 0.16),
      inset 0 -1px 0 rgba(0, 0, 0, 0.65),
      inset 0 0 26px rgba(53, 109, 216, 0.30),
      0 1px 0 rgba(0, 0, 0, 0.55),
      0 0 22px rgba(90, 140, 255, 0.18),
      0 3px 10px rgba(0, 0, 0, 0.40);
  }

  .header-search-field:focus-within {
    border-color: rgba(150, 185, 255, 0.78);
    background:
      linear-gradient(
        180deg,
        rgba(11, 24, 56, 0.92) 0%,
        rgba(4, 10, 24, 0.96) 55%,
        rgba(1, 3, 12, 0.99) 100%
      );
    box-shadow:
      inset 0 1px 0 rgba(200, 215, 255, 0.20),
      inset 0 -1px 0 rgba(0, 0, 0, 0.65),
      inset 0 0 30px rgba(53, 109, 216, 0.36),
      0 1px 0 rgba(0, 0, 0, 0.55),
      0 0 0 3px rgba(53, 109, 216, 0.22),
      0 0 26px rgba(120, 165, 255, 0.32),
      0 3px 10px rgba(0, 0, 0, 0.40);
  }

  .header-search-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: rgba(195, 210, 245, 1);
    filter: drop-shadow(0 0 6px rgba(90, 140, 255, 0.40));
    transition: color 240ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1)),
                filter 240ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1));
  }

  .header-search-field:focus-within .header-search-icon {
    color: rgba(240, 245, 255, 1);
    filter: drop-shadow(0 0 8px rgba(120, 165, 255, 0.65));
  }

  .header-search-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .header-search-input {
    flex: 1 1 auto;
    min-width: 0;
    height: 100%;
    background: transparent;
    border: 0;
    outline: none;
    color: #F0F3FF;
    font-family: inherit;
    font-size: 1.02rem;
    font-weight: 400;
    line-height: 1;
    padding: 0;
    letter-spacing: 0.005em;
  }

  .header-search-input::placeholder {
    color: #A5AED1;
    opacity: 1;
    font-weight: 400;
  }

  /* ── Right controls rail ──────────────────────────────────────
     Very light alignment wrapper — not a visible container, just a
     consistent vertical baseline + tightened pairing between the
     globe and the theme toggle so they read as one zone of the
     header rather than two stranded buttons. The hairline border
     and faint inner glow only register on close inspection; at
     viewport scale the rail looks like clean alignment. */
  .header-controls-rail {
    /* Gap sized for ALIGNMENT, not for ornamentation. The controls
       row is treated as one visual grid with the ContinueLearningCard
       below it. Given:
         card width   = 190px
         theme width  =  84px (must anchor to card's right edge)
         globe width  =  50px (should land slightly past card's left edge)
       the only gap that lands the globe just past the card's inline-start
       boundary while keeping the theme pinned to the inline-end boundary
       is ≈62px. The internal gap is filled by the rail's own glass
       surface, so the eye reads it as "one wider pill" rather than
       empty space between two stranded controls. */
    gap: 62px;
    /* PHYSICAL padding (not logical). The rail uses `flex-row-reverse`
       in RTL and the parent header-inner does the same — the two
       reversals cancel, so the theme pill is ALWAYS on the rail's
       physical right edge and the globe ALWAYS on the physical left
       edge, regardless of `dir`. Padding is zero on BOTH sides so the
       rail's outer edges land exactly on the card's outer edges (right
       edge of theme = card's right edge; left edge of globe sits ≈6 px
       past the card's left edge for the "slightly outside" cue). */
    padding-block: 0;
    padding-left: 0;
    padding-right: 0;
    border-radius: 9999px;
    /* Frame removed: the rail used to carry a hairline ring + faint
       glass gradient so the globe and theme pill read as one zone.
       That extra container made the two premium controls feel boxed
       in, so the surrounding surface is now fully transparent. The
       gap, padding and alignment math above are unchanged — the two
       controls remain anchored to the card's edges, just without a
       shared frame around them. */
    border: none;
    background: transparent;
    box-shadow: none;
  }

  /* Desktop only — the sky window widens from 84 → 110 px (+26 px) on
     ≥1024px screens (see ThemeToggle.astro). The 62 px gap was tuned
     for an 84 px theme; with a 110 px theme the globe would drift
     +26 px further past the card's left edge, breaking the
     "slightly outside" alignment we previously locked in. Pull the
     gap back by the same 26 px so the globe stays ≈6 px past the
     card's inline-start boundary — exact alignment preserved. */
  @media (min-width: 1024px) {
    .header-controls-rail {
      gap: 36px;
    }
  }

  /* ── Cosmic tooltip ──────────────────────────────────────────────
     Custom tooltip that replaces the browser's native `title` popup
     for the two header controls (language globe + theme window).
     Design intent: match the page's premium palette — charcoal-navy
     glass surface, faint gold hairline, serif typography (per the
     project's "luxury micro-elements = serif" principle), no neon /
     indigo. The bolt-thin gold halo around the pill echoes the same
     accent used by the LeftSidebar and the BookCard frames, so the
     tooltip feels like part of the same material family rather than
     a foreign overlay.

     Behavior:
       - Hidden until hover/focus-visible on the host element.
       - 250 ms hover delay before fade-in (matches the cadence the
         eye expects from a deliberate tooltip rather than a flicker).
       - Centered under the host with a tiny upward translate that
         resolves on appearance — that small motion is the only
         animation; everything else is static so the tooltip never
         distracts.
       - Pointer-events: none on the pseudo-element so it never
         intercepts clicks or steals the cursor away from the host.
       - z-index above siblings so the rail's box-shadow ring never
         cuts into the tooltip's pill.

     The tooltip is scoped to `.header-controls-rail` so the
     [data-tooltip] hook stays a header concept — adding the
     attribute elsewhere on the site won't accidentally render this
     specific design. */
  :global(.header-controls-rail [data-tooltip]) {
    position: relative;
  }

  :global(.header-controls-rail [data-tooltip])::after {
    content: attr(data-tooltip);
    position: absolute;
    top: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    opacity: 0;
    pointer-events: none;
    z-index: 50;
    white-space: nowrap;

    /* Typography — Assistant per Tomer's request for tooltips on
       the knowledge-space screen; tight letterspacing so the small
       size still reads as crafted, not casual. */
    font-family: 'Assistant', system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.015em;
    line-height: 1;
    color: rgba(243, 222, 155, 0.94);

    /* Surface — same charcoal-navy glass family as the floating
       cards. Border replaced with a soft gold ring via box-shadow
       so the corners stay clean inside the pill radius. */
    padding: 9px 16px 10px;
    border-radius: 9999px;
    background:
      radial-gradient(
        ellipse 80% 60% at 50% 0%,
        rgba(40, 60, 110, 0.30) 0%,
        transparent 70%
      ),
      linear-gradient(
        180deg,
        rgba(10, 14, 32, 0.96) 0%,
        rgba(4, 6, 18, 0.96) 100%
      );
    box-shadow:
      0 0 0 1px rgba(232, 197, 71, 0.22),
      0 8px 22px rgba(0, 0, 0, 0.55),
      0 0 18px rgba(232, 197, 71, 0.10),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);

    transition:
      opacity 200ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1)),
      transform 200ms var(--ease-emphasized, cubic-bezier(0.2, 0.7, 0.2, 1));
  }

  /* Small gold arrow above the pill, pointing up at the host control.
     Built from a rotated square with the same gold hairline + glass
     fill, then masked so only its top half shows above the pill. */
  :global(.header-controls-rail [data-tooltip])::before {
    content: '';
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    width: 10px;
    height: 10px;
    transform: translateX(-50%) rotate(45deg) translateY(-4px);
    opacity: 0;
    pointer-events: none;
    z-index: 51;
    background: linear-gradient(135deg, rgba(10, 14, 32, 0.96), rgba(4, 6, 18, 0.96));
    box-shadow:
      -1px -1px 0 0 rgba(232, 197, 71, 0.22);
    transition:
      opacity 200ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1)),
      transform 200ms var(--ease-emphasized, cubic-bezier(0.2, 0.7, 0.2, 1));
  }

  :global(.header-controls-rail [data-tooltip]:hover)::after,
  :global(.header-controls-rail [data-tooltip]:focus-visible)::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    transition-delay: 250ms;
  }

  :global(.header-controls-rail [data-tooltip]:hover)::before,
  :global(.header-controls-rail [data-tooltip]:focus-visible)::before {
    opacity: 1;
    transform: translateX(-50%) rotate(45deg) translateY(0);
    transition-delay: 250ms;
  }

  /* The globe trigger uses transform: translateX(8px) at rest (see
     the nudge rule below). That parent transform shifts ITS pseudo-
     elements too, so the tooltip would appear 8 px to the right of
     the disc's visual center. Compensate by sliding the tooltip back
     by the same 8 px so it sits dead-centered under the visible disc. */
  :global(.header-controls-rail .lgs-trigger[data-tooltip])::after,
  :global(.header-controls-rail .lgs-trigger[data-tooltip])::before {
    margin-left: -8px;
  }

  /* Suppress the tooltip while the cinematic overlay owns the screen.
     The trigger gets .is-launched-out from the moment the launch
     animation starts and keeps it until the return flight's cross-
     fade hands the small header globe back. During that entire
     window the trigger button still sits under the cursor (the
     mouse hasn't moved), so :hover stays active and the tooltip's
     ::after would otherwise show floating over an empty header
     spot — perceived as "stuck until refresh." Forcing opacity 0
     with 0 ms transition overrides the :hover / :focus-visible
     rules above and clears any pending 250 ms reveal delay. */
  :global(.header-controls-rail .lgs-trigger.is-launched-out[data-tooltip])::after,
  :global(.header-controls-rail .lgs-trigger.is-launched-out[data-tooltip])::before {
    opacity: 0 !important;
    transition-delay: 0ms !important;
    transition-duration: 0ms !important;
  }

  /* ── Language globe ring — refined inside the header only ─────
     Previous treatment painted a cool slate conic ring (and a
     blue-tinted hover halo) over the LGS default's champagne ring,
     because the warm gold default clashed with the darker header
     surface. Both treatments are now removed at the user's request:
     the small globe should feel like the SAME Earth that opens
     into the large center stage, not like a UI button containing
     a tiny photo. The transparent background lets the cosmic
     header surface show through right up to the globe silhouette,
     same visual ground the large Earth sits over against the
     overlay backdrop. The component default (set in
     LanguageGlobeSelector.astro) is already transparent — the
     overrides below are kept only as explicit !important
     declarations so any future header-only treatment can't
     accidentally re-introduce a frame without revisiting this
     decision. inset: 3px is preserved so the inner clip area
     stays consistent with the slightly larger 50 px trigger
     used inside the rail. */
  :global(.header-controls-rail .lgs-trigger) {
    background: transparent !important;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.28) !important;
  }

  :global(.header-controls-rail .lgs-trigger:hover) {
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.34) !important;
  }

  :global(.header-controls-rail .lgs-trigger:focus-visible) {
    outline: 2px solid rgba(120, 170, 220, 0.55) !important;
    outline-offset: 2px !important;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.28) !important;
  }

  :global(.header-controls-rail .lgs-disc) {
    inset: 3px !important;
  }

  /* Small physical nudge of the globe toward the theme pill — pushes
     it ~8 px to the physical right without changing flex layout, so
     the gap appears tighter on the eye while the rail's outer left
     edge (and the theme pill's outer right edge) stay anchored to
     the card's grid. Uses transform so it stacks with the existing
     hover translateY(-1px). */
  :global(.header-controls-rail .lgs-trigger) {
    transform: translateX(8px);
  }

  :global(.header-controls-rail .lgs-trigger:hover) {
    transform: translateX(8px) translateY(-1px);
  }

  /* Slight upscale of the globe trigger inside the header only. The
     component default is 46 px; in the rail we bump it to 50 px so the
     Earth disc reads as a confident, premium action next to the wider
     theme pill — still proportional, still circular, still elegant.
     Inner SVG canvas grows in lockstep so the planet keeps its relative
     scale inside the inner disc. */
  :global(.header-controls-rail .lgs-trigger) {
    width: 50px !important;
    height: 50px !important;
    min-width: 50px !important;
    min-height: 50px !important;
  }

  :global(.header-controls-rail .lgs-globe) {
    width: 44px !important;
    height: 44px !important;
  }

  /* Native search-input clear button — hidden so we own the visual. */
  .header-search-input::-webkit-search-cancel-button,
  .header-search-input::-webkit-search-decoration {
    -webkit-appearance: none;
    appearance: none;
  }

  /* RTL: keep input text aligned to the inline-start so the placeholder
     reads naturally in Hebrew. The icon sits on the inline-start side
     of the field (already correct because flex follows direction). */
  .header-search[data-rtl="true"] .header-search-input {
    text-align: right;
  }

  /* ── Mobile: compact header layout ────────────────────────────
     Brand + selectors stay on the top row. Search drops to a
     second row inside the same header so the bar remains
     reachable without hiding the language or theme toggle. */
  @media (max-width: 767px) {
    /* ── Mobile header row structure ─────────────────────────────
       The mobile top row hosts brand on one side and the controls
       rail (globe + theme) on the other, with justify-content
       between. The previous layout had three sources of crowding
       that this block now fixes together:

         1. .header-inner inherited Tailwind's px-4 (16 px on each
            side). Combined with the brand's own internal padding,
            the book icon sat ~20 px from the screen edge — too far
            in, eating usable middle width. Mobile now overrides
            horizontal padding to 6 px on each side so the row's
            content area is ~28 px wider than before.
         2. .header-controls-rail had its OWN padding-left/right
            (6/4) on top of the header-inner padding — a second
            inset that pushed the theme pill 4-6 px inward from
            where justify-between would have anchored it. Mobile
            now sets both rail paddings to 0, so the theme pill's
            outer edge lands exactly at the row's clean 6 px
            margin from the screen edge.
         3. The .lgs-trigger had a global transform: translateX(8px)
            (set unconditionally outside any media query, for the
            desktop card-grid alignment). On mobile this leaked in
            and ATE 8 px from the gap between the globe and the
            theme. The override below cancels it on mobile only.
       Result on a 320 px viewport: ~6 px from edge to brand, ~6 px
       from edge to theme, ~18 px gap between globe and theme, and
       ~20 px of breathing space between the brand cluster and the
       controls cluster in the middle. */
    .header-inner {
      flex-wrap: wrap;
      height: auto;
      min-height: 64px;
      padding-top: 8px;
      padding-bottom: 8px;
      padding-left: 6px !important;
      padding-right: 6px !important;
      row-gap: 8px;
    }

    .header-search {
      display: flex;
      flex: 1 0 100%;
      order: 3;
      padding: 0;
      /* Reveal-on-interaction: by default the search row is fully
         collapsed on mobile so the header reads as one compact line
         (brand + globe + theme). A pointermove / touchstart anywhere
         on the document adds `header-search-revealed` to <body> via
         the companion script below, which triggers the override
         further down — the field smoothly expands and becomes
         focusable. After ~1.8s without any pointer activity the
         class is removed and the row collapses back. Focus on the
         input keeps the row open as long as it has focus. Desktop
         (≥768px) does not use this rule (the tablet+ media query
         above already shows the search permanently). */
      max-height: 0;
      opacity: 0;
      pointer-events: none;
      overflow: hidden;
      transition:
        max-height 280ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1)),
        opacity 220ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1));
    }

    :global(body.header-search-revealed) .header-search {
      max-height: 60px;
      opacity: 1;
      pointer-events: auto;
    }

    .header-search-field {
      max-width: 100%;
      height: 44px;
      padding: 0 18px;
    }

    /* Controls rail — pin to the physical edge of the row and
       open up the globe↔theme gap. With padding 0 on each side,
       justify-content: between on the parent anchors the rail's
       outer edge directly at the row's 6 px screen-edge margin.
       Gap raised from 10 → 18 px so the two controls read as a
       clear pair, not a glued pill. */
    .header-controls-rail {
      gap: 18px;
      padding-left: 0;
      padding-right: 0;
    }

    /* Cancel the desktop translateX(8 px) nudge on mobile — there's
       no ContinueLearningCard below to align against, and the
       8 px shift would consume a third of the new globe↔theme
       gap. Hover keeps the vertical lift only. */
    :global(.header-controls-rail .lgs-trigger) {
      transform: none;
    }
    :global(.header-controls-rail .lgs-trigger:hover) {
      transform: translateY(-1px);
    }

    /* Brand cluster — consume only the width it really needs.
       padding-inline-start 16 → 4 px puts the book icon 4 px from
       the brand's start edge (so the hover background still has
       a tiny breath, not glued to the edge). padding-inline-end
       16 → 8 px tightens the right side of the brand so it
       doesn't stretch toward the middle of the row. Logical
       properties handle RTL automatically: start = right edge
       on Hebrew pages, where the icon also sits visually.
       Combined with the header-inner's 6 px screen-edge padding,
       the book icon ends up ~10 px from the screen edge — close
       enough to feel anchored to the edge, far enough to avoid
       looking glued. */
    .yuval-logo {
      padding-inline-start: 4px;
      padding-inline-end: 8px;
      gap: 10px;
    }
    .logo-mark {
      transform: translateY(-2px);
    }
    .yuval-logo:hover .logo-mark {
      transform: translateY(-3px);
    }

    :global(.header-controls-rail .lgs-trigger) {
      width: 46px !important;
      height: 46px !important;
      min-width: 46px !important;
      min-height: 46px !important;
    }

    :global(.header-controls-rail .lgs-globe) {
      width: 42px !important;
      height: 42px !important;
    }

    .logo-word {
      font-size: 1.55rem;
      letter-spacing: 0.16em;
    }
  }

  /* ── Reading-mode reset ───────────────────────────────────────
     The reading shell is parchment cream — the cosmic surface and
     the ambient star particles must not bleed in. The existing
     `body.reading-mode .yuval-header` rule already overrides the
     background; here we silence the new pseudo-element layers and
     soften the search field to the cream palette. */
  :global(body.reading-mode) .yuval-header::after,
  :global(body.reading-mode) .yuval-header > .header-inner::before {
    display: none;
  }

  :global(body.reading-mode) .header-search-field {
    background: rgba(255, 255, 255, 0.55);
    border-color: rgba(201, 169, 110, 0.35);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }

  :global(body.reading-mode) .header-search-input {
    color: #4a3f35;
  }

  :global(body.reading-mode) .header-search-input::placeholder {
    color: #8b7355;
  }

  :global(body.reading-mode) .header-search-icon {
    color: #8b7355;
  }

  :global(.dark body.reading-mode) .header-search-field {
    background: rgba(20, 20, 24, 0.6);
    border-color: rgba(139, 115, 85, 0.35);
  }

  :global(.dark body.reading-mode) .header-search-input {
    color: #d4c4a8;
  }

  :global(.dark body.reading-mode) .header-search-input::placeholder {
    color: #8b7355;
  }

  .logo-letter {
    /* Cinzel — Roman-inscription serif, the typeface of luxury
       wordmarks. Capitals only by design, which is why the Y reads
       as a monumental letter instead of a stylized italic. */
    font-family: 'Cinzel', 'Trajan Pro', 'Playfair Display', Georgia, serif;
    font-size: 2.0rem;
    font-weight: 600;
    font-style: normal;
    letter-spacing: 0.02em;
    /* Subtle gold-cream gradient on the italic Y so it reads as
       jewelry rather than flat text. background-clip: text paints
       the gradient onto the glyph; no text-shadow here — with a
       transparent fill, any shadow leaks behind the glyph and
       reads as a black smudge on the WONK curl. */
    color: #6b4f1c;
    /* Royal-gold engraving (light mode). Two-layer background:
       (1) shimmer stripe — bright cream sliver, 220% wide, parked
           off-screen at -110% by default. Animates across the text
           on page load and hover.
       (2) base bevel — diagonal deep umber → warm gold → cream
           highlight at 55% → deep gold (unchanged from before). */
    background:
      linear-gradient(
        105deg,
        transparent 35%,
        rgba(255, 248, 220, 0.85) 50%,
        transparent 65%
      ),
      linear-gradient(
        135deg,
        #6b4f1c 0%,
        #a07a30 18%,
        #d4af55 40%,
        #f4e0a0 55%,
        #d4af55 70%,
        #a07a30 88%,
        #5a3f14 100%
      );
    background-size: 220% 100%, 100% 100%;
    background-position: -110% 0%, 0% 0%;
    background-repeat: no-repeat, no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter:
      drop-shadow(0 1px 0 rgba(255, 240, 200, 0.6))
      drop-shadow(0 -1px 0 rgba(91, 64, 20, 0.45))
      drop-shadow(0 2px 4px rgba(91, 64, 20, 0.35))
      drop-shadow(0 0 12px rgba(212, 175, 85, 0.35));
    margin-right: -1px;
    line-height: 1;
    transition: filter 300ms var(--ease-standard),
                font-variation-settings 300ms var(--ease-standard);
  }

  :global([dir="rtl"]) .logo-letter {
    margin-right: 0;
    margin-left: -1px;
  }

  .logo-rest {
    font-family: 'Cinzel', 'Trajan Pro', 'Playfair Display', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    color: #6b4f1c;
    line-height: 1;
    /* Same royal-gold bevel as the Y, plus the same animated shimmer
       stripe layered on top so the whole wordmark sweeps as a unit. */
    background:
      linear-gradient(
        105deg,
        transparent 35%,
        rgba(255, 248, 220, 0.85) 50%,
        transparent 65%
      ),
      linear-gradient(
        135deg,
        #6b4f1c 0%,
        #a07a30 22%,
        #d4af55 50%,
        #f4e0a0 62%,
        #c9a052 80%,
        #6b4f1c 100%
      );
    background-size: 220% 100%, 100% 100%;
    background-position: -110% 0%, 0% 0%;
    background-repeat: no-repeat, no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter:
      drop-shadow(0 1px 0 rgba(255, 240, 200, 0.55))
      drop-shadow(0 -1px 0 rgba(91, 64, 20, 0.40))
      drop-shadow(0 1px 3px rgba(91, 64, 20, 0.30))
      drop-shadow(0 0 10px rgba(212, 175, 85, 0.28));
    transition: letter-spacing 300ms var(--ease-standard),
                filter 300ms var(--ease-standard);
  }

  /* ── Yuval logo shimmer ────────────────────────────────────────
     Single sweep of a bright cream stripe across the engraved gold
     wordmark. Triggers on:
       (1) initial page load (via .is-mounted class added by the
           inline script at the bottom of this file, removed after
           the animation completes);
       (2) hover, every time the user re-hovers the logo.
     The stripe is the first background layer (animates `background-
     position`); the base gold bevel is the second layer (static).
     Reduced motion: animation is disabled and the stripe stays
     parked off-screen — the wordmark looks identical to before. */
  @keyframes yuval-shimmer-sweep {
    0%   { background-position: -110% 0%, 0% 0%; }
    100% { background-position:  220% 0%, 0% 0%; }
  }

  /* Page-load shimmer — a bit slower (1.4s) and slightly delayed so
     the effect lands AFTER the page chrome has settled. The Y leads,
     "uval" follows ~0.15s behind for a natural left-to-right read. */
  .yuval-logo.is-mounted .logo-letter {
    animation: yuval-shimmer-sweep 1.4s cubic-bezier(0.4, 0, 0.2, 1) 0.30s 1 backwards;
  }
  .yuval-logo.is-mounted .logo-rest {
    animation: yuval-shimmer-sweep 1.4s cubic-bezier(0.4, 0, 0.2, 1) 0.45s 1 backwards;
  }

  /* Hover shimmer — quicker (1s), lands on the Y first. */
  .yuval-logo:hover .logo-letter {
    animation: yuval-shimmer-sweep 1.0s cubic-bezier(0.4, 0, 0.2, 1) 1;
  }
  .yuval-logo:hover .logo-rest {
    animation: yuval-shimmer-sweep 1.0s cubic-bezier(0.4, 0, 0.2, 1) 0.05s 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .yuval-logo .logo-letter,
    .yuval-logo .logo-rest {
      animation: none !important;
    }
  }

  /* Dark mode: same royal-gold engraving as light mode — the bevel
     reads as carved metal regardless of the surrounding atmosphere.
     Slightly warmer mid-tones because the surface behind it is dark,
     so the highlight needs more presence to stay legible. */
  :global(.dark) .logo-letter {
    background: linear-gradient(
      135deg,
      #6b4f1c 0%,
      #a07a30 18%,
      #d4af55 40%,
      #f4e0a0 55%,
      #d4af55 70%,
      #a07a30 88%,
      #5a3f14 100%
    );
    background-size: 100% 100%;
    background-repeat: no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter:
      drop-shadow(0 1px 0 rgba(255, 240, 200, 0.45))
      drop-shadow(0 -1px 0 rgba(0, 0, 0, 0.55))
      drop-shadow(0 2px 4px rgba(0, 0, 0, 0.45))
      drop-shadow(0 0 14px rgba(212, 175, 85, 0.45));
  }

  :global(.dark) .logo-rest {
    background: linear-gradient(
      135deg,
      #6b4f1c 0%,
      #a07a30 22%,
      #d4af55 50%,
      #f4e0a0 62%,
      #c9a052 80%,
      #6b4f1c 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter:
      drop-shadow(0 1px 0 rgba(255, 240, 200, 0.40))
      drop-shadow(0 -1px 0 rgba(0, 0, 0, 0.50))
      drop-shadow(0 1px 3px rgba(0, 0, 0, 0.40))
      drop-shadow(0 0 12px rgba(212, 175, 85, 0.35));
  }

  /* Hover (light): brighten the bevel — push the cream highlight
     wider so the metal looks freshly polished. */
  .yuval-logo:hover .logo-letter {
    background: linear-gradient(
      135deg,
      #8b6829 0%,
      #c9a052 18%,
      #f4e0a0 45%,
      #fff4c8 58%,
      #f4e0a0 70%,
      #c9a052 88%,
      #6b4f1c 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter:
      drop-shadow(0 1px 0 rgba(255, 248, 220, 0.75))
      drop-shadow(0 -1px 0 rgba(91, 64, 20, 0.45))
      drop-shadow(0 2px 5px rgba(91, 64, 20, 0.35))
      drop-shadow(0 0 16px rgba(244, 224, 160, 0.55));
  }

  .yuval-logo:hover .logo-rest {
    background: linear-gradient(
      150deg,
      #6b5a48 0%,
      #8b7355 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: 0.16em;
  }

  /* Hover: nothing to vary on Cinzel beyond the existing color
     gradient + filter shifts handled in the gradient hover rules. */

  /* Hover (dark): the gold pops more, with a subtle drop-shadow
     halo so the Y feels lit from within. */
  :global(.dark) .yuval-logo:hover .logo-letter {
    background: linear-gradient(
      150deg,
      #fffaf0 0%,
      #f0d9a8 50%,
      #d4a85c 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 8px rgba(212, 168, 92, 0.45));
  }

  :global(.dark) .yuval-logo:hover .logo-rest {
    background: linear-gradient(
      150deg,
      #f0e6d0 0%,
      #d4c4a8 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .yuval-logo:focus-visible {
    outline: 2px solid #c9a96e;
    outline-offset: 4px;
  }

  :global(.dark) .yuval-logo:focus-visible {
    outline-color: #8b7355;
  }

  @media (min-width: 640px) {
    .logo-letter {
      font-size: 2.4rem;
    }
    .logo-rest {
      font-size: 1.7rem;
      letter-spacing: 0.20em;
    }
  }

  .quote-container {
    flex: 1;
    display: none;
    justify-content: center;
    align-items: center;
    padding: 0 24px;
    max-width: 700px;
    margin: 0 auto;
  }

  /* Inner stack sized to the quote text's width — that way the
     author's `align-self: flex-end` puts its end UNDER the quote's
     visual end (not under the wide outer container's edge). */
  .quote-stack {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: max-content;
    max-width: 100%;
    /* Author is positioned via align-self + transform, not gap. */
    gap: 0;
  }

  @media (min-width: 640px) {
    .quote-container {
      display: flex;
    }
  }

  .quote-author {
    font-family: 'Spectral', 'David Libre', Georgia, serif;
    font-size: 0.82rem;
    font-style: normal;
    font-weight: 500;
    color: #8b7355;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 1;
    /* Inline-end edge of the inner .quote-stack — the stack is
       sized to the quote text, so this is the visual end of the
       quote, not the wide outer container's edge. */
    align-self: flex-end;
    /* Negative margin-inline-end lets the author's tail stick OUT
       past the inline-end of the quote stack by about half a word —
       a deliberate "signature flowing past the edge" overhang.
       Negative on inline-end = leftward in RTL, rightward in LTR. */
    margin-inline-end: -1.5ch;
    /* Tight to the quote line above + half of the author's height
       protrudes below the quote container — the "signature
       straddling the bottom edge" effect requested. line-height: 1
       keeps the protrusion clean (no extra ascender padding). */
    line-height: 1;
    margin-top: -0.5em;
    transform: translateY(50%);
  }

  .quote-author:empty {
    display: none;
  }

  /* Per-word stagger animation via keyframes. Each .qw child runs
     its own animation with a delay computed from --i. Keyframes are
     more reliable than transitions because the browser plays them
     unconditionally from the moment the rule applies — no need to
     juggle paint cycles to "register" a starting state. */
  /* Entry direction is driven by --qw-from-x / --qw-from-y, set per
     quote in JS so each appearance can come from a random direction
     (above / below / left / right). Defaults preserve the original
     "from below" behaviour if JS doesn't set them. */
  @keyframes qw-fade-in-up {
    from {
      opacity: 0;
      filter: blur(10px);
      transform: translate(var(--qw-from-x, 0px), var(--qw-from-y, 14px));
    }
    to {
      opacity: 1;
      filter: blur(0);
      transform: translate(0, 0);
    }
  }

  @keyframes qw-fade-out {
    from {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
    to {
      opacity: 0;
      filter: blur(6px);
      transform: translateY(-4px);
    }
  }

  /* :global(.qw) — these spans are created dynamically by JS, so they
     don't receive Astro's scoped data-astro-cid attribute. Without
     :global the scoped selector wouldn't match them and the animation
     wouldn't run. The parent (.quote-text/.quote-author) is still
     scoped — only the descendant class needs to escape scoping. */
  .quote-text :global(.qw),
  .quote-author :global(.qw) {
    display: inline-block;
    opacity: 1;
    will-change: opacity, filter, transform;
  }

  /* Default state: parent has no fade-out class, so any .qw children
     present (typically just-inserted ones) play the fade-in-up. The
     `both` fill mode keeps them at the final keyframe after the run. */
  .quote-text:not(.fade-out) :global(.qw),
  .quote-author:not(.fade-out) :global(.qw) {
    animation: qw-fade-in-up 550ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
    animation-delay: calc(var(--i, 0) * 35ms);
  }

  .quote-text.fade-out :global(.qw),
  .quote-author.fade-out :global(.qw) {
    animation: qw-fade-out 380ms cubic-bezier(0.4, 0, 0.6, 1) both;
    animation-delay: calc(var(--i, 0) * 22ms);
  }

  .quote-author::before {
    content: '— ';
  }

  :global(.dark) .quote-author {
    color: #c9a96e;
  }

  @media (min-width: 768px) {
    .quote-author {
      font-size: 0.86rem;
    }
  }

  @media (min-width: 1024px) {
    .quote-author {
      font-size: 0.92rem;
    }
  }

  .quote-text {
    font-family: 'Spectral', 'David Libre', Georgia, serif;
    font-size: calc(1.1rem * var(--quote-scale, 1));
    font-style: italic;
    font-weight: 400;
    color: #4a3f35;
    text-align: center;
    line-height: 1.5;
    opacity: 1;
    letter-spacing: 0.005em;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.5);
