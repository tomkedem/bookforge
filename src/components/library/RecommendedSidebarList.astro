---
/**
 * RecommendedSidebarList — compact recommendation list for the desktop
 * left sidebar of /library.
 *
 * Why this exists separately from RecommendationStrip:
 *   The bottom strip is a large visual rail of full LibraryCards. The
 *   sidebar list is a dense navigation hint — type pill + title only,
 *   one line per row. Both surfaces draw from the same recommended
 *   items, but they answer different questions:
 *     - strip:  "what to look at next, visually"
 *     - list:   "what's queued up, at a glance"
 *
 * Hard rules:
 *   - No mock-data import. Items are passed in by the page.
 *   - No new i18n keys. Reuses library.recommendation.forYou.
 *   - No card chrome. The list rows must NOT look like LibraryCard.
 *   - Generic by item type only — no per-title branches.
 *   - Safe links open as <a>. Unsafe items render as <article aria-disabled>.
 */
import type { Language } from '../../types/index';
import type { LibraryItem } from '../../types/library';
import { t } from '../../i18n';
import {
  getItemTitle,
  getItemTypeLabelKey,
  getTypeAccentVar,
  isSafeLibraryHref,
} from '../../utils/library-display';

interface Props {
  items: LibraryItem[];
  language: Language;
}
const { items, language } = Astro.props;

const hasItems = items.length > 0;
---

<section class="rsl" aria-label={t('library.recommendation.forYou', language)}>
  <header class="rsl-header">
    <span class="rsl-dot" aria-hidden="true"></span>
    <h2 class="rsl-title">{t('library.recommendation.forYou', language)}</h2>
  </header>

  {hasItems ? (
    <ul class="rsl-list" role="list">
      {items.map((item) => {
        const title = getItemTitle(item, language);
        const typeLabel = t(getItemTypeLabelKey(item.type), language);
        const isSafe = isSafeLibraryHref(item.href);
        const rowStyle = `--row-accent: ${getTypeAccentVar(item.type)};`;
        return (
          <li class="rsl-row-wrap">
            {isSafe ? (
              <a class="rsl-row rsl-row-link" href={item.href} style={rowStyle} aria-label={title}>
                <span class="rsl-accent" aria-hidden="true"></span>
                <span class="rsl-row-body">
                  <span class="rsl-type">{typeLabel}</span>
                  <span class="rsl-row-title">{title}</span>
                </span>
                <span class="rsl-chevron" aria-hidden="true">›</span>
              </a>
            ) : (
              <article class="rsl-row rsl-row-static" style={rowStyle} aria-label={title} aria-disabled="true">
                <span class="rsl-accent" aria-hidden="true"></span>
                <span class="rsl-row-body">
                  <span class="rsl-type">{typeLabel}</span>
                  <span class="rsl-row-title">{title}</span>
                </span>
              </article>
            )}
          </li>
        );
      })}
    </ul>
  ) : (
    <p class="rsl-empty">{t('library.recommendation.none', language)}</p>
  )}
</section>

<style>
  .rsl {
    position: relative;
    padding: 1rem 1rem 1.125rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-panel-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
    overflow: hidden;
    isolation: isolate;
  }
  /* Quiet inner accent — same family as KnowledgeSpaceCard, but with
     the cyan side of the palette so the sidebar reads as alternating
     purple / cyan moods top-to-bottom. */
  .rsl::after {
    content: "";
    position: absolute;
    inset-block-start: -40%;
    inset-inline-start: -25%;
    width: 70%;
    aspect-ratio: 1;
    background: radial-gradient(circle,
      var(--yuval-galaxy-accent-cyan) 0%,
      transparent 65%);
    opacity: 0.08;
    pointer-events: none;
    z-index: -1;
  }

  .rsl-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.625rem;
  }
  .rsl-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--yuval-galaxy-accent-cyan);
    box-shadow: var(--yuval-galaxy-glow-soft);
  }
  .rsl-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
    color: var(--yuval-galaxy-text-muted);
  }

  .rsl-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .rsl-row-wrap { min-width: 0; }

  .rsl-row {
    --row-accent: var(--yuval-galaxy-accent);
    position: relative;
    display: grid;
    grid-template-columns: 3px 1fr auto;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.625rem;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    background-color: transparent;
    border: 1px solid transparent;
    transition:
      background-color var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out),
      border-color var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out);
  }
  /* Inline-start accent stripe per row, driven by --row-accent (item type). */
  .rsl-accent {
    width: 3px;
    height: 24px;
    border-radius: 999px;
    background-color: var(--row-accent);
    opacity: 0.85;
  }
  .rsl-row-body {
    display: flex;
    flex-direction: column;
    gap: 0.1875rem;
    min-width: 0;
  }
  .rsl-type {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--row-accent);
    line-height: 1;
  }
  .rsl-row-title {
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--yuval-galaxy-text);
    /* One line, ellipsis on overflow — keeps every row the same height. */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .rsl-chevron {
    color: var(--yuval-galaxy-text-soft);
    font-size: 1rem;
    line-height: 1;
  }
  /* Flip the chevron in RTL so it always points "forward". */
  :global([dir="rtl"]) .rsl-chevron {
    transform: scaleX(-1);
  }

  .rsl-row-link:hover {
    background-color: var(--yuval-galaxy-surface-muted);
    border-color: var(--yuval-galaxy-border-strong);
  }
  .rsl-row-link:focus-visible {
    outline: none;
    border-color: var(--yuval-galaxy-border-glow);
    box-shadow: var(--yuval-galaxy-glow-soft);
  }
  .rsl-row-static {
    cursor: default;
    opacity: 0.7;
  }

  .rsl-empty {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--yuval-galaxy-text-soft);
    margin: 0;
  }
</style>
