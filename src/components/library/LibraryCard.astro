---
/**
 * LibraryCard — generic card for any LibraryItem.
 *
 * Visual upgrade (Prompt 7):
 *   - Filled status badge using the status color at low alpha (color-mix).
 *   - Topics chips row when topics exist (defensive: hidden when empty).
 *   - Hover lift on linked cards (translateY -2px); static cards do not lift.
 *   - Slightly stronger inner contrast via card-surface-hover on hover.
 *   - Inner side-glow rooted on the type accent.
 *
 * Open/Closed: zero per-type branches. Type and status drive only CSS
 * variables (--card-accent, --card-status), so adding a new type or
 * status requires no edit here.
 */
import type { Language } from '../../types/index';
import type { LibraryItem } from '../../types/library';
import { t } from '../../i18n';
import {
  getItemTitle,
  getItemSummary,
  getItemTopics,
  getItemTypeLabelKey,
  getItemStatusLabelKey,
  getTypeAccentVar,
  getStatusAccentVar,
  formatLibraryDate,
  formatReadingMinutes,
  getItemGlyph,
  isSafeLibraryHref,
} from '../../utils/library-display';

interface Props {
  item: LibraryItem;
  language: Language;
  /**
   * default — full card with summary, topics, meta.
   * compact — trimmed card for dense rails (recommendation strip).
   * orbit   — denser premium "floating" card for the desktop galaxy stage.
   */
  variant?: 'default' | 'compact' | 'orbit';
}
const { item, language, variant = 'default' } = Astro.props;

const title = getItemTitle(item, language);
const summary = getItemSummary(item, language);
const topics = getItemTopics(item, language);
const typeLabel = t(getItemTypeLabelKey(item.type), language);
const statusLabel = t(getItemStatusLabelKey(item.status), language);
const minutes = formatReadingMinutes(item.readingMinutes);
const dateString = formatLibraryDate(item.updatedAt, language);
const wordCount = typeof item.wordCount === 'number' ? item.wordCount : undefined;

// Two CSS vars on the card: type accent (stripe + type label colour)
// and status accent (badge tint + border). Inline style is the only
// way to set them dynamically per-item without per-type CSS branches.
const cardStyle = [
  `--card-accent: ${getTypeAccentVar(item.type)};`,
  `--card-status: ${getStatusAccentVar(item.status)};`,
].join(' ');

// Orbit shows the status pill (premium feel) and a small meta line, but
// no topic chips — keeps the floating card visually clean and readable.
const showStatus = variant === 'default' || variant === 'orbit';
const showMeta   = variant === 'default' || variant === 'orbit';
const showTopics = variant === 'default' && topics.length > 0;
const showOrbitVisual = variant === 'orbit';

const isSafe = isSafeLibraryHref(item.href);
const wrapperClass = ['lc', `lc-${variant}`, isSafe ? 'lc-link' : 'lc-static'].join(' ');

// Generic abstract glyph by item type (never by item title/slug).
const glyph = getItemGlyph(item.type);

// Limit topic chips to keep the card compact and predictable on mobile.
const topicChips = topics.slice(0, 3);
const extraTopics = topics.length - topicChips.length;
---

{isSafe ? (
  <a class={wrapperClass} href={item.href} style={cardStyle} aria-label={title}>
    <span class="lc-stripe" aria-hidden="true"></span>
    {showOrbitVisual && (
      <span class="lc-orbit-visual" aria-hidden="true">
        <span class="lc-orbit-medallion">
          <span class="lc-orbit-medallion-aura"></span>
          <span class="lc-orbit-medallion-ring"></span>
          <span class="lc-orbit-glyph">
            {glyph === 'book' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 5.5C4 4.7 4.7 4 5.5 4H10v15H5.5c-.8 0-1.5.7-1.5 1.5V5.5z"></path>
                <path d="M20 5.5c0-.8-.7-1.5-1.5-1.5H14v15h4.5c.8 0 1.5.7 1.5 1.5V5.5z"></path>
                <path d="M10 4v15M14 4v15"></path>
              </svg>
            )}
            {glyph === 'course' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-4 9 4-9 4-9-4z"></path>
                <path d="M7 11v5c0 1.5 2.5 2.5 5 2.5S17 17.5 17 16v-5"></path>
                <path d="M21 9v5"></path>
              </svg>
            )}
            {glyph === 'article' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 3h9l4 4v14H6z"></path>
                <path d="M14 3v5h5"></path>
                <path d="M9 13h7M9 16h7M9 10h4"></path>
              </svg>
            )}
            {glyph === 'series' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="8" width="14" height="11" rx="1.5"></rect>
                <path d="M6 5h14v11"></path>
                <path d="M9 2h13v11"></path>
              </svg>
            )}
            {glyph === 'document' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 3h12v18H6z"></path>
                <path d="M9 8h6M9 12h6M9 16h4"></path>
              </svg>
            )}
            {glyph === 'slides' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="12" rx="1.5"></rect>
                <path d="M9 20h6M12 16v4"></path>
                <path d="M8 10l3 2 5-4"></path>
              </svg>
            )}
            {glyph === 'lab' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 3h6"></path>
                <path d="M10 3v6L5 18a2 2 0 0 0 1.8 3h10.4A2 2 0 0 0 19 18l-5-9V3"></path>
                <path d="M8 14h8"></path>
              </svg>
            )}
            {glyph === 'transcript' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 6h14v10H8l-3 3z"></path>
                <path d="M8 10h8M8 13h5"></path>
              </svg>
            )}
          </span>
        </span>
      </span>
    )}
    <header class="lc-header">
      <p class="lc-type">{typeLabel}</p>
      {showStatus && <span class="lc-status">{statusLabel}</span>}
    </header>
    <h3 class="lc-title">{title}</h3>
    {summary && <p class="lc-summary">{summary}</p>}
    {showTopics && (
      <ul class="lc-topics" aria-label="topics">
        {topicChips.map((topic) => <li class="lc-topic">{topic}</li>)}
        {extraTopics > 0 && <li class="lc-topic lc-topic-more">+{extraTopics}</li>}
      </ul>
    )}
    {showMeta && (minutes !== undefined || wordCount !== undefined || dateString) && (
      <p class="lc-meta">
        {minutes !== undefined && (
          <span>{t('library.stats.readingMinutes', language, { n: minutes })}</span>
        )}
        {wordCount !== undefined && (
          <span>{t('library.stats.words', language, { n: wordCount })}</span>
        )}
        {dateString && (
          <span>{t('library.stats.updatedRecently', language, { when: dateString })}</span>
        )}
      </p>
    )}
    {showOrbitVisual && <span class="lc-orbit-status-bar" aria-hidden="true"></span>}
  </a>
) : (
  <article class={wrapperClass} style={cardStyle} aria-label={title} aria-disabled="true">
    <span class="lc-stripe" aria-hidden="true"></span>
    {showOrbitVisual && (
      <span class="lc-orbit-visual" aria-hidden="true">
        <span class="lc-orbit-medallion">
          <span class="lc-orbit-medallion-aura"></span>
          <span class="lc-orbit-medallion-ring"></span>
          <span class="lc-orbit-glyph">
            {glyph === 'book' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 5.5C4 4.7 4.7 4 5.5 4H10v15H5.5c-.8 0-1.5.7-1.5 1.5V5.5z"></path>
                <path d="M20 5.5c0-.8-.7-1.5-1.5-1.5H14v15h4.5c.8 0 1.5.7 1.5 1.5V5.5z"></path>
                <path d="M10 4v15M14 4v15"></path>
              </svg>
            )}
            {glyph === 'course' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-4 9 4-9 4-9-4z"></path>
                <path d="M7 11v5c0 1.5 2.5 2.5 5 2.5S17 17.5 17 16v-5"></path>
                <path d="M21 9v5"></path>
              </svg>
            )}
            {glyph === 'article' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 3h9l4 4v14H6z"></path>
                <path d="M14 3v5h5"></path>
                <path d="M9 13h7M9 16h7M9 10h4"></path>
              </svg>
            )}
            {glyph === 'series' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="8" width="14" height="11" rx="1.5"></rect>
                <path d="M6 5h14v11"></path>
                <path d="M9 2h13v11"></path>
              </svg>
            )}
            {glyph === 'document' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 3h12v18H6z"></path>
                <path d="M9 8h6M9 12h6M9 16h4"></path>
              </svg>
            )}
            {glyph === 'slides' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="12" rx="1.5"></rect>
                <path d="M9 20h6M12 16v4"></path>
                <path d="M8 10l3 2 5-4"></path>
              </svg>
            )}
            {glyph === 'lab' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 3h6"></path>
                <path d="M10 3v6L5 18a2 2 0 0 0 1.8 3h10.4A2 2 0 0 0 19 18l-5-9V3"></path>
                <path d="M8 14h8"></path>
              </svg>
            )}
            {glyph === 'transcript' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 6h14v10H8l-3 3z"></path>
                <path d="M8 10h8M8 13h5"></path>
              </svg>
            )}
          </span>
        </span>
      </span>
    )}
    <header class="lc-header">
      <p class="lc-type">{typeLabel}</p>
      {showStatus && <span class="lc-status">{statusLabel}</span>}
    </header>
    <h3 class="lc-title">{title}</h3>
    {summary && <p class="lc-summary">{summary}</p>}
    {showTopics && (
      <ul class="lc-topics" aria-label="topics">
        {topicChips.map((topic) => <li class="lc-topic">{topic}</li>)}
        {extraTopics > 0 && <li class="lc-topic lc-topic-more">+{extraTopics}</li>}
      </ul>
    )}
    {showMeta && (minutes !== undefined || wordCount !== undefined || dateString) && (
      <p class="lc-meta">
        {minutes !== undefined && (
          <span>{t('library.stats.readingMinutes', language, { n: minutes })}</span>
        )}
        {wordCount !== undefined && (
          <span>{t('library.stats.words', language, { n: wordCount })}</span>
        )}
        {dateString && (
          <span>{t('library.stats.updatedRecently', language, { when: dateString })}</span>
        )}
      </p>
    )}
    {showOrbitVisual && <span class="lc-orbit-status-bar" aria-hidden="true"></span>}
  </article>
)}

<style>
  .lc {
    --card-accent: var(--yuval-galaxy-accent);
    --card-status: var(--yuval-galaxy-status-ready);
    position: relative;
    display: block;
    padding: 1.125rem 1.125rem 1.25rem;
    border: 1px solid var(--yuval-galaxy-card-border);
    border-radius: var(--yuval-galaxy-card-radius);
    background-color: var(--yuval-galaxy-card-surface);
    box-shadow: var(--yuval-galaxy-card-shadow);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    isolation: isolate;
  }

  /* Top accent stripe driven by --card-accent. */
  .lc-stripe {
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 0;
    inset-inline-end: 0;
    height: 2px;
    background-color: var(--card-accent);
    opacity: 0.85;
    z-index: 1;
  }

  /* Inner side glow rooted on the accent — gives each type a faint
     atmospheric tint without dominating the card. Pseudo-element so
     it never blocks pointer events. */
  .lc::after {
    content: "";
    position: absolute;
    inset-block-start: -30%;
    inset-inline-end: -20%;
    width: 70%;
    aspect-ratio: 1;
    background: radial-gradient(circle,
      var(--card-accent) 0%,
      transparent 70%);
    opacity: 0.10;
    pointer-events: none;
    z-index: 0;
  }

  .lc-header,
  .lc-title,
  .lc-summary,
  .lc-topics,
  .lc-meta { position: relative; z-index: 1; }

  /* Linked variant — interactive cues. */
  .lc-link {
    cursor: pointer;
    transition:
      transform var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out),
      box-shadow var(--yuval-galaxy-motion-normal) var(--yuval-galaxy-ease-out),
      background-color var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out),
      border-color var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out);
  }
  .lc-link:hover {
    transform: translateY(-2px);
    background-color: var(--yuval-galaxy-card-surface-hover);
    border-color: var(--yuval-galaxy-border-strong);
  }
  .lc-link:focus-visible {
    outline: none;
    box-shadow: var(--yuval-galaxy-card-shadow), var(--yuval-galaxy-glow-primary);
  }

  /* Static variant — make it visually clear nothing happens on click. */
  .lc-static {
    cursor: default;
    opacity: 0.92;
  }

  .lc-compact { padding: 1rem 1rem 1.125rem; }

  /* ── Orbit variant — premium floating card for the desktop galaxy stage ──
     Generic across every LibraryItem (no per-title branching). The
     symbolic visual area at the top is a circular medallion containing
     a generic per-type glyph, themed entirely by --card-accent.
     Stronger glass: layered shadow, hairline highlight at the top edge,
     elevated surface with backdrop blur.
  */
  .lc-orbit {
    padding: 1rem 1rem 1.125rem;
    border-radius: var(--yuval-galaxy-card-radius);
    background-color: var(--yuval-galaxy-surface-elevated);
    border-color: var(--yuval-galaxy-border-strong);
    /* Layered shadow built from existing tokens:
        - hairline highlight along the top edge (border-strong inset)
        - the standard card-shadow stack for depth
        - an outer accent-tinted glow for the futuristic feel */
    box-shadow:
      0 1px 0 0 var(--yuval-galaxy-border-strong) inset,
      var(--yuval-galaxy-card-shadow),
      0 0 24px -4px color-mix(in srgb, var(--card-accent) 22%, transparent);
    backdrop-filter: blur(calc(var(--yuval-galaxy-card-blur) + 4px));
    -webkit-backdrop-filter: blur(calc(var(--yuval-galaxy-card-blur) + 4px));
  }
  /* Hairline highlight along the top — gives the glass a real edge */
  .lc-orbit::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 12%;
    inset-inline-end: 12%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      var(--yuval-galaxy-border-strong) 50%,
      transparent 100%);
    opacity: 0.9;
    pointer-events: none;
    z-index: 0;
  }
  /* Type-tinted halo radiating from the upper-corner — subtle tint */
  .lc-orbit::after {
    inset-block-start: -40%;
    inset-inline-end: -25%;
    width: 80%;
    opacity: 0.18;
  }

  /* Hide the top stripe in orbit — the medallion + halo carry the
     accent visually, the stripe makes the card feel like a notion list. */
  .lc-orbit .lc-stripe { display: none; }

  /* Symbolic visual area — circular medallion + per-type glyph.
     The medallion is the main "icon block" the brief asks for. */
  .lc-orbit-visual {
    position: relative;
    display: block;
    width: 56px;
    height: 56px;
    margin-block: 0.125rem 0.625rem;
    z-index: 1;
  }
  .lc-orbit-medallion {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%,
      color-mix(in srgb, var(--card-accent) 22%, var(--yuval-galaxy-surface-muted)) 0%,
      var(--yuval-galaxy-surface-muted) 100%);
    border: 1px solid color-mix(in srgb, var(--card-accent) 45%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }
  .lc-orbit-medallion-aura {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: radial-gradient(circle,
      var(--card-accent) 0%,
      transparent 65%);
    opacity: 0.30;
    filter: blur(8px);
    pointer-events: none;
  }
  .lc-orbit-medallion-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--card-accent) 40%, transparent);
    opacity: 0.7;
    pointer-events: none;
  }
  .lc-orbit-glyph {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    color: var(--card-accent);
    z-index: 1;
  }
  .lc-orbit-glyph svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 0 4px color-mix(in srgb, var(--card-accent) 60%, transparent));
  }

  /* Header treatment in orbit — tighter row with type pill + status dot.
     The status pill becomes a tiny round chip so the row stays calm. */
  .lc-orbit .lc-header {
    align-items: center;
    margin-block-end: 0.4375rem;
  }
  .lc-orbit .lc-type {
    font-size: 0.625rem;
    padding: 0.1875rem 0.5rem;
    border-radius: 999px;
    color: var(--card-accent);
    background-color: color-mix(in srgb, var(--card-accent) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-accent) 30%, transparent);
  }
  .lc-orbit .lc-status {
    font-size: 0;
    padding: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--card-status);
    border-color: color-mix(in srgb, var(--card-status) 50%, transparent);
    box-shadow: 0 0 8px 0 color-mix(in srgb, var(--card-status) 60%, transparent);
  }
  .lc-orbit .lc-title {
    font-size: 0.9375rem;
    line-height: 1.3;
    margin-block-end: 0.4375rem;
  }
  .lc-orbit .lc-summary {
    font-size: 0.8125rem;
    line-height: 1.45;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    margin-block-end: 0.5rem;
  }
  .lc-orbit .lc-meta {
    font-size: 0.6875rem;
    gap: 0.25rem 0.625rem;
    margin-block-end: 0.5rem;
  }

  /* Status pulse line — decorative, status-color, sits at the very
     bottom of the orbit card. Static gradient (no animation), reads
     like a faint power indicator on a futuristic dashboard tile. */
  .lc-orbit::after,
  .lc-orbit::before { z-index: 0; }
  .lc-orbit .lc-orbit-status-bar {
    position: relative;
    z-index: 1;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(to right,
      var(--card-status) 0%,
      var(--card-status) 60%,
      transparent 100%);
    opacity: 0.55;
  }
  :global([dir="rtl"]) .lc-orbit .lc-orbit-status-bar {
    background: linear-gradient(to left,
      var(--card-status) 0%,
      var(--card-status) 60%,
      transparent 100%);
  }

  .lc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-block-end: 0.5rem;
  }
  .lc-type {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--card-accent);
    margin: 0;
  }
  .lc-status {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.1875rem 0.625rem;
    border-radius: 999px;
    color: var(--card-status);
    /* Filled tint via color-mix for a "fluid" badge look that still
       reads well on the dark card surface. Falls back to transparent
       border when color-mix is unsupported. */
    background-color: color-mix(in srgb, var(--card-status) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-status) 35%, transparent);
    white-space: nowrap;
  }
  .lc-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.4375rem;
    color: var(--yuval-galaxy-text);
    /* Allow up to two lines for long Hebrew titles. */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .lc-summary {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--yuval-galaxy-text-muted);
    margin: 0 0 0.625rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Topics chips */
  .lc-topics {
    list-style: none;
    margin: 0 0 0.625rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3125rem;
  }
  .lc-topic {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    color: var(--yuval-galaxy-text-soft);
    background-color: var(--yuval-galaxy-surface-muted);
    border: 1px solid var(--yuval-galaxy-border);
    line-height: 1.4;
  }
  .lc-topic-more {
    color: var(--yuval-galaxy-text-muted);
    font-weight: 600;
  }

  .lc-meta {
    font-size: 0.75rem;
    color: var(--yuval-galaxy-text-soft);
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3125rem 0.875rem;
  }
</style>
