---
/**
 * ContinueReadingCard — primary anchor of the /library experience.
 *
 * Visual upgrade (Prompt 7):
 *   - Larger panel radius and tighter typographic rhythm.
 *   - Halo glow behind the inner card using --yuval-galaxy-glow-core
 *     so this panel reads as the page's main "active" surface.
 *   - Honest "activity indicator" line at the bottom — a static gradient
 *     bar rooted on the type accent. It signals "this item is alive"
 *     without faking real progress (we don't have progress data yet).
 *   - Title eyebrow with a small dot glyph as a calm visual anchor.
 *
 * Defensive: empty state remains a clear "nothing in progress" panel.
 * CTA stays disabled until safe-link routing is wired.
 */
import type { Language } from '../../types/index';
import type { LibraryItem } from '../../types/library';
import { t } from '../../i18n';
import {
  getItemTitle,
  getItemSummary,
  getItemTypeLabelKey,
  getTypeAccentVar,
  isSafeLibraryHref,
} from '../../utils/library-display';

interface Props {
  item?: LibraryItem;
  language: Language;
}
const { item, language } = Astro.props;

const cardStyle = item
  ? `--card-accent: ${getTypeAccentVar(item.type)};`
  : '';

// True only when we actually know this reader's last-opened item from
// real per-user reading state. Today no such state is wired into the
// SSR layer, so the card presents itself as a recommended starting
// point instead of pretending to remember the user. The day a real
// last-opened source lands (localStorage hydration / server session),
// pass it as a prop and flip this to true.
const hasPersonalLastOpened = false;

const sectionTitleKey = hasPersonalLastOpened
  ? 'library.continueReading.title'           // "Continue where you left off"
  : 'library.continueReading.recommendedStart'; // "Recommended starting point"

const ctaKey = hasPersonalLastOpened
  ? 'library.continueReading.cta'             // "Continue reading"
  : 'library.continueReading.startReading';   // "Start reading"

const isSafe = item ? isSafeLibraryHref(item.href) : false;
const itemTitle = item ? getItemTitle(item, language) : '';
---

<section class="crc" aria-label={t('library.a11y.continueReadingCard', language)}>
  <header class="crc-header">
    <span class="crc-dot" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
      </svg>
    </span>
    <h2 class="crc-title">{t(sectionTitleKey, language)}</h2>
  </header>

  {item ? (
    <article class="crc-card" style={cardStyle}>
      <div class="crc-card-glow" aria-hidden="true"></div>
      <div class="crc-card-row">
        {item.coverImage && (
          <div class="crc-card-cover" aria-hidden="true">
            <img src={item.coverImage} alt="" loading="lazy" decoding="async" />
          </div>
        )}
        <div class="crc-card-text">
          <h3 class="crc-card-title">{itemTitle}</h3>
          {!hasPersonalLastOpened && (
            <p class="crc-card-meta">
              {t('library.continueReading.recommendedStartText', language)}
            </p>
          )}
        </div>
      </div>
      {isSafe ? (
        <a
          class="crc-cta"
          href={item.href}
          aria-label={`${t(ctaKey, language)}: ${itemTitle}`}
        >
          <svg class="crc-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h6a4 4 0 0 1 4 4v12a3 3 0 0 0-3-3H4z"></path>
            <path d="M20 4h-6a4 4 0 0 0-4 4v12a3 3 0 0 1 3-3h7z"></path>
          </svg>
          <span>{t(ctaKey, language)}</span>
        </a>
      ) : (
        <button type="button" class="crc-cta" disabled aria-disabled="true">
          {t(ctaKey, language)}
        </button>
      )}
    </article>
  ) : (
    <div class="crc-empty">
      <p class="crc-empty-text">{t('library.continueReading.noActive', language)}</p>
      <button type="button" class="crc-cta" disabled aria-disabled="true">
        {t('library.continueReading.startLearning', language)}
      </button>
    </div>
  )}
</section>

<style>
  .crc {
    position: relative;
    padding: 1.375rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-panel-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
    overflow: hidden;
    isolation: isolate;
  }

  .crc-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.875rem;
  }
  .crc-dot {
    display: inline-flex;
    width: 18px;
    height: 18px;
    color: var(--yuval-galaxy-accent-cyan);
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent-cyan) 40%, transparent));
  }
  .crc-dot svg { width: 100%; height: 100%; }
  .crc-title {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0;
    color: var(--yuval-galaxy-text);
  }

  .crc-card {
    --card-accent: var(--yuval-galaxy-accent);
    position: relative;
    padding: 1.125rem 1.125rem 1.25rem;
    border: 1px solid var(--yuval-galaxy-card-border);
    border-radius: calc(var(--yuval-galaxy-panel-radius) - 6px);
    background-color: var(--yuval-galaxy-card-surface);
    box-shadow: var(--yuval-galaxy-card-shadow);
    overflow: hidden;
    isolation: isolate;
  }
  /* Halo behind the card — uses the core glow token so this panel
     visually outranks the side panels. */
  .crc-card-glow {
    position: absolute;
    inset-block-start: -50%;
    inset-inline-end: -30%;
    width: 90%;
    aspect-ratio: 1;
    background: radial-gradient(circle,
      var(--card-accent) 0%,
      transparent 65%);
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }
  .crc-card > *:not(.crc-card-glow) { position: relative; z-index: 1; }

  .crc-card-type {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--card-accent);
    margin: 0 0 0.5rem;
  }
  /* Cover thumbnail + text layout — reference shows the cover at the
     inline-start, title and supporting line beside it. */
  .crc-card-row {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-block-end: 0.625rem;
  }
  .crc-card-cover {
    flex: 0 0 auto;
    width: 56px;
    aspect-ratio: 3 / 4;
    border-radius: 8px;
    overflow: hidden;
    background-color: var(--yuval-galaxy-surface-muted);
    border: 1px solid var(--yuval-galaxy-border);
    box-shadow: 0 0 12px -2px color-mix(in srgb, var(--card-accent) 40%, transparent);
  }
  .crc-card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .crc-card-text {
    min-width: 0;
    flex: 1 1 auto;
  }
  .crc-card-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 0.375rem;
    color: var(--yuval-galaxy-text);
  }
  .crc-cta-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .crc-card-summary {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--yuval-galaxy-text-muted);
    margin: 0 0 0.625rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .crc-card-meta {
    font-size: 0.75rem;
    color: var(--yuval-galaxy-text-soft);
    margin: 0;
  }

  /* Activity indicator — static gradient bar, not a real progress meter. */
  .crc-card-activity {
    height: 3px;
    border-radius: 999px;
    margin-block: 1rem 0.875rem;
    background: linear-gradient(to right,
      var(--card-accent) 0%,
      var(--card-accent) 35%,
      transparent 100%);
    opacity: 0.7;
  }

  .crc-empty {
    padding: 0.75rem 0 0.25rem;
  }
  .crc-empty-text {
    font-size: 0.9375rem;
    color: var(--yuval-galaxy-text-muted);
    margin: 0 0 0.875rem;
  }

  .crc-cta {
    appearance: none;
    /* Inline-flex so the rule applies cleanly whether crc-cta is a
       <button> or an <a>. */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.625rem 1.125rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--yuval-galaxy-text-inverse);
    background-color: var(--yuval-galaxy-accent);
    border: 1px solid transparent;
    border-radius: 999px;
    text-decoration: none;
    cursor: pointer;
    box-shadow: var(--yuval-galaxy-glow-primary);
    transition: box-shadow var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out);
  }
  .crc-cta:disabled { opacity: 0.78; cursor: not-allowed; }
  .crc-cta:focus-visible {
    outline: none;
    box-shadow: var(--yuval-galaxy-glow-primary);
  }
  /* Hover lift only on the active <a> variant; disabled <button> stays put. */
  a.crc-cta:hover {
    box-shadow:
      var(--yuval-galaxy-glow-primary),
      0 6px 18px -4px var(--yuval-galaxy-accent);
  }
</style>
