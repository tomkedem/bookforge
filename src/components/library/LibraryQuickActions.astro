---
/**
 * LibraryQuickActions — future AI side rail.
 *
 * Visual upgrade (Prompt 7):
 *   - Two visual groups separated by a hairline divider:
 *       1) AI assistant actions (ask / summarize / find-related / what-next)
 *       2) Library navigation actions (bookmarks / history)
 *   - Group eyebrow above each group, rooted in i18n keys we already own.
 *   - Tiny chevron glyph at the inline-end of each button to telegraph
 *     "this opens something" — purely decorative, aria-hidden.
 *   - All buttons remain disabled + aria-disabled (no behavior wired).
 *
 * On mobile the rail collapses naturally into a normal panel via the
 * page grid; nothing component-specific to do for that.
 */
import type { Language } from '../../types/index';
import type { TranslationKey } from '../../i18n';
import { t } from '../../i18n';

interface Props {
  language: Language;
  /**
   * default — full panel with AI sub-actions + nav (mobile / non-rail).
   * rail    — slim vertical pill toolbar with only the three top-level
   *           entries: AI assistant, bookmarks, history. Used by /library
   *           desktop dashboard.
   */
  variant?: 'default' | 'rail';
}
const { language, variant = 'default' } = Astro.props;

const aiActionKeys: TranslationKey[] = [
  'library.action.askAboutItem',
  'library.action.summarizeArticle',
  'library.action.findRelated',
  'library.action.whatNext',
];

const navActionKeys: TranslationKey[] = [
  'library.action.bookmarks',
  'library.action.history',
];

// Rail entries: just three top-level actions, each gets a small inline-SVG
// glyph. All glyphs are aria-hidden — the accessible name comes from the
// button's translated text label.
type RailEntry = {
  labelKey: TranslationKey;
  ariaKey: TranslationKey;
  glyph: 'sparkle' | 'bookmark' | 'clock';
};
const railEntries: RailEntry[] = [
  { labelKey: 'library.action.aiAssistant', ariaKey: 'library.action.openAssistant', glyph: 'sparkle' },
  { labelKey: 'library.action.bookmarks',   ariaKey: 'library.action.bookmarks',     glyph: 'bookmark' },
  { labelKey: 'library.action.history',     ariaKey: 'library.action.history',       glyph: 'clock' },
];

const isRail = variant === 'rail';
---

{isRail ? (
  <aside class="lqa lqa-rail" aria-label={t('library.action.aiAssistant', language)}>
    <ul class="lqa-rail-list">
      {railEntries.map((entry, idx) => (
        <li class="lqa-rail-item">
          <button
            type="button"
            class="lqa-rail-btn"
            disabled
            aria-disabled="true"
            aria-label={t(entry.ariaKey, language)}
          >
            <span class="lqa-rail-icon" aria-hidden="true">
              {entry.glyph === 'sparkle' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 5c.6 3 1.5 4.5 4.5 5-3 .5-3.9 2-4.5 5-.6-3-1.5-4.5-4.5-5 3-.5 3.9-2 4.5-5z"></path>
                  <path d="M19 14l.5 1.5L21 16l-1.5.5L19 18l-.5-1.5L17 16l1.5-.5z"></path>
                  <path d="M5 4l.4 1.2L6.6 5.6 5.4 6 5 7.2 4.6 6 3.4 5.6 4.6 5.2z"></path>
                </svg>
              )}
              {entry.glyph === 'bookmark' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 4h12v17l-6-4-6 4z"></path>
                </svg>
              )}
              {entry.glyph === 'clock' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="9"></circle>
                  <path d="M12 7v5l3 2"></path>
                </svg>
              )}
            </span>
            <span class="lqa-rail-label">{t(entry.labelKey, language)}</span>
          </button>
          {idx < railEntries.length - 1 && (
            <span class="lqa-rail-divider" aria-hidden="true"></span>
          )}
        </li>
      ))}
    </ul>
  </aside>
) : (
  <aside class="lqa" aria-label={t('library.a11y.openAssistant', language)}>
    <header class="lqa-header">
      <span class="lqa-dot" aria-hidden="true"></span>
      <h2 class="lqa-title">{t('library.action.aiAssistant', language)}</h2>
    </header>

    <ul class="lqa-list">
      {aiActionKeys.map((key) => (
        <li>
          <button type="button" class="lqa-btn" disabled aria-disabled="true">
            <span class="lqa-btn-label">{t(key, language)}</span>
            <span class="lqa-chevron" aria-hidden="true">›</span>
          </button>
        </li>
      ))}
    </ul>

    <div class="lqa-divider" aria-hidden="true"></div>

    <ul class="lqa-list">
      {navActionKeys.map((key) => (
        <li>
          <button type="button" class="lqa-btn lqa-btn-quiet" disabled aria-disabled="true">
            <span class="lqa-btn-label">{t(key, language)}</span>
            <span class="lqa-chevron" aria-hidden="true">›</span>
          </button>
        </li>
      ))}
    </ul>
  </aside>
)}

<style>
  .lqa {
    padding: 1.375rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-panel-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
  }

  .lqa-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.875rem;
  }
  .lqa-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--yuval-galaxy-accent-cyan);
    box-shadow: var(--yuval-galaxy-glow-soft);
  }
  .lqa-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
    color: var(--yuval-galaxy-text-muted);
  }

  .lqa-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lqa-divider {
    height: 1px;
    background: var(--yuval-galaxy-divider);
    margin-block: 1rem;
  }

  .lqa-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    text-align: start;
    min-height: 44px;
    padding: 0.625rem 0.875rem;
    font-size: 0.875rem;
    color: var(--yuval-galaxy-text);
    background-color: var(--yuval-galaxy-surface-muted);
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: 12px;
    cursor: not-allowed;
    transition: border-color var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out);
  }
  .lqa-btn-label { min-width: 0; }
  .lqa-btn-quiet {
    color: var(--yuval-galaxy-text-muted);
  }
  .lqa-chevron {
    color: var(--yuval-galaxy-text-soft);
    font-size: 1rem;
    line-height: 1;
    /* Flip the chevron in RTL so it always points "forward". */
  }
  :global([dir="rtl"]) .lqa-chevron {
    transform: scaleX(-1);
  }
  .lqa-btn:disabled { opacity: 0.78; }
  .lqa-btn:focus-visible {
    outline: none;
    border-color: var(--yuval-galaxy-border-glow);
    box-shadow: var(--yuval-galaxy-glow-soft);
  }

  /* ── Desktop (≥1024px): become a slim, glassy floating right rail.
        Sticky so it stays visible as the galaxy stage scrolls past.
        Slightly stronger blur and tighter padding fit the rail look. */
  @media (min-width: 1024px) {
    .lqa {
      position: sticky;
      inset-block-start: 5.5rem; /* clear the global header */
      padding: 1.125rem 0.875rem;
      backdrop-filter: blur(calc(var(--yuval-galaxy-card-blur) + 4px));
      -webkit-backdrop-filter: blur(calc(var(--yuval-galaxy-card-blur) + 4px));
    }
    .lqa-btn {
      padding: 0.5rem 0.75rem;
      font-size: 0.8125rem;
    }
  }

  /* ── Rail variant — vertical glass column with labels.
     Reference: each entry is icon + label, separated by hairline
     dividers, the whole column wrapped in a tall pill-shaped panel. */
  .lqa-rail {
    position: relative;
    display: inline-flex;
    padding: 1rem 0.625rem;
    border-radius: 28px;
    background:
      linear-gradient(
        180deg,
        var(--yuval-galaxy-surface-elevated) 0%,
        var(--yuval-galaxy-surface) 100%);
    border: 1px solid var(--yuval-galaxy-border-strong);
    box-shadow:
      0 1px 0 0 var(--yuval-galaxy-border-glow) inset,
      var(--yuval-galaxy-glow-card);
    backdrop-filter: blur(calc(var(--yuval-galaxy-card-blur) + 4px));
    -webkit-backdrop-filter: blur(calc(var(--yuval-galaxy-card-blur) + 4px));
  }
  .lqa-rail-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.375rem;
  }
  .lqa-rail-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.375rem;
  }
  .lqa-rail-btn {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    width: 64px;
    padding: 0.5rem 0;
    background: transparent;
    border: 0;
    color: var(--yuval-galaxy-text-muted);
    cursor: not-allowed;
    transition:
      color var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out);
  }
  .lqa-rail-btn:disabled { opacity: 0.95; }
  .lqa-rail-btn:focus-visible {
    outline: none;
    color: var(--yuval-galaxy-text);
  }
  .lqa-rail-icon {
    display: inline-flex;
    width: 26px;
    height: 26px;
    color: var(--yuval-galaxy-accent-purple);
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--yuval-galaxy-accent-purple) 40%, transparent));
  }
  .lqa-rail-icon svg { width: 100%; height: 100%; }
  .lqa-rail-label {
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    color: var(--yuval-galaxy-text-muted);
    line-height: 1;
  }
  .lqa-rail-divider {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      var(--yuval-galaxy-border-strong) 50%,
      transparent 100%);
  }

  /* ── Desktop rail (≥1024px): vertical column ─────────────────── */
  @media (min-width: 1024px) {
    .lqa-rail-list {
      flex-direction: column;
      gap: 0.5rem;
    }
    .lqa-rail-item {
      flex-direction: column;
      gap: 0.5rem;
    }
    .lqa-rail-divider {
      width: 1px;
      height: 18px;
      background: linear-gradient(
        to bottom,
        transparent 0%,
        var(--yuval-galaxy-border-strong) 50%,
        transparent 100%);
    }
  }
</style>
