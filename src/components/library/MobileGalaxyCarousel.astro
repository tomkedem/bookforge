---
/**
 * MobileGalaxyCarousel — mobile-first horizontal galaxy showcase.
 *
 * The phone counterpart of the desktop orbit stage. It does NOT mirror
 * the desktop absolute orbit layout (cards stacked around a core in
 * 2D space) — that composition does not survive on a 360-pixel canvas.
 * Instead it gives mobile a dedicated visual language that still feels
 * part of the same galaxy:
 *
 *   - a faint mini "knowledge core" glow centered behind the rail
 *   - two faint orbit rings behind the cards
 *   - a horizontal scroll-snap rail of premium glass cards
 *   - one card visually centered, neighbours peeking on each side
 *
 * Pure CSS, no JS, no animations yet, no carousel library.
 *
 * Hidden on desktop (≥1024px) — the existing absolute orbit stage in
 * library.astro takes over there.
 *
 * Items are passed in by the page, never imported from mock or
 * discovery utilities. Only safe-link items should be passed; this
 * component renders LibraryCard with `variant="orbit"`, which already
 * handles unsafe items by rendering a non-clickable <article>, so a
 * stray unsafe item degrades gracefully — but the carousel is meant
 * for readable content only.
 */
import type { Language } from '../../types/index';
import type { LibraryItem } from '../../types/library';
import { t } from '../../i18n';
import LibraryCard from './LibraryCard.astro';

interface Props {
  items: LibraryItem[];
  language: Language;
}
const { items, language } = Astro.props;

const hasItems = items.length > 0;
---

<section class="mgc" aria-label={t('library.mobileGalaxy.title', language)}>
  <header class="mgc-header">
    <span class="mgc-dot" aria-hidden="true"></span>
    <h2 class="mgc-title">{t('library.mobileGalaxy.title', language)}</h2>
  </header>
  <p class="mgc-subtitle">{t('library.mobileGalaxy.subtitle', language)}</p>

  {hasItems && (
    <div class="mgc-stage">
      {/* Decorative galaxy backdrop, scaled for mobile. Pure CSS,
          aria-hidden, sits behind the rail. No animation yet. */}
      <div class="mgc-backdrop" aria-hidden="true">
        <div class="mgc-orbit mgc-orbit-1"></div>
        <div class="mgc-orbit mgc-orbit-2"></div>
        <div class="mgc-core">
          <div class="mgc-core-aura"></div>
          <div class="mgc-core-orb"></div>
        </div>
      </div>

      <ul class="mgc-rail" role="list">
        {items.map((item) => (
          <li class="mgc-row" role="listitem" data-slug={item.slug}>
            <LibraryCard item={item} language={language} variant="orbit" />
          </li>
        ))}
      </ul>
    </div>
  )}
</section>

<style>
  /* ── Section chrome — same family as KnowledgeSpaceCard / ksc, lsp,
        rsl. Tight padding so the carousel reads as part of the mobile
        flow, not a heavy panel. */
  .mgc {
    position: relative;
    /* Tight top padding so the section title lands close to the Hero
       above and the user sees "Available AI content" immediately
       after scrolling past the Hero. */
    padding: 0.5rem 0 1rem;
    isolation: isolate;
  }

  .mgc-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.375rem;
    padding-inline: 1rem;
  }
  .mgc-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--yuval-galaxy-accent-cyan);
    box-shadow: var(--yuval-galaxy-glow-soft);
  }
  .mgc-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
    color: var(--yuval-galaxy-text-muted);
  }
  .mgc-subtitle {
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--yuval-galaxy-text-soft);
    margin: 0 0 0.875rem;
    padding-inline: 1rem;
  }

  /* ── Stage wraps the rail + decorative backdrop ────────────────── */
  .mgc-stage {
    position: relative;
    /* The stage hosts the absolute backdrop and the rail. overflow-x
       hidden prevents the page from scrolling sideways even though
       the rail itself scrolls — neighbouring cards peek without
       leaking horizontal scrollbars to the body. */
    overflow-x: clip;
    overflow-y: visible;
  }

  /* ── Decorative backdrop ───────────────────────────────────────── */
  .mgc-backdrop {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  /* Two faint orbit rings behind the cards. Smaller than desktop. */
  .mgc-orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 1px solid var(--yuval-galaxy-border-strong);
    pointer-events: none;
    /* Vertical fade so the rings recede top/bottom — same trick as
       the desktop orbits. */
    -webkit-mask-image: linear-gradient(
      to bottom, transparent 0%, black 30%, black 70%, transparent 100%);
    mask-image: linear-gradient(
      to bottom, transparent 0%, black 30%, black 70%, transparent 100%);
  }
  .mgc-orbit-1 { width: 220px; height: 220px; opacity: 0.45;
                 border-color: var(--yuval-galaxy-border-glow); }
  .mgc-orbit-2 { width: 360px; height: 360px; opacity: 0.22; }

  /* Mini knowledge core — small, glowing, centered behind the rail. */
  .mgc-core {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 120px;
    height: 120px;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }
  .mgc-core-aura {
    position: absolute;
    inset: -24px;
    border-radius: 50%;
    background: radial-gradient(circle,
      var(--yuval-galaxy-accent-purple) 0%,
      transparent 65%);
    opacity: 0.40;
    filter: blur(20px);
  }
  .mgc-core-orb {
    position: absolute;
    inset: 28%;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%,
      var(--yuval-galaxy-accent-cyan) 0%,
      var(--yuval-galaxy-accent-purple) 70%);
    box-shadow:
      var(--yuval-galaxy-glow-core),
      0 0 0 1px var(--yuval-galaxy-border-glow) inset;
    opacity: 0.85;
  }

  /* ── Horizontal scroll-snap rail ──────────────────────────────── */
  .mgc-rail {
    position: relative;
    z-index: 1;
    list-style: none;
    margin: 0;
    padding: 0.5rem 1rem 0.75rem;
    display: flex;
    flex-direction: row;
    gap: 0.875rem;
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--yuval-galaxy-accent-cyan) transparent;
  }
  .mgc-rail::-webkit-scrollbar { height: 6px; }
  .mgc-rail::-webkit-scrollbar-track { background: transparent; }
  .mgc-rail::-webkit-scrollbar-thumb {
    background-color: var(--yuval-galaxy-accent-cyan);
    border-radius: 999px;
    opacity: 0.5;
  }

  .mgc-row {
    flex: 0 0 78vw;
    max-width: 320px;
    min-width: 0;
    /* Centered snap so the active card lands in the middle and the
       neighbours peek on either side. */
    scroll-snap-align: center;
    scroll-snap-stop: always;
  }

  /* ── Tablet (≥640px): bigger card slots, rail still horizontal ── */
  @media (min-width: 640px) {
    .mgc-header,
    .mgc-subtitle { padding-inline: 1.5rem; }
    .mgc-rail { padding-inline: 1.5rem; }
    .mgc-row { flex-basis: 56vw; max-width: 360px; }
  }

  /* ── Desktop (≥1024px): handed off to the orbit stage in library.astro */
  @media (min-width: 1024px) {
    .mgc { display: none; }
  }
</style>
