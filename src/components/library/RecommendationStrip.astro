---
/**
 * RecommendationStrip — premium horizontal discovery rail.
 *
 * Visual upgrade (Prompt 7):
 *   - Section header with a small dot glyph for calm anchoring.
 *   - Trailing-edge gradient mask hints "more content scrolls this way"
 *     (and respects RTL via direction-aware mask-image).
 *   - Custom thin scrollbar styled with the cyan accent token.
 *   - Uses LibraryCard variant="compact" — same component, less detail.
 *
 * Still no JS, no carousel rotation, no animation.
 */
import type { Language } from '../../types/index';
import type { LibraryItem } from '../../types/library';
import { t } from '../../i18n';
import LibraryCard from './LibraryCard.astro';

interface Props {
  items: LibraryItem[];
  language: Language;
}
const { items, language } = Astro.props;
const hasItems = items.length > 0;
---

<div class="rs-frame">
  {/* Carousel navigation arrows live OUTSIDE the strip, on the far
      left and far right of the frame, exactly as in the reference.
      Disabled buttons today (no JS pager wired); kept keyboard-safe
      and screen-reader-labelled for future hookup. */}
  <button
    type="button"
    class="rs-arrow rs-arrow-prev"
    aria-label={t('library.a11y.carouselPrev', language)}
    disabled
    aria-disabled="true"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="15 6 9 12 15 18"></polyline>
    </svg>
  </button>

  <section class="rs" aria-label={t('library.a11y.recommendationCarousel', language)}>
    <header class="rs-header">
      <h2 class="rs-title">{t('library.recommendation.forYou', language)}</h2>
      <span class="rs-spark" aria-hidden="true">✦</span>
    </header>

    {hasItems ? (
      <div class="rs-strip-wrap">
        <div class="rs-strip" role="list">
          {items.map((item) => (
            <div class="rs-item" role="listitem">
              <LibraryCard item={item} language={language} variant="compact" />
            </div>
          ))}
        </div>
      </div>
    ) : (
      <p class="rs-empty">{t('library.recommendation.none', language)}</p>
    )}
  </section>

  <button
    type="button"
    class="rs-arrow rs-arrow-next"
    aria-label={t('library.a11y.carouselNext', language)}
    disabled
    aria-disabled="true"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="9 6 15 12 9 18"></polyline>
    </svg>
  </button>
</div>

<style>
  /* Frame surrounds the strip + flanking arrows, all on the same row.
     Locked to LTR so the prev arrow is always physical-left and the
     next arrow is always physical-right. The strip inside resets to
     page direction so the title and Hebrew card text read correctly. */
  .rs-frame {
    display: flex;
    align-items: stretch;
    gap: 0.625rem;
    margin: 0.75rem auto 0;
    max-width: 1280px;
    direction: ltr;
  }
  .rs-frame > .rs {
    direction: var(--page-direction, ltr);
  }

  .rs {
    flex: 1 1 auto;
    min-width: 0;
    padding: 1rem 1.375rem 1.125rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-panel-radius);
    background:
      linear-gradient(
        180deg,
        var(--yuval-galaxy-surface-elevated) 0%,
        var(--yuval-galaxy-surface) 100%);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow:
      0 1px 0 0 var(--yuval-galaxy-border-glow) inset,
      var(--yuval-galaxy-glow-card);
    overflow: hidden;
    position: relative;
  }

  .rs-header {
    display: flex;
    align-items: center;
    /* flex-start follows the page's natural reading direction:
       inline-start in Hebrew (rtl) = visual right, in English (ltr) =
       visual left. The reference (Hebrew) shows the title at the
       inline-start of the strip, matching this rule. */
    justify-content: flex-start;
    gap: 0.5rem;
    margin-block-end: 0.625rem;
  }
  .rs-title {
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0;
    color: var(--yuval-galaxy-text);
  }
  .rs-spark {
    font-size: 1rem;
    line-height: 1;
    color: var(--yuval-galaxy-accent-cyan);
    text-shadow: 0 0 12px var(--yuval-galaxy-accent-cyan);
  }

  /* ── Arrow buttons flanking the strip ────────────────────────── */
  .rs-arrow {
    flex: 0 0 auto;
    width: 44px;
    align-self: center;
    aspect-ratio: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 50%;
    color: var(--yuval-galaxy-text-muted);
    background:
      radial-gradient(circle at 30% 30%,
        var(--yuval-galaxy-surface-elevated) 0%,
        var(--yuval-galaxy-surface-muted) 100%);
    border: 1px solid var(--yuval-galaxy-border-strong);
    box-shadow: 0 0 0 1px var(--yuval-galaxy-border) inset;
    cursor: not-allowed;
  }
  .rs-arrow:disabled { opacity: 0.85; }
  .rs-arrow:focus-visible {
    outline: none;
    border-color: var(--yuval-galaxy-border-glow);
    box-shadow: var(--yuval-galaxy-glow-soft);
  }
  .rs-arrow svg { width: 18px; height: 18px; }
  /* Frame is locked to LTR direction (see .rs-frame above), so the
     chevrons keep their physical left/right meaning regardless of
     page language. No RTL flip needed. */
  .rs-empty {
    font-size: 0.9375rem;
    color: var(--yuval-galaxy-text-muted);
    margin: 0;
  }

  /* Wrapper provides the trailing fade mask so the scrollbar still
     lives inside .rs-strip and remains accessible. */
  .rs-strip-wrap {
    position: relative;
    margin-inline: -0.5rem;
    padding-inline: 0.5rem;
    /* Direction-aware fade — uses mask-image with `to right`, then
       flips for RTL via [dir="rtl"] override below. */
    mask-image: linear-gradient(to right,
      black 0%,
      black 90%,
      transparent 100%);
    -webkit-mask-image: linear-gradient(to right,
      black 0%,
      black 90%,
      transparent 100%);
  }
  :global([dir="rtl"]) .rs-strip-wrap {
    mask-image: linear-gradient(to left,
      black 0%,
      black 90%,
      transparent 100%);
    -webkit-mask-image: linear-gradient(to left,
      black 0%,
      black 90%,
      transparent 100%);
  }

  .rs-strip {
    display: flex;
    gap: 0.875rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-block-end: 0.5rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--yuval-galaxy-accent-cyan) transparent;
  }
  .rs-strip::-webkit-scrollbar {
    height: 6px;
  }
  .rs-strip::-webkit-scrollbar-track { background: transparent; }
  .rs-strip::-webkit-scrollbar-thumb {
    background-color: var(--yuval-galaxy-accent-cyan);
    border-radius: 999px;
    opacity: 0.5;
  }

  .rs-item {
    flex: 0 0 80%;
    max-width: 320px;
    scroll-snap-align: start;
    min-width: 0;
  }

  @media (min-width: 640px) {
    .rs-item { flex-basis: 45%; }
  }
  @media (min-width: 1024px) {
    .rs-item { flex-basis: 30%; }
  }
</style>
