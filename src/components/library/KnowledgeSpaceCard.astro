---
/**
 * KnowledgeSpaceCard — small explanation panel for the left sidebar.
 *
 * Tells the visitor (in one short sentence) what the knowledge space
 * is and how content gets into it. Uses the neutral product wording
 * agreed in the copy correction step:
 *   - "מרחב הידע" / "The Knowledge Space"
 *   - content is processed by BookForge (no user-upload phrasing)
 *   - no payment / pricing implications
 *
 * Pure presentation. Accepts only `language`, no data.
 */
import type { Language } from '../../types/index';
import { t } from '../../i18n';

interface Props {
  language: Language;
}
const { language } = Astro.props;
---

<section class="ksc" aria-label={t('library.galaxy.explainerTitle', language)}>
  <header class="ksc-header">
    <span class="ksc-dot" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0z"></path>
        <path d="M12 3v18"></path>
        <path d="M3 12h18"></path>
      </svg>
    </span>
    <h2 class="ksc-title">{t('library.galaxy.explainerTitle', language)}</h2>
  </header>
  <p class="ksc-body">{t('library.galaxy.explainerBody', language)}</p>

  {/* Mini glowing book illustration — purely decorative, mirrors the
      central knowledge core so the panel feels like a small window
      onto the galaxy stage. CSS-only, aria-hidden. */}
  <div class="ksc-mini-core" aria-hidden="true">
    <span class="ksc-mini-aura"></span>
    <span class="ksc-mini-orbit ksc-mini-orbit-1"></span>
    <span class="ksc-mini-orbit ksc-mini-orbit-2"></span>
    <span class="ksc-mini-orb">
      <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 9C13.5 7.5 10.5 6.5 6 6.7v17C10.5 23.5 13.5 24.5 16 26"></path>
        <path d="M16 9C18.5 7.5 21.5 6.5 26 6.7v17c-4.5-.2-7.5.8-10 2.3"></path>
        <path d="M16 9v17"></path>
      </svg>
    </span>
  </div>
</section>

<style>
  .ksc {
    position: relative;
    padding: 1.25rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-panel-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
    overflow: hidden;
    isolation: isolate;
  }
  /* Subtle inner accent — uses the soft purple ambience to tie this
     panel back to the galaxy core thematically. */
  .ksc::after {
    content: "";
    position: absolute;
    inset-block-start: -50%;
    inset-inline-end: -30%;
    width: 80%;
    aspect-ratio: 1;
    background: radial-gradient(circle,
      var(--yuval-galaxy-accent-purple) 0%,
      transparent 65%);
    opacity: 0.10;
    pointer-events: none;
    z-index: -1;
  }
  .ksc-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.625rem;
  }
  .ksc-dot {
    display: inline-flex;
    width: 18px;
    height: 18px;
    color: var(--yuval-galaxy-accent-cyan);
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent-cyan) 40%, transparent));
  }
  .ksc-dot svg { width: 100%; height: 100%; }
  .ksc-title {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0;
    color: var(--yuval-galaxy-text);
  }
  .ksc-body {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--yuval-galaxy-text-muted);
    margin: 0;
  }

  /* Mini knowledge-core illustration at the bottom of the panel.
     CSS-only, decorative, mirrors the desktop central core scaled
     down to fit a sidebar tile. */
  .ksc-mini-core {
    position: relative;
    margin: 1rem auto 0;
    width: 110px;
    height: 80px;
    pointer-events: none;
  }
  .ksc-mini-aura {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    background: radial-gradient(ellipse at center,
      var(--yuval-galaxy-accent-purple) 0%,
      transparent 65%);
    opacity: 0.40;
    filter: blur(14px);
  }
  .ksc-mini-orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    border: 1px solid var(--yuval-galaxy-border-glow);
    transform: translate(-50%, -50%);
    -webkit-mask-image: linear-gradient(
      to bottom, transparent 0%, black 30%, black 70%, transparent 100%);
    mask-image: linear-gradient(
      to bottom, transparent 0%, black 30%, black 70%, transparent 100%);
  }
  .ksc-mini-orbit-1 { width: 70px; height: 70px; opacity: 0.55; }
  .ksc-mini-orbit-2 { width: 105px; height: 105px; opacity: 0.30; }
  .ksc-mini-orb {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 38px;
    height: 38px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%,
      var(--yuval-galaxy-accent-cyan) 0%,
      var(--yuval-galaxy-accent-purple) 70%);
    box-shadow:
      0 0 0 1px var(--yuval-galaxy-border-glow) inset,
      0 0 20px 0 color-mix(in srgb, var(--yuval-galaxy-accent-purple) 60%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--yuval-galaxy-text);
  }
  .ksc-mini-orb svg {
    width: 22px;
    height: 22px;
    opacity: 0.92;
  }
</style>
