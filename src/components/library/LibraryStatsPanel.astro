---
/**
 * LibraryStatsPanel — premium analytics tile dashboard.
 *
 * Semantics (Prompt 8.7 update):
 *   - Hero tile shows "available content items" (readable count) — not
 *     the raw `total` which now includes synthetic course meta.
 *   - Type tiles render dynamically: only types with count > 0 appear.
 *     Avoids the "0 articles / 0 series" awkwardness on a real-content
 *     library that doesn't have those types yet.
 *   - When the page passes `courseProgress`, the panel adds an honest
 *     "X of Y lesson summaries available" line per course.
 *   - course_lesson is rendered as "lesson summaries" via its own key.
 *
 * Defensive: every count falls back to 0; missing courseProgress is
 * silently skipped.
 */
import type { Language } from '../../types/index';
import type { LibraryCourseProgress, LibraryStats } from '../../types/library';
import type { TranslationKey } from '../../i18n';
import { t } from '../../i18n';
import { getTypeAccentVar } from '../../utils/library-display';

interface Props {
  stats: LibraryStats;
  language: Language;
  /**
   * Optional per-course progress fed by library-adapter. When omitted,
   * the panel does not render any "X of Y lessons" lines.
   */
  courseProgress?: LibraryCourseProgress[];
}
const { stats, language, courseProgress = [] } = Astro.props;

const counts = {
  readable: stats.readable ?? 0,
  books:    stats.byType.book ?? 0,
  courses:  stats.byType.course ?? 0,
  lessons:  stats.byType.course_lesson ?? 0,
  series:   stats.byType.series ?? 0,
  articles: stats.byType.article ?? 0,
  minutes:  stats.totalReadingMinutes ?? 0,
  words:    stats.totalWordCount ?? 0,
};

// Tile config — full set declared declaratively, then filtered to count>0.
// Order is the order tiles will appear in the 2×N grid: books first
// (most concrete content), lessons second, course third, then optional
// types only if they ever land.
type TileSpec = {
  key: TranslationKey;
  n: number;
  accent: string;
};
const allTiles: TileSpec[] = [
  { key: 'library.stats.booksCount',    n: counts.books,    accent: getTypeAccentVar('book') },
  { key: 'library.stats.lessonsCount',  n: counts.lessons,  accent: getTypeAccentVar('course_lesson') },
  { key: 'library.stats.coursesCount',  n: counts.courses,  accent: getTypeAccentVar('course') },
  { key: 'library.stats.seriesCount',   n: counts.series,   accent: getTypeAccentVar('series') },
  { key: 'library.stats.articlesCount', n: counts.articles, accent: getTypeAccentVar('article') },
];
const typeTiles: TileSpec[] = allTiles.filter((tile) => tile.n > 0);
---

<section class="lsp" aria-label={t('library.a11y.libraryStatsPanel', language)}>
  <header class="lsp-header">
    <span class="lsp-dot" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2a10 10 0 1 0 10 10h-10z"></path>
        <path d="M12 2a10 10 0 0 1 10 10"></path>
      </svg>
    </span>
    <h2 class="lsp-title">{t('library.stats.title', language)}</h2>
  </header>

  <div class="lsp-hero">
    <span class="lsp-hero-num">{counts.readable}</span>
    <span class="lsp-hero-label">{t('library.stats.readableItems', language, { n: '' }).replace(/^\s*/, '').trim()}</span>
  </div>

  {typeTiles.length > 0 && (
    <ul class="lsp-chips">
      {typeTiles.map((tile) => (
        <li class="lsp-chip" style={`--chip-accent: ${tile.accent};`}>
          <span class="lsp-chip-dot" aria-hidden="true"></span>
          {t(tile.key, language, { n: tile.n })}
        </li>
      ))}
    </ul>
  )}

  {courseProgress.length > 0 && (
    <ul class="lsp-progress-list" aria-label={t('library.stats.courseProgressTitle', language)}>
      {courseProgress.map((cp) => (
        <li class="lsp-progress-row">
          <span class="lsp-progress-bar" aria-hidden="true">
            <span
              class="lsp-progress-bar-fill"
              style={`width: ${cp.total > 0 ? Math.round((cp.available / cp.total) * 100) : 0}%;`}
            ></span>
          </span>
          <span class="lsp-progress-text">
            {t('library.stats.lessonsAvailable', language, { available: cp.available, total: cp.total })}
          </span>
        </li>
      ))}
    </ul>
  )}
</section>

<style>
  .lsp {
    padding: 1.375rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-panel-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
  }

  .lsp-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.875rem;
  }
  .lsp-dot {
    display: inline-flex;
    width: 18px;
    height: 18px;
    color: var(--yuval-galaxy-accent-purple);
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent-purple) 40%, transparent));
  }
  .lsp-dot svg { width: 100%; height: 100%; }
  .lsp-title {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0;
    color: var(--yuval-galaxy-text);
  }

  /* Hero — big number "6" + descriptor "available content items".
     Per reference: number is huge and luminous, label sits beside or
     under it as a subtle line. */
  .lsp-hero {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    margin-block-end: 0.875rem;
  }
  .lsp-hero-num {
    font-size: 2.625rem;
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(135deg,
      var(--yuval-galaxy-accent-cyan) 0%,
      var(--yuval-galaxy-accent-purple) 100%);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 14px color-mix(in srgb, var(--yuval-galaxy-accent-purple) 35%, transparent));
  }
  .lsp-hero-label {
    font-size: 0.875rem;
    color: var(--yuval-galaxy-text-muted);
    line-height: 1.3;
  }

  /* Type chips — small pill rows, one per type, with a colored dot. */
  .lsp-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .lsp-chip {
    --chip-accent: var(--yuval-galaxy-accent);
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4375rem;
    padding: 0.3125rem 0.625rem;
    border-radius: 999px;
    border: 1px solid var(--yuval-galaxy-border-strong);
    background-color: var(--yuval-galaxy-surface-muted);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--yuval-galaxy-text-muted);
  }
  .lsp-chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--chip-accent);
    box-shadow: 0 0 6px 0 color-mix(in srgb, var(--chip-accent) 60%, transparent);
  }

  /* Course progress: thin gradient bar + label line below.
     Reference shows the bar as the visible signal of "X of Y". */
  .lsp-progress-list {
    list-style: none;
    margin: 0.875rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .lsp-progress-row {
    display: flex;
    flex-direction: column;
    gap: 0.4375rem;
  }
  .lsp-progress-bar {
    display: block;
    width: 100%;
    height: 4px;
    border-radius: 999px;
    background-color: var(--yuval-galaxy-surface-muted);
    border: 1px solid var(--yuval-galaxy-border);
    overflow: hidden;
  }
  .lsp-progress-bar-fill {
    display: block;
    height: 100%;
    background: linear-gradient(
      90deg,
      var(--yuval-galaxy-accent-cyan) 0%,
      var(--yuval-galaxy-accent-purple) 100%);
    border-radius: 999px;
    box-shadow: 0 0 10px 0 color-mix(in srgb, var(--yuval-galaxy-accent-cyan) 50%, transparent);
  }
  .lsp-progress-text {
    font-size: 0.75rem;
    color: var(--yuval-galaxy-text-muted);
    line-height: 1.3;
  }
</style>
