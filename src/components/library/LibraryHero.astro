---
/**
 * LibraryHero — text-only header strip for the /library page.
 *
 * Surfaces three localized lines: eyebrow welcome, gradient title,
 * and a single-line subtitle. The previous decorative knowledge-core
 * preview, the readonly search input and the inner mini-CTA panel
 * were removed once the global header carried the canonical search;
 * the .lh-halo behind the text is the only chrome that remains,
 * scoped to the tablet range via the @media block below.
 */
import type { Language } from '../../types/index';
import { t } from '../../i18n';

interface Props {
  language: Language;
}
const { language } = Astro.props;
---

<section class="lh" aria-label={t('library.a11y.mainRegion', language)}>
  {/* Decorative inner halo — sits above bg, below content. */}
  <div class="lh-halo" aria-hidden="true"></div>

  <div class="lh-header">
    <div class="lh-text">
      <p class="lh-eyebrow">
        <span class="lh-eyebrow-text">{t('library.galaxy.welcome', language)}</span>
      </p>
      <h1 class="lh-title">{t('library.galaxy.title', language)}</h1>
      <p class="lh-subtitle">{t('library.galaxy.subtitle', language)}</p>
    </div>

  </div>
</section>

<style>
  .lh {
    position: relative;
    /* Compact mobile padding — minimises vertical space so the galaxy
       orbit stage beneath it lands above the fold on common phone
       heights (640-740px). */
    padding: 0.875rem 1.125rem 1rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-panel-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
    overflow: hidden;
    isolation: isolate;
  }
  .lh-halo {
    position: absolute;
    inset-block-start: -40%;
    inset-inline-start: 50%;
    transform: translateX(-50%);
    width: 120%;
    aspect-ratio: 2 / 1;
    background: radial-gradient(ellipse at center,
      var(--yuval-galaxy-accent-purple) 0%,
      transparent 60%);
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }
  .lh-header {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-block-end: 0.625rem;
  }
  .lh-text { min-width: 0; flex: 1 1 auto; }

  .lh-eyebrow {
    font-size: 0.75rem;
    color: var(--yuval-galaxy-text-soft);
    margin: 0 0 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .lh-title {
    /* Compact responsive clamp: 18px → 26px across all viewports.
       Previous bounds (22px → 32px) still read as oversized on tablet
       widths once the side panels were brought in, because the central
       hero strip is much narrower than the page. `white-space: nowrap`
       keeps the title on a single line so it never breaks into two
       lines (which would make the title VISUALLY take more vertical
       space than its font-size suggests). */
    font-size: clamp(1.125rem, 2.2vw, 1.625rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
    white-space: nowrap;
    background: var(--yuval-galaxy-title-gradient);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  .lh-subtitle {
    /* Subtitle scales softly so it stays a single line wherever
       possible without forcing a hard min on narrow phones. */
    font-size: clamp(0.8125rem, 1.6vw, 0.9375rem);
    line-height: 1.45;
    color: var(--yuval-galaxy-text-muted);
    margin: 0;
    max-width: 56ch;
  }

  /* ── Tablet (768–1023px): hero stays centered, more breathing room. ──
        The previous row-layout override was paired with the inline
        knowledge-core preview that's been removed, so it pushed the
        single remaining child (.lh-text) to the inline-start edge,
        where it collided with the fixed ContinueLearningCard on the
        right (RTL inline-start = right). The hero now keeps the
        mobile column layout at this breakpoint and simply gains a
        little extra padding. */
  @media (min-width: 768px) and (max-width: 1023px) {
    .lh { padding: 1.5rem 1.5rem; text-align: center; }
    .lh-header {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: 0;
      margin-block-end: 0.5rem;
    }
    .lh-text { text-align: center; }
  }

  /* ── Desktop (≥1024px): hero text floats over the galaxy stage.
        The panel chrome (border, surface, shadow, blur, halo) is
        STRIPPED so the hero stops feeling like a card and reads as
        free-floating text above the central core. The inline mini-core
        is also hidden — the big central core in library.astro's
        galaxy stage is the singular anchor. Search input is hidden too
        because the desktop dashboard surfaces no functional search yet
        and a readonly pill would look like dead chrome on a clean stage. */
  @media (min-width: 1024px) {
    /* Hero acts as the title strip of the galaxy stage. Vertical
       budget tightened again: the entire block now occupies roughly
       the height of the title + one subtitle line + one CTA row,
       with the smallest gaps that still feel intentional. */
    .lh {
      padding: 0;
      text-align: center;
      border: 0;
      background-color: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      box-shadow: none;
      overflow: visible;
    }
    .lh-halo { display: none; }
    .lh-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0;
      margin-block-end: 0.125rem;
    }
    .lh-text { text-align: center; }
    /* Eyebrow — cyan→violet gradient text + accent spark. */
    .lh-eyebrow {
      margin-block-end: 0.1875rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      letter-spacing: 0.06em;
      text-transform: none;
      font-weight: 500;
      background: linear-gradient(
        90deg,
        var(--yuval-galaxy-accent-cyan) 0%,
        var(--yuval-galaxy-accent-purple) 100%);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }
    /* Title on desktop keeps the base responsive clamp (≤32px) and
       only adjusts the trailing rhythm — line-height + margin —
       since the hero is a centered strip above the galaxy stage.
       The previous fixed 2.25rem clamp competed with the base
       declaration and produced an oversized title at common desktop
       widths. */
    .lh-title {
      line-height: 1;
      margin-block-end: 0.1875rem;
    }
    .lh-subtitle {
      margin-inline: auto;
      max-width: 60ch;
      line-height: 1.35;
    }
  }
</style>
