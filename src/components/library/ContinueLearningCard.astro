---
import type { Language } from '../../types/index';
import { t } from '../../i18n';
import { getLanguageDirection } from '../../utils/language';

interface Props {
  language: Language;
  courseTitle?: string;
  metaLine1?: string;
  metaLine2?: string;
  progress?: number;
  href?: string;
  class?: string;
  /** Available lesson summaries already published for this course. */
  lessonsAvailable?: number;
  /** Total planned lesson summaries for this course. */
  lessonsTotal?: number;
}

const {
  language,
  courseTitle = 'AI Engineering',
  metaLine1 = 'Series · Chapter 8',
  metaLine2 = 'Agentic Workflows',
  progress = 68,
  href = '#',
  class: className = '',
  lessonsAvailable,
  lessonsTotal,
} = Astro.props;

const hasLessonAvailability =
  typeof lessonsAvailable === 'number' &&
  typeof lessonsTotal === 'number' &&
  lessonsTotal > 0;

const direction = getLanguageDirection(language);
const safeProgress = Math.max(0, Math.min(100, progress));

const RADIUS = 34;
const CIRCUMFERENCE = 2 * Math.PI * RADIUS;
const dashLength = (safeProgress / 100) * CIRCUMFERENCE;
---

<article
  class={`continue-learning-card ${className}`}
  dir={direction}
  aria-label={t('library.a11y.continueReadingCard', language)}
>
  <header class="continue-learning-card__header">
    <span class="continue-learning-card__header-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5c.6 3 1.5 4.5 4.5 5-3 .5-3.9 2-4.5 5-.6-3-1.5-4.5-4.5-5 3-.5 3.9-2 4.5-5z"></path>
        <path d="M19 14l.5 1.5L21 16l-1.5.5L19 18l-.5-1.5L17 16l1.5-.5z"></path>
        <path d="M5 4l.4 1.2L6.6 5.6 5.4 6 5 7.2 4.6 6 3.4 5.6 4.6 5.2z"></path>
      </svg>
    </span>
    <h3 class="continue-learning-card__title">
      {t('library.continueReading.title', language)}
    </h3>
  </header>

  <div class="continue-learning-card__body">
    <div
      class="continue-learning-card__progress"
      role="img"
      aria-label={`${safeProgress}%`}
    >
      <svg viewBox="0 0 80 80" width="80" height="80">
        <defs>
          <linearGradient id="cl-donut-progress" x1="100%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#a78bfa" />
            <stop offset="100%" stop-color="#7c3aed" />
          </linearGradient>
        </defs>
        <circle
          cx="40"
          cy="40"
          r={RADIUS}
          fill="none"
          stroke="currentColor"
          stroke-width="6"
          opacity="0.15"
        />
        <circle
          cx="40"
          cy="40"
          r={RADIUS}
          fill="none"
          stroke="url(#cl-donut-progress)"
          stroke-width="6"
          stroke-linecap="round"
          stroke-dasharray={`${dashLength} ${CIRCUMFERENCE}`}
          transform="rotate(-90 40 40)"
        />
      </svg>
      <span class="continue-learning-card__percent">{safeProgress}%</span>
    </div>

    <div class="continue-learning-card__info">
      <p class="continue-learning-card__course-title">{courseTitle}</p>
      <p class="continue-learning-card__meta">{metaLine1}</p>
      {metaLine2 && <p class="continue-learning-card__meta">{metaLine2}</p>}
      {hasLessonAvailability && (
        <p class="continue-learning-card__meta continue-learning-card__lessons">
          {t('library.continueReading.lessonsAvailable', language, {
            available: lessonsAvailable!,
            total: lessonsTotal!,
          })}
        </p>
      )}
    </div>
  </div>

  <a class="continue-learning-card__cta" href={href}>
    <span class="continue-learning-card__cta-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h6a4 4 0 0 1 4 4v12a3 3 0 0 0-3-3H4z"></path>
        <path d="M20 4h-6a4 4 0 0 0-4 4v12a3 3 0 0 1 3-3h7z"></path>
      </svg>
    </span>
    <span>{t('library.continueReading.cta', language)}</span>
  </a>
</article>

<style>
  .continue-learning-card {
    /* Fixed positioning — pinned to the inline-start edge of the
       viewport (right in RTL, left in LTR), 20px below the global
       Header. Stays visible during scroll. */
    position: fixed;
    top: calc(var(--library-header-offset, 72px) + 20px);
    inset-inline-start: 20px;
    inset-inline-end: auto;
    z-index: 30;
    max-width: 320px;
    padding: 20px;
    border: 1px solid rgba(120, 140, 200, 0.18);
    border-radius: var(--yuval-galaxy-panel-radius, 22px);
    /* Layered surface adopted verbatim from FloatingSidebar so the card
       reads as part of the same premium material family:
         1. Soft radial highlight at top, fading to transparent at 60%.
         2. Linear navy with very low contrast top/middle/bottom. */
    background:
      radial-gradient(
        ellipse 80% 40% at 50% 0%,
        rgba(40, 70, 130, 0.22) 0%,
        transparent 60%),
      linear-gradient(
        180deg,
        #08091a 0%,
        #0b0e22 50%,
        #08091a 100%);
    /* 4-layer depth + glow stack from FloatingSidebar:
         - inset hairline (the "inside cyan line")
         - inset soft glow toward center
         - outer atmospheric halo
         - depth shadow underneath */
    box-shadow:
      inset 0 0 0 1px rgba(140, 190, 255, 0.10),
      inset 0 0 28px rgba(60, 110, 200, 0.12),
      0 0 36px rgba(80, 130, 220, 0.22),
      0 12px 32px rgba(2, 4, 14, 0.45);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur, 20px));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur, 20px));
    isolation: isolate;
    color: var(--yuval-galaxy-text);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .continue-learning-card__header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .continue-learning-card__header-icon {
    display: inline-flex;
    width: 16px;
    height: 16px;
    color: var(--yuval-galaxy-accent-cyan);
  }
  .continue-learning-card__header-icon svg {
    width: 100%;
    height: 100%;
  }

  .continue-learning-card__title {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--yuval-galaxy-accent-cyan);
  }

  /* Inner inset card around donut + info. Recessed sibling of the outer
     surface — same border family at lower opacity, half-opacity inset
     hairline so it reads as nested rather than floating on its own. */
  .continue-learning-card__body {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px;
    background-color: var(--yuval-galaxy-surface-elevated);
    border: 1px solid rgba(120, 140, 200, 0.12);
    border-radius: 12px;
    box-shadow: inset 0 0 0 1px rgba(140, 190, 255, 0.06);
  }

  .continue-learning-card__progress {
    position: relative;
    flex: 0 0 auto;
    width: 80px;
    height: 80px;
    color: var(--yuval-galaxy-accent-purple);
  }
  .continue-learning-card__percent {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    color: var(--yuval-galaxy-text);
  }

  .continue-learning-card__info {
    min-width: 0;
    flex: 1 1 auto;
  }
  .continue-learning-card__course-title {
    margin: 0 0 4px;
    font-size: 0.9375rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--yuval-galaxy-text);
  }
  .continue-learning-card__meta {
    margin: 0;
    font-size: 0.75rem;
    line-height: 1.35;
    color: var(--yuval-galaxy-text-soft);
  }

  .continue-learning-card__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 12px 16px;
    border-radius: 14px;
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--yuval-galaxy-text);
    background-color: var(--yuval-galaxy-surface-elevated);
    border: 1px solid rgba(120, 140, 200, 0.12);
    box-shadow: inset 0 0 0 1px rgba(140, 190, 255, 0.06);
    transition: opacity 150ms ease-out;
  }
  .continue-learning-card__cta:hover {
    opacity: 0.9;
  }
  .continue-learning-card__cta-icon {
    display: inline-flex;
    width: 18px;
    height: 18px;
  }
  .continue-learning-card__cta-icon svg {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .continue-learning-card {
      display: none;
    }
  }
</style>
