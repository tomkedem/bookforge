---
import type { Language } from '../types/index';
import { LANGUAGES, SUPPORTED_LANGUAGES } from '../utils/language';

interface Props {
  currentLanguage?: Language;
  class?: string;
}

const { currentLanguage = LANGUAGES.EN, class: className } = Astro.props;
---

<div
  class:list={[
    'inline-flex',
    'items-center',
    'gap-1',
    'p-1',
    'rounded-full',
    'bg-yuval-bg-secondary',
    'border',
    'border-yuval-border',
    className,
  ]}
  role="radiogroup"
  aria-label="Language Selection"
>
  {SUPPORTED_LANGUAGES.map(lang => (
    <button
      type="button"
      class:list={[
        'px-3',
        'py-1.5',
        'rounded-full',
        'transition-all',
        'duration-200',
        'font-body',
        'text-sm',
        'font-medium',
        currentLanguage === lang.code && 'bg-yuval-text text-yuval-bg',
        currentLanguage !== lang.code && 'text-yuval-text hover:bg-yuval-border',
        'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yuval-highlight focus-visible:ring-offset-1',
      ]}
      data-language={lang.code}
      aria-pressed={currentLanguage === lang.code}
      aria-label={`Switch to ${lang.labelEn}`}
    >
      {lang.label}
    </button>
  ))}
</div>

<script>
  import { LANGUAGES, SUPPORTED_LANGUAGES, setLanguageToStorage, isValidLanguage } from '../utils/language';
  import type { Language } from '../types/index';

  function initLanguageToggle(controller: AbortController) {
    const buttons = document.querySelectorAll<HTMLButtonElement>(
      '[role="radiogroup"] button[data-language]'
    );

    const clickHandler = (e: Event) => {
      const target = e.currentTarget as HTMLButtonElement;
      const lang = target.dataset.language;

      if (lang && isValidLanguage(lang)) {
        setLanguageToStorage(lang);
        const meta = SUPPORTED_LANGUAGES.find(l => l.code === lang);
        document.documentElement.lang = lang;
        document.documentElement.dir = meta?.dir ?? 'ltr';

        // Update aria-pressed state
        buttons.forEach((btn) => {
          const btnLang = (btn as HTMLButtonElement).dataset.language;
          (btn as HTMLButtonElement).setAttribute(
            'aria-pressed',
            btnLang === lang ? 'true' : 'false'
          );
        });

        // Dispatch custom event for other components
        window.dispatchEvent(
          new CustomEvent('language-changed', {
            detail: { language: lang as Language }
          })
        );
      }
    };

    buttons.forEach((button) => {
      button.addEventListener('click', clickHandler, { signal: controller.signal });
      const btnLang = (button as HTMLButtonElement).dataset.language;
      (button as HTMLButtonElement).setAttribute(
        'aria-pressed',
        btnLang === LANGUAGES.EN ? 'true' : 'false'
      );
    });
  }

  function initializeLanguageToggle() {
    const controller = new AbortController();
    initLanguageToggle(controller);
    const unloadHandler = () => controller.abort();
    document.addEventListener('astro:before-unmount', unloadHandler);
    window.addEventListener('unload', unloadHandler);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeLanguageToggle);
  } else {
    initializeLanguageToggle();
  }

  document.addEventListener('astro:after-swap', initializeLanguageToggle);
</script>
