---
interface Props {
  threshold?: number;
}

const { threshold = 300 } = Astro.props;
---

<button
  id="back-to-top"
  type="button"
  class="fixed bottom-6 right-6 z-40 hidden items-center justify-center w-11 h-11 rounded-full bg-yuval-accent text-yuval-accent-text shadow-lg hover:bg-yuval-accent-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yuval-highlight focus-visible:ring-offset-2 transition-all duration-300 opacity-0 translate-y-4"
  aria-label="Back to top"
  data-threshold={threshold}
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
  </svg>
</button>

<style>
  /* Desktop-only: the unified mobile FAB + chapter-title tap gesture
     replace this button below 1024px. */
  @media (max-width: 1023px) {
    #back-to-top { display: none !important; }
  }
</style>

<script>
  const btn = document.getElementById('back-to-top') as HTMLButtonElement | null;
  if (btn) {
    const threshold = parseInt(btn.dataset.threshold || '300', 10);
    const desktopMq = window.matchMedia('(min-width: 1024px)');
    let ticking = false;
    let scrollAttached = false;

    function onScroll() {
      if (ticking || !btn) return;
      ticking = true;
      requestAnimationFrame(() => {
        const show = window.scrollY > threshold;
        btn.classList.toggle('hidden', !show);
        btn.classList.toggle('flex', show);
        btn.classList.toggle('opacity-0', !show);
        btn.classList.toggle('translate-y-4', !show);
        btn.classList.toggle('opacity-100', show);
        btn.classList.toggle('translate-y-0', show);
        ticking = false;
      });
    }

    function attach() {
      if (scrollAttached) return;
      scrollAttached = true;
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    function detach() {
      if (!scrollAttached) return;
      scrollAttached = false;
      window.removeEventListener('scroll', onScroll);
    }

    if (desktopMq.matches) attach();
    desktopMq.addEventListener('change', (e) => {
      if (e.matches) attach(); else detach();
    });

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
