---
interface Props {
  threshold?: number;
}

const { threshold = 300 } = Astro.props;
---

<button
  id="back-to-top"
  type="button"
  class="fixed bottom-6 z-40 hidden items-center justify-center w-9 h-9 rounded-full bg-yuval-accent text-yuval-accent-text shadow-lg hover:bg-yuval-accent-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yuval-highlight focus-visible:ring-offset-2 transition-all duration-300 opacity-0 translate-y-4"
  aria-label="Back to top"
  data-threshold={threshold}
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
  </svg>
</button>

<style>
  /* Lift the button above the platform status bar when one is mounted
     (reading pages). On pages without the bar the variable falls back
     to 0px and the button stays at the original Tailwind bottom-6 (24px).
     !important needed to win over Tailwind's `bottom-6` utility. */
  #back-to-top {
    bottom: calc(1.5rem + var(--platform-status-bar-height, 0px)) !important;
    transition: bottom 320ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Desktop-only: the unified mobile FAB + chapter-title tap gesture
     replace this button below 1024px. */
  @media (max-width: 1023px) {
    #back-to-top { display: none !important; }
  }

  /* Pin in the gap between the chapter sidebar and the reading
     content — just outside the sidebar's inline-end boundary, in
     the gutter that separates sidebar from text. 320px = sidebar
     width, 12px = gap from the sidebar edge.
     RTL: sits in the gap to the LEFT of the sidebar.
     LTR: sits in the gap to the RIGHT of the sidebar. */
  @media (min-width: 1024px) {
    #back-to-top {
      inset-inline-start: calc(320px + 6px);
      transition:
        inset-inline-start 380ms cubic-bezier(0.33, 1, 0.68, 1),
        bottom 320ms cubic-bezier(0.4, 0, 0.2, 1),
        opacity 300ms ease,
        transform 300ms ease,
        background-color 200ms ease;
    }

    /* Chapter sidebar collapsed → slide into the freed sidebar gutter
       so the button stays anchored to the screen edge instead of
       hovering mid-page. RTL: moves toward the right edge.
       LTR: moves toward the left edge. */
    body.sidebar-collapsed #back-to-top {
      inset-inline-start: 12px;
    }
  }
</style>

<script>
  const btn = document.getElementById('back-to-top') as HTMLButtonElement | null;
  if (btn) {
    const threshold = parseInt(btn.dataset.threshold || '300', 10);
    const desktopMq = window.matchMedia('(min-width: 1024px)');
    let ticking = false;
    let scrollAttached = false;

    function onScroll() {
      if (ticking || !btn) return;
      ticking = true;
      requestAnimationFrame(() => {
        const show = window.scrollY > threshold;
        btn.classList.toggle('hidden', !show);
        btn.classList.toggle('flex', show);
        btn.classList.toggle('opacity-0', !show);
        btn.classList.toggle('translate-y-4', !show);
        btn.classList.toggle('opacity-100', show);
        btn.classList.toggle('translate-y-0', show);
        ticking = false;
      });
    }

    function attach() {
      if (scrollAttached) return;
      scrollAttached = true;
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    function detach() {
      if (!scrollAttached) return;
      scrollAttached = false;
      window.removeEventListener('scroll', onScroll);
    }

    if (desktopMq.matches) attach();
    desktopMq.addEventListener('change', (e) => {
      if (e.matches) attach(); else detach();
    });

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
