---
import type { Language, Chapter } from '../types/index';

interface Props {
  currentChapterId: number;
  chapters: Chapter[];
  bookSlug: string;
  language?: Language;
  class?: string;
}

const {
  currentChapterId,
  chapters,
  bookSlug,
  language = 'en',
  class: className,
} = Astro.props;

const currentChapter = chapters.find((ch) => ch.id === currentChapterId);
const previousChapter = chapters.find((ch) => ch.id === currentChapterId - 1);
const nextChapter = chapters.find((ch) => ch.id === currentChapterId + 1);

const getPreviousUrl = () =>
  previousChapter ? `/read/${bookSlug}/${previousChapter.id}` : '';
const getNextUrl = () =>
  nextChapter ? `/read/${bookSlug}/${nextChapter.id}` : '';

const isRtl = language === 'he';
---

<nav
  class:list={[
    'flex',
    'flex-col',
    isRtl ? 'sm:flex-row-reverse' : 'sm:flex-row',
    'items-center',
    'justify-between',
    'gap-3',
    'sm:gap-4',
    'py-6',
    'border-t',
    'border-yuval-border-secondary',
    'mt-8',
    'sm:mt-12',
    className,
  ]}
  aria-label={language === 'he' ? 'ניווט פרקים' : 'Chapter navigation'}
>
  {
    previousChapter && (
      <a
        href={getPreviousUrl()}
        class="chapter-nav-link inline-flex items-center gap-2 px-3 py-2 sm:px-4 font-body text-xs sm:text-sm font-medium text-yuval-text hover:text-yuval-text-secondary transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yuval-highlight max-w-[45%] sm:max-w-none"
        data-base-url={getPreviousUrl()}
      >
        {isRtl ? (
          <>
            <span data-he={previousChapter.title_he} data-en={previousChapter.title_en}>{previousChapter.title_he}</span>
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width={2}
                d="M9 5l7 7-7 7"
              />
            </svg>
          </>
        ) : (
          <>
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width={2}
                d="M15 19l-7-7 7-7"
              />
            </svg>
            <span data-he={previousChapter.title_he} data-en={previousChapter.title_en}>{previousChapter.title_en}</span>
          </>
        )}
      </a>
    )
  }

  {
    currentChapter && (
      <div class="hidden sm:flex flex-col items-center gap-1">
        <span
          class="text-xs font-body text-yuval-text-tertiary uppercase tracking-wide"
          data-he={`פרק ${currentChapter.id + 1} מתוך ${chapters.length}`}
          data-en={`Chapter ${currentChapter.id + 1} of ${chapters.length}`}
        >
          Chapter {currentChapter.id + 1} of {chapters.length}
        </span>
        <h2
          class="text-center font-heading font-bold text-lg text-yuval-text"
          data-he={currentChapter.title_he}
          data-en={currentChapter.title_en}
        >
          {language === 'he' ? currentChapter.title_he : currentChapter.title_en}
        </h2>
      </div>
    )
  }

  {
    nextChapter && (
      <a
        href={getNextUrl()}
        class="chapter-nav-link inline-flex items-center gap-2 px-3 py-2 sm:px-4 font-body text-xs sm:text-sm font-medium text-yuval-text hover:text-yuval-text-secondary transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yuval-highlight max-w-[45%] sm:max-w-none"
        data-base-url={getNextUrl()}
      >
        {isRtl ? (
          <>
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width={2}
                d="M15 19l-7-7 7-7"
              />
            </svg>
            <span data-he={nextChapter.title_he} data-en={nextChapter.title_en}>{nextChapter.title_he}</span>
          </>
        ) : (
          <>
            <span data-he={nextChapter.title_he} data-en={nextChapter.title_en}>{nextChapter.title_en}</span>
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width={2}
                d="M9 5l7 7-7 7"
              />
            </svg>
          </>
        )}
      </a>
    )
  }
</nav>

<script>
  function updateNavLinks() {
    const lang = new URLSearchParams(window.location.search).get('lang')
      || localStorage.getItem('yuval_language') || 'en';
    document.querySelectorAll<HTMLAnchorElement>('.chapter-nav-link').forEach(link => {
      const base = link.dataset.baseUrl || '';
      if (!base) return;
      link.href = lang === 'he' ? `${base}?lang=he` : base;
    });
  }

  updateNavLinks();
  window.addEventListener('language-changed', updateNavLinks);
</script>
