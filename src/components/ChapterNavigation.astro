---
import type { Language, Chapter } from '../types/index';
import { getLanguageDirection } from '../utils/language';

interface Props {
  currentChapterId: number;
  chapters: Chapter[];
  bookSlug: string;
  language?: Language;
  class?: string;
}

const {
  currentChapterId,
  chapters,
  bookSlug,
  language = 'en',
  class: className,
} = Astro.props;

const currentChapter = chapters.find((ch) => ch.id === currentChapterId);
const previousChapter = chapters.find((ch) => ch.id === currentChapterId - 1);
const nextChapter = chapters.find((ch) => ch.id === currentChapterId + 1);

const getPreviousUrl = () =>
  previousChapter ? `/read/${bookSlug}/${previousChapter.id}` : '';

const getNextUrl = () =>
  nextChapter ? `/read/${bookSlug}/${nextChapter.id}` : '';

function getLocalizedText(
  map: Record<string, string> | undefined,
  lang: string
): string {
  if (!map) return '';
  return map[lang] ?? map['en'] ?? Object.values(map)[0] ?? '';
}

const isRtl = getLanguageDirection(language) === 'rtl';
---

<nav
  class:list={[
    'chapter-nav',
    'flex',
    'flex-col',
    isRtl ? 'sm:flex-row-reverse' : 'sm:flex-row',
    'items-center',
    'justify-between',
    'gap-3',
    'sm:gap-4',
    'py-6',
    'border-t',
    'border-yuval-border-secondary',
    'mt-8',
    'sm:mt-12',
    className,
  ]}
  id="chapter-nav"
  aria-label="chapter navigation"
>
  {
    previousChapter && (
      <a
        href={getPreviousUrl()}
        class="chapter-nav-link inline-flex items-center gap-2 px-3 py-2 sm:px-4 text-xs sm:text-sm font-medium max-w-[45%] sm:max-w-none"
        data-nav="prev"
        data-chapter-titles={JSON.stringify(previousChapter.titles)}
        data-prev-arrow={isRtl ? '→' : '←'}
        title={getLocalizedText(previousChapter.titles, language)}
        aria-label={getLocalizedText(previousChapter.titles, language)}
      >
        <span class="chapter-nav-arrow">{isRtl ? '→' : '←'}</span>
        <span class="chapter-nav-label">{getLocalizedText(previousChapter.titles, language)}</span>
      </a>
    )
  }

  {
    currentChapter && (
      <div class="hidden sm:flex flex-col items-center gap-1">
        <span class="text-xs text-yuval-text-tertiary">
          {currentChapterId + 1} / {chapters.length}
        </span>

        <h2
          class="text-center font-bold text-lg"
          data-nav="current"
          data-chapter-titles={JSON.stringify(currentChapter.titles)}
        >
          {getLocalizedText(currentChapter.titles, language)}
        </h2>
      </div>
    )
  }

  {
    nextChapter && (
      <a
        href={getNextUrl()}
        class="chapter-nav-link inline-flex items-center gap-2 px-3 py-2 sm:px-4 text-xs sm:text-sm font-medium max-w-[45%] sm:max-w-none"
        data-nav="next"
        data-chapter-titles={JSON.stringify(nextChapter.titles)}
        data-next-arrow={isRtl ? '←' : '→'}
        title={getLocalizedText(nextChapter.titles, language)}
        aria-label={getLocalizedText(nextChapter.titles, language)}
      >
        <span class="chapter-nav-label">{getLocalizedText(nextChapter.titles, language)}</span>
        <span class="chapter-nav-arrow">{isRtl ? '←' : '→'}</span>
      </a>
    )
  }
</nav>

<style>
  #chapter-nav {
    max-width: var(--reading-content-width, 720px);
    margin-left: auto;
    margin-right: auto;
  }

  .chapter-nav-link .chapter-nav-label {
    text-align: start;
  }
</style>