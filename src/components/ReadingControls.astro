---
// Reading Controls - FAB that expands to reveal: Focus Mode, Typography, Theme
// Mobile: typography opens as bottom sheet. Desktop: floating card.
---

<!-- ═══ FAB cluster ═══ -->
<div id="reading-fab" class="reading-fab" aria-label="Reading controls">

  <!-- Sub-actions (hidden by default, slide up when FAB is open) -->
  <div id="fab-actions" class="fab-actions" aria-hidden="true">

    <!-- Theme cycle -->
    <div class="fab-item">
      <span class="fab-label" data-i18n="fab.theme">Theme</span>
      <button id="theme-cycle-btn" class="fab-sub-btn" aria-label="Cycle theme" title="Theme">
        <svg class="theme-icon theme-icon-light w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="theme-icon theme-icon-sepia w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <svg class="theme-icon theme-icon-dark w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>

    <!-- Typography -->
    <div class="fab-item">
      <span class="fab-label" data-i18n="fab.typography">Typography</span>
      <button id="typography-btn" class="fab-sub-btn" aria-label="Typography settings" title="Typography (T)">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 6h16M4 12h8m-8 6h16" />
        </svg>
      </button>
    </div>

    <!-- Focus mode -->
    <div class="fab-item">
      <span class="fab-label" data-i18n="fab.focus">Focus</span>
      <button id="focus-mode-btn" class="fab-sub-btn" aria-label="Toggle focus mode" title="Focus Mode (F)">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
      </button>
    </div>

    <!-- Navigation (mobile only) -->
    <div class="fab-item fab-item-mobile-only">
      <span class="fab-label" data-i18n="fab.navigation">Navigation</span>
      <button id="fab-nav-btn" class="fab-sub-btn" aria-label="Open navigation" title="Navigation">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Highlights (mobile only) -->
    <div class="fab-item fab-item-mobile-only">
      <span class="fab-label" data-i18n="fab.highlights">Highlights</span>
      <button id="fab-highlights-btn" class="fab-sub-btn" aria-label="Open highlights" title="Highlights">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
        </svg>
      </button>
    </div>

    <!-- Read aloud (mobile only) -->
    <div class="fab-item fab-item-mobile-only">
      <span class="fab-label" data-i18n="tts.panelTitle">Read aloud</span>
      <button id="fab-tts-btn" class="fab-sub-btn" aria-label="Read aloud" title="Read aloud">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M11 5 6 9H2v6h4l5 4V5z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M15.54 8.46a5 5 0 0 1 0 7.07M19.07 4.93a10 10 0 0 1 0 14.14" />
        </svg>
      </button>
    </div>

  </div><!-- /fab-actions -->

  <!-- Main FAB toggle -->
  <button id="fab-toggle" class="fab-main" aria-expanded="false" aria-label="Reading controls" title="Reading controls" data-i18n-title="fab.reading">
    <!-- Sliders icon (closed state) -->
    <svg class="fab-icon-closed w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
        d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
    </svg>
    <!-- X icon (open state) -->
    <svg class="fab-icon-open w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

</div><!-- /reading-fab -->


<!-- ═══ Typography Panel ═══ -->
<div id="typography-panel" class="typography-panel" aria-hidden="true" aria-label="Typography settings">
  <!-- Mobile drag handle -->
  <div class="panel-handle" id="panel-drag-handle"></div>

  <div class="panel-header">
    <h3 data-i18n="display.settings">Display Settings</h3>
    <button id="close-typography" class="panel-close" aria-label="Close">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="panel-body">
    <!-- Font Size -->
    <div class="setting-row">
      <label data-i18n="display.textSize">Text Size</label>
      <div class="size-stepper">
        <button id="font-decrease" class="step-btn" aria-label="Decrease font size">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
          </svg>
        </button>
        <span id="font-size-display" class="step-value">18px</span>
        <button id="font-increase" class="step-btn" aria-label="Increase font size">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Line Height -->
    <div class="setting-row">
      <label data-i18n="display.lineHeight">Line Height</label>
      <div class="slider-wrap">
        <input type="range" id="line-height-slider" min="1.4" max="2.4" step="0.1" value="1.8" aria-label="Line height" />
        <span id="line-height-display" class="slider-value">1.8</span>
      </div>
    </div>

    <!-- Content Width -->
    <div class="setting-row">
      <label data-i18n="display.width">Width</label>
      <div class="seg-control">
        <button class="seg-btn" data-width="600" data-i18n="display.widthNarrow">Narrow</button>
        <button class="seg-btn active" data-width="720" data-i18n="display.widthMedium">Medium</button>
        <button class="seg-btn" data-width="900" data-i18n="display.widthWide">Wide</button>
      </div>
    </div>

    <!-- Font Family (Typography Mode) -->
    <div class="setting-row">
      <label data-i18n="display.font">Font</label>
      <div class="seg-control">
        <button class="seg-btn typography-mode-btn" data-mode="modern" type="button" aria-pressed="true" data-i18n="display.fontModern">Modern</button>
        <button class="seg-btn typography-mode-btn" data-mode="clean" type="button" aria-pressed="false" data-i18n="display.fontClean">Clean</button>
      </div>
    </div>
<script is:inline>
  // Typography mode toggle logic
  const STORAGE_KEY = 'typography-mode';
  function setTypographyMode(mode) {
    window.dispatchEvent(new CustomEvent('typography-mode-change', { detail: { mode } }));
  }
  function updateTypographyButtons(mode) {
    document.querySelectorAll('.typography-mode-btn').forEach(btn => {
      btn.setAttribute('aria-pressed', btn.dataset.mode === mode ? 'true' : 'false');
      btn.classList.toggle('active', btn.dataset.mode === mode);
    });
  }
  document.querySelectorAll('.typography-mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.mode;
      setTypographyMode(mode);
      updateTypographyButtons(mode);
      localStorage.setItem(STORAGE_KEY, mode);
    });
  });
  // On load: set active button
  const saved = localStorage.getItem(STORAGE_KEY);
  updateTypographyButtons(saved === 'clean' ? 'clean' : 'modern');
</script>

    <button id="reset-typography" class="reset-btn" data-i18n="display.reset">
      Reset defaults
    </button>
  </div>
</div>

<!-- Mobile backdrop -->
<div id="panel-backdrop" class="panel-backdrop"></div>

<!-- Focus indicator toast -->
<div id="focus-indicator" class="focus-toast hidden" aria-live="polite">
  <span data-i18n="focus.mode">Focus Mode</span>
  <kbd>F</kbd>
  <span data-i18n="focus.toExit">to exit</span>
</div>

<style>
  /* ══════════════════════════════════════
     FAB CLUSTER
  ══════════════════════════════════════ */
  .reading-fab {
    position: fixed;
    bottom: 32px;
    right: 28px;
    z-index: 45;
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 10px;
    opacity: 1;
    transition: opacity 300ms var(--ease-standard);
  }

  .reading-fab.scrolling {
    opacity: 0.15;
    pointer-events: none;
  }

  @media (min-width: 1024px) {
    .reading-fab {
      right: 348px;
    }
    [dir="rtl"] .reading-fab {
      right: auto;
      left: 348px;
    }
  }

  @media (max-width: 639px) {
    .reading-fab {
      bottom: 24px;
      right: 20px;
    }
    [dir="rtl"] .reading-fab {
      right: auto;
      left: 20px;
    }
  }

  [dir="rtl"] .reading-fab {
    right: auto;
    left: 28px;
  }

  [dir="rtl"] .fab-label {
    transform: translate(-8px, -50%);
  }

  [dir="rtl"] .fab-item:hover .fab-label {
    transform: translate(0, -50%);
  }

  /* Main FAB button */
  .fab-main {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--yuval-surface);
    border: 1px solid var(--yuval-border);
    color: var(--yuval-text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0,0,0,0.14), 0 1px 4px rgba(0,0,0,0.08);
    transition:
      transform 200ms var(--ease-standard),
      box-shadow 200ms var(--ease-standard),
      background 200ms var(--ease-standard);
    position: relative;
    z-index: 2;
  }

  .fab-main:hover {
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 8px 24px rgba(0,0,0,0.18), 0 2px 6px rgba(0,0,0,0.1);
    background: var(--yuval-bg-secondary);
    color: var(--yuval-text);
  }

  .fab-main[aria-expanded="true"] {
    background: var(--yuval-accent);
    color: var(--yuval-accent-text);
    border-color: var(--yuval-accent);
  }

  /* Icon swap */
  .fab-icon-open { display: none; }
  .fab-main[aria-expanded="true"] .fab-icon-closed { display: none; }
  .fab-main[aria-expanded="true"] .fab-icon-open { display: block; }

  /* Theme icons */
  .theme-icon { display: none; }
  .theme-icon-light { display: block; }
  :global(.dark) .theme-icon-light { display: none; }
  :global(.dark) .theme-icon-dark { display: block; }
  :global(.sepia) .theme-icon-light { display: none; }
  :global(.sepia) .theme-icon-sepia { display: block; }

  /* Sub-actions container */
  .fab-actions {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 8px;
    /* Hidden by default */
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px) scale(0.9);
    transition: opacity 200ms var(--ease-standard), transform 250ms var(--ease-emphasized);
  }

  .fab-actions.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  /* Each sub-action row */
  .fab-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
  }

  .fab-label {
    position: absolute;
    top: 50%;
    inset-inline-end: calc(100% + 10px);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--yuval-text-secondary);
    background: var(--yuval-surface);
    border: 1px solid var(--yuval-border);
    padding: 3px 10px;
    border-radius: 99px;
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    opacity: 0;
    transform: translate(8px, -50%);
    transition: opacity 150ms var(--ease-standard), transform 150ms var(--ease-standard);
    pointer-events: none;
  }

  .fab-item:hover .fab-label {
    opacity: 1;
    transform: translate(0, -50%);
  }

  /* Sub buttons */
  .fab-sub-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--yuval-surface);
    border: 1px solid var(--yuval-border);
    color: var(--yuval-text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transition: background 150ms var(--ease-standard), color 150ms var(--ease-standard), transform 150ms var(--ease-standard);
  }

  .fab-sub-btn:hover {
    background: var(--yuval-bg-secondary);
    color: var(--yuval-text);
    transform: scale(1.06);
  }

  .fab-sub-btn.active {
    background: var(--yuval-accent);
    color: var(--yuval-accent-text);
    border-color: transparent;
  }

  /* Stagger animation for sub-items */
  .fab-actions.open .fab-item:nth-child(1) { transition-delay: 0ms; }
  .fab-actions.open .fab-item:nth-child(2) { transition-delay: 40ms; }
  .fab-actions.open .fab-item:nth-child(3) { transition-delay: 80ms; }
  .fab-actions.open .fab-item:nth-child(4) { transition-delay: 120ms; }
  .fab-actions.open .fab-item:nth-child(5) { transition-delay: 160ms; }

  /* Mobile-only sub-items (Navigation): hidden on desktop */
  @media (min-width: 1024px) {
    .fab-item-mobile-only { display: none; }
  }

  /* ══════════════════════════════════════
     TYPOGRAPHY PANEL
  ══════════════════════════════════════ */
  .typography-panel {
    position: fixed;
    z-index: 60;
    background: var(--yuval-surface);
    border: 1px solid var(--yuval-border);
    border-radius: 16px 16px 16px 16px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.08);
    width: 300px;

    /* Desktop: floats near FAB */
    bottom: 96px;
    right: 28px;

    /* Hidden by default */
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px) scale(0.97);
    transform-origin: bottom right;
    transition: opacity 200ms var(--ease-standard), transform 320ms var(--ease-emphasized);
  }

  @media (min-width: 1024px) {
    .typography-panel {
      right: 348px;
    }
    [dir="rtl"] .typography-panel {
      right: auto;
      left: 348px;
      transform-origin: bottom left;
    }
  }

  [dir="rtl"] .typography-panel {
    right: auto;
    left: 28px;
    transform-origin: bottom left;
  }

  /* Mobile: bottom sheet */
  @media (max-width: 767px) {
    .typography-panel {
      width: 100%;
      left: 0;
      right: 0;
      bottom: 0;
      border-radius: 20px 20px 0 0;
      transform: translateY(100%);
      transform-origin: bottom center;
      max-height: 85vh;
      overflow-y: auto;
    }
  }

  .typography-panel.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  /* Drag handle (mobile only) */
  .panel-handle {
    display: none;
    width: 36px;
    height: 4px;
    background: var(--yuval-border-secondary);
    border-radius: 2px;
    margin: 12px auto 0;
  }

  @media (max-width: 767px) {
    .panel-handle { display: block; }
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px 12px;
    border-bottom: 1px solid var(--yuval-border);
  }

  .panel-header h3 {
    font-size: 13px;
    font-weight: 600;
    color: var(--yuval-text);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .panel-close {
    background: none;
    border: none;
    color: var(--yuval-text-tertiary);
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    line-height: 0;
    transition: color 0.15s, background 0.15s;
  }

  .panel-close:hover {
    color: var(--yuval-text);
    background: var(--yuval-bg-secondary);
  }

  .panel-body {
    padding: 16px 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  /* Setting rows */
  .setting-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .setting-row label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--yuval-text-muted);
  }

  /* Font size stepper */
  .size-stepper {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--yuval-bg-secondary);
    border: 1px solid var(--yuval-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .step-btn {
    flex: 1;
    padding: 9px;
    background: none;
    border: none;
    color: var(--yuval-text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
  }

  .step-btn:hover {
    background: var(--yuval-border);
    color: var(--yuval-text);
  }

  .step-value {
    font-size: 13px;
    font-weight: 600;
    color: var(--yuval-text);
    min-width: 44px;
    text-align: center;
    border-left: 1px solid var(--yuval-border);
    border-right: 1px solid var(--yuval-border);
    padding: 9px 4px;
  }

  /* Slider */
  .slider-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .slider-wrap input[type="range"] {
    flex: 1;
    accent-color: var(--yuval-accent);
    height: 4px;
    cursor: pointer;
  }

  .slider-value {
    font-size: 12px;
    font-weight: 600;
    color: var(--yuval-text);
    min-width: 28px;
    text-align: right;
  }

  /* Segmented control */
  .seg-control {
    display: flex;
    gap: 0;
    background: var(--yuval-bg-secondary);
    border: 1px solid var(--yuval-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .seg-btn {
    flex: 1;
    padding: 8px 4px;
    font-size: 12px;
    font-weight: 500;
    color: var(--yuval-text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    border-right: 1px solid var(--yuval-border);
  }

  .seg-btn:last-child { border-right: none; }

  .seg-btn.active,
  .seg-btn:hover {
    background: var(--yuval-accent);
    color: var(--yuval-accent-text);
  }

  /* Font select */
  select {
    width: 100%;
    padding: 9px 12px;
    border-radius: 10px;
    border: 1px solid var(--yuval-border);
    background: var(--yuval-bg-secondary);
    color: var(--yuval-text);
    font-size: 13px;
    cursor: pointer;
    appearance: auto;
  }

  .reset-btn {
    align-self: flex-start;
    padding: 0;
    background: none;
    border: none;
    color: var(--yuval-text-muted);
    font-size: 12px;
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    transition: color 0.15s;
  }

  .reset-btn:hover { color: var(--yuval-text-secondary); }

  /* ── Mobile backdrop ── */
  .panel-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 55;
    opacity: 0;
    transition: opacity 200ms var(--ease-standard);
  }

  .panel-backdrop.open {
    opacity: 1;
  }

  @media (max-width: 767px) {
    .panel-backdrop { display: block; pointer-events: none; }
    .panel-backdrop.open { pointer-events: auto; }
  }

  /* ── Focus toast ── */
  .focus-toast {
    position: fixed;
    top: 72px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.82);
    backdrop-filter: blur(8px);
    color: #fff;
    padding: 7px 16px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    z-index: 9999;
    animation: slideDown 250ms var(--ease-emphasized);
  }

  .focus-toast.hidden { display: none; }

  .focus-toast kbd {
    background: rgba(255,255,255,0.18);
    padding: 1px 7px;
    border-radius: 4px;
    font-family: monospace;
    font-size: 12px;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translate(-50%, -10px); }
    to   { opacity: 1; transform: translate(-50%, 0); }
  }
</style>

<script>
  /* ════════════════════════════════════════
     State
  ════════════════════════════════════════ */
  let fabOpen = false;
  let typoPanelOpen = false;
  let focusActive = false;
  const themes = ['light', 'sepia', 'dark'];

  /* ── Helpers ── */
  const $ = (id: string) => document.getElementById(id);

  function getCurrentTheme() {
    if (document.documentElement.classList.contains('dark'))  return 'dark';
    if (document.documentElement.classList.contains('sepia')) return 'sepia';
    return 'light';
  }

  function setTheme(t: string) {
    document.documentElement.classList.remove('dark', 'sepia');
    if (t !== 'light') document.documentElement.classList.add(t);
    localStorage.setItem('yuval-theme', t);
  }

  /* ── FAB toggle ── */
  function toggleFab(force?: boolean) {
    fabOpen = force !== undefined ? force : !fabOpen;
    const btn = $('fab-toggle');
    const actions = $('fab-actions');
    btn?.setAttribute('aria-expanded', String(fabOpen));
    actions?.classList.toggle('open', fabOpen);
    if (!fabOpen && typoPanelOpen) closeTypoPanel();
  }

  /* ── Typography panel ── */
  function openTypoPanel() {
    typoPanelOpen = true;
    const panel = $('typography-panel');
    const backdrop = $('panel-backdrop');
    panel?.classList.add('open');
    panel?.removeAttribute('aria-hidden');
    backdrop?.classList.add('open');
    $('typography-btn')?.classList.add('active');
  }

  function closeTypoPanel() {
    typoPanelOpen = false;
    const panel = $('typography-panel');
    const backdrop = $('panel-backdrop');
    panel?.classList.remove('open');
    panel?.setAttribute('aria-hidden', 'true');
    backdrop?.classList.remove('open');
    $('typography-btn')?.classList.remove('active');
  }

  function toggleTypoPanel() {
    typoPanelOpen ? closeTypoPanel() : openTypoPanel();
  }

  /* ── Focus mode ── */
  function toggleFocus() {
    focusActive = !focusActive;
    document.body.classList.toggle('focus-mode', focusActive);
    $('focus-mode-btn')?.classList.toggle('active', focusActive);

    const toast = $('focus-indicator');
    if (toast) {
      toast.classList.toggle('hidden', !focusActive);
      if (focusActive) setTimeout(() => toast.classList.add('hidden'), 3000);
    }
  }

  /* ── Typography settings ── */
  const DEFAULTS = { fontSize: 18, lineHeight: 1.8, contentWidth: 720 };

  function loadTypo() {
    try { return { ...DEFAULTS, ...JSON.parse(localStorage.getItem('yuval-typography') || '{}') }; }
    catch { return { ...DEFAULTS }; }
  }

  function saveTypo(s) {
    localStorage.setItem('yuval-typography', JSON.stringify(s));
  }

  function applyTypo(s) {
    const root = document.documentElement;
    root.style.setProperty('--reading-font-size', `${s.fontSize}px`);
    root.style.setProperty('--reading-line-height', String(s.lineHeight));
    root.style.setProperty('--reading-content-width', `${s.contentWidth}px`);
    // font-family is now handled by the typography mode system only

    const fsEl = $('font-size-display');    if (fsEl) fsEl.textContent = `${s.fontSize}px`;
    const lhEl = $('line-height-display');  if (lhEl) lhEl.textContent = s.lineHeight.toFixed(1);
    const slider = $('line-height-slider') as HTMLInputElement | null;
    if (slider) slider.value = String(s.lineHeight);

    document.querySelectorAll<HTMLButtonElement>('.seg-btn').forEach(btn => {
      btn.classList.toggle('active', parseInt(btn.dataset.width || '0') === s.contentWidth);
    });
  }

  /* ── Init ── */
  function init() {
    /* FAB toggle */
    $('fab-toggle')?.addEventListener('click', () => toggleFab());

    /* Sub-buttons */
    $('theme-cycle-btn')?.addEventListener('click', () => {
      const next = themes[(themes.indexOf(getCurrentTheme()) + 1) % themes.length];
      setTheme(next);
    });

    $('focus-mode-btn')?.addEventListener('click', toggleFocus);

    $('typography-btn')?.addEventListener('click', () => {
      toggleTypoPanel();
    });

    /* Navigation (mobile-only): delegate to the hidden drawer toggle */
    $('fab-nav-btn')?.addEventListener('click', () => {
      toggleFab(false);
      $('mobile-toc-toggle')?.click();
    });

    /* Highlights (mobile-only): delegate to the hidden highlights FAB */
    $('fab-highlights-btn')?.addEventListener('click', () => {
      toggleFab(false);
      $('highlights-fab')?.click();
    });

    /* Read aloud (mobile-only): open the TTS panel via global hook */
    $('fab-tts-btn')?.addEventListener('click', () => {
      toggleFab(false);
      const open = (window as unknown as { __ttsOpenPanel?: () => void }).__ttsOpenPanel;
      if (typeof open === 'function') open();
      else (window as unknown as { __ttsToggle?: () => void }).__ttsToggle?.();
    });

    /* Close panel */
    $('close-typography')?.addEventListener('click', closeTypoPanel);
    $('panel-backdrop')?.addEventListener('click', closeTypoPanel);

    /* Close FAB on outside click */
    document.addEventListener('click', (e) => {
      const fab = $('reading-fab');
      const panel = $('typography-panel');
      if (!fab?.contains(e.target as Node) && !panel?.contains(e.target as Node)) {
        toggleFab(false);
      }
    }, { capture: true });

    /* Typography controls */
    applyTypo(loadTypo());

    $('font-decrease')?.addEventListener('click', () => {
      const s = loadTypo(); s.fontSize = Math.max(14, s.fontSize - 2);
      saveTypo(s); applyTypo(s);
    });

    $('font-increase')?.addEventListener('click', () => {
      const s = loadTypo(); s.fontSize = Math.min(28, s.fontSize + 2);
      saveTypo(s); applyTypo(s);
    });

    $('line-height-slider')?.addEventListener('input', (e) => {
      const s = loadTypo(); s.lineHeight = parseFloat((e.target as HTMLInputElement).value);
      saveTypo(s); applyTypo(s);
    });

    document.querySelectorAll<HTMLButtonElement>('.seg-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = loadTypo(); s.contentWidth = parseInt(btn.dataset.width || '720');
        saveTypo(s); applyTypo(s);
      });
    });



    $('reset-typography')?.addEventListener('click', () => {
      saveTypo(DEFAULTS); applyTypo(DEFAULTS);
    });

    /* Keyboard shortcuts */
    document.addEventListener('keydown', (e) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement || e.target instanceof HTMLSelectElement) return;
      if (e.key.toLowerCase() === 'f') { e.preventDefault(); toggleFocus(); }
      if (e.key.toLowerCase() === 't') { e.preventDefault(); if (!typoPanelOpen) { toggleFab(true); } toggleTypoPanel(); }
      if (e.key === 'Escape') { closeTypoPanel(); toggleFab(false); if (focusActive) toggleFocus(); }
    });

    /* Hide FAB while scrolling */
    let scrollTimeout: ReturnType<typeof setTimeout>;
    const fab = $('reading-fab');
    window.addEventListener('scroll', () => {
      if (fab && !fabOpen) {
        fab.classList.add('scrolling');
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(() => {
          fab.classList.remove('scrolling');
        }, 800);
      }
    }, { passive: true });

    /* Restore saved theme */
    const saved = localStorage.getItem('yuval-theme');
    if (saved === 'sepia' || saved === 'dark') setTheme(saved);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:after-swap', init);
</script>
