---
// Reading Controls - FAB that expands to reveal: Focus Mode, Typography, Theme
// Mobile: typography opens as bottom sheet. Desktop: floating card.
---

<!-- ═══ FAB cluster ═══ -->
<div id="reading-fab" class="reading-fab" aria-label="Reading controls">

  <!-- Sub-actions (hidden by default, slide up when FAB is open) -->
  <div id="fab-actions" class="fab-actions" aria-hidden="true">

    <!-- Theme cycle -->
    <div class="fab-item">
      <span class="fab-label" data-i18n="fab.theme">Theme</span>
      <button id="theme-cycle-btn" class="fab-sub-btn" aria-label="Cycle theme" data-i18n-title="fab.theme">
        <svg class="theme-icon theme-icon-light w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="theme-icon theme-icon-sepia w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <svg class="theme-icon theme-icon-dark w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>

    <!-- Typography -->
    <div class="fab-item">
      <span class="fab-label" data-i18n="fab.typography">Typography</span>
      <button id="typography-btn" class="fab-sub-btn" aria-label="Typography settings" data-i18n-title="fab.typography">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 6h16M4 12h8m-8 6h16" />
        </svg>
      </button>
    </div>

    <!-- Focus mode -->
    <div class="fab-item">
      <span class="fab-label" data-i18n="fab.focus">Focus</span>
      <button id="focus-mode-btn" class="fab-sub-btn" aria-label="Toggle focus mode" data-i18n-title="fab.focus">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
      </button>
    </div>

    <!-- Navigation -->
    <div class="fab-item">
      <span class="fab-label" data-i18n="fab.navigation">Navigation</span>
      <button id="fab-nav-btn" class="fab-sub-btn" aria-label="Open navigation" data-i18n-title="fab.navigation">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Highlights -->
    <div class="fab-item">
      <span class="fab-label" data-i18n="fab.highlights">Highlights</span>
      <button id="fab-highlights-btn" class="fab-sub-btn" aria-label="Open highlights" data-i18n-title="fab.highlights">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
        </svg>
      </button>
    </div>

    <!-- Bookmarks -->
    <div class="fab-item">
      <span class="fab-label" data-i18n="bookmarks.title">Bookmarks</span>
      <button id="fab-bookmarks-btn" class="fab-sub-btn" aria-label="Open bookmarks" data-i18n-title="bookmarks.title">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
        </svg>
      </button>
    </div>

    <!-- Read aloud -->
    <div class="fab-item">
      <span class="fab-label" data-i18n="tts.panelTitle">Read aloud</span>
      <button id="fab-tts-btn" class="fab-sub-btn" aria-label="Read aloud" data-i18n-title="fab.readAloud">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M11 5 6 9H2v6h4l5 4V5z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
            d="M15.54 8.46a5 5 0 0 1 0 7.07M19.07 4.93a10 10 0 0 1 0 14.14" />
        </svg>
      </button>
    </div>

  </div><!-- /fab-actions -->

  <!-- Main FAB toggle -->
  <button id="fab-toggle" class="fab-main" aria-expanded="false" aria-label="Reading controls" data-i18n-title="fab.reading">
    <!-- Sliders icon (closed state) -->
    <svg class="fab-icon-closed w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
        d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
    </svg>
    <!-- X icon (open state) -->
    <svg class="fab-icon-open w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

</div><!-- /reading-fab -->


<!-- ═══ Typography Panel ═══ -->
<div id="typography-panel" class="typography-panel" aria-hidden="true" aria-label="Typography settings">
  <!-- Mobile drag handle -->
  <div class="panel-handle" id="panel-drag-handle"></div>

  <div class="panel-header">
    <h3 data-i18n="display.settings">Display Settings</h3>
    <button id="close-typography" class="panel-close" aria-label="Close">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="panel-body">
    <!-- Font Size -->
    <div class="setting-row">
      <span class="setting-label" data-i18n="display.textSize">Text Size</span>
      <div class="size-stepper">
        <button id="font-decrease" class="step-btn" aria-label="Decrease font size">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
          </svg>
        </button>
        <span id="font-size-display" class="step-value">18px</span>
        <button id="font-increase" class="step-btn" aria-label="Increase font size">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Line Height -->
    <div class="setting-row">
      <label class="setting-label" for="line-height-slider" data-i18n="display.lineHeight">Line Height</label>
      <div class="slider-wrap">
        <input type="range" id="line-height-slider" min="1.4" max="2.4" step="0.1" value="1.8" aria-label="Line height" />
        <span id="line-height-display" class="slider-value">1.8</span>
      </div>
    </div>

    <!-- Content Width -->
    <div class="setting-row">
      <span class="setting-label" data-i18n="display.width">Width</span>
      <div class="seg-control">
        <button class="seg-btn" data-width="600" data-i18n="display.widthNarrow">Narrow</button>
        <button class="seg-btn active" data-width="720" data-i18n="display.widthMedium">Medium</button>
        <button class="seg-btn" data-width="900" data-i18n="display.widthWide">Wide</button>
      </div>
    </div>

    <!-- Font Family (Typography Mode) -->
    <div class="setting-row">
      <span class="setting-label" data-i18n="display.font">Font</span>
      <div class="seg-control">
        <button class="seg-btn typography-mode-btn" data-mode="modern" type="button" aria-pressed="true" data-i18n="display.fontModern">Modern</button>
        <button class="seg-btn typography-mode-btn" data-mode="clean" type="button" aria-pressed="false" data-i18n="display.fontClean">Clean</button>
      </div>
    </div>
<script is:inline>
  // Typography mode toggle logic
  const STORAGE_KEY = 'typography-mode';
  function setTypographyMode(mode) {
    window.dispatchEvent(new CustomEvent('typography-mode-change', { detail: { mode } }));
  }
  function updateTypographyButtons(mode) {
    document.querySelectorAll('.typography-mode-btn').forEach(btn => {
      btn.setAttribute('aria-pressed', btn.dataset.mode === mode ? 'true' : 'false');
      btn.classList.toggle('active', btn.dataset.mode === mode);
    });
  }
  document.querySelectorAll('.typography-mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.mode;
      setTypographyMode(mode);
      updateTypographyButtons(mode);
      localStorage.setItem(STORAGE_KEY, mode);
    });
  });
  // On load: set active button
  const saved = localStorage.getItem(STORAGE_KEY);
  updateTypographyButtons(saved === 'clean' ? 'clean' : 'modern');
</script>

    <button id="reset-typography" class="reset-btn" data-i18n="display.reset">
      Reset defaults
    </button>
  </div>
</div>

<!-- Mobile backdrop -->
<div id="panel-backdrop" class="panel-backdrop"></div>

<!-- Focus indicator toast -->
<div id="focus-indicator" class="focus-toast hidden" aria-live="polite">
  <span data-i18n="focus.mode">Focus Mode</span>
  <kbd>F</kbd>
  <span data-i18n="focus.toExit">to exit</span>
</div>

<!-- Return-both pill: rises from the bottom edge of the screen when
     BOTH sidebars are collapsed, and slides back below the fold once
     they're restored. The "handle bar" above the pill mimics a drawer
     grab, hinting that the pill itself can be "pulled up" to restore.
     Pure CSS visibility — keyed to body classes set by sidebar-collapse.
     Click handler is the same `.sidebar-focus-btn` delegate. -->
<button
  type="button"
  id="return-both-pill"
  class="return-both-pill sidebar-focus-btn"
  aria-label="Restore panels"
  data-i18n-aria-label="reading.restorePanels"
  title="Restore panels"
  data-i18n-title="reading.restorePanels"
>
  <span class="return-both-handle" aria-hidden="true"></span>
  <span class="return-both-glow" aria-hidden="true"></span>
  <svg class="return-both-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
    <!-- Two arrows pointing outward — restore / expand. Mirror of
         the inward focus icon. -->
    <path d="M9 7 L4 12 L9 17" stroke="currentColor" stroke-width="2"
          fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M15 7 L20 12 L15 17" stroke="currentColor" stroke-width="2"
          fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <span class="return-both-label" data-i18n="reading.restorePanels">החזר תפריטים</span>
</button>

<style>
  /* ══════════════════════════════════════
     FAB CLUSTER
  ══════════════════════════════════════ */
  .reading-fab {
    position: fixed;
    /* Lift well above the platform status bar so NO FAB in the stack
     — including the topmost when the panel is open — is ever hidden
       behind the bar. Generous 72px clearance above the bar; falls
       back to 56px (the bar's default height) so the math holds even
       if the CSS var hasn't been set yet. */
    bottom: calc(72px + var(--platform-status-bar-height, 56px));
    right: 28px;
    z-index: 45;
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 10px;
    opacity: 1;
    transition: opacity 300ms var(--ease-standard);
  }

  .reading-fab.scrolling {
    opacity: 0.15;
    pointer-events: none;
  }

  @media (min-width: 1024px) {
    .reading-fab {
      right: 323px;
    }
    [dir="rtl"] .reading-fab {
      right: auto;
      left: 323px;
    }
  }

  @media (max-width: 639px) {
    .reading-fab {
      /* Same lift logic as desktop — generous clearance above the
         (mobile-height) status bar so no FAB ever sits behind it. */
      bottom: calc(56px + var(--platform-status-bar-height, 48px));
      right: 20px;
    }
    [dir="rtl"] .reading-fab {
      right: auto;
      left: 20px;
    }
  }

  [dir="rtl"] .reading-fab {
    right: auto;
    left: 28px;
  }

  /* When the chapter sidebar (`body.sidebar-collapsed`) is hidden,
     slide the reading FAB toward the freed sidebar gutter so it stays
     anchored to the screen edge instead of floating mid-page. Smooth
     glide matches the sidebar's own collapse animation cadence. */
  @media (min-width: 1024px) {
    .reading-fab {
      transition:
        opacity 300ms var(--ease-standard),
        right 380ms cubic-bezier(0.33, 1, 0.68, 1),
        left 380ms cubic-bezier(0.33, 1, 0.68, 1);
    }

    body.sidebar-collapsed .reading-fab {
      right: 28px;
      left: auto;
    }
    [dir="rtl"] body.sidebar-collapsed .reading-fab,
    body.sidebar-collapsed [dir="rtl"] .reading-fab {
      left: auto;
      right: 28px;
    }
  }

  [dir="rtl"] .fab-label {
    transform: translate(-8px, -50%);
  }

  [dir="rtl"] .fab-item:hover .fab-label {
    transform: translate(0, -50%);
  }

  /* Main FAB button */
  .fab-main {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--yuval-surface);
    border: 1px solid var(--yuval-border);
    color: var(--yuval-text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0,0,0,0.14), 0 1px 4px rgba(0,0,0,0.08);
    transition:
      transform 200ms var(--ease-standard),
      box-shadow 200ms var(--ease-standard),
      background 200ms var(--ease-standard);
    position: relative;
    z-index: 2;
  }

  .fab-main:hover {
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 8px 24px rgba(0,0,0,0.18), 0 2px 6px rgba(0,0,0,0.1);
    background: var(--yuval-bg-secondary);
    color: var(--yuval-text);
  }

  .fab-main[aria-expanded="true"] {
    background: var(--yuval-accent);
    color: var(--yuval-accent-text);
    border-color: var(--yuval-accent);
  }

  /* Icon swap */
  .fab-icon-open { display: none; }
  .fab-main[aria-expanded="true"] .fab-icon-closed { display: none; }
  .fab-main[aria-expanded="true"] .fab-icon-open { display: block; }

 
  @media (min-width: 1024px) {
    .fab-main {
      width: 42px;
      height: 42px;
    }
    .fab-icon-closed,
    .fab-icon-open {
      width: 1rem;
      height: 1rem;
    }
  }

  /* Theme icons */
  .theme-icon { display: none; }
  .theme-icon-light { display: block; }
  :global(.dark) .theme-icon-light { display: none; }
  :global(.dark) .theme-icon-dark { display: block; }
  :global(.sepia) .theme-icon-light { display: none; }
  :global(.sepia) .theme-icon-sepia { display: block; }

  /* Sub-actions container */
  .fab-actions {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 8px;
    /* Hidden by default */
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px) scale(0.9);
    transition: opacity 200ms var(--ease-standard), transform 250ms var(--ease-emphasized);
  }

  .fab-actions.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  /* Each sub-action row */
  .fab-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
  }

  /* Custom CSS-styled hover label, hidden — the buttons now rely on
     the browser's native tooltip driven by data-i18n-title. The span
     stays in the DOM (with its data-i18n="…" key) so accessibility
     consumers + future re-enable both keep working. */
  .fab-label {
    display: none;
    position: absolute;
    top: 50%;
    inset-inline-end: calc(100% + 10px);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--yuval-text-secondary);
    background: var(--yuval-surface);
    border: 1px solid var(--yuval-border);
    padding: 3px 10px;
    border-radius: 99px;
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    opacity: 0;
    transform: translate(8px, -50%);
    transition: opacity 150ms var(--ease-standard), transform 150ms var(--ease-standard);
    pointer-events: none;
  }

  .fab-item:hover .fab-label {
    opacity: 1;
    transform: translate(0, -50%);
  }

  /* Sub buttons */
  .fab-sub-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--yuval-surface);
    border: 1px solid var(--yuval-border);
    color: var(--yuval-text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transition: background 150ms var(--ease-standard), color 150ms var(--ease-standard), transform 150ms var(--ease-standard);
  }

  .fab-sub-btn:hover {
    background: var(--yuval-bg-secondary);
    color: var(--yuval-text);
    transform: scale(1.06);
  }

  .fab-sub-btn.active {
    background: var(--yuval-accent);
    color: var(--yuval-accent-text);
    border-color: transparent;
  }

  /* Stagger animation for sub-items */
  .fab-actions.open .fab-item:nth-child(1) { transition-delay: 0ms; }
  .fab-actions.open .fab-item:nth-child(2) { transition-delay: 35ms; }
  .fab-actions.open .fab-item:nth-child(3) { transition-delay: 70ms; }
  .fab-actions.open .fab-item:nth-child(4) { transition-delay: 105ms; }
  .fab-actions.open .fab-item:nth-child(5) { transition-delay: 140ms; }
  .fab-actions.open .fab-item:nth-child(6) { transition-delay: 175ms; }
  .fab-actions.open .fab-item:nth-child(7) { transition-delay: 210ms; }

  /* Mobile-only sub-items (Navigation): hidden on desktop */
  @media (min-width: 1024px) {
    .fab-item-mobile-only { display: none; }
  }

  /* ══════════════════════════════════════
     TYPOGRAPHY PANEL
  ══════════════════════════════════════ */
  .typography-panel {
    position: fixed;
    z-index: 60;
    background: var(--yuval-surface);
    border: 1px solid var(--yuval-border);
    border-radius: 16px 16px 16px 16px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.08);
    width: 300px;

    /* Desktop: floats near FAB */
    bottom: 96px;
    right: 28px;

    /* Hidden by default */
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px) scale(0.97);
    transform-origin: bottom right;
    transition: opacity 200ms var(--ease-standard), transform 320ms var(--ease-emphasized);
  }

  @media (min-width: 1024px) {
    .typography-panel {
      right: 348px;
    }
    [dir="rtl"] .typography-panel {
      right: auto;
      left: 348px;
      transform-origin: bottom left;
    }
  }

  [dir="rtl"] .typography-panel {
    right: auto;
    left: 28px;
    transform-origin: bottom left;
  }

  /* Mobile: bottom sheet */
  @media (max-width: 767px) {
    .typography-panel {
      width: 100%;
      left: 0;
      right: 0;
      bottom: 0;
      border-radius: 20px 20px 0 0;
      transform: translateY(100%);
      transform-origin: bottom center;
      max-height: 85vh;
      overflow-y: auto;
    }
  }

  .typography-panel.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  /* Drag handle (mobile only) */
  .panel-handle {
    display: none;
    width: 36px;
    height: 4px;
    background: var(--yuval-border-secondary);
    border-radius: 2px;
    margin: 12px auto 0;
  }

  @media (max-width: 767px) {
    .panel-handle { display: block; }
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px 12px;
    border-bottom: 1px solid var(--yuval-border);
  }

  .panel-header h3 {
    font-size: 13px;
    font-weight: 600;
    color: var(--yuval-text);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .panel-close {
    background: none;
    border: none;
    color: var(--yuval-text-tertiary);
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    line-height: 0;
    transition: color 0.15s, background 0.15s;
  }

  .panel-close:hover {
    color: var(--yuval-text);
    background: var(--yuval-bg-secondary);
  }

  .panel-body {
    padding: 16px 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  /* Setting rows */
  .setting-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .setting-row label,
  .setting-row .setting-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--yuval-text-muted);
  }

  /* Font size stepper */
  .size-stepper {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--yuval-bg-secondary);
    border: 1px solid var(--yuval-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .step-btn {
    flex: 1;
    padding: 9px;
    background: none;
    border: none;
    color: var(--yuval-text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
  }

  .step-btn:hover {
    background: var(--yuval-border);
    color: var(--yuval-text);
  }

  .step-value {
    font-size: 13px;
    font-weight: 600;
    color: var(--yuval-text);
    min-width: 44px;
    text-align: center;
    border-left: 1px solid var(--yuval-border);
    border-right: 1px solid var(--yuval-border);
    padding: 9px 4px;
  }

  /* Slider */
  .slider-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .slider-wrap input[type="range"] {
    flex: 1;
    accent-color: var(--yuval-accent);
    height: 4px;
    cursor: pointer;
  }

  .slider-value {
    font-size: 12px;
    font-weight: 600;
    color: var(--yuval-text);
    min-width: 28px;
    text-align: right;
  }

  /* Segmented control */
  .seg-control {
    display: flex;
    gap: 0;
    background: var(--yuval-bg-secondary);
    border: 1px solid var(--yuval-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .seg-btn {
    flex: 1;
    padding: 8px 4px;
    font-size: 12px;
    font-weight: 500;
    color: var(--yuval-text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    border-right: 1px solid var(--yuval-border);
  }

  .seg-btn:last-child { border-right: none; }

  .seg-btn.active,
  .seg-btn:hover {
    background: var(--yuval-accent);
    color: var(--yuval-accent-text);
  }

  /* Font select */
  select {
    width: 100%;
    padding: 9px 12px;
    border-radius: 10px;
    border: 1px solid var(--yuval-border);
    background: var(--yuval-bg-secondary);
    color: var(--yuval-text);
    font-size: 13px;
    cursor: pointer;
    appearance: auto;
  }

  .reset-btn {
    align-self: flex-start;
    padding: 0;
    background: none;
    border: none;
    color: var(--yuval-text-muted);
    font-size: 12px;
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    transition: color 0.15s;
  }

  .reset-btn:hover { color: var(--yuval-text-secondary); }

  /* ── Mobile backdrop ── */
  .panel-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 55;
    opacity: 0;
    transition: opacity 200ms var(--ease-standard);
  }

  .panel-backdrop.open {
    opacity: 1;
  }

  @media (max-width: 767px) {
    .panel-backdrop { display: block; pointer-events: none; }
    .panel-backdrop.open { pointer-events: auto; }
  }

  /* ── Focus toast ── */
  .focus-toast {
    position: fixed;
    top: 72px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.82);
    backdrop-filter: blur(8px);
    color: #fff;
    padding: 7px 16px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    z-index: 9999;
    animation: slideDown 250ms var(--ease-emphasized);
  }

  .focus-toast.hidden { display: none; }

  .focus-toast kbd {
    background: rgba(255,255,255,0.18);
    padding: 1px 7px;
    border-radius: 4px;
    font-family: monospace;
    font-size: 12px;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translate(-50%, -10px); }
    to   { opacity: 1; transform: translate(-50%, 0); }
  }

  /* ══════════════════════════════════════
     RETURN-BOTH PILL
     A drawer-handle-shaped affordance that lives just below the
     fold while both sidebars are visible, and rises into view at
     bottom-center the moment the user collapses both. Click =
     restore both. The "handle bar" up top is the visual hint —
     reads as a grab handle on a drawer you can pull up.
  ══════════════════════════════════════ */
  .return-both-pill {
    position: fixed;
    bottom: 22px;
    left: 50%;
    transform: translate(-50%, calc(100% + 40px));
    z-index: 60;
    appearance: none;
    border: 1px solid rgba(184, 146, 63, 0.50);
    background: linear-gradient(
      180deg,
      rgba(40, 30, 14, 0.92) 0%,
      rgba(28, 22, 10, 0.88) 100%
    );
    backdrop-filter: blur(14px) saturate(150%);
    -webkit-backdrop-filter: blur(14px) saturate(150%);
    color: #e6c98a;
    /* Asymmetric inline padding: tighter on the icon side, more
       breathing room on the label side. Logical properties so RTL
       (icon naturally on the right) gets the same effect for free. */
    padding-block: 10px;
    padding-inline-start: 18px;
    padding-inline-end: 22px;
    border-radius: 999px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    opacity: 0;
    pointer-events: none;
    box-shadow:
      0 12px 30px -8px rgba(0, 0, 0, 0.55),
      0 4px 12px -4px rgba(212, 175, 55, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    transition:
      opacity 380ms ease,
      transform 520ms cubic-bezier(0.22, 1, 0.36, 1),
      background 220ms ease,
      border-color 220ms ease,
      box-shadow 220ms ease;
  }

  /* Reveal: slide up into view + soft initial pulse to catch the eye
     for the first beat after both sidebars collapse. */
  body.sidebar-collapsed.left-sidebar-collapsed .return-both-pill {
    opacity: 1;
    transform: translate(-50%, 0);
    pointer-events: auto;
    animation: return-pill-pulse 2.4s ease-in-out 0.6s 2;
  }

  @keyframes return-pill-pulse {
    0%, 100% {
      box-shadow:
        0 12px 30px -8px rgba(0, 0, 0, 0.55),
        0 4px 12px -4px rgba(212, 175, 55, 0.25),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }
    50% {
      box-shadow:
        0 14px 36px -8px rgba(0, 0, 0, 0.55),
        0 8px 22px -2px rgba(212, 175, 55, 0.55),
        inset 0 1px 0 rgba(255, 255, 255, 0.12);
    }
  }

  .return-both-pill:hover {
    background: linear-gradient(
      180deg,
      rgba(50, 38, 18, 0.94) 0%,
      rgba(36, 28, 12, 0.92) 100%
    );
    border-color: rgba(212, 175, 55, 0.78);
    color: #ffffff;
    box-shadow:
      0 16px 36px -8px rgba(0, 0, 0, 0.60),
      0 8px 22px -4px rgba(212, 175, 55, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
  }

  body.sidebar-collapsed.left-sidebar-collapsed .return-both-pill:hover {
    transform: translate(-50%, -2px);
    /* Stop the attention-pulse the moment the user has clearly
       found the pill (mouse is on it). */
    animation: none;
  }

  .return-both-pill:active {
    transform: translate(-50%, 0) scale(0.97);
  }

  .return-both-pill:focus-visible {
    outline: 2px solid rgba(212, 175, 55, 0.8);
    outline-offset: 3px;
  }

  /* Drawer-handle bar above the pill — pure visual affordance.
     Sits centered, 36px wide, breathing softly so the eye lands
     on it before the label registers. */
  .return-both-handle {
    position: absolute;
    top: -7px;
    left: 50%;
    transform: translateX(-50%);
    width: 36px;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      rgba(212, 175, 55, 0.0) 0%,
      rgba(212, 175, 55, 0.85) 50%,
      rgba(212, 175, 55, 0.0) 100%
    );
    pointer-events: none;
    animation: return-handle-breathe 2.6s ease-in-out infinite;
  }

  @keyframes return-handle-breathe {
    0%, 100% { opacity: 0.55; width: 32px; }
    50%      { opacity: 1.0;  width: 44px; }
  }

  /* Soft halo behind the pill — same gold key, larger blur, very
     low opacity. Adds depth without adding visual weight. */
  .return-both-glow {
    position: absolute;
    inset: -8px -16px;
    border-radius: 999px;
    background: radial-gradient(
      ellipse at center,
      rgba(212, 175, 55, 0.25) 0%,
      rgba(212, 175, 55, 0) 70%
    );
    pointer-events: none;
    z-index: -1;
    opacity: 0.7;
  }

  .return-both-icon {
    flex-shrink: 0;
  }

  .return-both-label {
    white-space: nowrap;
  }

  /* Light-mode palette: cream surface, dark gold ink. */
  :global(:root:not(.dark)) .return-both-pill {
    background: linear-gradient(
      180deg,
      rgba(255, 248, 232, 0.95) 0%,
      rgba(248, 240, 220, 0.92) 100%
    );
    border-color: rgba(184, 146, 63, 0.55);
    color: #6d5320;
    box-shadow:
      0 12px 30px -8px rgba(80, 60, 20, 0.30),
      0 4px 12px -4px rgba(184, 146, 63, 0.30),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }

  :global(:root:not(.dark)) .return-both-pill:hover {
    background: linear-gradient(
      180deg,
      rgba(255, 250, 235, 0.98) 0%,
      rgba(250, 240, 215, 0.96) 100%
    );
    border-color: rgba(184, 146, 63, 0.85);
    color: #2c2410;
  }

  /* Mobile: hide the return pill — sidebars are off-canvas drawers
     there with their own restore mechanics. */
  @media (max-width: 1023px) {
    .return-both-pill { display: none !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .return-both-pill,
    .return-both-handle {
      transition-duration: 0ms !important;
      animation: none !important;
    }
  }
</style>

<script>
  import { rightSidebar, leftSidebar } from '../scripts/sidebar-collapse';

  /* ════════════════════════════════════════
     State
  ════════════════════════════════════════ */
  let fabOpen = false;
  let typoPanelOpen = false;
  let focusActive = false;
  const themes = ['light', 'sepia', 'dark'];

  /* ── Helpers ── */
  const $ = (id: string) => document.getElementById(id);

  function getCurrentTheme() {
    if (document.documentElement.classList.contains('dark'))  return 'dark';
    if (document.documentElement.classList.contains('sepia')) return 'sepia';
    return 'light';
  }

  function setTheme(t: string) {
    document.documentElement.classList.remove('dark', 'sepia');
    if (t !== 'light') document.documentElement.classList.add(t);
    localStorage.setItem('yuval-theme', t);
  }

  /* ── FAB toggle ── */
  function toggleFab(force?: boolean) {
    fabOpen = force !== undefined ? force : !fabOpen;
    const btn = $('fab-toggle');
    const actions = $('fab-actions');
    btn?.setAttribute('aria-expanded', String(fabOpen));
    actions?.classList.toggle('open', fabOpen);
    if (!fabOpen && typoPanelOpen) closeTypoPanel();
  }

  /* ── Typography panel ── */
  function openTypoPanel() {
    typoPanelOpen = true;
    const panel = $('typography-panel');
    const backdrop = $('panel-backdrop');
    panel?.classList.add('open');
    panel?.removeAttribute('aria-hidden');
    backdrop?.classList.add('open');
    $('typography-btn')?.classList.add('active');
  }

  function closeTypoPanel() {
    typoPanelOpen = false;
    const panel = $('typography-panel');
    const backdrop = $('panel-backdrop');
    panel?.classList.remove('open');
    panel?.setAttribute('aria-hidden', 'true');
    backdrop?.classList.remove('open');
    $('typography-btn')?.classList.remove('active');
  }

  function toggleTypoPanel() {
    typoPanelOpen ? closeTypoPanel() : openTypoPanel();
  }

  /* ── Focus mode ──
     Two distinct toggles share the "Focus" label but do different
     things — the in-sidebar gold buttons collapse BOTH sidebars only
     (the cleanest distraction-free reading), while the FAB Focus
     button additionally activates body.focus-mode (dims chrome,
     centers the article). Keeping them separate so the in-sidebar
     toggle doesn't override the user's typography settings. */
  function bothSidebarsCollapsed(): boolean {
    return document.body.classList.contains('sidebar-collapsed') &&
           document.body.classList.contains('left-sidebar-collapsed');
  }

  function syncFocusButtons() {
    const sidebarsHidden = bothSidebarsCollapsed();
    $('focus-mode-btn')?.classList.toggle('active', focusActive);
    document.querySelectorAll('.sidebar-focus-btn').forEach((b) => {
      b.classList.toggle('active', sidebarsHidden);
      b.setAttribute('aria-pressed', String(sidebarsHidden));
    });
  }

  /* Sidebar-only focus: collapses (or restores) both sidebars in
     lockstep. Does NOT touch body.focus-mode — pure sidebar action,
     mirroring what the original top-center button did. */
  function toggleSidebars() {
    if (!window.matchMedia('(min-width: 1024px)').matches) return;
    const next = !bothSidebarsCollapsed();
    rightSidebar.setCollapsed(next);
    leftSidebar.setCollapsed(next);
  }

  /* Full focus mode (FAB Focus / F key): dims chrome AND collapses
     both sidebars. Original behavior preserved. */
  function toggleFocus() {
    focusActive = !focusActive;
    document.body.classList.toggle('focus-mode', focusActive);
    syncFocusButtons();

    if (window.matchMedia('(min-width: 1024px)').matches) {
      rightSidebar.setCollapsed(focusActive);
      leftSidebar.setCollapsed(focusActive);
    }

    const toast = $('focus-indicator');
    if (toast) {
      toast.classList.toggle('hidden', !focusActive);
      if (focusActive) setTimeout(() => toast.classList.add('hidden'), 3000);
    }
  }

  /* ── Typography settings ── */
  const DEFAULTS = { fontSize: 18, lineHeight: 1.8, contentWidth: 720 };

  function loadTypo() {
    try { return { ...DEFAULTS, ...JSON.parse(localStorage.getItem('yuval-typography') || '{}') }; }
    catch { return { ...DEFAULTS }; }
  }

  function saveTypo(s) {
    localStorage.setItem('yuval-typography', JSON.stringify(s));
  }

  function applyTypo(s) {
    const root = document.documentElement;
    root.style.setProperty('--reading-font-size', `${s.fontSize}px`);
    root.style.setProperty('--reading-line-height', String(s.lineHeight));
    root.style.setProperty('--reading-content-width', `${s.contentWidth}px`);
    // font-family is now handled by the typography mode system only

    const fsEl = $('font-size-display');    if (fsEl) fsEl.textContent = `${s.fontSize}px`;
    const lhEl = $('line-height-display');  if (lhEl) lhEl.textContent = s.lineHeight.toFixed(1);
    const slider = $('line-height-slider') as HTMLInputElement | null;
    if (slider) slider.value = String(s.lineHeight);

    document.querySelectorAll<HTMLButtonElement>('.seg-btn').forEach(btn => {
      btn.classList.toggle('active', parseInt(btn.dataset.width || '0') === s.contentWidth);
    });
  }

  /* ── Init ── */
  function init() {
    /* FAB toggle */
    $('fab-toggle')?.addEventListener('click', () => toggleFab());

    /* Sub-buttons */
    $('theme-cycle-btn')?.addEventListener('click', () => {
      const next = themes[(themes.indexOf(getCurrentTheme()) + 1) % themes.length];
      setTheme(next);
    });

    $('focus-mode-btn')?.addEventListener('click', toggleFocus);

    /* Sidebar-mounted focus toggles (one in each sidebar header) —
       collapse-only, delegated so it survives Astro view transitions
       without rebinding per element. */
    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement | null)?.closest('.sidebar-focus-btn');
      if (btn) {
        e.preventDefault();
        toggleSidebars();
      }
    });

    /* Keep the in-sidebar focus button's "active" pill in sync with
       reality (both sidebars collapsed). Watching <body class> covers
       all paths — the gold button stays correct even if the user
       collapses one side via its own button. */
    new MutationObserver(syncFocusButtons).observe(document.body, {
      attributes: true,
      attributeFilter: ['class'],
    });

    syncFocusButtons();

    $('typography-btn')?.addEventListener('click', () => {
      toggleTypoPanel();
    });

    /* Navigation (mobile-only): delegate to the hidden drawer toggle */
    $('fab-nav-btn')?.addEventListener('click', () => {
      toggleFab(false);
      $('mobile-toc-toggle')?.click();
    });

    /* Highlights: delegate to the hidden highlights FAB */
    $('fab-highlights-btn')?.addEventListener('click', () => {
      toggleFab(false);
      $('highlights-fab')?.click();
    });

    /* Bookmarks: delegate to the floating bookmarks FAB created by bookmarks.ts */
    $('fab-bookmarks-btn')?.addEventListener('click', () => {
      toggleFab(false);
      $('bm-fab-btn')?.click();
    });

    /* Read aloud (mobile-only): open the TTS panel via global hook */
    $('fab-tts-btn')?.addEventListener('click', () => {
      toggleFab(false);
      const open = (window as unknown as { __ttsOpenPanel?: () => void }).__ttsOpenPanel;
      if (typeof open === 'function') open();
      else (window as unknown as { __ttsToggle?: () => void }).__ttsToggle?.();
    });

    /* Close panel */
    $('close-typography')?.addEventListener('click', closeTypoPanel);
    $('panel-backdrop')?.addEventListener('click', closeTypoPanel);

    /* Close FAB on outside click */
    document.addEventListener('click', (e) => {
      const fab = $('reading-fab');
      const panel = $('typography-panel');
      if (!fab?.contains(e.target as Node) && !panel?.contains(e.target as Node)) {
        toggleFab(false);
      }
    }, { capture: true });

    /* Typography controls */
    applyTypo(loadTypo());

    $('font-decrease')?.addEventListener('click', () => {
      const s = loadTypo(); s.fontSize = Math.max(14, s.fontSize - 2);
      saveTypo(s); applyTypo(s);
    });

    $('font-increase')?.addEventListener('click', () => {
      const s = loadTypo(); s.fontSize = Math.min(28, s.fontSize + 2);
      saveTypo(s); applyTypo(s);
    });

    $('line-height-slider')?.addEventListener('input', (e) => {
      const s = loadTypo(); s.lineHeight = parseFloat((e.target as HTMLInputElement).value);
      saveTypo(s); applyTypo(s);
    });

    document.querySelectorAll<HTMLButtonElement>('.seg-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = loadTypo(); s.contentWidth = parseInt(btn.dataset.width || '720');
        saveTypo(s); applyTypo(s);
      });
    });



    $('reset-typography')?.addEventListener('click', () => {
      saveTypo(DEFAULTS); applyTypo(DEFAULTS);
    });

    /* Keyboard shortcuts */
    document.addEventListener('keydown', (e) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement || e.target instanceof HTMLSelectElement) return;
      if (e.key.toLowerCase() === 'f') { e.preventDefault(); toggleFocus(); }
      if (e.key.toLowerCase() === 't') { e.preventDefault(); if (!typoPanelOpen) { toggleFab(true); } toggleTypoPanel(); }
      if (e.key === 'Escape') { closeTypoPanel(); toggleFab(false); if (focusActive) toggleFocus(); }
    });

    /* Hide FAB while scrolling */
    let scrollTimeout: ReturnType<typeof setTimeout>;
    const fab = $('reading-fab');
    window.addEventListener('scroll', () => {
      if (fab && !fabOpen) {
        fab.classList.add('scrolling');
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(() => {
          fab.classList.remove('scrolling');
        }, 800);
      }
    }, { passive: true });

    /* Restore saved theme */
    const saved = localStorage.getItem('yuval-theme');
    if (saved === 'sepia' || saved === 'dark') setTheme(saved);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:after-swap', init);
</script>