---
// Platform Status Bar — persistent bottom strip showing book reading
// progress. Hosts the pencil progress meter (the .usb-progress-track
// CSS artwork wrapping the NeuronBar canvas) plus completion counts
// and time remaining.
//
// IDs preserved (`usb-progress-canvas`, `usb-completion-done`,
// `usb-progress-percent`, `usb-time-remaining`) so the existing
// sidebar-render.ts wiring keeps working untouched — only the DOM
// location moves.
//
// Auto-hides when the dock is collapsed (manual collapse via the dock's
// chevron, or focus mode via the ‹‹focus›› toggle). Mobile (≤600px)
// drops the pencil entirely per user spec; stats stay.

interface Props {
  /** Book title shown on the inline-start side. Optional. */
  bookTitle?: string;
  /** Author name (already localised). Renders below the title in the
      "by [author]" form using the `book.by` translation key. */
  bookAuthor?: string;
  /** Total chapter count for the X / Y completion ratio. */
  chapterCount: number;
}

const { bookTitle = '', bookAuthor = '', chapterCount } = Astro.props;
---

<aside class="platform-status-bar" aria-label="Reading progress">
  <div class="psb-inner">
    <!-- Inline-start: book context, secondary text. Title sits above
         the author line so the bar mirrors a book cover hierarchy. -->
    <div class="psb-context">
      {bookTitle && <span class="psb-book-title">{bookTitle}</span>}
      {bookAuthor && (
        <span class="psb-book-author">
          <span class="psb-author-prefix" data-i18n="book.by">מאת:</span>
          <span class="psb-author-name">{bookAuthor}</span>
        </span>
      )}
    </div>

    <!-- Center: the pencil — the hero of this strip. The .usb-progress-track
         class carries the full pencil artwork (clip-path + ::before tip +
         ::after ferrule) defined in chapter-sidebar.css; the canvas inside
         renders the NeuronBar particles. -->
    <div class="psb-pencil-wrap">
      <div class="usb-progress-track">
        <canvas class="usb-toc-progress-canvas" id="usb-progress-canvas" aria-hidden="true"></canvas>
      </div>
    </div>

    <!-- Inline-end: stats trio. -->
    <div class="psb-stats">
      <span class="usb-completion-count">
        <span class="usb-completion-done" id="usb-completion-done">0</span><span class="usb-completion-sep">/</span><span class="usb-completion-total">{chapterCount}</span>
        <span class="usb-completion-suffix" data-i18n="sidebar.completed">הושלמו</span>
      </span>
      <span class="psb-stat-sep" aria-hidden="true">·</span>
      <span class="usb-progress-percent" id="usb-progress-percent">0%</span>
      <span class="psb-stat-sep" aria-hidden="true">·</span>
      <span class="usb-time-remaining" id="usb-time-remaining"></span>
    </div>
  </div>
</aside>

<!-- Layout reservation. Exposes the bar's height as a global CSS variable
     so other fixed-position chrome (the dock, the TOC) can reserve space
     for it without hard-coding the same number in three places. -->
<style is:global>
  :root {
    --platform-status-bar-height: 56px;
  }

  @media (max-width: 600px) {
    :root {
      --platform-status-bar-height: 48px;
    }
  }
</style>

<style>
  /* Surface — matches the reading-mode header (Header.astro:757-768)
     pixel-for-pixel. The header's default gradient is overridden in
     reading mode (body.reading-mode, which ReadingLayout always sets)
     to a solid surface + backdrop blur; this bar lives only inside
     reading-mode pages, so it uses those final values directly. */
  .platform-status-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 30;
    background: #F5F4EF;
    backdrop-filter: blur(6px) saturate(115%);
    -webkit-backdrop-filter: blur(6px) saturate(115%);
    box-shadow: 0 -1px 2px rgba(0, 0, 0, 0.04);
    transition:
      transform 320ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 240ms ease-out;
  }

  /* Top hairline — refined vignette: fades to transparent at both
     edges instead of running edge-to-edge as a hard line. Reduced
     alpha + horizontal fade together read as "implied boundary"
     rather than "drawn line", which is what a delicate frame should
     do on a wide chrome strip. */
  .platform-status-bar::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(201, 169, 110, 0.14) 20%,
      rgba(201, 169, 110, 0.14) 80%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 2;
  }
  /* Outer flare is removed in reading mode on the header
     (Header.astro:771); no `::after` here for the bar either. */

  /* Dark mode — mirrors the dark reading-mode header
     (Header.astro:765-768). Same `--yuval-surface` solid, same shadow. */
  :global(.dark) .platform-status-bar {
    background: var(--yuval-surface, #1a1a1a);
    box-shadow: 0 -1px 2px rgba(0, 0, 0, 0.12);
  }

  :global(.dark) .platform-status-bar::before {
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(139, 115, 85, 0.18) 20%,
      rgba(139, 115, 85, 0.18) 80%,
      transparent 100%
    );
  }

  .psb-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    column-gap: 24px;
    height: 56px;
    padding: 0 24px;
    z-index: 1;
  }

  /* Inline-start: book title, muted secondary text. */
  .psb-context {
    min-width: 0;
    overflow: hidden;
    justify-self: start;
  }

  .psb-book-title {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--yuval-text-secondary, #555);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: 0.005em;
    line-height: 1.25;
  }

  /* Author line — sits one tier below the title in the same way the
     hierarchy works on a real book cover (title dominant, author
     supporting). Smaller, more muted, and with the "מאת: / By:" prefix
     in an even quieter tone so the eye lands on the name itself. */
  .psb-book-author {
    display: block;
    margin-top: 2px;
    font-size: 11px;
    line-height: 1.25;
    color: var(--yuval-text-tertiary, var(--yuval-text-muted, #777));
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .psb-author-prefix {
    opacity: 0.65;
    margin-inline-end: 4px;
  }

  .psb-author-name {
    font-weight: 500;
  }

  /* Center: pencil wrap. Sized so the artwork keeps its proportions
     across viewports — the V-tip and ferrule are fixed-pixel pseudos,
     so only the middle stretches; capping the wrap width keeps the
     middle from looking "vacuum-stretched".

     Tuned per user request — ~50% longer than the original
     (clamp(320px, 38vw, 480px)) on every screen above smartphone:

       Viewport    Old width    New width    Δ
       1024 px     389 px       563 px       +45 %
       1440 px     480 px       720 px       +50 %
       1920 px     480 px       720 px       +50 %
       768 px      320 px       422 px       +32 %
       600 px      320 px       380 px       +19 %  (tablet floor)

     Min raised to 380 so the pencil never collapses to "thumbnail"
     size on narrow tablets; max raised to 720 so wide screens
     finally see the artwork at the scale it deserves. */
  .psb-pencil-wrap {
    width: clamp(380px, 55vw, 720px);
    flex-shrink: 0;
    justify-self: center;
  }

  /* Inline-end: stats. Uses the same .usb-completion-* / .usb-progress-*
     classes the original TOC header used so existing colour/typography
     rules in chapter-sidebar.css apply unchanged. */
  .psb-stats {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    justify-self: end;
    font-size: 13px;
    color: var(--yuval-text-muted, #6b7280);
    white-space: nowrap;
  }

  .psb-stats :global(.usb-completion-count) {
    font-size: 13px;
  }

  .psb-stat-sep {
    opacity: 0.4;
    font-size: 13px;
  }

  /* Narrow desktop / tablet: hide the verbose "הושלמו / completed"
     suffix so the compact "X/Y · 39% · ~1h" trio leaves room for the
     wider pencil. Above 1280px the bar has enough horizontal slack
     to display the suffix without crowding. */
  @media (max-width: 1280px) {
    .usb-completion-suffix {
      display: none;
    }
  }

  /* Author line — hidden in the narrow tablet / laptop zone where the
     bigger pencil eats most of the horizontal real estate. Mobile
     (<600px, pencil hidden) gets the author back via the mobile rule
     below; wide desktops (≥1024px) keep it from this rule's exclusion. */
  @media (min-width: 600px) and (max-width: 1023.98px) {
    .psb-book-author {
      display: none;
    }
  }

  /* Auto-hide together with the dock — collapsing the dock (manual
     chevron OR focus mode, which both add body.left-sidebar-collapsed)
     slides the bar off-screen. Per user spec: "(ב) — מתקפל יחד עם
     ה-dock". translateY keeps the element in the DOM so the NeuronBar's
     RAF loop doesn't churn on remount; pointer-events: none prevents
     interaction with the hidden bar.

     IMPORTANT: do NOT key off `body.reading-mode` — that class is added
     by ReadingLayout for every reading page (it's the "we're reading"
     signal that lets Header dim itself), not a user-controlled focus
     state. Using it here hid the bar permanently. */
  :global(body.left-sidebar-collapsed) .platform-status-bar {
    transform: translateY(100%);
    opacity: 0;
    pointer-events: none;
  }

  /* Mobile — drop the pencil. Stats stay so the user still sees
     "X/Y · 39% · ~1h" at a glance. Reduced height and padding match
     mobile chrome conventions. */
  @media (max-width: 600px) {
    .platform-status-bar {
      box-shadow:
        0 -1px 4px rgba(0, 0, 0, 0.08),
        0 -2px 8px rgba(0, 0, 0, 0.04);
    }
    .psb-inner {
      grid-template-columns: 1fr auto;
      height: 48px;
      column-gap: 12px;
      padding: 0 16px;
    }
    .psb-pencil-wrap {
      display: none;
    }
    .psb-context {
      grid-column: 1;
    }
    .psb-stats {
      grid-column: 2;
      gap: 6px;
      font-size: 12px;
    }
    .psb-stats :global(.usb-completion-count) {
      font-size: 12px;
    }
  }

  /* Print — chrome doesn't belong on paper. */
  @media print {
    .platform-status-bar {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .platform-status-bar {
      transition: none;
    }
  }
</style>
