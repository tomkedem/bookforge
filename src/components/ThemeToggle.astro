---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<button
  id="theme-toggle"
  type="button"
  role="switch"
  aria-checked="false"
  aria-label="Toggle dark mode"
  dir="ltr"
  class:list={['sky-window', className]}
>
  <!-- Sky background layers -->
  <div class="sky-scene">
    <!-- Day sky -->
    <div class="sky-layer sky-day"></div>
    <!-- Night sky -->
    <div class="sky-layer sky-night">
      <div class="galaxy-layer galaxy-base"></div>
      <div class="galaxy-layer galaxy-nebula"></div>
      <div class="galaxy-layer galaxy-dust"></div>
    </div>

    <!--
      Stars — populated dynamically per visit. The init script
      picks a constellation from CONSTELLATIONS[] based on today's
      date (one per month, roughly matching what's actually visible
      in the Northern-Hemisphere evening sky for that month) and
      lays its stars out in this container. Brightness, tint and
      twinkle phase still vary star-to-star so the field reads as
      a real night sky rather than a dot pattern.
    -->
    <div class="stars" data-sky-stars></div>

    <!-- Shooting stars container — populated dynamically by script -->
    <div class="shooters" data-sky-shooters aria-hidden="true"></div>

    <!-- Birds container — spawned dynamically. Four species cycle through
         at random intervals, only in the light (day-sky) theme. -->
    <div class="birds" data-sky-birds aria-hidden="true"></div>

    <!-- Sun (visible in dark theme as a preview of light theme) -->
    <div class="celestial sun">
      <div class="sun-core"></div>
      <div class="sun-rays"></div>
      <div class="sun-glow"></div>
    </div>

    <!--
      Moon — now on the LEFT of the window (same side as the sun), and its
      crescent shape is driven by the real lunar phase for today. The body
      is a warm circle; a dark "terminator" circle slides across it to mask
      out the unlit portion. The sparkle anchors to the lit cusp.
    -->
    <div class="celestial moon" data-sky-moon>
      <div class="moon-glow"></div>
      <div class="moon-body">
        <div class="moon-terminator"></div>
      </div>
      <div class="moon-sparkle"></div>
    </div>

    <!-- Clouds — JS-spawned, each with fully randomized geometry,
         altitude, opacity, drift speed and puff layout. The host
         starts empty; clouds enter from the right and self-remove
         when they exit on the left. Edge-fade mask in CSS keeps
         their entry/exit gentle. -->
    <div class="clouds" data-sky-clouds aria-hidden="true"></div>
  </div>

  <!-- Glass frame overlay -->
  <div class="window-frame"></div>
</button>

<style>
  /* +15% lift in both dimensions over the previous 73×32 baseline,
     so the sky window earns a touch more presence in the header
     without dominating it. Both axes scale together to preserve
     proportions. */
  .sky-window {
    position: relative;
    width: 84px;
    height: 37px;
    border-radius: 18px;
    overflow: visible;
    cursor: pointer;
    border: none;
    padding: 0;
    background: transparent;
    transition: transform 300ms var(--ease-standard),
                filter 600ms var(--ease-standard);
  }

  .sky-window:hover {
    transform: scale(1.05);
    /* Subtle daylight shift on hover — reads as a "warmer moment"
       inside the window without lighting up the whole header. */
    filter: brightness(1.06) saturate(1.05);
  }

  .sky-window:active {
    transform: scale(0.98);
  }

  .sky-window:focus {
    outline: none;
  }

  .sky-window:focus .window-frame {
    box-shadow:
      0 0 0 2px var(--yuval-highlight),
      0 2px 8px rgba(139, 105, 20, 0.3),
      inset 0 1px 2px rgba(255, 255, 255, 0.5),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2);
  }

  .sky-scene {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: 12px;
    z-index: 2;
  }

  /* Sky backgrounds */
  .sky-layer {
    position: absolute;
    inset: 0;
    transition: opacity 600ms var(--ease-standard);
  }

  .sky-day {
    background: linear-gradient(
      180deg,
      #4facfe 0%,
      #87ceeb 40%,
      #b4e4ff 100%
    );
    opacity: 0;
  }

  .sky-night {
    background: #050510;
    opacity: 1;
    overflow: hidden;
  }

  .galaxy-layer {
    position: absolute;
    inset: -50%;
    width: 200%;
    height: 200%;
  }

  .galaxy-base {
    background: radial-gradient(
      ellipse at 30% 40%,
      #1a1035 0%,
      #0d0d1a 40%,
      #050510 70%
    );
    animation: galaxy-drift 60s linear infinite;
  }

  .galaxy-nebula {
    background:
      radial-gradient(ellipse at 20% 30%, rgba(99, 66, 153, 0.4) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 60%, rgba(45, 85, 150, 0.35) 0%, transparent 45%),
      radial-gradient(ellipse at 50% 80%, rgba(150, 70, 120, 0.3) 0%, transparent 40%),
      radial-gradient(ellipse at 80% 20%, rgba(70, 100, 170, 0.25) 0%, transparent 35%);
    animation: nebula-flow 45s var(--ease-standard) infinite alternate;
    mix-blend-mode: screen;
  }

  .galaxy-dust {
    background:
      radial-gradient(ellipse at 40% 50%, rgba(255, 200, 150, 0.08) 0%, transparent 30%),
      radial-gradient(ellipse at 60% 30%, rgba(200, 180, 255, 0.06) 0%, transparent 25%);
    animation: dust-shimmer 30s var(--ease-standard) infinite alternate-reverse;
    mix-blend-mode: overlay;
  }

  @keyframes galaxy-drift {
    0% { transform: translate(0, 0) rotate(0deg); }
    100% { transform: translate(-25%, -25%) rotate(10deg); }
  }

  /* Opacity values dialed back ~35% from the original peaks so the
     nebula + dust layers read as ambient atmosphere rather than a
     competing focal element. The moon and stars carry the
     scene; these gradients are background mood. */
  @keyframes nebula-flow {
    0% { transform: translate(0, 0) scale(1); opacity: 0.5; }
    50% { transform: translate(-10%, 5%) scale(1.1); opacity: 0.65; }
    100% { transform: translate(5%, -10%) scale(1.05); opacity: 0.58; }
  }

  @keyframes dust-shimmer {
    0% { transform: translate(0, 0); opacity: 0.32; }
    100% { transform: translate(10%, -5%); opacity: 0.52; }
  }

  :global(.dark) .sky-day {
    opacity: 1;
  }

  :global(.dark) .sky-night {
    opacity: 0;
  }

  :global(.dark) .galaxy-base,
  :global(.dark) .galaxy-nebula,
  :global(.dark) .galaxy-dust {
    animation-play-state: paused;
  }

  /* Stars — each star reads position/size/hue from CSS vars the script sets */
  .stars {
    position: absolute;
    inset: 0;
    opacity: 1;
    transition: opacity 600ms var(--ease-standard) 200ms;
  }

  :global(.dark) .stars {
    opacity: 0;
  }

  /* Stars are spawned dynamically by JS (constellation pattern per
     month). Astro's per-component scoping is bypassed via :global
     so the rules apply to the newly-created spans — same approach
     used for .bird and .cloud below. */
  :global(.star) {
    position: absolute;
    top: var(--star-y, 10px);
    left: var(--star-x, 10px);
    width: var(--star-size, 1.5px);
    height: var(--star-size, 1.5px);
    background: var(--star-tint, #ffffff);
    border-radius: 50%;
    animation: star-twinkle var(--star-dur, 2s) ease-in-out infinite;
    animation-delay: var(--star-delay, 0s);
    box-shadow:
      0 0 3px var(--star-glow, rgba(255, 255, 255, 0.8)),
      0 0 6px rgba(200, 180, 255, 0.4);
    pointer-events: none;
  }

  @keyframes star-twinkle {
    0%, 100% { opacity: 0.4; transform: scale(1); filter: brightness(0.8); }
    25% { opacity: 0.8; }
    50% { opacity: 1; transform: scale(1.3); filter: brightness(1.3); }
    75% { opacity: 0.7; }
  }

  /* Shooting stars — a 1px head with a gradient trail behind it */
  .shooters {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  :global(.dark) .shooters {
    opacity: 0;
  }

  .shooter {
    position: absolute;
    top: var(--shoot-start-y, 4px);
    left: var(--shoot-start-x, 60px);
    width: 2px;
    height: 1px;
    background: #ffffff;
    border-radius: 1px;
    box-shadow: 0 0 3px rgba(255, 255, 255, 0.9);
    transform-origin: center;
    animation: shoot var(--shoot-dur, 1.4s) linear forwards;
  }

  .shooter::before {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    width: 16px;
    height: 1px;
    background: linear-gradient(
      -90deg,
      rgba(255, 255, 255, 0.95),
      rgba(220, 220, 255, 0.5) 40%,
      transparent 100%
    );
  }

  @keyframes shoot {
    0% {
      transform: translate(0, 0) rotate(var(--shoot-angle, 20deg));
      opacity: 0;
    }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% {
      transform:
        translate(var(--shoot-dx, -50px), var(--shoot-dy, 18px))
        rotate(var(--shoot-angle, 20deg));
      opacity: 0;
    }
  }

  /* ─── Birds ─────────────────────────────────────────────────────────
     Birds are real inline-SVG silhouettes, not emoji — each species has
     a distinct wing profile (eagle/seagull/dove/sparrow) and two path
     frames (wings-up / wings-down) that alternate to flap. Colors use
     currentColor, so species color is controlled via the `.bird` `color`
     property. Birds appear only while the day sky is visible, which on
     this preview-of-opposite toggle is when the site is in dark mode. */
  .birds {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  :global(html:not(.dark)) .birds {
    display: none !important;
  }

  :global(.bird) {
    position: absolute;
    top: var(--bird-y, 8px);
    left: var(--bird-start-x, -20px);
    width: var(--bird-size, 14px);
    height: calc(var(--bird-size, 14px) * 0.5);
    opacity: var(--bird-opacity, 0.6);
    pointer-events: none;
    will-change: transform;
    /* Soft atmospheric blur — blends the silhouette with the sky so
       the bird reads as part of the scene rather than a UI sprite.
       The filter is kept off-the-main-thread by using a single
       transform-only animation; the blur stays static. */
    filter: blur(0.25px);
    /* Linear timing so the bird crosses the frame at a constant
       glide speed — real birds don't ease-in or ease-out within a
       2-4s pass; an easing curve shows up here as an unnatural
       accel/decel mid-frame. The y-drift in the keyframes already
       provides the "soft" feel the spec asks for. */
    animation: bird-fly var(--bird-dur, 3s) linear forwards;
    /* The transform in bird-fly already owns scaleX for direction; we
       keep the bird group itself untransformed here. */
  }

  :global(.bird svg) {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  /* Species palette — silhouette color. Kept slightly lighter than pure
     black so the bird reads against the cyan day-sky gradient without
     looking pasted on. Each species has a slight tonal shift so a
     mixed-species sky reads as varied even when birds overlap. */
  :global(.bird-eagle)   { color: #1d1208; }
  :global(.bird-seagull) { color: #2a2a34; }
  :global(.bird-dove)    { color: #4a4e5a; }
  :global(.bird-sparrow) { color: #2b1f14; }
  :global(.bird-stork)   { color: #3a3530; }
  :global(.bird-swallow) { color: #2c2538; }
  :global(.bird-hawk)    { color: #2a1f10; }
  :global(.bird-crow)    { color: #15151a; }
  :global(.bird-heron)   { color: #4a4c52; }
  :global(.bird-crane)   { color: #5a5048; }

  /* Wing-flap: two path groups per bird, swapped rapidly via opacity.
     steps(1) gives a snap between poses (no crossfade), which reads as
     a genuine flap. The duration is set per-species via --flap-dur. */
  :global(.bird .wings-up) {
    animation: bird-flap-up var(--flap-dur, 320ms) steps(1, end) infinite;
  }
  :global(.bird .wings-down) {
    animation: bird-flap-down var(--flap-dur, 320ms) steps(1, end) infinite;
  }

  @keyframes bird-flap-up {
    0%, 49%   { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  @keyframes bird-flap-down {
    0%, 49%   { opacity: 0; }
    50%, 100% { opacity: 1; }
  }

  /* Mostly horizontal — small (≤1.4px) vertical drift keeps the
     flock reading as a calm V/wave line instead of a roller-coaster. */
  @keyframes bird-fly {
    0%   { transform: translate(0, 0) scaleX(var(--bird-dir, 1)); }
    25%  { transform: translate(var(--bird-x-25, 0), -1.2px) scaleX(var(--bird-dir, 1)); }
    50%  { transform: translate(var(--bird-x-50, 0),  0.8px) scaleX(var(--bird-dir, 1)); }
    75%  { transform: translate(var(--bird-x-75, 0), -0.8px) scaleX(var(--bird-dir, 1)); }
    100% { transform: translate(var(--bird-x-100, 0), 0)    scaleX(var(--bird-dir, 1)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .birds { display: none; }
  }

  /* Celestial bodies positioning */
  .celestial {
    position: absolute;
    /* top/left also transition so the gentle hour-of-day shift
       between page navigations / scheduled refreshes glides into
       place instead of snapping. */
    transition:
      transform 600ms var(--ease-emphasized),
      top 1200ms var(--ease-standard),
      left 1200ms var(--ease-standard);
  }

  /* Sun — visible in dark theme. top/left set per page load by
     applyCelestialPositions() so the sun rides a low arc east→west
     mirroring the real local hour of day. */
  .sun {
    width: 18px;
    height: 18px;
    top: var(--sun-top, 5px);
    left: var(--sun-left, 6px);
    transform: translateY(30px) scale(0.5);
  }

  :global(.dark) .sun {
    transform: translateY(0) scale(1);
  }

  .sun-core {
    position: absolute;
    width: 14px;
    height: 14px;
    top: 2px;
    left: 2px;
    background: linear-gradient(135deg, #fff9c4 0%, #ffeb3b 50%, #ffc107 100%);
    border-radius: 50%;
    box-shadow: 0 0 8px #ffeb3b;
  }

  .sun-rays {
    position: absolute;
    width: 18px;
    height: 18px;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      rgba(255, 235, 59, 0.4) 10deg,
      transparent 20deg,
      transparent 45deg,
      rgba(255, 235, 59, 0.4) 55deg,
      transparent 65deg,
      transparent 90deg,
      rgba(255, 235, 59, 0.4) 100deg,
      transparent 110deg,
      transparent 135deg,
      rgba(255, 235, 59, 0.4) 145deg,
      transparent 155deg,
      transparent 180deg,
      rgba(255, 235, 59, 0.4) 190deg,
      transparent 200deg,
      transparent 225deg,
      rgba(255, 235, 59, 0.4) 235deg,
      transparent 245deg,
      transparent 270deg,
      rgba(255, 235, 59, 0.4) 280deg,
      transparent 290deg,
      transparent 315deg,
      rgba(255, 235, 59, 0.4) 325deg,
      transparent 335deg
    );
    border-radius: 50%;
    animation: rotate-rays 20s linear infinite;
  }

  @keyframes rotate-rays {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .sun-glow {
    position: absolute;
    width: 22px;
    height: 22px;
    top: -2px;
    left: -2px;
    background: radial-gradient(
      circle,
      rgba(255, 235, 59, 0.3) 0%,
      transparent 70%
    );
    border-radius: 50%;
    animation: pulse-glow 3s var(--ease-standard) infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.1); opacity: 0.8; }
  }

  /*
    Moon — LEFT-anchored, same edge as the sun. The moon-body is a warm
    cream circle; the moon-terminator is a dark circle of equal size that
    slides horizontally to eclipse a fraction of the body. The offset and
    sparkle position are controlled by CSS variables that the init script
    computes from today's lunar phase.

    --moon-shadow-x:   horizontal offset of the terminator (-14..+14)
                       negative = shadow on left  (waxing / right-lit)
                       positive = shadow on right (waning / left-lit)
    --moon-sparkle-x:  left position of the sparkle in px (cusp tip)
    --moon-sparkle-opacity: 0..1, fades sparkle near full moon
  */
  .moon {
    width: 16px;
    height: 16px;
    top: var(--moon-top, 6px);
    left: var(--moon-left, 6px);
    right: auto;
    transform: translateY(0) scale(1);
    --moon-shadow-x: -5px;
    --moon-sparkle-x: 12px;
    --moon-sparkle-opacity: 1;
  }

  :global(.dark) .moon {
    transform: translateY(30px) scale(0.5);
  }

  .moon-body {
    position: absolute;
    width: 14px;
    height: 14px;
    top: 1px;
    left: 1px;
    border-radius: 50%;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 35% 30%,
        #fffbe0 0%,
        #f9e4a4 45%,
        #d9a84a 90%,
        #a67a2c 100%
      );
    box-shadow:
      inset -1.5px -1.5px 2.5px rgba(90, 70, 40, 0.35),
      0 0 8px rgba(255, 231, 154, 0.5);
    animation: moon-breath 5s var(--ease-standard) infinite;
  }

  @keyframes moon-breath {
    0%, 100% {
      box-shadow:
        inset -1.5px -1.5px 2.5px rgba(90, 70, 40, 0.35),
        0 0 8px rgba(255, 231, 154, 0.5);
    }
    50% {
      box-shadow:
        inset -1.5px -1.5px 2.5px rgba(90, 70, 40, 0.25),
        0 0 14px rgba(255, 231, 154, 0.85);
    }
  }

  /*
    Terminator — a dark circle equal in size to the body. Translating it
    horizontally carves the moon into the correct phase geometry (lune
    intersection). The fill blends with the night sky behind the body so
    the covered portion appears as deep shadow.
  */
  .moon-terminator {
    position: absolute;
    width: 14px;
    height: 14px;
    top: 0;
    left: var(--moon-shadow-x, -5px);
    border-radius: 50%;
    background:
      radial-gradient(
        circle at 50% 50%,
        #0a0a1e 0%,
        #050510 70%,
        #020208 100%
      );
    box-shadow: inset 1px 0 2px rgba(30, 25, 55, 0.6);
    transition: left 900ms var(--ease-standard);
  }

  .moon-sparkle {
    position: absolute;
    top: 0px;
    left: var(--moon-sparkle-x, 12px);
    width: 3px;
    height: 3px;
    background: radial-gradient(
      circle,
      #ffffff 0%,
      #fff6d5 45%,
      rgba(255, 246, 213, 0) 80%
    );
    border-radius: 50%;
    box-shadow:
      0 0 3px rgba(255, 255, 255, 0.9),
      0 0 6px rgba(255, 231, 154, 0.6);
    opacity: var(--moon-sparkle-opacity, 1);
    animation: moon-sparkle-twinkle 2.6s var(--ease-standard) infinite;
    pointer-events: none;
    transition: left 900ms var(--ease-standard), opacity 900ms var(--ease-standard);
  }

  @keyframes moon-sparkle-twinkle {
    0%, 100% { transform: scale(0.7); }
    45%, 55% { transform: scale(1.15); }
  }

  .moon-glow {
    position: absolute;
    width: 20px;
    height: 20px;
    top: -2px;
    left: -2px;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.2) 0%,
      transparent 60%
    );
    border-radius: 50%;
  }

  /* Clouds */
  .clouds {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 600ms var(--ease-standard);
    overflow: hidden;
    /* Edge-fade mask: clouds entering from the right fade IN over
       the first ~12% of the window's width and OUT over the last
       ~12%. Reads as clouds drifting in/out of view through a
       soft horizon, instead of "popping" at the edges. Both the
       webkit prefix and the standard property are set so all
       evergreen browsers pick it up. */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 12%,
      #000 88%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 12%,
      #000 88%,
      transparent 100%
    );
  }

  :global(.dark) .clouds {
    opacity: 1;
  }

  /*
    Each cloud is now a JS-spawned <div> that drifts independently
    across the window. No two are alike: width, height, altitude,
    opacity, drift duration, and the count + size + position of
    its inner puffs are all randomized per spawn.

    The body is a soft radial-gradient ellipse (no hard edges).
    Inside it, 2-4 .cloud-puff children layer additional rounded
    bumps for the cumulus / "sheep wool" silhouette. A 0.6px filter
    blur fluffs whatever crisp edges remain.
  */
  :global(.cloud) {
    position: absolute;
    bottom: var(--cloud-y, 8px);
    left: 0;
    width: var(--cloud-w, 22px);
    height: var(--cloud-h, 12px);
    opacity: var(--cloud-opacity, 0.85);
    border-radius: 50%;
    background: radial-gradient(
      ellipse at 35% 45%,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(255, 255, 255, 0.85) 45%,
      rgba(255, 255, 255, 0.55) 80%,
      rgba(255, 255, 255, 0.0) 100%
    );
    filter: blur(0.6px);
    pointer-events: none;
    will-change: transform;
    animation: cloud-drift var(--cloud-dur, 26s) linear forwards;
    animation-delay: var(--cloud-delay, 0s);
  }

  :global(.cloud-puff) {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(
      circle at 40% 40%,
      rgba(255, 255, 255, 0.94) 0%,
      rgba(255, 255, 255, 0.72) 55%,
      rgba(255, 255, 255, 0.0) 100%
    );
    pointer-events: none;
  }

  /* Drift right→left across the window; the JS sets --cloud-x-start
     (just outside the right edge) and --cloud-x-end (just past the
     left edge). transform stays the GPU-friendly path. */
  @keyframes cloud-drift {
    0%   { transform: translateX(var(--cloud-x-start, 100px)); }
    100% { transform: translateX(var(--cloud-x-end, -40px)); }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.cloud) { animation: none; }
  }

  /* Window frame */
  .window-frame {
    position: absolute;
    inset: -2px;
    border-radius: 16px;
    pointer-events: none;
    background: linear-gradient(
      135deg,
      #7c8ba1 0%,
      #c4d0e4 15%,
      #9ba8c2 30%,
      #4a5568 45%,
      #6b7db3 55%,
      #a78bba 70%,
      #c4b5d8 85%,
      #8b7ca8 100%
    );
    z-index: 0;
    box-shadow:
      0 2px 12px rgba(107, 125, 179, 0.4),
      0 0 20px rgba(167, 139, 186, 0.2),
      inset 0 1px 2px rgba(255, 255, 255, 0.4),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3);
    transition: all 600ms var(--ease-standard);
  }

  .window-frame::before {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 12px;
    border: 1px solid rgba(196, 181, 216, 0.3);
    background: transparent;
  }

  :global(.dark) .window-frame {
    background: linear-gradient(
      135deg,
      #d4a574 0%,
      #f4e4bc 15%,
      #c9a55c 30%,
      #8b6914 50%,
      #c9a55c 70%,
      #f4e4bc 85%,
      #d4a574 100%
    );
    box-shadow:
      0 2px 8px rgba(139, 105, 20, 0.3),
      inset 0 1px 2px rgba(255, 255, 255, 0.5),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2);
  }

  :global(.dark) .window-frame::before {
    border-color: rgba(255, 255, 255, 0.3);
  }

  :global(.dark) .sky-window:focus .window-frame {
    box-shadow:
      0 0 0 2px var(--yuval-highlight),
      0 2px 8px rgba(139, 105, 20, 0.3),
      inset 0 1px 2px rgba(255, 255, 255, 0.5),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2);
  }

  @media (prefers-reduced-motion: reduce) {
    .galaxy-base,
    .galaxy-nebula,
    .galaxy-dust,
    .star,
    .moon-body,
    .moon-sparkle,
    .sun-rays,
    .sun-glow,
    .cloud-track,
    .shooter {
      animation: none !important;
    }
  }
</style>

<script>
  function getStoredTheme(): 'light' | 'dark' | null {
    try {
      const stored = localStorage.getItem('yuval-theme');
      if (stored === 'light' || stored === 'dark') return stored;
    } catch { /* storage unavailable */ }
    return null;
  }

  function getSystemPreference(): 'dark' | 'light' {
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function getEffectiveTheme(): 'light' | 'dark' {
    return getStoredTheme() || getSystemPreference();
  }

  function applyTheme(theme: 'light' | 'dark') {
    document.documentElement.classList.toggle('dark', theme === 'dark');
    const toggle = document.getElementById('theme-toggle');
    if (toggle) {
      toggle.setAttribute('aria-checked', theme === 'dark' ? 'true' : 'false');
    }
  }

  /*
    Moon phase — returns a fraction 0..1 of the synodic lunar cycle, where
    0 = new moon, 0.25 = first quarter (waxing), 0.5 = full, 0.75 = last
    quarter (waning), back to 1 = new. Reference new moon is 2000-01-06
    18:14 UTC, a canonical epoch for this kind of calculation.
  */
  function computeMoonPhase(date = new Date()): number {
    const LUNAR_CYCLE_DAYS = 29.53058867;
    const KNOWN_NEW_MOON_MS = Date.UTC(2000, 0, 6, 18, 14, 0);
    const daysSince = (date.getTime() - KNOWN_NEW_MOON_MS) / 86400000;
    let phase = (daysSince % LUNAR_CYCLE_DAYS) / LUNAR_CYCLE_DAYS;
    if (phase < 0) phase += 1;
    return phase;
  }

  /*
    Apply lunar phase to the moon element. The body is 14px wide; shifting
    the terminator by ±14px fully un-eclipses or re-eclipses the body. We
    treat 0..0.5 as waxing (shadow slides LEFT, right side lit) and
    0.5..1 as waning (shadow slides RIGHT, left side lit). Near full moon
    the sparkle fades out — there's no single cusp to anchor on.
  */
  function applyMoonPhase(moonEl: HTMLElement) {
    const phase = computeMoonPhase();
    const MOON_W = 14;
    let shadowX: number;
    let sparkleX: number;
    let sparkleOpacity: number;

    if (phase < 0.5) {
      // Waxing: illum grows 0 → 1
      const illum = phase * 2;
      shadowX = -illum * MOON_W;
      sparkleX = 12;
      sparkleOpacity = illum < 0.85 ? 1 : Math.max(0, 1 - (illum - 0.85) * 6);
    } else {
      // Waning: illum shrinks 1 → 0
      const illum = (1 - phase) * 2;
      shadowX = illum * MOON_W;
      sparkleX = 1;
      sparkleOpacity = illum < 0.85 ? 1 : Math.max(0, 1 - (illum - 0.85) * 6);
    }

    moonEl.style.setProperty('--moon-shadow-x', `${shadowX.toFixed(2)}px`);
    moonEl.style.setProperty('--moon-sparkle-x', `${sparkleX}px`);
    moonEl.style.setProperty('--moon-sparkle-opacity', sparkleOpacity.toFixed(2));
    moonEl.setAttribute('data-moon-phase', phase.toFixed(3));
  }

  /*
    Randomize star positions and sizes on mount. We keep them spread over
    the full window but skip the 18px-wide zone where the moon sits so
    they don't bleed into its glow. Twinkle hue alternates between warm
    (cream/amber) and cool (pale blue / pink) so the field feels varied.
  */
  const STAR_TINTS: Array<{ body: string; glow: string }> = [
    { body: '#ffffff', glow: 'rgba(255, 255, 255, 0.85)' },
    { body: '#fff2c0', glow: 'rgba(255, 200, 150, 0.9)' },
    { body: '#d0d8ff', glow: 'rgba(180, 200, 255, 0.9)' },
    { body: '#ffd0e0', glow: 'rgba(255, 180, 200, 0.85)' },
  ];

  function randomInRange(min: number, max: number): number {
    return min + Math.random() * (max - min);
  }

  // ── Constellations ────────────────────────────────────────────────
  /*
    Twelve constellations, one for each calendar month, chosen to
    match what's actually visible high in the Northern-Hemisphere
    evening sky during that month. Star coordinates are normalized
    (0..1 in both axes) and scaled by applyConstellation() into the
    drawable region of the window — i.e. the right ~70% of the
    width (the moon owns the left side) and most of the height.

    Each star carries a `bright` value (0..1) used both for the dot
    size and for whether the star tints toward a "named" hue: the
    brightest one in each constellation (e.g. Sirius, Betelgeuse,
    Arcturus, Antares) gets a real-life tint, the rest stay white-
    or warm-cream so the named star stands out the way it does in
    the real sky.
  */
  type ConstellationStar = {
    x: number;          // 0..1 in the drawable area
    y: number;          // 0..1
    bright: number;     // 0..1 — both size scalar and "named" cue
    tint?: { body: string; glow: string };  // override for famous named stars
  };
  type Constellation = {
    name: string;
    stars: ConstellationStar[];
  };

  const TINT_BLUE_GIANT  = { body: '#cfe0ff', glow: 'rgba(180, 210, 255, 0.95)' };  // Rigel, Sirius
  const TINT_RED_GIANT   = { body: '#ffd0a8', glow: 'rgba(255, 170, 120, 0.95)' };  // Betelgeuse, Antares
  const TINT_GOLD_GIANT  = { body: '#ffe6a8', glow: 'rgba(255, 220, 140, 0.92)' };  // Arcturus
  const TINT_WHITE_GIANT = { body: '#ffffff', glow: 'rgba(255, 255, 255, 0.95)' };  // Deneb, Vega

  const CONSTELLATIONS: Constellation[] = [
    // January — Orion (the iconic winter pattern; Betelgeuse + Rigel)
    { name: 'Orion', stars: [
      { x: 0.30, y: 0.15, bright: 0.6 },                              // Bellatrix
      { x: 0.70, y: 0.10, bright: 1.0, tint: TINT_RED_GIANT },        // Betelgeuse
      { x: 0.40, y: 0.45, bright: 0.5 },                              // Belt 1 (Mintaka)
      { x: 0.50, y: 0.50, bright: 0.5 },                              // Belt 2 (Alnilam)
      { x: 0.60, y: 0.55, bright: 0.5 },                              // Belt 3 (Alnitak)
      { x: 0.30, y: 0.82, bright: 0.6 },                              // Saiph
      { x: 0.72, y: 0.88, bright: 1.0, tint: TINT_BLUE_GIANT },       // Rigel
    ]},
    // February — Canis Major (Sirius, brightest star in night sky)
    { name: 'Canis Major', stars: [
      { x: 0.30, y: 0.40, bright: 1.0, tint: TINT_BLUE_GIANT },       // Sirius
      { x: 0.50, y: 0.25, bright: 0.5 },
      { x: 0.55, y: 0.55, bright: 0.5 },
      { x: 0.70, y: 0.50, bright: 0.6 },
      { x: 0.82, y: 0.70, bright: 0.5 },
    ]},
    // March — Leo (the sickle + triangle; Regulus, Denebola)
    { name: 'Leo', stars: [
      { x: 0.18, y: 0.35, bright: 0.5 },                              // Mane top
      { x: 0.28, y: 0.20, bright: 0.5 },
      { x: 0.40, y: 0.18, bright: 0.6 },
      { x: 0.42, y: 0.50, bright: 0.9 },                              // Regulus (heart)
      { x: 0.62, y: 0.32, bright: 0.5 },                              // Body
      { x: 0.86, y: 0.58, bright: 0.8 },                              // Denebola (tail)
      { x: 0.62, y: 0.70, bright: 0.5 },
    ]},
    // April — Virgo (the long Y; Spica anchors the bottom)
    { name: 'Virgo', stars: [
      { x: 0.15, y: 0.20, bright: 0.5 },
      { x: 0.35, y: 0.30, bright: 0.6 },
      { x: 0.50, y: 0.50, bright: 0.5 },
      { x: 0.62, y: 0.72, bright: 1.0, tint: TINT_BLUE_GIANT },       // Spica
      { x: 0.80, y: 0.30, bright: 0.5 },
      { x: 0.78, y: 0.55, bright: 0.5 },
    ]},
    // May — Bootes (kite shape; Arcturus is the orange anchor)
    { name: 'Bootes', stars: [
      { x: 0.50, y: 0.10, bright: 0.6 },                              // Top of kite
      { x: 0.30, y: 0.40, bright: 0.5 },                              // Left
      { x: 0.70, y: 0.40, bright: 0.5 },                              // Right
      { x: 0.50, y: 0.60, bright: 1.0, tint: TINT_GOLD_GIANT },       // Arcturus
      { x: 0.50, y: 0.88, bright: 0.5 },                              // Foot
    ]},
    // June — Hercules (the keystone trapezoid)
    { name: 'Hercules', stars: [
      { x: 0.30, y: 0.18, bright: 0.5 },
      { x: 0.65, y: 0.15, bright: 0.6 },
      { x: 0.34, y: 0.55, bright: 0.7 },
      { x: 0.70, y: 0.55, bright: 0.7 },
      { x: 0.20, y: 0.78, bright: 0.5 },
      { x: 0.85, y: 0.80, bright: 0.5 },
    ]},
    // July — Scorpius (curved S; Antares is the red heart)
    { name: 'Scorpius', stars: [
      { x: 0.18, y: 0.18, bright: 0.5 },
      { x: 0.28, y: 0.32, bright: 0.5 },
      { x: 0.40, y: 0.45, bright: 1.0, tint: TINT_RED_GIANT },        // Antares
      { x: 0.50, y: 0.55, bright: 0.5 },
      { x: 0.62, y: 0.65, bright: 0.6 },
      { x: 0.78, y: 0.72, bright: 0.5 },
      { x: 0.88, y: 0.55, bright: 0.7 },                              // Stinger
    ]},
    // August — Sagittarius (the Teapot)
    { name: 'Sagittarius', stars: [
      { x: 0.25, y: 0.40, bright: 0.6 },                              // Spout top
      { x: 0.20, y: 0.65, bright: 0.5 },                              // Bottom-left
      { x: 0.55, y: 0.68, bright: 0.5 },                              // Bottom-right
      { x: 0.55, y: 0.40, bright: 0.7 },                              // Handle attach
      { x: 0.40, y: 0.18, bright: 0.8 },                              // Lid
      { x: 0.75, y: 0.45, bright: 0.5 },
      { x: 0.86, y: 0.55, bright: 0.5 },
    ]},
    // September — Cygnus (Northern Cross; Deneb at the top)
    { name: 'Cygnus', stars: [
      { x: 0.50, y: 0.15, bright: 1.0, tint: TINT_WHITE_GIANT },      // Deneb
      { x: 0.50, y: 0.45, bright: 0.5 },                              // Cross center
      { x: 0.50, y: 0.85, bright: 0.7 },                              // Albireo
      { x: 0.22, y: 0.55, bright: 0.5 },                              // Left wing
      { x: 0.78, y: 0.55, bright: 0.6 },                              // Right wing
    ]},
    // October — Pegasus (the Great Square)
    { name: 'Pegasus', stars: [
      { x: 0.30, y: 0.20, bright: 0.7 },                              // Markab
      { x: 0.72, y: 0.20, bright: 0.7 },                              // Scheat
      { x: 0.30, y: 0.78, bright: 0.7 },                              // Algenib
      { x: 0.72, y: 0.78, bright: 0.7 },                              // Alpheratz (shared with Andromeda)
      { x: 0.10, y: 0.18, bright: 0.5 },                              // Enif (nose)
    ]},
    // November — Andromeda (the chain reaching from Pegasus)
    { name: 'Andromeda', stars: [
      { x: 0.18, y: 0.30, bright: 0.8 },                              // Alpheratz
      { x: 0.40, y: 0.45, bright: 0.7 },                              // Mirach
      { x: 0.62, y: 0.55, bright: 0.6 },                              // Almach
      { x: 0.84, y: 0.65, bright: 0.5 },
      { x: 0.40, y: 0.22, bright: 0.5 },                              // Galaxy hint above Mirach
      { x: 0.58, y: 0.78, bright: 0.5 },
    ]},
    // December — Cassiopeia (the W)
    { name: 'Cassiopeia', stars: [
      { x: 0.13, y: 0.30, bright: 0.7 },                              // Caph
      { x: 0.30, y: 0.68, bright: 0.6 },                              // Schedar
      { x: 0.50, y: 0.30, bright: 0.8 },                              // Gamma Cas (middle peak)
      { x: 0.70, y: 0.68, bright: 0.6 },                              // Ruchbah
      { x: 0.87, y: 0.30, bright: 0.7 },                              // Segin
    ]},
  ];

  /* Drawable region inside the 84×37 window (avoids the moon on the
     left and keeps a small safety margin from the frame). */
  const STAR_X_MIN = 26, STAR_X_MAX = 80;
  const STAR_Y_MIN = 3,  STAR_Y_MAX = 30;

  function getTodaysConstellation(date: Date = new Date()): Constellation {
    return CONSTELLATIONS[date.getMonth()] || CONSTELLATIONS[0];
  }

  // ── Celestial positioning ────────────────────────────────────────
  /*
    Sun and moon ride a parabolic arc across the window matching the
    local hour of day:
      sun:  6 AM (left horizon) → noon (high middle) → 6 PM (right horizon)
      moon: 6 PM (left horizon) → midnight (high middle) → 6 AM (right horizon)
    Outside their own visibility windows each body parks at the
    horizon on the relevant edge — they're hidden by the existing
    transform/scale anyway, so the parked position only matters
    visually during the brief sunrise/sunset transitions.

    The window is 84×37 with the moon-zone left margin from earlier;
    sun is 18×18, moon is 16×16. The math leaves a 4px gutter on
    every edge so the body never visually clips the frame.
  */
  function clamp(v: number, lo: number, hi: number): number {
    return Math.min(hi, Math.max(lo, v));
  }
  function lerp(a: number, b: number, t: number): number {
    return a + (b - a) * t;
  }

  function applyCelestialPositions(toggle: HTMLElement, date: Date = new Date()) {
    const hour = date.getHours() + date.getMinutes() / 60;  // 0..24 fractional

    // ── Sun arc: visible 6:00–18:00, parabolic y peaking at noon ──
    const sunProgress = clamp((hour - 6) / 12, 0, 1);
    const sunX = lerp(4, 84 - 18 - 4, sunProgress);          // 4..62
    const sunY = 16 - 14 * Math.sin(Math.PI * sunProgress);  // 16 (horizon) → 2 (noon) → 16

    // ── Moon arc: visible 18:00–06:00, parabolic y peaking at midnight ──
    // Progress = 0 at 18:00 (rises on left), 1 at 06:00 (sets on right).
    const moonProgress = clamp(
      hour >= 18 ? (hour - 18) / 12 : (hour + 6) / 12,
      0, 1
    );
    const moonX = lerp(4, 84 - 16 - 4, moonProgress);          // 4..64
    const moonY = 17 - 13 * Math.sin(Math.PI * moonProgress);  // 17 → 4 → 17

    toggle.style.setProperty('--sun-left', `${sunX.toFixed(1)}px`);
    toggle.style.setProperty('--sun-top',  `${sunY.toFixed(1)}px`);
    toggle.style.setProperty('--moon-left', `${moonX.toFixed(1)}px`);
    toggle.style.setProperty('--moon-top',  `${moonY.toFixed(1)}px`);
  }

  function applyConstellation(root: HTMLElement, date: Date = new Date()) {
    const host = root.querySelector<HTMLElement>('[data-sky-stars]');
    if (!host) return;
    host.replaceChildren();

    const c = getTodaysConstellation(date);
    const dx = STAR_X_MAX - STAR_X_MIN;
    const dy = STAR_Y_MAX - STAR_Y_MIN;

    c.stars.forEach((s) => {
      const star = document.createElement('span');
      star.className = 'star';

      const x = STAR_X_MIN + s.x * dx;
      const y = STAR_Y_MIN + s.y * dy;
      // Brightness 0..1 maps to size 1..2.4px (named giants top out
      // bigger than ordinary stars).
      const size = 1 + s.bright * 1.4;
      // Named star? Use its real-life tint. Otherwise pick from the
      // neutral white/cream/blue/pink palette — gives subtle variety
      // even within one constellation.
      const tint = s.tint
        ?? STAR_TINTS[Math.floor(Math.random() * STAR_TINTS.length)];
      const dur = randomInRange(1.6, 2.8);
      const delay = randomInRange(0, 2);

      star.style.setProperty('--star-x', `${x.toFixed(1)}px`);
      star.style.setProperty('--star-y', `${y.toFixed(1)}px`);
      star.style.setProperty('--star-size', `${size.toFixed(2)}px`);
      star.style.setProperty('--star-tint', tint.body);
      star.style.setProperty('--star-glow', tint.glow);
      star.style.setProperty('--star-dur', `${dur.toFixed(2)}s`);
      star.style.setProperty('--star-delay', `${delay.toFixed(2)}s`);
      // Name is set as data-attr for inspection / future tooltip.
      star.dataset.constellation = c.name;
      host.appendChild(star);
    });
  }

  function randomizeStars(root: HTMLElement) {
    // Wrapper kept for callsite compatibility; the actual placement
    // is now constellation-driven.
    applyConstellation(root);
  }

  /*
    Shooting star scheduler — fires a meteor at a random interval in the
    range [MIN, MAX] seconds. Each meteor spawns with a random start
    position on the top/right edge and travels down-left at a shallow
    angle. The element self-removes via animationend.
  */
  const METEOR_MIN_INTERVAL_S = 6;
  const METEOR_MAX_INTERVAL_S = 16;

  function spawnShootingStar(host: HTMLElement) {
    // Don't animate if window is hidden or user prefers reduced motion.
    if (document.hidden) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    // Don't animate in dark mode — the night sky with meteors is for
    // the light theme preview only.
    if (document.documentElement.classList.contains('dark')) return;

    const el = document.createElement('span');
    el.className = 'shooter';

    // Start position: right edge, upper half of the window
    const startX = randomInRange(50, 62);
    const startY = randomInRange(0, 10);
    // Travel: down-left diagonal across the window
    const dx = randomInRange(-55, -35);
    const dy = randomInRange(14, 22);
    const dur = randomInRange(1.1, 1.7);
    // Rotation to align trail with travel direction
    const angle = Math.atan2(dy, dx) * (180 / Math.PI);

    el.style.setProperty('--shoot-start-x', `${startX.toFixed(1)}px`);
    el.style.setProperty('--shoot-start-y', `${startY.toFixed(1)}px`);
    el.style.setProperty('--shoot-dx', `${dx.toFixed(1)}px`);
    el.style.setProperty('--shoot-dy', `${dy.toFixed(1)}px`);
    el.style.setProperty('--shoot-dur', `${dur.toFixed(2)}s`);
    el.style.setProperty('--shoot-angle', `${angle.toFixed(1)}deg`);

    el.addEventListener('animationend', () => el.remove(), { once: true });
    host.appendChild(el);
  }

  // Track scheduler so we don't leak timers across Astro swaps.
  let meteorTimer: number | undefined;

  function scheduleNextMeteor(host: HTMLElement) {
    const wait = randomInRange(METEOR_MIN_INTERVAL_S, METEOR_MAX_INTERVAL_S) * 1000;
    meteorTimer = window.setTimeout(() => {
      spawnShootingStar(host);
      scheduleNextMeteor(host);
    }, wait);
  }

  function stopMeteors() {
    if (meteorTimer !== undefined) {
      clearTimeout(meteorTimer);
      meteorTimer = undefined;
    }
  }

  /*
    Birds — ten species (eagle, seagull, dove, sparrow, stork, swallow,
    hawk, crow, heron, crane) drift across the day sky at irregular
    intervals. Each spawn picks a random species (with no immediate
    repeats for solo birds), direction, altitude, speed and flap rate,
    then self-removes when its flight animation ends. Birds are skipped
    in dark mode or under prefers-reduced-motion, mirroring the meteor
    scheduler.
  */
  type BirdSpecies = {
    name: string;
    size: [number, number];
    opacity: [number, number];
    altitude: [number, number];
    duration: [number, number];
    /* Wing-flap cycle in ms. Smaller birds flap faster than raptors. */
    flap: [number, number];
    /* SVG markup: a single <svg> with two path groups, .wings-up and
       .wings-down, swapped via the flap animation. viewBox is 40x20 for
       every species so the sizing math in spawnBird() stays uniform. */
    svg: string;
  };

  /*
    Four silhouettes, each with two hand-tuned wing poses. Uses
    stroke="currentColor" with fill="none" so the species `color`
    defined in CSS paints the bird. The body dot is a filled circle
    near the center; head is a small bump just in front of it.
  */
  const EAGLE_SVG =
    '<svg viewBox="0 0 40 20" preserveAspectRatio="xMidYMid meet">' +
      '<g class="wings-up" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 2 13 Q 10 2 20 10 Q 30 2 38 13"/>' +
      '</g>' +
      '<g class="wings-down" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 2 7 Q 10 18 20 10 Q 30 18 38 7"/>' +
      '</g>' +
      '<circle cx="20" cy="10" r="1.5" fill="currentColor"/>' +
      '<path d="M 21 9.5 Q 23 9 23.5 10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/>' +
    '</svg>';

  // Seagull: sharp angular M, pointed wingtips.
  const SEAGULL_SVG =
    '<svg viewBox="0 0 40 20" preserveAspectRatio="xMidYMid meet">' +
      '<g class="wings-up" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 2 12 L 10 3 L 20 10 L 30 3 L 38 12"/>' +
      '</g>' +
      '<g class="wings-down" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 2 8 L 10 17 L 20 10 L 30 17 L 38 8"/>' +
      '</g>' +
    '</svg>';

  // Dove: rounded, softer arcs.
  const DOVE_SVG =
    '<svg viewBox="0 0 40 20" preserveAspectRatio="xMidYMid meet">' +
      '<g class="wings-up" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 5 12 Q 12 4 20 10 Q 28 4 35 12"/>' +
      '</g>' +
      '<g class="wings-down" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 5 9 Q 12 16 20 10 Q 28 16 35 9"/>' +
      '</g>' +
      '<circle cx="20" cy="10" r="1.2" fill="currentColor"/>' +
    '</svg>';

  // Sparrow: compact, short wingspan, fast flap.
  const SPARROW_SVG =
    '<svg viewBox="0 0 40 20" preserveAspectRatio="xMidYMid meet">' +
      '<g class="wings-up" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 10 12 Q 14 6 20 10 Q 26 6 30 12"/>' +
      '</g>' +
      '<g class="wings-down" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 10 9 Q 14 14 20 10 Q 26 14 30 9"/>' +
      '</g>' +
      '<circle cx="20" cy="10" r="1.1" fill="currentColor"/>' +
    '</svg>';

  // Stork (חסידה): wide arched wings, neck stretched forward, legs
  // trailing behind. Slow, graceful flap. The horizontal neck-line
  // is what reads as "stork" at small scale.
  const STORK_SVG =
    '<svg viewBox="0 0 40 20" preserveAspectRatio="xMidYMid meet">' +
      '<g class="wings-up" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 2 11 Q 11 2 20 9 Q 29 2 38 11"/>' +
        '<path d="M 20 9 L 27 8.5 L 30 9.5"/>' +
        '<path d="M 11 11 L 6 14"/>' +
      '</g>' +
      '<g class="wings-down" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 2 8 Q 11 17 20 10 Q 29 17 38 8"/>' +
        '<path d="M 20 10 L 27 9.5 L 30 10"/>' +
        '<path d="M 11 11 L 6 14"/>' +
      '</g>' +
    '</svg>';

  // Swallow (סנונית): sharp V wings, distinctive forked tail.
  // Smallest of the new set, fastest flap.
  const SWALLOW_SVG =
    '<svg viewBox="0 0 40 20" preserveAspectRatio="xMidYMid meet">' +
      '<g class="wings-up" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 4 14 L 14 5 L 20 10 L 26 5 L 36 14"/>' +
        '<path d="M 18 10 L 14 13 M 22 10 L 18 13"/>' +
      '</g>' +
      '<g class="wings-down" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 4 6 L 14 14 L 20 10 L 26 14 L 36 6"/>' +
        '<path d="M 18 10 L 14 13 M 22 10 L 18 13"/>' +
      '</g>' +
    '</svg>';

  // Hawk: swept-back pointed wings with flared tips.
  const HAWK_SVG =
    '<svg viewBox="0 0 40 20" preserveAspectRatio="xMidYMid meet">' +
      '<g class="wings-up" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 6 13 Q 14 4 20 10 Q 26 4 34 13"/>' +
        '<path d="M 6 13 L 3 11"/>' +
        '<path d="M 34 13 L 37 11"/>' +
      '</g>' +
      '<g class="wings-down" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 6 7 Q 14 17 20 10 Q 26 17 34 7"/>' +
        '<path d="M 6 7 L 3 5"/>' +
        '<path d="M 34 7 L 37 5"/>' +
      '</g>' +
      '<circle cx="20" cy="10" r="1.4" fill="currentColor"/>' +
    '</svg>';

  // Crow: blocky, sharp angles. Heaviest stroke for a "solid" feel.
  const CROW_SVG =
    '<svg viewBox="0 0 40 20" preserveAspectRatio="xMidYMid meet">' +
      '<g class="wings-up" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 6 12 L 14 6 L 20 10 L 26 6 L 34 12"/>' +
      '</g>' +
      '<g class="wings-down" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 6 8 L 14 15 L 20 10 L 26 15 L 34 8"/>' +
      '</g>' +
      '<circle cx="20" cy="10" r="1.7" fill="currentColor"/>' +
    '</svg>';

  // Heron: slow, wide wings with a long stretched neck.
  const HERON_SVG =
    '<svg viewBox="0 0 40 20" preserveAspectRatio="xMidYMid meet">' +
      '<g class="wings-up" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 2 12 Q 11 3 20 10 Q 29 3 38 12"/>' +
        '<path d="M 20 10 Q 26 8.5 31 10"/>' +
      '</g>' +
      '<g class="wings-down" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 2 8 Q 11 17 20 10 Q 29 17 38 8"/>' +
        '<path d="M 20 10 Q 26 11.5 31 10"/>' +
      '</g>' +
    '</svg>';

  // Crane: similar long-neck profile to heron but lighter stroke
  // and slimmer body — reads as the slighter cousin in the same sky.
  const CRANE_SVG =
    '<svg viewBox="0 0 40 20" preserveAspectRatio="xMidYMid meet">' +
      '<g class="wings-up" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 4 11 Q 12 3 20 10 Q 28 3 36 11"/>' +
        '<path d="M 20 10 L 26 9.2"/>' +
        '<path d="M 9 11 L 5 13.5"/>' +
      '</g>' +
      '<g class="wings-down" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M 4 9 Q 12 16 20 10 Q 28 16 36 9"/>' +
        '<path d="M 20 10 L 26 10.2"/>' +
        '<path d="M 9 11 L 5 13.5"/>' +
      '</g>' +
    '</svg>';

  /*
    Tuning per species — duration is now 2–4s per the calm-flock spec
    (one flock pass shouldn't linger), and opacity is dialed down to
    0.5–0.7 so the silhouettes blend into the sky atmosphere instead
    of advertising themselves to the reader's peripheral vision.
    Altitude ranges scaled up a touch for the new 32px window height.
  */
  /* Ten silhouettes for real variety — each with a distinct
     profile (wing shape, neck length, body weight, flap rate).
     Stork carries the longest neck/leg trail; swallow is the
     smallest with a forked tail; crane is the slim cousin of
     the heron; crow is the heaviest stroke. Solitary spawns
     also receive a sizeMul + speedMul so no two birds of the
     same species look identical. */
  const BIRD_SPECIES: BirdSpecies[] = [
    { name: 'eagle',   size: [14, 26], opacity: [0.50, 0.72], altitude: [3, 14], duration: [2.8, 4.4], flap: [460, 660], svg: EAGLE_SVG },
    { name: 'seagull', size: [12, 22], opacity: [0.50, 0.74], altitude: [2, 12], duration: [2.4, 3.8], flap: [340, 480], svg: SEAGULL_SVG },
    { name: 'dove',    size: [10, 18], opacity: [0.55, 0.72], altitude: [4, 16], duration: [2.2, 3.6], flap: [240, 360], svg: DOVE_SVG },
    { name: 'sparrow', size: [7,  15], opacity: [0.45, 0.68], altitude: [5, 19], duration: [1.8, 3.2], flap: [150, 240], svg: SPARROW_SVG },
    { name: 'stork',   size: [18, 30], opacity: [0.50, 0.70], altitude: [3, 12], duration: [3.4, 4.8], flap: [560, 760], svg: STORK_SVG },
    { name: 'swallow', size: [8,  14], opacity: [0.45, 0.65], altitude: [4, 18], duration: [1.6, 2.6], flap: [120, 200], svg: SWALLOW_SVG },
    { name: 'hawk',    size: [13, 21], opacity: [0.55, 0.74], altitude: [3, 14], duration: [2.4, 3.6], flap: [380, 520], svg: HAWK_SVG },
    { name: 'crow',    size: [12, 20], opacity: [0.55, 0.78], altitude: [4, 15], duration: [2.6, 4.0], flap: [320, 440], svg: CROW_SVG },
    { name: 'heron',   size: [16, 26], opacity: [0.48, 0.70], altitude: [3, 13], duration: [3.0, 4.4], flap: [520, 700], svg: HERON_SVG },
    { name: 'crane',   size: [14, 22], opacity: [0.48, 0.68], altitude: [3, 14], duration: [3.0, 4.2], flap: [500, 680], svg: CRANE_SVG },
  ];

  /* Window dimensions — read once and reused so size tweaks here
     stay in one place (CSS keeps the source of truth). */
  const WINDOW_WIDTH_PX = 84;
  const WINDOW_HEIGHT_PX = 37;

  // ── Clouds ────────────────────────────────────────────────────────
  /*
    Random cloud spawner. Each cloud is fully procedural — the
    chance of seeing the same shape twice is effectively zero
    because every dimension and every puff is sampled from a
    continuous range.

      width: 14–28px
      height: 45–60% of width (proportional ellipse)
      altitude: anywhere in the available vertical range
      opacity: 0.6–0.95
      drift duration: 22–34s (slower clouds outlast faster ones,
                              so different clouds overlap on screen)
      puff count: 2–4
      puff size: 40–70% of cloud width
      puff position: scattered across the cloud body
  */
  function spawnCloud(host: HTMLElement, opts: { delaySec?: number } = {}) {
    if (document.hidden) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (!document.documentElement.classList.contains('dark')) return;
    if (document.documentElement.dataset.disableSkyClouds === 'true') return;

    /* Smaller, more delicate cumulus — was 14-28 px, now 8-17 px so
       the clouds read as distant rather than pressing up against the
       window. The proportional height ratio stays the same. */
    const w = randomInRange(8, 17);
    const h = randomInRange(w * 0.45, w * 0.6);
    // Altitude: keep the cloud fully inside the window vertically
    // (with a tiny margin so the soft halo doesn't get clipped).
    const maxY = Math.max(2, WINDOW_HEIGHT_PX - h - 2);
    const y = randomInRange(2, maxY);
    const opacity = randomInRange(0.6, 0.95);
    const dur = randomInRange(22, 34);

    const startX = WINDOW_WIDTH_PX + 4;
    const endX = -(w + 4);
    const dx = endX - startX;

    const cloud = document.createElement('div');
    cloud.className = 'cloud';
    cloud.style.setProperty('--cloud-w', `${w.toFixed(1)}px`);
    cloud.style.setProperty('--cloud-h', `${h.toFixed(1)}px`);
    cloud.style.setProperty('--cloud-y', `${y.toFixed(1)}px`);
    cloud.style.setProperty('--cloud-opacity', opacity.toFixed(2));
    cloud.style.setProperty('--cloud-dur', `${dur.toFixed(1)}s`);
    cloud.style.setProperty('--cloud-x-start', `${startX.toFixed(1)}px`);
    cloud.style.setProperty('--cloud-x-end', `${(startX + dx).toFixed(1)}px`);
    if (opts.delaySec) {
      // Negative delay = "skip ahead" — used at init to bootstrap
      // clouds already partway across the window so the sky isn't
      // empty for the first 20s.
      cloud.style.setProperty('--cloud-delay', `${opts.delaySec.toFixed(1)}s`);
    }

    // 2–3 puffs (was 2–4) scattered along the upper half of the body.
    // Smaller clouds carry fewer puffs — keeps the silhouette tidy
    // without blob-ing up. Each puff is its own random size + position.
    const numPuffs = 2 + Math.floor(Math.random() * 2); // 2 / 3
    for (let i = 0; i < numPuffs; i++) {
      const puff = document.createElement('span');
      puff.className = 'cloud-puff';
      const pw = randomInRange(w * 0.40, w * 0.70);
      const ph = pw * randomInRange(0.85, 1.15); // near-circle
      // Spread puffs across the full width so two never stack
      // identically. The leftmost puff is biased left, rightmost
      // biased right, middle puffs anywhere in between.
      const slot = (i + randomInRange(0, 0.6)) / numPuffs;
      const px = slot * (w - pw);
      // Sit on top of the body — top offset between -55% and -15%
      // of the puff width so each puff peeks above at a different
      // height.
      const py = -pw * randomInRange(0.15, 0.55);
      puff.style.width = `${pw.toFixed(1)}px`;
      puff.style.height = `${ph.toFixed(1)}px`;
      puff.style.left = `${px.toFixed(1)}px`;
      puff.style.top = `${py.toFixed(1)}px`;
      cloud.appendChild(puff);
    }

    cloud.addEventListener('animationend', () => cloud.remove(), { once: true });
    host.appendChild(cloud);
  }

  /* Cadence: clouds spawn every 3.5–7.5s, with each lasting 22–34s
     across the window. That gives ~4–8 clouds visible at any time
     — continuous ambient sky cover, but every cloud unique. Hover
     speeds the cadence up. */
  const CLOUD_INTERVAL_S: [number, number] = [3.5, 7.5];
  const CLOUD_INTERVAL_HOVER_S: [number, number] = [2.0, 4.5];

  let cloudTimer: number | undefined;
  let cloudHoverActive = false;
  let celestialTimer: number | undefined;

  function scheduleNextCloud(host: HTMLElement) {
    const range = cloudHoverActive ? CLOUD_INTERVAL_HOVER_S : CLOUD_INTERVAL_S;
    const wait = randomInRange(range[0], range[1]) * 1000;
    cloudTimer = window.setTimeout(() => {
      spawnCloud(host);
      scheduleNextCloud(host);
    }, wait);
  }

  function stopClouds() {
    if (cloudTimer !== undefined) {
      clearTimeout(cloudTimer);
      cloudTimer = undefined;
    }
  }

  /* Bootstrap: when the page first opens (or theme flips back to
     dark), the cloud host is empty. Pre-seed 4 clouds with negative
     animation-delays so they appear already mid-flight, distributed
     across the window. The user sees a populated sky immediately. */
  function bootstrapClouds(host: HTMLElement) {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (!document.documentElement.classList.contains('dark')) return;
    if (document.documentElement.dataset.disableSkyClouds === 'true') return;

    const seedCount = 4;
    for (let i = 0; i < seedCount; i++) {
      // Each seed is "already X seconds into its drift" — distributed
      // evenly across the cycle so they spread across the window.
      const progress = (i + randomInRange(0, 0.6)) / seedCount; // 0..1
      const dur = randomInRange(22, 34);
      spawnCloud(host, { delaySec: -dur * progress });
    }
  }

  /* Per-bird spawn options — when omitted, every parameter is
     randomized independently. The flock spawner overrides them so
     all birds in a flock share a species + direction + altitude
     with small per-bird variation, which is what reads as "flock"
     vs. "scattered solo birds". */
  type SpawnOpts = {
    species?: BirdSpecies;
    dir?: 1 | -1;
    altitudeBase?: number;
    altitudeJitter?: number;
    sizeMul?: number;
    speedMul?: number;
  };

  function birdsDisabled(): boolean {
    if (document.hidden) return true;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return true;
    // Future-toggle hook: any code path may opt out of bird animation
    // by setting <html data-disable-sky-birds="true">. Keeps the API
    // pre-wired without imposing a UI yet.
    if (document.documentElement.dataset.disableSkyBirds === 'true') return true;
    // Day-sky only renders as a preview while the site is in dark mode.
    if (!document.documentElement.classList.contains('dark')) return true;
    return false;
  }

  function spawnBird(host: HTMLElement, opts: SpawnOpts = {}) {
    if (birdsDisabled()) return;

    const species = opts.species
      ?? BIRD_SPECIES[Math.floor(Math.random() * BIRD_SPECIES.length)];
    const dir: 1 | -1 = opts.dir ?? (Math.random() < 0.5 ? 1 : -1);
    const sizeMul = opts.sizeMul ?? 1;
    const speedMul = opts.speedMul ?? 1;
    const size = randomInRange(species.size[0], species.size[1]) * sizeMul;

    // Altitude: when a flock supplies a base + small jitter, all birds
    // sit on roughly the same line (with mild scatter). Otherwise we
    // fall back to the species range.
    const altitude = opts.altitudeBase !== undefined
      ? opts.altitudeBase + randomInRange(-(opts.altitudeJitter ?? 1.5), (opts.altitudeJitter ?? 1.5))
      : randomInRange(species.altitude[0], species.altitude[1]);

    // Start just outside the window and fly all the way across to the other
    // edge (+/- a bit of overscan so the bird doesn't pop in/out visibly).
    const overscan = size + 6;
    const W = WINDOW_WIDTH_PX;
    const startX = dir === 1 ? -overscan : (W + overscan);
    const endX   = dir === 1 ? (W + overscan) : -overscan;
    const dx = endX - startX;

    const bird = document.createElement('span');
    bird.className = `bird bird-${species.name}`;
    bird.innerHTML = species.svg;

    bird.style.setProperty('--bird-size', `${size.toFixed(1)}px`);
    bird.style.setProperty('--bird-y', `${altitude.toFixed(1)}px`);
    bird.style.setProperty('--bird-start-x', `${startX.toFixed(1)}px`);
    // Precomputed X offsets relative to start position for each keyframe,
    // because calc() inside @keyframes with nested var() can fail to
    // resolve in some engines. Pure numeric px values sidestep that.
    bird.style.setProperty('--bird-x-25',  `${(dx * 0.25).toFixed(1)}px`);
    bird.style.setProperty('--bird-x-50',  `${(dx * 0.50).toFixed(1)}px`);
    bird.style.setProperty('--bird-x-75',  `${(dx * 0.75).toFixed(1)}px`);
    bird.style.setProperty('--bird-x-100', `${dx.toFixed(1)}px`);
    const dur = randomInRange(species.duration[0], species.duration[1]) / speedMul;
    bird.style.setProperty('--bird-dur', `${dur.toFixed(2)}s`);
    bird.style.setProperty('--bird-opacity', randomInRange(species.opacity[0], species.opacity[1]).toFixed(2));
    // Wing-flap rate — faster for small birds, slower for raptors.
    bird.style.setProperty('--flap-dur', `${Math.round(randomInRange(species.flap[0], species.flap[1]))}ms`);
    // SVGs face right by convention; flip when flying R→L so the head
    // and body point the right way.
    bird.style.setProperty('--bird-dir', dir === 1 ? '1' : '-1');

    bird.addEventListener('animationend', () => bird.remove(), { once: true });
    host.appendChild(bird);
  }

  /*
    Flock spawner — all birds share species + direction + a common
    altitude, but each gets per-bird variation:
      - size ±10%
      - speed ±15% (some birds drift ahead, others fall behind →
        natural V/streamer formation instead of a parade line)
      - altitude ±3px (wider scatter than before; the previous
        1.8px felt too "single-line" and stiff)
      - stagger is randomized PER bird (60–260ms) instead of a
        constant interval, so the flock arrives in irregular clumps

    Flock size leans small (mostly 3–6, occasional 7–12) — the spec
    asks for "calm breathing moment", not a migration event.
  */
  function spawnFlock(host: HTMLElement) {
    if (birdsDisabled()) return;

    const species = BIRD_SPECIES[Math.floor(Math.random() * BIRD_SPECIES.length)];
    const dir: 1 | -1 = Math.random() < 0.5 ? 1 : -1;
    const altitudeBase = randomInRange(species.altitude[0] + 1, species.altitude[1] - 1);

    // Heavily biased toward smaller flocks: ~75% are 3–6, ~25% are
    // 7–12. Real flocks of these sizes feel native; larger ones
    // are reserved for the rare migration moment.
    const isLarge = Math.random() < 0.25;
    const size = isLarge
      ? Math.floor(randomInRange(7, 12.99))
      : Math.floor(randomInRange(3, 6.99));

    let cumulativeDelay = 0;
    for (let i = 0; i < size; i++) {
      // Each gap is independently random — the second bird might
      // arrive 70ms after the first, the third 240ms after that, etc.
      // Reads as breathing rather than ticking.
      if (i > 0) cumulativeDelay += randomInRange(60, 260);
      const captureDelay = cumulativeDelay;
      window.setTimeout(() => {
        spawnBird(host, {
          species,
          dir,
          altitudeBase,
          altitudeJitter: 3.0,
          sizeMul: randomInRange(0.88, 1.10),
          speedMul: randomInRange(0.85, 1.15),
        });
      }, captureDelay);
    }
  }

  /* Solitary spawner — a single bird drifts across alone. Each
     solitary gets a sizeMul (0.78–1.25) and speedMul (0.85–1.20)
     applied on top of the species range, so two doves still look
     different from each other. To force perceptible variety we
     also avoid spawning the same species two solitaries in a row:
     `lastSoloSpecies` is excluded from the random pick. */
  let lastSoloSpecies: string | null = null;

  function pickSoloSpecies(): BirdSpecies {
    const pool = lastSoloSpecies
      ? BIRD_SPECIES.filter(s => s.name !== lastSoloSpecies)
      : BIRD_SPECIES;
    const choice = pool[Math.floor(Math.random() * pool.length)];
    lastSoloSpecies = choice.name;
    return choice;
  }

  function spawnSolitary(host: HTMLElement) {
    if (birdsDisabled()) return;
    const species = pickSoloSpecies();
    spawnBird(host, {
      species,
      // direction stays fully random so consecutive birds can
      // cross from opposite sides
      sizeMul: randomInRange(0.78, 1.25),
      speedMul: randomInRange(0.85, 1.20),
    });
    // Occasional pair: 18% chance a second bird (DIFFERENT species
    // again — also picked via pickSoloSpecies) trails 400-900ms
    // behind. Reads as two unrelated birds happening to cross at
    // once rather than a tiny flock.
    if (Math.random() < 0.18) {
      const secondSpecies = pickSoloSpecies();
      window.setTimeout(() => spawnBird(host, {
        species: secondSpecies,
        sizeMul: randomInRange(0.78, 1.25),
        speedMul: randomInRange(0.85, 1.20),
      }), randomInRange(400, 900));
    }
  }

  /* Cadence — a bird (or flock) starts every 1.5–3.5s, so the user
     sees something passing through the window at least every ~3
     seconds on average. Hover tightens it further. The intervals
     are sampled uniformly so the gap feels organic, never on a
     metronome. */
  const BIRD_INTERVAL_S: [number, number] = [1.5, 3.5];
  const BIRD_INTERVAL_HOVER_S: [number, number] = [0.8, 2.0];

  /* Mode mix per scheduled tick: 85% solitary, 15% flock. Flocks
     are rare events; solitary birds (random species, random
     direction) carry the day-to-day "sky is alive" feel without
     overcrowding the window. */
  const FLOCK_PROBABILITY = 0.15;

  let birdTimer: number | undefined;
  let birdHoverActive = false;

  function scheduleNextBird(host: HTMLElement) {
    const range = birdHoverActive ? BIRD_INTERVAL_HOVER_S : BIRD_INTERVAL_S;
    const wait = randomInRange(range[0], range[1]) * 1000;
    birdTimer = window.setTimeout(() => {
      if (Math.random() < FLOCK_PROBABILITY) {
        spawnFlock(host);
      } else {
        spawnSolitary(host);
      }
      scheduleNextBird(host);
    }, wait);
  }

  function stopBirds() {
    if (birdTimer !== undefined) {
      clearTimeout(birdTimer);
      birdTimer = undefined;
    }
  }

  function initThemeToggle() {
    const toggle = document.getElementById('theme-toggle');
    if (!toggle) return;

    // Apply current theme
    const current = getEffectiveTheme();
    applyTheme(current);

    // Randomize star positions for this page load so the sky never
    // looks identical twice in a row.
    randomizeStars(toggle);

    // Compute and apply today's lunar phase.
    const moonEl = toggle.querySelector<HTMLElement>('[data-sky-moon]');
    if (moonEl) applyMoonPhase(moonEl);

    // Position sun + moon along their hour-of-day arcs. Refreshed
    // every 10 minutes via a low-impact timer so the bodies glide
    // forward across long open sessions without animating constantly.
    applyCelestialPositions(toggle);
    if (celestialTimer !== undefined) clearInterval(celestialTimer);
    celestialTimer = window.setInterval(() => {
      applyCelestialPositions(toggle);
    }, 10 * 60 * 1000);

    // Kick off the shooting-star loop.
    const shooterHost = toggle.querySelector<HTMLElement>('[data-sky-shooters]');
    stopMeteors();
    if (shooterHost) scheduleNextMeteor(shooterHost);

    // Kick off the bird loop (day-sky only; the spawn function gates
    // itself). The first solitary bird appears within 0.5-1.5s so
    // the window reads as alive immediately on page load; subsequent
    // birds follow the random 1.5-3.5s cadence.
    const birdHost = toggle.querySelector<HTMLElement>('[data-sky-birds]');
    stopBirds();
    if (birdHost) {
      window.setTimeout(() => spawnSolitary(birdHost), randomInRange(500, 1500));
      scheduleNextBird(birdHost);
    }

    // Kick off the cloud loop — bootstrap a few mid-flight clouds so
    // the sky reads as populated immediately, then schedule fresh
    // unique clouds at the configured cadence.
    const cloudHost = toggle.querySelector<HTMLElement>('[data-sky-clouds]');
    stopClouds();
    if (cloudHost) {
      bootstrapClouds(cloudHost);
      scheduleNextCloud(cloudHost);
    }

    // Hover handler — bumps both bird and cloud cadence into their
    // faster ranges while the cursor is over the window, reverts on
    // leave. Doesn't trigger an instant spawn; the next scheduled
    // tick simply uses the shorter interval.
    toggle.addEventListener('mouseenter', () => {
      birdHoverActive = true;
      cloudHoverActive = true;
    });
    toggle.addEventListener('mouseleave', () => {
      birdHoverActive = false;
      cloudHoverActive = false;
    });

    // Toggle on click
    toggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const newTheme = isDark ? 'light' : 'dark';
      try { localStorage.setItem('yuval-theme', newTheme); } catch { /* */ }
      applyTheme(newTheme);

      // Birds live in the toggle's day sky, which is only visible while
      // the site is in dark mode. When switching to dark, kick off a
      // quick first bird so the freshly-revealed day sky feels alive,
      // and re-bootstrap clouds so the sky isn't empty for the first
      // 3-7s of cadence. Switching to light: clear mid-flight elements
      // so they don't linger behind the night-sky scene.
      if (newTheme === 'dark') {
        if (birdHost) {
          window.setTimeout(() => spawnBird(birdHost), randomInRange(600, 1400));
        }
        if (cloudHost) {
          cloudHost.replaceChildren();
          bootstrapClouds(cloudHost);
        }
      } else {
        if (birdHost) birdHost.replaceChildren();
        if (cloudHost) cloudHost.replaceChildren();
      }
    });
  }

  // System preference change — only follow if user hasn't made a choice
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!getStoredTheme()) {
      applyTheme(e.matches ? 'dark' : 'light');
    }
  });

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThemeToggle);
  } else {
    initThemeToggle();
  }

  // Re-init on Astro navigation (and clean up the old schedulers)
  document.addEventListener('astro:before-swap', () => {
    stopMeteors();
    stopBirds();
    stopClouds();
    if (celestialTimer !== undefined) {
      clearInterval(celestialTimer);
      celestialTimer = undefined;
    }
  });
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
