---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<button
  id="theme-toggle"
  type="button"
  role="switch"
  aria-checked="false"
  aria-label="Toggle dark mode"
  dir="ltr"
  class:list={['sky-window', className]}
>
  <!-- Sky background layers -->
  <div class="sky-scene">
    <!-- Day sky -->
    <div class="sky-layer sky-day"></div>
    <!-- Night sky -->
    <div class="sky-layer sky-night">
      <div class="galaxy-layer galaxy-base"></div>
      <div class="galaxy-layer galaxy-nebula"></div>
      <div class="galaxy-layer galaxy-dust"></div>
    </div>
    
    <!-- Stars (night only) - galaxy field -->
    <div class="stars">
      <span class="star star-1"></span>
      <span class="star star-2"></span>
      <span class="star star-3"></span>
      <span class="star star-4"></span>
      <span class="star star-5"></span>
      <span class="star star-6"></span>
      <span class="star star-7"></span>
      <span class="star star-8"></span>
      <span class="star star-9"></span>
      <span class="star star-10"></span>
      <span class="star star-11"></span>
      <span class="star star-12"></span>
    </div>
    
    <!-- Sun -->
    <div class="celestial sun">
      <div class="sun-core"></div>
      <div class="sun-rays"></div>
      <div class="sun-glow"></div>
    </div>
    
    <!-- Moon -->
    <div class="celestial moon">
      <div class="moon-surface"></div>
      <div class="moon-crater moon-crater-1"></div>
      <div class="moon-crater moon-crater-2"></div>
      <div class="moon-crater moon-crater-3"></div>
      <div class="moon-glow"></div>
    </div>
    
    <!-- Clouds - continuous drift -->
    <div class="clouds">
      <div class="cloud-track">
        <div class="cloud cloud-a"></div>
        <div class="cloud cloud-b"></div>
        <div class="cloud cloud-c"></div>
        <div class="cloud cloud-d"></div>
        <div class="cloud cloud-e"></div>
      </div>
    </div>
  </div>
  
  <!-- Glass frame overlay -->
  <div class="window-frame"></div>
</button>

<style>
  .sky-window {
    position: relative;
    width: 64px;
    height: 28px;
    border-radius: 14px;
    overflow: visible;
    cursor: pointer;
    border: none;
    padding: 0;
    background: transparent;
    transition: transform 0.3s ease;
  }
  
  .sky-window:hover {
    transform: scale(1.05);
  }
  
  .sky-window:active {
    transform: scale(0.98);
  }
  
  .sky-window:focus {
    outline: none;
  }
  
  .sky-window:focus .window-frame {
    box-shadow:
      0 0 0 2px var(--yuval-highlight),
      0 2px 8px rgba(139, 105, 20, 0.3),
      inset 0 1px 2px rgba(255, 255, 255, 0.5),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2);
  }
  
  .sky-scene {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: 12px;
    z-index: 2;
  }
  
  /* Sky backgrounds */
  .sky-layer {
    position: absolute;
    inset: 0;
    transition: opacity 0.6s ease;
  }
  
  /* In LIGHT mode: show night sky (preview of what you'll get) */
  /* In DARK mode: show day sky (preview of what you'll get) */
  .sky-day {
    background: linear-gradient(
      180deg,
      #4facfe 0%,
      #87ceeb 40%,
      #b4e4ff 100%
    );
    opacity: 0;
  }
  
  .sky-night {
    background: #050510;
    opacity: 1;
    overflow: hidden;
  }

  .galaxy-layer {
    position: absolute;
    inset: -50%;
    width: 200%;
    height: 200%;
  }

  /* Deep space base with cosmic colors */
  .galaxy-base {
    background: radial-gradient(
      ellipse at 30% 40%,
      #1a1035 0%,
      #0d0d1a 40%,
      #050510 70%
    );
    animation: galaxy-drift 60s linear infinite;
  }

  /* Nebula clouds - purples, blues, pinks */
  .galaxy-nebula {
    background: 
      radial-gradient(ellipse at 20% 30%, rgba(99, 66, 153, 0.4) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 60%, rgba(45, 85, 150, 0.35) 0%, transparent 45%),
      radial-gradient(ellipse at 50% 80%, rgba(150, 70, 120, 0.3) 0%, transparent 40%),
      radial-gradient(ellipse at 80% 20%, rgba(70, 100, 170, 0.25) 0%, transparent 35%);
    animation: nebula-flow 45s ease-in-out infinite alternate;
    mix-blend-mode: screen;
  }

  /* Cosmic dust and glow */
  .galaxy-dust {
    background: 
      radial-gradient(ellipse at 40% 50%, rgba(255, 200, 150, 0.08) 0%, transparent 30%),
      radial-gradient(ellipse at 60% 30%, rgba(200, 180, 255, 0.06) 0%, transparent 25%);
    animation: dust-shimmer 30s ease-in-out infinite alternate-reverse;
    mix-blend-mode: overlay;
  }

  @keyframes galaxy-drift {
    0% { transform: translate(0, 0) rotate(0deg); }
    100% { transform: translate(-25%, -25%) rotate(10deg); }
  }

  @keyframes nebula-flow {
    0% { transform: translate(0, 0) scale(1); opacity: 0.8; }
    50% { transform: translate(-10%, 5%) scale(1.1); opacity: 1; }
    100% { transform: translate(5%, -10%) scale(1.05); opacity: 0.9; }
  }

  @keyframes dust-shimmer {
    0% { transform: translate(0, 0); opacity: 0.5; }
    100% { transform: translate(10%, -5%); opacity: 0.8; }
  }

  :global(.dark) .sky-day {
    opacity: 1;
  }

  :global(.dark) .sky-night {
    opacity: 0;
  }

  :global(.dark) .galaxy-base,
  :global(.dark) .galaxy-nebula,
  :global(.dark) .galaxy-dust {
    animation-play-state: paused;
  }
  
  /* Stars - visible in light mode (preview of dark) */
  .stars {
    position: absolute;
    inset: 0;
    opacity: 1;
    transition: opacity 0.6s ease 0.2s;
  }
  
  :global(.dark) .stars {
    opacity: 0;
  }
  
  .star {
    position: absolute;
    width: 2px;
    height: 2px;
    background: white;
    border-radius: 50%;
    animation: twinkle 2s ease-in-out infinite;
    box-shadow: 0 0 3px rgba(255, 255, 255, 0.8), 0 0 6px rgba(200, 180, 255, 0.4);
  }
  
  .star-1 { top: 5px; left: 8px; animation-delay: 0s; box-shadow: 0 0 4px rgba(255, 200, 150, 0.9); }
  .star-2 { top: 8px; left: 44px; animation-delay: 0.3s; width: 1.5px; height: 1.5px; }
  .star-3 { top: 15px; left: 6px; animation-delay: 0.6s; width: 1px; height: 1px; }
  .star-4 { top: 4px; left: 24px; animation-delay: 0.9s; width: 1.5px; height: 1.5px; box-shadow: 0 0 4px rgba(180, 200, 255, 0.9); }
  .star-5 { top: 18px; left: 50px; animation-delay: 1.2s; width: 1px; height: 1px; }
  .star-6 { top: 22px; left: 14px; animation-delay: 0.4s; width: 1px; height: 1px; }
  .star-7 { top: 10px; left: 54px; animation-delay: 0.8s; width: 1.5px; height: 1.5px; }
  .star-8 { top: 3px; left: 36px; animation-delay: 1.5s; width: 1px; height: 1px; }
  .star-9 { top: 20px; left: 30px; animation-delay: 0.2s; width: 1.5px; height: 1.5px; box-shadow: 0 0 4px rgba(255, 180, 200, 0.8); }
  .star-10 { top: 12px; left: 18px; animation-delay: 1.1s; width: 1px; height: 1px; }
  .star-11 { top: 7px; left: 56px; animation-delay: 0.7s; width: 1px; height: 1px; }
  .star-12 { top: 24px; left: 42px; animation-delay: 1.4s; width: 1px; height: 1px; }
  
  @keyframes twinkle {
    0%, 100% { opacity: 0.4; transform: scale(1); filter: brightness(0.8); }
    25% { opacity: 0.8; }
    50% { opacity: 1; transform: scale(1.3); filter: brightness(1.3); }
    75% { opacity: 0.7; }
  }
  
  /* Celestial bodies positioning */
  .celestial {
    position: absolute;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  
  /* Sun - hidden in light mode, visible in dark (preview of light) */
  .sun {
    width: 18px;
    height: 18px;
    top: 5px;
    left: 6px;
    transform: translateY(30px) scale(0.5);
  }
  
  :global(.dark) .sun {
    transform: translateY(0) scale(1);
  }
  
  .sun-core {
    position: absolute;
    width: 14px;
    height: 14px;
    top: 2px;
    left: 2px;
    background: linear-gradient(135deg, #fff9c4 0%, #ffeb3b 50%, #ffc107 100%);
    border-radius: 50%;
    box-shadow: 0 0 8px #ffeb3b;
  }
  
  .sun-rays {
    position: absolute;
    width: 18px;
    height: 18px;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      rgba(255, 235, 59, 0.4) 10deg,
      transparent 20deg,
      transparent 45deg,
      rgba(255, 235, 59, 0.4) 55deg,
      transparent 65deg,
      transparent 90deg,
      rgba(255, 235, 59, 0.4) 100deg,
      transparent 110deg,
      transparent 135deg,
      rgba(255, 235, 59, 0.4) 145deg,
      transparent 155deg,
      transparent 180deg,
      rgba(255, 235, 59, 0.4) 190deg,
      transparent 200deg,
      transparent 225deg,
      rgba(255, 235, 59, 0.4) 235deg,
      transparent 245deg,
      transparent 270deg,
      rgba(255, 235, 59, 0.4) 280deg,
      transparent 290deg,
      transparent 315deg,
      rgba(255, 235, 59, 0.4) 325deg,
      transparent 335deg
    );
    border-radius: 50%;
    animation: rotate-rays 20s linear infinite;
  }
  
  @keyframes rotate-rays {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  .sun-glow {
    position: absolute;
    width: 22px;
    height: 22px;
    top: -2px;
    left: -2px;
    background: radial-gradient(
      circle,
      rgba(255, 235, 59, 0.3) 0%,
      transparent 70%
    );
    border-radius: 50%;
    animation: pulse-glow 3s ease-in-out infinite;
  }
  
  @keyframes pulse-glow {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.1); opacity: 0.8; }
  }
  
  /* Moon - visible in light mode (preview of dark), hidden in dark */
  .moon {
    width: 16px;
    height: 16px;
    top: 6px;
    right: 6px;
    left: auto;
    transform: translateY(0) scale(1);
  }
  
  :global(.dark) .moon {
    transform: translateY(30px) scale(0.5);
  }
  
  .moon-surface {
    position: absolute;
    width: 14px;
    height: 14px;
    top: 1px;
    left: 1px;
    background: linear-gradient(135deg, #eceff1 0%, #cfd8dc 50%, #b0bec5 100%);
    border-radius: 50%;
    box-shadow: 
      inset -2px -2px 4px rgba(0, 0, 0, 0.1),
      0 0 12px rgba(255, 255, 255, 0.3);
  }
  
  .moon-crater {
    position: absolute;
    background: rgba(176, 190, 197, 0.6);
    border-radius: 50%;
  }
  
  .moon-crater-1 {
    width: 3px;
    height: 3px;
    top: 4px;
    left: 4px;
  }
  
  .moon-crater-2 {
    width: 2px;
    height: 2px;
    top: 8px;
    left: 8px;
  }
  
  .moon-crater-3 {
    width: 2px;
    height: 2px;
    top: 5px;
    left: 10px;
  }
  
  .moon-glow {
    position: absolute;
    width: 20px;
    height: 20px;
    top: -2px;
    left: -2px;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.2) 0%,
      transparent 60%
    );
    border-radius: 50%;
  }
  
  /* Clouds - hidden in light mode, visible in dark (preview of light) */
  .clouds {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    overflow: hidden;
  }
  
  :global(.dark) .clouds {
    opacity: 1;
  }
  
  /* Cloud track - infinite scroll container */
  .cloud-track {
    position: absolute;
    width: 200%;
    height: 100%;
    animation: drift-clouds 25s linear infinite;
  }
  
  @keyframes drift-clouds {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  
  .cloud {
    position: absolute;
    background: rgba(255, 255, 255, 0.85);
    border-radius: 10px;
  }
  
  .cloud::before,
  .cloud::after {
    content: '';
    position: absolute;
    background: inherit;
    border-radius: 50%;
  }
  
  /* Cloud A - fluffy cumulus */
  .cloud-a {
    width: 14px;
    height: 5px;
    bottom: 8px;
    left: 5px;
  }
  .cloud-a::before {
    width: 7px;
    height: 7px;
    top: -4px;
    left: 2px;
  }
  .cloud-a::after {
    width: 6px;
    height: 6px;
    top: -3px;
    left: 7px;
  }
  
  /* Cloud B - small wisp */
  .cloud-b {
    width: 8px;
    height: 3px;
    bottom: 14px;
    left: 28px;
    opacity: 0.7;
  }
  .cloud-b::before {
    width: 4px;
    height: 4px;
    top: -2px;
    left: 1px;
  }
  .cloud-b::after {
    width: 3px;
    height: 3px;
    top: -1px;
    left: 4px;
  }
  
  /* Cloud C - tall puffy */
  .cloud-c {
    width: 11px;
    height: 4px;
    bottom: 5px;
    left: 45px;
  }
  .cloud-c::before {
    width: 8px;
    height: 8px;
    top: -5px;
    left: 1px;
  }
  .cloud-c::after {
    width: 5px;
    height: 5px;
    top: -2px;
    left: 5px;
  }
  
  /* Cloud D - stretched cirrus (duplicate of A for seamless loop) */
  .cloud-d {
    width: 14px;
    height: 5px;
    bottom: 8px;
    left: 57px;
  }
  .cloud-d::before {
    width: 7px;
    height: 7px;
    top: -4px;
    left: 2px;
  }
  .cloud-d::after {
    width: 6px;
    height: 6px;
    top: -3px;
    left: 7px;
  }
  
  /* Cloud E - small wisp (duplicate of B for seamless loop) */
  .cloud-e {
    width: 8px;
    height: 3px;
    bottom: 14px;
    left: 80px;
    opacity: 0.7;
  }
  .cloud-e::before {
    width: 4px;
    height: 4px;
    top: -2px;
    left: 1px;
  }
  .cloud-e::after {
    width: 3px;
    height: 3px;
    top: -1px;
    left: 4px;
  }

  /* Window frame - metallic with animated shine */
  .window-frame {
    position: absolute;
    inset: -2px;
    border-radius: 16px;
    pointer-events: none;
    /* Light mode: silver/purple frame (matches moon preview) */
    background: linear-gradient(
      135deg,
      #7c8ba1 0%,
      #c4d0e4 15%,
      #9ba8c2 30%,
      #4a5568 45%,
      #6b7db3 55%,
      #a78bba 70%,
      #c4b5d8 85%,
      #8b7ca8 100%
    );
    z-index: 0;
    box-shadow:
      0 2px 12px rgba(107, 125, 179, 0.4),
      0 0 20px rgba(167, 139, 186, 0.2),
      inset 0 1px 2px rgba(255, 255, 255, 0.4),
      inset 0 -1px 2px rgba(0, 0, 0, 0.3);
    transition: all 0.6s ease;
  }
  
  /* Inner frame edge */
  .window-frame::before {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 12px;
    border: 1px solid rgba(196, 181, 216, 0.3);
    background: transparent;
  }
  
  /* Dark mode: gold frame (matches sun preview) */
  :global(.dark) .window-frame {
    background: linear-gradient(
      135deg,
      #d4a574 0%,
      #f4e4bc 15%,
      #c9a55c 30%,
      #8b6914 50%,
      #c9a55c 70%,
      #f4e4bc 85%,
      #d4a574 100%
    );
    box-shadow:
      0 2px 8px rgba(139, 105, 20, 0.3),
      inset 0 1px 2px rgba(255, 255, 255, 0.5),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2);
  }
  
  :global(.dark) .window-frame::before {
    border-color: rgba(255, 255, 255, 0.3);
  }
  
  :global(.dark) .sky-window:focus .window-frame {
    box-shadow:
      0 0 0 2px var(--yuval-highlight),
      0 2px 8px rgba(139, 105, 20, 0.3),
      inset 0 1px 2px rgba(255, 255, 255, 0.5),
      inset 0 -1px 2px rgba(0, 0, 0, 0.2);
  }
</style>

<script>
  function getStoredTheme(): 'light' | 'dark' | null {
    try {
      const stored = localStorage.getItem('yuval-theme');
      if (stored === 'light' || stored === 'dark') return stored;
    } catch { /* storage unavailable */ }
    return null;
  }

  function getSystemPreference(): 'dark' | 'light' {
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function getEffectiveTheme(): 'light' | 'dark' {
    return getStoredTheme() || getSystemPreference();
  }

  function applyTheme(theme: 'light' | 'dark') {
    document.documentElement.classList.toggle('dark', theme === 'dark');
    const toggle = document.getElementById('theme-toggle');
    if (toggle) {
      toggle.setAttribute('aria-checked', theme === 'dark' ? 'true' : 'false');
    }
  }

  function initThemeToggle() {
    const toggle = document.getElementById('theme-toggle');
    if (!toggle) return;

    // Apply current theme
    const current = getEffectiveTheme();
    applyTheme(current);

    // Toggle on click
    toggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const newTheme = isDark ? 'light' : 'dark';
      try { localStorage.setItem('yuval-theme', newTheme); } catch { /* */ }
      applyTheme(newTheme);
    });
  }

  // Listen for system preference changes
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!getStoredTheme()) {
      applyTheme(e.matches ? 'dark' : 'light');
    }
  });

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThemeToggle);
  } else {
    initThemeToggle();
  }

  // Re-init on Astro navigation
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
