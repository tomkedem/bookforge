---
import type { Language } from '../types/index';
import { SOURCE_LANGUAGE } from '../utils/language';

interface Props {
  scrollPercentage?: number;
  language?: Language;
  class?: string;
}

const { scrollPercentage = 0, language = SOURCE_LANGUAGE, class: className } = Astro.props;

const ariaLabel =
  language === 'he' ? `התקדמות קריאה: ${Math.round(scrollPercentage)}%` : `Reading progress: ${Math.round(scrollPercentage)}%`;
---

<div
  class:list={['reading-progress-bar', className]}
  role="progressbar"
  aria-label={ariaLabel}
  aria-valuenow={Math.round(scrollPercentage)}
  aria-valuemin={0}
  aria-valuemax={100}
>
  <div class="progress-fill" style={`width: ${scrollPercentage}%`}></div>
</div>

<style>
  .reading-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 60;
    height: 3px;
    background: transparent;
    pointer-events: none;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    border-radius: 0 2px 2px 0;
    background: linear-gradient(90deg,
      #f59e0b,
      #ef4444,
      #ec4899,
      #8b5cf6,
      #3b82f6,
      #06b6d4
    );
    background-size: 300% 100%;
    animation: shimmer 8s linear infinite;
    transition: width 0.12s linear;
    box-shadow: 0 0 8px rgba(139, 92, 246, 0.4);
  }

  @keyframes shimmer {
    0%   { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }

  /* Dark mode — brighter glow */
  :global(.dark) .progress-fill {
    background: linear-gradient(90deg,
      #fbbf24,
      #f87171,
      #f472b6,
      #a78bfa,
      #60a5fa,
      #22d3ee
    );
    background-size: 300% 100%;
    animation: shimmer 8s linear infinite;
    box-shadow: 0 0 12px rgba(167, 139, 250, 0.6);
  }

  @media (prefers-reduced-motion: reduce) {
    .progress-fill {
      animation: none;
    }
  }
</style>

<script>
  function initializeProgress(controller: AbortController) {
    const bar = document.querySelector('.reading-progress-bar') as HTMLElement | null;
    if (!bar) return;

    const fill = bar.querySelector('.progress-fill') as HTMLElement | null;

    function update() {
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const pct = total > 0 ? Math.min(100, (window.scrollY / total) * 100) : 0;

      if (fill) fill.style.width = `${pct}%`;
      if (bar) bar.setAttribute('aria-valuenow', Math.round(pct).toString());
    }

    window.addEventListener('scroll', update, { passive: true, signal: controller.signal });
    update();
  }

  function setup() {
    const controller = new AbortController();
    initializeProgress(controller);

    const cleanup = () => controller.abort();
    document.addEventListener('astro:before-unmount', cleanup);
    window.addEventListener('unload', cleanup);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }

  document.addEventListener('astro:after-swap', setup);
</script>
