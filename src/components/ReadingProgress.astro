---
/**
 * ReadingProgress.astro
 * Fixed 2px progress bar tracking scroll position.
 * Position: directly below the header (top: 68px).
 */
---

<div
  id="reading-progress-bar"
  class="fixed left-0 right-0 z-[99] h-0.5 origin-left"
  style="top: 68px; transform: scaleX(0); background-color: #1a1a1a;"
  role="progressbar"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-valuenow="0"
  aria-label="Reading progress"
></div>

<script>
  (function () {
    const bar = document.getElementById('reading-progress-bar');
    if (!bar) return;

    function update(): void {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
      (bar as HTMLElement).style.transform = `scaleX(${progress})`;
      bar.setAttribute('aria-valuenow', String(Math.round(progress * 100)));
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  })();
</script>
