---
/**
 * Book Overview — Progress section.
 *
 * Three-column layout in the new BO palette:
 *   Left   → "Progress" label + large percentage
 *   Center → gradient progress bar (purple → blue → cyan)
 *   Right  → "Chapter X of Y" link + "n of total completed" line
 *
 * All colors come from `--bo-*` tokens. No gold anywhere.
 *
 * Server renders the calm not-started state (label + 0% empty bar).
 * A scoped client script scans `localStorage` for
 * `yuval_reading_progress_<slug>_ch<id>` keys (same shape used by the
 * page's updateChapterProgress) and swaps in:
 *   - overall percentage  (avg of clamped chapter percentages)
 *   - completed-chapters count  (chapters with pct >= 85)
 *   - current chapter      (most-recently-updated unfinished chapter,
 *                           falling back to first not-yet-completed)
 *
 * Chapter id+titles travel via a `data-chapters` JSON attribute so the
 * client can re-render on language toggle without a server hop.
 */

import type { Chapter, Language } from '../../types/index';
import { t } from '../../i18n';

interface Props {
  chapters: Chapter[];
  slug: string;
  language: Language;
  isRtl: boolean;
}

const { chapters, slug, language, isRtl } = Astro.props;

// Strip down to what the client script needs (id + titles). Keeps the
// inline JSON small even on long books.
const chaptersData = JSON.stringify(
  chapters.map((c) => ({ id: c.id, titles: c.titles })),
);
---

<section
  class:list={['bop', isRtl && 'is-rtl']}
  aria-label={t('bookOverview.notStarted', language)}
  data-book-slug={slug}
  data-chapters={chaptersData}
>
  <div class="bop-card" data-bop-state="empty">
    <!-- LEFT: label + percentage -->
    <div class="bop-left">
      <span class="bop-label" data-i18n="reading.leftDock.progress">
        {t('reading.leftDock.progress', language)}
      </span>
      <span class="bop-pct" data-bop-pct>0%</span>
    </div>

    <!-- CENTER: gradient bar (or empty-state message + empty track) -->
    <div class="bop-center">
      <p
        class="bop-empty"
        data-bop-empty
        data-i18n="bookOverview.notStarted"
      >
        {t('bookOverview.notStarted', language)}
      </p>
      <div class="bop-bar" aria-hidden="true">
        <div class="bop-bar-fill" data-bop-fill style="width: 0%"></div>
      </div>
    </div>

    <!-- RIGHT: current chapter + completed count -->
    <div class="bop-right" data-bop-right hidden>
      <a
        class="bop-current"
        data-bop-current-link
        href="#"
        data-i18n-template="nav.chapterOf"
      ></a>
      <span class="bop-completed" data-bop-completed></span>
    </div>
  </div>
</section>

<script>
  // Hydrate from localStorage. Storage shape is set by the reading
  // page's progress tracker:
  //   yuval_reading_progress_<slug>_ch<id> =>
  //     { percentage?: number, scrollPosition?: number, lastUpdated?: number }
  // Re-runs on view transitions, language toggles, and tab focus.
  import { t, resolveLanguage } from '../../i18n';

  const COMPLETED_THRESHOLD = 85;

  type ChapterEntry = { id: string | number; titles: Record<string, string> };
  type ChapterProgress = { pct: number; updated: number };

  function pickLocalized(
    titles: Record<string, string>,
    lang: string,
  ): string {
    return (
      titles[lang] ||
      titles['he'] ||
      Object.values(titles).find(Boolean) ||
      ''
    );
  }

  function readProgress(slug: string): Map<string, ChapterProgress> {
    const fragment = `reading_progress_${slug}_ch`;
    const out = new Map<string, ChapterProgress>();

    for (let i = 0; i < localStorage.length; i++) {
      const k = localStorage.key(i);
      if (!k || !k.includes(fragment)) continue;
      try {
        const d = JSON.parse(localStorage.getItem(k) || '{}');
        const m = k.match(/_ch(.+)$/);
        if (!m) continue;
        const id = m[1];

        let pct =
          typeof d.percentage === 'number' && d.percentage > 0
            ? Math.min(100, d.percentage)
            : 0;
        if (
          pct === 0 &&
          typeof d.scrollPosition === 'number' &&
          d.scrollPosition > 200
        ) {
          // Old entry without `percentage`. Estimate roughly from pixels.
          pct = Math.min(95, Math.round((d.scrollPosition / 3000) * 100));
        }
        const updated = typeof d.lastUpdated === 'number' ? d.lastUpdated : 0;

        const prev = out.get(id);
        if (!prev || updated > prev.updated) out.set(id, { pct, updated });
      } catch {
        /* skip malformed */
      }
    }
    return out;
  }

  function update(): void {
    const root = document.querySelector<HTMLElement>('.bop[data-book-slug]');
    if (!root) return;

    const slug = root.dataset.bookSlug;
    const raw = root.dataset.chapters;
    if (!slug || !raw) return;

    let chapters: ChapterEntry[] = [];
    try {
      chapters = JSON.parse(raw);
    } catch {
      return;
    }

    const lang = resolveLanguage(document.documentElement.lang);
    const progress = readProgress(slug);
    const total = chapters.length;

    let completed = 0;
    let sumPct = 0;
    let bestCurrent: ChapterEntry | null = null;
    let bestCurrentIdx = -1;
    let bestUpdated = -Infinity;

    chapters.forEach((ch, idx) => {
      const idStr = String(ch.id);
      const entry = progress.get(idStr);
      const pct = entry?.pct ?? 0;
      sumPct += pct;
      if (pct >= COMPLETED_THRESHOLD) {
        completed += 1;
      } else if (pct > 0 && entry && entry.updated > bestUpdated) {
        bestUpdated = entry.updated;
        bestCurrent = ch;
        bestCurrentIdx = idx;
      }
    });

    // Fall back to the first not-yet-completed chapter when nothing is
    // mid-read but some chapters are done — gives the user a target.
    if (!bestCurrent && completed > 0 && completed < total) {
      const fallbackIdx = chapters.findIndex((c) => {
        const e = progress.get(String(c.id));
        return !e || e.pct < COMPLETED_THRESHOLD;
      });
      if (fallbackIdx >= 0) {
        bestCurrent = chapters[fallbackIdx];
        bestCurrentIdx = fallbackIdx;
      }
    }

    const overallPct = total > 0 ? Math.round(sumPct / total) : 0;
    const hasAnyProgress = sumPct > 0 || completed > 0;

    // ── DOM updates ───────────────────────────────────────────────
    const card = root.querySelector<HTMLElement>('.bop-card');
    const fill = root.querySelector<HTMLElement>('[data-bop-fill]');
    const pctEl = root.querySelector<HTMLElement>('[data-bop-pct]');
    const emptyEl = root.querySelector<HTMLElement>('[data-bop-empty]');
    const rightEl = root.querySelector<HTMLElement>('[data-bop-right]');
    const currentLink = root.querySelector<HTMLAnchorElement>(
      '[data-bop-current-link]',
    );
    const completedEl = root.querySelector<HTMLElement>(
      '[data-bop-completed]',
    );

    if (fill) fill.style.width = `${overallPct}%`;

    if (!hasAnyProgress) {
      if (card) card.dataset.bopState = 'empty';
      if (pctEl) pctEl.textContent = '0%';
      if (emptyEl) {
        emptyEl.hidden = false;
        emptyEl.textContent = t('bookOverview.notStarted', lang);
      }
      if (rightEl) rightEl.hidden = true;
      root.setAttribute('aria-label', t('bookOverview.notStarted', lang));
      return;
    }

    if (card) card.dataset.bopState = 'progress';
    if (pctEl) pctEl.textContent = `${overallPct}%`;
    if (emptyEl) emptyEl.hidden = true;

    if (rightEl && currentLink && completedEl) {
      if (bestCurrent && bestCurrentIdx >= 0) {
        const chapterNum = bestCurrentIdx + 1;
        const label = t('nav.chapterOf', lang, {
          n: String(chapterNum),
          total: String(total),
        });
        currentLink.textContent = label;
        currentLink.href = `/read/${slug}/${bestCurrent.id}`;
        currentLink.title = pickLocalized(bestCurrent.titles, lang);
        currentLink.hidden = false;
      } else {
        currentLink.textContent = '';
        currentLink.removeAttribute('href');
        currentLink.title = '';
        currentLink.hidden = true;
      }

      completedEl.textContent = t('bookOverview.chaptersCompleted', lang, {
        n: String(completed),
        total: String(total),
      });

      rightEl.hidden = false;
    }

    root.setAttribute(
      'aria-label',
      `${overallPct}% — ${t('bookOverview.chaptersCompleted', lang, {
        n: String(completed),
        total: String(total),
      })}`,
    );
  }

  function boot(): void {
    update();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot, { once: true });
  } else {
    boot();
  }

  document.addEventListener('astro:after-swap', boot);
  window.addEventListener('language-changed', boot);
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') boot();
  });
  window.addEventListener('pageshow', boot);
</script>

<style>
  /* ── Card shell ───────────────────────────────────────────────────
     Dark glass surface with a faint surface-elevated bias. Sits below
     the hero, so visual weight stays well under the hero card. */
  .bop {
    width: 100%;
  }

  .bop-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem 1.25rem;
    align-items: center;
    padding: 0.85rem 1.1rem;
    border-radius: 14px;
    background: linear-gradient(
      135deg,
      var(--bo-surface) 0%,
      var(--bo-surface-elevated) 100%
    );
    border: 1px solid var(--bo-border);
    color: var(--bo-text-primary);
  }

  /* Three columns once the card has the room. The bar takes the bulk
     of the width; left/right hug their content. */
  @media (min-width: 640px) {
    .bop-card {
      grid-template-columns: minmax(auto, 6.5rem) minmax(0, 1fr) minmax(auto, 14rem);
      padding: 1rem 1.25rem;
    }
  }

  /* ── Left: label + percentage ────────────────────────────────── */
  .bop-left {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1.1;
  }
  .bop-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--bo-text-muted);
  }
  .bop-pct {
    font-family: 'Spectral', 'Frank Ruhl Libre', ui-serif, Georgia, serif;
    font-weight: 600;
    font-size: clamp(1.4rem, 2.2vw, 1.75rem);
    color: var(--bo-text-primary);
    font-feature-settings: 'tnum';
    letter-spacing: -0.01em;
  }
  /* Empty state: gentle muted percentage rather than a loud "0%". */
  .bop-card[data-bop-state='empty'] .bop-pct {
    color: var(--bo-text-muted);
  }

  /* ── Center: bar + empty-state line ──────────────────────────── */
  .bop-center {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }
  .bop-empty {
    margin: 0;
    font-size: 0.85rem;
    font-style: italic;
    color: var(--bo-text-muted);
  }
  .bop-card[data-bop-state='progress'] .bop-empty {
    display: none;
  }
  /* In the empty state, the empty-line sits *above* the empty bar so
     the bar reads as a placeholder rail rather than as data. */
  .bop-card[data-bop-state='empty'] .bop-empty {
    display: block;
  }

  .bop-bar {
    position: relative;
    height: 6px;
    border-radius: 999px;
    background: rgba(148, 163, 184, 0.10);
    overflow: hidden;
  }
  .bop-bar-fill {
    block-size: 100%;
    inline-size: 0;
    border-radius: inherit;
    background: var(--bo-grad-progress);
    box-shadow: 0 0 12px rgba(124, 58, 237, 0.25);
    transition: inline-size 600ms cubic-bezier(0.22, 0.61, 0.36, 1),
                width 600ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  /* RTL: brighter cyan end aligns with the reading-direction leading
     edge. The fill still grows from the inline-start side because the
     width transition is direction-agnostic. */
  .bop.is-rtl .bop-bar-fill {
    background: var(--bo-grad-progress-rtl);
  }

  /* ── Right: current + completed ──────────────────────────────── */
  .bop-right {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-align: end;
    min-width: 0;
  }
  .bop-right[hidden] {
    display: none;
  }
  .bop-current {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--bo-text-primary);
    text-decoration: none;
    border-block-end: 1px solid transparent;
    transition: color 160ms ease, border-color 160ms ease;
    align-self: flex-end;
  }
  .bop-current:hover {
    color: var(--bo-cyan);
    border-block-end-color: var(--bo-cyan);
  }
  .bop-current:focus-visible {
    outline: 2px solid var(--bo-focus-ring);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .bop-completed {
    font-size: 0.8rem;
    color: var(--bo-text-secondary);
    font-feature-settings: 'tnum';
  }

  /* ── RTL alignment ───────────────────────────────────────────── */
  /* The grid template is direction-agnostic via logical properties on
     children — the container's text-align gets swapped by the .is-rtl
     flag for the right column to read as the leading-edge data. */
  .bop.is-rtl .bop-right {
    text-align: end; /* still end (= start of RTL line) */
  }

  /* ── Reduced motion ──────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .bop-bar-fill {
      transition: none;
    }
    .bop-current {
      transition: none;
    }
  }
</style>
