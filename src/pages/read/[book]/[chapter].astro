---
import ReadingLayout from '../../../layouts/ReadingLayout.astro';
import ChapterNavigation from '../../../components/ChapterNavigation.astro';
import ChapterSidebars from '../../../components/ChapterSidebars.astro';
import ChapterMeta from '../../../components/ChapterMeta.astro';
import type { Language, Chapter } from '../../../types/index';
import { SUPPORTED_LANGUAGES, SOURCE_LANGUAGE } from '../../../utils/language';
import { t } from '../../../i18n';
import { readFileSync } from 'fs';
import { resolve } from 'path';
import { marked } from '../../../utils/markdown';
import { discoverAllBooks } from '../../../utils/book-discovery';
import { extractSectionPreviews } from '../../../utils/sidebar/preview-extractor';

type LocalizedMap = Record<string, string | undefined>;

function getLocalized(value: LocalizedMap | undefined, lang: string): string {
  if (!value) return '';
  return value[lang] ?? value[SOURCE_LANGUAGE] ?? Object.values(value)[0] ?? '';
}

export async function getStaticPaths() {
  const books = discoverAllBooks();
  return books.flatMap(book =>
    book.chapters.map(ch => ({
      params: { book: book.slug, chapter: String(ch.id) }
    }))
  );
}

const { book, chapter: chapterIdStr } = Astro.params;
const rawChapterId = chapterIdStr || '0';
const parsedNum = parseInt(rawChapterId, 10);
const chapterId: number | string =
  !Number.isNaN(parsedNum) && String(parsedNum) === rawChapterId ? parsedNum : rawChapterId;

const books = discoverAllBooks();
const bookData = books.find(b => b.slug === book);

if (!bookData) {
  return new Response('Book not found', { status: 404 });
}

const chapters: Chapter[] = bookData.chapters ?? [];
const current = chapters.find(ch => String(ch.id) === String(chapterId));

if (!current) {
  return new Response('Chapter not found', { status: 404 });
}

const availableLangs =
  bookData.languages?.length
    ? bookData.languages
    : Object.keys(bookData.titles || {});

const supportedCodes = SUPPORTED_LANGUAGES.map(l => l.code);

const langs = supportedCodes.filter(l => availableLangs.includes(l));

function annotateBookmarkAnchors(html: string): string {
  const counters = { p: 0, h: 0 };
  return html.replace(/<(p|h2|h3)(\s[^>]*)?>/gi, (_, tagRaw: string, attrsRaw?: string) => {
    const tag = tagRaw.toLowerCase();
    const attrs = attrsRaw || '';
    if (/\sdata-bm-anchor=/.test(attrs)) {
      return `<${tag}${attrs}>`;
    }
    const key = tag === 'p' ? 'p' : 'h';
    const n = ++counters[key];
    return `<${tag}${attrs} data-bm-anchor="${key}-${n}">`;
  });
}

/** Serialize section previews into a `<script type="application/json">`
 *  tag that lives at the very top of `.chapter-content` (before the
 *  first heading), so it's never a sibling of any h2/h3 — important
 *  because `extractSectionsFromDoc` walks heading siblings to count
 *  characters per section, and including this JSON in that count would
 *  poison the per-section reading-time distribution.
 *
 *  JSON inside `<script type="application/json">` isn't HTML-parsed
 *  except for one sequence: `</script>` closes the tag. Replacing the
 *  literal `<` with its unicode escape inside the JSON string body is
 *  the standard guard, and a no-op for valid JSON readers. */
function buildPreviewsScript(md: string): string {
  const previews = extractSectionPreviews(md);
  if (previews.length === 0) return '';
  const json = JSON.stringify(previews).replace(/</g, '\\u003c');
  return `<script type="application/json" class="chapter-previews-data">${json}</script>`;
}

async function loadContent(lang: string): Promise<string> {
  const fileSlug =
    (current as any).file_slug ||
    (typeof chapterId === 'string'
      ? chapterId
      : `chapter-${String(chapterId).padStart(2, '0')}`);
  const filename = `${fileSlug}.${lang}.md`;

  const path = resolve(`output/${book}`, filename);

  try {
    const md = readFileSync(path, 'utf-8');
    const previewsScript = buildPreviewsScript(md);
    let html = await marked(md);
    html = html.replaceAll('src="../assets/', `src="/${book}/assets/`);
    // Remove leading <h1>...</h1> if present (to avoid duplicate chapter title)
    html = html.replace(/^<h1[^>]*>.*?<\/h1>/s, '');
    html = annotateBookmarkAnchors(html);
    return previewsScript + html;
  } catch {
    return `<h2 data-bm-anchor="h-1">${getLocalized(current.titles, lang)}</h2>`;
  }
}

const contentByLang = Object.fromEntries(
  await Promise.all(
    langs.map(async l => [l, await loadContent(l)])
  )
) as Record<string, string>;

const language = (langs.includes(SOURCE_LANGUAGE) ? SOURCE_LANGUAGE : langs[0] || SOURCE_LANGUAGE) as Language;
---

<ReadingLayout
  title={getLocalized(current.titles, language)}
  language={language}
  availableLanguages={langs as Language[]}
>

  <ChapterSidebars
    slot="sidebars"
    chapters={chapters}
    currentChapterId={chapterId}
    bookSlug={book || ''}
    language={language}
  />
  {/* Unified top strip: sticky band between the sidebars that merges what
      used to be three stacked regions — title card, meta stats, progress
      chip — into a single compact row. Nested IDs are preserved so every
      consumer keeps working:
        #chapter-top-strip  → sticky shadow + ResizeObserver (sticky-header.ts)
        #chapter-header     → language-switcher + tap-to-top (chapter-title-tap.ts)
        #chapter-meta-bar   → language-switcher
      All [data-lang] blocks live once inside the same DOM subtree; the
      switcher toggles them once per ID it scans, which is idempotent. */}
  <div id="chapter-top-strip" class="chapter-top-strip">
    <div id="chapter-header" class="chapter-strip-inner">
      <div id="chapter-meta-bar" class="chapter-strip-rows">
        {langs.map(l => {
          const hasNumber = typeof chapterId === 'number';
          const chapterWord = t('chapter.label', l);
          return (
            <div
              data-lang={l}
              class={l === language ? 'visible strip-row' : 'hidden strip-row'}
              dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
            >
              {hasNumber && (
                <div class="strip-num-cluster" aria-hidden="true">
                  <span class="strip-eyebrow">{chapterWord}</span>
                  <div class="strip-pill">
                    <span class="pill-number">{String(chapterId).padStart(2, '0')}</span>
                  </div>
                </div>
              )}
              <div class="strip-title-wrap">
                <h1 class="chapter-title strip-title">
                  <span class="chapter-title-text">{getLocalized(current.titles, l)}</span>
                </h1>
              </div>
              <div class="strip-meta">
                <ChapterMeta
                  wordCount={current.word_count}
                  readingTimeMinutes={Math.ceil(current.word_count / 200)}
                  sections={current.sections}
                  language={l}
                />
              </div>
              {/* Completion indicator — hidden by default, revealed by
                  the chapter-row class toggler in ChapterSidebars when
                  the chapter is marked complete. Sits inline with the
                  meta items so it reads as one row. */}
              <div class="strip-completion" id={`strip-completion-${l}`} aria-hidden="true">
                <span class="strip-completion-dot" aria-hidden="true"></span>
                <span class="strip-completion-text">{l === 'he' ? 'הקריאה הושלמה' : l === 'es' ? 'Lectura completa' : 'Reading complete'}</span>
              </div>
              {/* Position-in-chapter percentage. The ID is preserved
                  (progress-badge-{l}) so existing scroll listeners
                  continue to find it; the visual is now plain text
                  with a thin progress bar painted as a sibling at the
                  bottom of the strip-row. No SVG. */}
              <div class="progress-badge" id={`progress-badge-${l}`} role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
                <span class="progress-label">0%</span>
              </div>
              {/* Thin progress bar that runs the full width of the row.
                  Updated alongside the percentage by sidebar-progress.ts.
                  Position: absolute so it sits flush with the row's
                  bottom border. */}
              <div class="strip-progress-bar" id={`strip-progress-bar-${l}`} aria-hidden="true">
                <div class="strip-progress-bar-fill"></div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <div id="chapter-container" data-book={book} data-chapter-id={chapterId} data-word-count={current.word_count}>
    {langs.map(l => (
      <div
        data-lang={l}
        class={l === language ? 'visible' : 'hidden'}
        dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
      >
        <div class="chapter-content prose prose-lg">
          <Fragment set:html={contentByLang[l]} />
        </div>
      </div>
    ))}

    <ChapterNavigation
      currentChapterId={chapterId}
      chapters={chapters}
      bookSlug={book || ''}
      language={language}
    />
  </div>
</ReadingLayout>

<style>
.hidden { display: none !important; }
.visible { display: block; }

/* ─────────────────────────────────────────────────────────────
   UNIFIED TOP STRIP — modernized
   Sticky band between sidebars that holds chapter number + title
   + meta stats + progress badge in a single row.

   Visual update: replaced the heavy gold-on-gold "old book" feel
   with a flat, modern bar that uses gold only as accent (chapter
   pill, eyebrow, progress ring). The bar itself is nearly
   transparent with a faint gold tint and a thin bottom divider —
   enough hierarchy to separate it from content while sticky, but
   not enough to compete with the reading text.
   ───────────────────────────────────────────────────────────── */
.chapter-top-strip {
  position: sticky;
  /* Dock flush against the bottom of the platform header.
     sticky-header.ts keeps --reading-sticky-top in sync with
     #site-header.offsetHeight via a ResizeObserver, so this
     value matches the header's height exactly at every
     breakpoint and on font/quote changes. */
  top: var(--reading-sticky-top, 4rem);
  z-index: 46;
  /* No explicit width — let block-level `width: auto` fill the
     available inline space. This is what allows the negative
     `margin-inline-end` at desktop (-320px - 2rem) to extend the
     strip past .reading-article's content edge all the way to the
     LeftSidebar. With `width: 100%` the layout was over-constrained
     and the browser silently dropped the trailing margin, leaving
     a large empty gap on the inline-end side. */
  /* No vertical margin — the strip must sit flush against the
     platform header above and provide its own breathing room
     to the content below. */
  margin: 0 0 1rem;
  padding: 0;

  /* Faint gold tint over the reading background — gives the strip a
     "tone" so it reads as header chrome, but the eye doesn't get
     pulled to it. */
  background:
    linear-gradient(to bottom,
      color-mix(in srgb, var(--yuval-reading-bg) 96%, transparent),
      color-mix(in srgb, var(--yuval-reading-bg) 88%, transparent 12%));
  backdrop-filter: blur(14px);
  box-shadow: none;
}

/* Mobile / tablet: parent .reading-article has horizontal padding
   (px-4 = 16px on phone, sm:px-6 = 24px on tablet) that constrains
   our strip to a narrower column. Use negative inline margins to
   break out of that padding and let the strip extend edge-to-edge.
   Also add a small top margin so the strip isn't flush against the
   quote on mobile (the desktop -15px lift was tuned for the desktop
   header layout). */
@media (max-width: 1023px) {
  .chapter-top-strip {
    /* Break out of .reading-article's px-6 (24px) horizontal padding. */
    margin-inline-start: -1.5rem;
    margin-inline-end: -1.5rem;
  }
}

@media (max-width: 639px) {
  .chapter-top-strip {
    /* Force true edge-to-edge on phone regardless of any ancestor
       padding (px-4 on .reading-article, plus any other wrappers
       that might constrain width). 100vw + negative half-vw margin
       is the one trick that always wins. */
    width: 100vw;
    max-width: 100vw;
    margin-inline-start: calc(50% - 50vw);
    margin-inline-end: calc(50% - 50vw);
    /* Tighter spacing on phone so the strip doesn't dominate the
       viewport. */
    margin-bottom: 0.25rem;
  }
}

.chapter-top-strip.scrolled {
  box-shadow: none;
}

.chapter-strip-inner,
.chapter-strip-rows {
  width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 0;
}

/* One row per language (language-switcher toggles .hidden/.visible).
   Modern flat row: faint gold tint (4%), thin bottom divider, no
   border accent strip — gold "lives" in the chapter pill + eyebrow
   instead. */
.strip-row {
  position: relative;
  display: flex;
  /* baseline alignment so the completion pill, percent text, and meta
     items all sit on the same text baseline. align-items: center
     made the pill optically drop below text since its border+padding
     gave it more vertical mass than the surrounding meta. */
  align-items: baseline;
  /* No-wrap so the completion pill stays inline with the meta items
     instead of dropping to a second row when the strip is narrow.
     The meta items themselves will compress / ellipsize before the
     pill is pushed below. */
  flex-wrap: nowrap;
  gap: 0.4rem 0.85rem;
  /* Tighter vertical padding for a compact, single-line header.
     Note: padding-bottom is forced to 0 by the global selector in
     reading-typography.css (.reading-content *:not(code)...), so
     row height is controlled entirely by padding-top. To shave 2px
     off the row, padding-top is dropped 2px below 0.5rem (8px → 6px). */
  padding: 6px 0.85rem 0.5rem;
  border-radius: 0;
  background: rgba(201, 162, 39, 0.04);
  border-bottom: 0.5px solid var(--yuval-border, rgba(127, 127, 127, 0.18));
  box-shadow: none;
  overflow: visible;
}

.strip-row.hidden {
  display: none !important;
}

/* "Tucked-under" illusion: a thin gradient overlay painted on top of
   the strip-row's background, fading from a soft shadow at the very
   top edge to transparent ~10px down. The eye reads this as the
   platform header casting a shadow onto the strip below — i.e. the
   strip is sliding out from under the header.
   Pointer-events: none so it doesn't block taps; positioned absolute
   in the row's relative box, painted above .strip-row's solid
   background but below its text. */
.strip-row::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 10px;
  background: linear-gradient(
    to bottom,
    rgba(17, 24, 39, 0.18) 0%,
    rgba(17, 24, 39, 0.06) 55%,
    transparent 100%
  );
  pointer-events: none;
  z-index: 0;
}

:global(.dark) .strip-row::before {
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.55) 0%,
    rgba(0, 0, 0, 0.20) 55%,
    transparent 100%
  );
}

/* Lift the row's actual content above the shadow overlay. */
.strip-row > * {
  position: relative;
  z-index: 1;
}

:global(.dark) .strip-row {
  background: rgba(201, 162, 39, 0.05);
  border-bottom-color: rgba(255, 255, 255, 0.06);
  box-shadow: none;
}

/* "Chapter NN" cluster — groups the localized label with the gold
   number pill so they read as one unit, mirroring the pattern used on
   the book landing page. The inner pill keeps its own styling. */
/* "Chapter NN" cluster — groups the localized label with the gold
   number pill so they read as one unit ("פרק 04" / "Chapter 04"). */
.strip-num-cluster {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

/* Compact number pill — modernized.
   Old: solid gold gradient + ring-shadow + inset highlight (heavy).
   New: outlined gold pill (border + faint fill), text in gold instead
   of white. Reads as accent, not as a button. */
.strip-pill {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 1.5rem;
  min-width: 1.5rem;
  padding: 0 0.45rem;
  border-radius: 99px;
  background: rgba(201, 162, 39, 0.10);
  border: 1px solid rgba(201, 162, 39, 0.4);
  box-shadow: none;
}

:global(.dark) .strip-pill {
  background: rgba(168, 149, 109, 0.12);
  border-color: rgba(168, 149, 109, 0.45);
  box-shadow: none;
}

.pill-number {
  font-family: var(--reading-font-family);
  font-size: 0.85rem;
  font-weight: 500;
  color: #c9a227;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.03em;
  direction: ltr;
}

:global(.dark) .pill-number {
  color: #d4c098;
}

/* Eyebrow + title laid out inline on a single baseline so the whole
   strip collapses to one row. The title takes the remaining width and
   truncates with ellipsis if it can't all fit. */
.strip-title-wrap {
  flex: 1 1 12rem;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 0.5rem;
  line-height: 1.2;
}

/* Eyebrow ("פרק" / "Chapter") — modernized.
   Old: tiny 0.62rem extra-bold uppercase in gold-mix, sat as a separate
   word above/beside the pill.
   New: same-size as pill, sits cleanly to the trailing side of the
   pill. Subtler weight, same gold tone — reads as one unit
   "פרק 04". */
.strip-eyebrow {
  flex-shrink: 0;
  font-family: var(--reading-font-family);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #c9a227;
  line-height: 1;
  user-select: none;
}

:global(.dark) .strip-eyebrow {
  color: #d4c098;
}

/* Title — the class .chapter-title is preserved (highlighter depends
   on it at highlighter.ts:820). Modernized: weight 500 instead of 700
   so the title doesn't compete with the gold pill or the reading
   text below. Color stays semantic via --yuval-chapter-title. */
.strip-title {
  margin: 0;
  display: block;
  font-family: var(--reading-font-family);
  font-size: clamp(1rem, 0.85rem + 0.55vw, 1.15rem);
  font-weight: 500;
  line-height: 1.25;
  letter-spacing: -0.005em;
  color: var(--yuval-chapter-title);
  text-align: start;
  text-wrap: balance;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chapter-title-text {
  flex: 1 1 auto;
  min-width: 0;
}

/* Meta stats pushed to the trailing edge; ChapterMeta's own styles are
   overridden in this context so it renders as a thin icon+text row. */
.strip-meta {
  flex: 0 1 auto;
  min-width: 0;
  margin-inline-start: auto;
}

#chapter-meta-bar :global(.chapter-meta),
#chapter-meta-bar :global(.chapter-meta .meta-item),
#chapter-meta-bar :global(.chapter-meta .meta-item *:not(.meta-icon):not(.meta-dot)) {
  font-size: 0.78rem;
}

#chapter-meta-bar :global(.chapter-meta) {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  gap: 0.25rem 0.5rem;
  justify-content: flex-end;
  flex-wrap: nowrap;
  color: var(--yuval-text-secondary, #374151);
  opacity: 1;
  font-weight: 500;
}

#chapter-meta-bar :global(.meta-icon) {
  width: 0.9rem;
  height: 0.9rem;
  opacity: 1;
}

#chapter-meta-bar :global(.meta-dot) {
  font-size: 0.9rem;
  opacity: 0.7;
}

/* Progress ring — pinned to the trailing edge of the strip row.
   Apple-Activity-ring style gold ring that fills as you scroll; the
   center label shows minutes remaining (e.g. "7'") with a % fallback
   if word_count isn't available. Filled state shows a ✓ mark.
   The SVG ring references #ring-gold-gradient from the global <defs>
   in ReadingLayout.astro so all three language-row rings share one gradient. */
/* Progress percent — text-only.
   Lives inline in the meta row and shows the reader's CURRENT POSITION
   in the chapter (not whether they have completed it). The matching
   horizontal bar lives below at .strip-progress-bar. */
.progress-badge {
  flex-shrink: 0;
  display: inline-flex;
  align-items: baseline;
  gap: 0.2rem;
  font-family: var(--reading-font-family);
}

.progress-label {
  font-size: 0.85rem;
  font-weight: 600;
  color: #c9a227;
  letter-spacing: 0.01em;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  direction: ltr;
  unicode-bidi: isolate;
}

:global(.dark) .progress-label {
  color: #d4c098;
}

/* Horizontal progress bar — option ג.
   Sits flush at the bottom edge of .strip-row, runs the full width
   minus the row's padding (negative margins extend it edge-to-edge).
   Static rail + gold gradient fill that grows with scroll position. */
.strip-progress-bar {
  position: absolute;
  inset-inline-start: 0;
  inset-inline-end: 0;
  bottom: 0;
  height: 2px;
  background: rgba(201, 162, 39, 0.10);
  pointer-events: none;
  overflow: hidden;
}

.strip-progress-bar-fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, #c9a227, #e8c547);
  border-radius: 0 99px 99px 0;
  transition: width 320ms cubic-bezier(0.4, 0, 0.2, 1);
}

:global(.dark) .strip-progress-bar {
  background: rgba(212, 192, 152, 0.12);
}

:global(.dark) .strip-progress-bar-fill {
  background: linear-gradient(90deg, #c9a227, #d4c098);
}

@media (prefers-reduced-motion: reduce) {
  .strip-progress-bar-fill {
    transition: none;
  }
}

/* ─────────────────────────────────────────────────────────────
   STRIP COMPLETION INDICATOR
   Inline pill that reveals itself when the chapter is marked
   complete. Shown by the chapter-row class toggler in
   ChapterSidebars (it adds .is-complete to the wrapping
   .strip-completion when the chapter's id is in the completed list).
   Hidden by default so unfinished chapters get no chrome.
   ───────────────────────────────────────────────────────────── */
.strip-completion {
  display: none;
  align-items: center;
  gap: 0.35rem;
  flex-shrink: 0;
  /* Inline-block-ish behavior: the pill sits on the text baseline of
     its row neighbors. Padding is asymmetric (a hair more on top)
     because the dot+text inside the pill optically pulls down. */
  padding: 0.05rem 0.55rem;
  border-radius: 99px;
  background: rgba(31, 138, 77, 0.08);
  border: 0.5px solid rgba(31, 138, 77, 0.3);
  font-size: 0.72rem;
  font-weight: 500;
  color: #1f8a4d;
  line-height: 1.2;
  white-space: nowrap;
  /* Lift the pill ~5px above its natural baseline position so it
     visually sits in line with the meta text. Without this, the
     pill sits slightly below the meta items because of its border
     and padding adding optical weight at the bottom. */
  transform: translateY(-5px);
  transition: opacity 200ms ease;
}

.strip-completion.is-complete {
  display: inline-flex;
}

.strip-completion-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #1f8a4d;
  flex-shrink: 0;
}

:global(.dark) .strip-completion {
  background: rgba(74, 222, 128, 0.10);
  border-color: rgba(74, 222, 128, 0.35);
  color: #4ade80;
}

:global(.dark) .strip-completion-dot {
  background: #4ade80;
}

/* Resume bookmark — when progress-tracker restores the scroll position
   after returning to a chapter, the paragraph nearest the viewport
   center gets this class for ~2.6s. A warm gold halo lands on it so
   the eye finds the resume point without needing to read the toast.
   Global selector because the class is applied to <p>/<h2> inside the
   reading content, which doesn't share this file's scoped cid. */
:global(.resume-pulse) {
  position: relative;
  border-radius: 6px;
  animation: resumeGoldPulse 2.6s cubic-bezier(0.2, 0, 0, 1) forwards;
}
@keyframes resumeGoldPulse {
  0% {
    background-color: color-mix(in srgb, var(--gold-500) 22%, transparent);
    box-shadow:
      0 0 0 6px color-mix(in srgb, var(--gold-500) 10%, transparent),
      0 0 22px color-mix(in srgb, var(--gold-500) 28%, transparent);
  }
  60% {
    background-color: color-mix(in srgb, var(--gold-500) 10%, transparent);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--gold-500) 5%, transparent),
      0 0 14px color-mix(in srgb, var(--gold-500) 12%, transparent);
  }
  100% {
    background-color: transparent;
    box-shadow:
      0 0 0 0 transparent,
