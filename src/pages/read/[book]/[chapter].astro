---
import ReadingLayout from '../../../layouts/ReadingLayout.astro';
import ChapterNavigation from '../../../components/ChapterNavigation.astro';
import ChapterSidebars from '../../../components/ChapterSidebars.astro';
import ChapterMeta from '../../../components/ChapterMeta.astro';
import type { Language, Chapter } from '../../../types/index';
import { SUPPORTED_LANGUAGES, SOURCE_LANGUAGE } from '../../../utils/language';
import { t } from '../../../i18n';
import { readFileSync } from 'fs';
import { resolve } from 'path';
import { marked } from '../../../utils/markdown';
import { discoverAllBooks } from '../../../utils/book-discovery';

type LocalizedMap = Record<string, string | undefined>;

function getLocalized(value: LocalizedMap | undefined, lang: string): string {
  if (!value) return '';
  return value[lang] ?? value[SOURCE_LANGUAGE] ?? Object.values(value)[0] ?? '';
}

export async function getStaticPaths() {
  const books = discoverAllBooks();
  return books.flatMap(book =>
    book.chapters.map(ch => ({
      params: { book: book.slug, chapter: String(ch.id) }
    }))
  );
}

const { book, chapter: chapterIdStr } = Astro.params;
const rawChapterId = chapterIdStr || '0';
const parsedNum = parseInt(rawChapterId, 10);
const chapterId: number | string =
  !Number.isNaN(parsedNum) && String(parsedNum) === rawChapterId ? parsedNum : rawChapterId;

const books = discoverAllBooks();
const bookData = books.find(b => b.slug === book);

if (!bookData) {
  return new Response('Book not found', { status: 404 });
}

const chapters: Chapter[] = bookData.chapters ?? [];
const current = chapters.find(ch => String(ch.id) === String(chapterId));

if (!current) {
  return new Response('Chapter not found', { status: 404 });
}

const availableLangs =
  bookData.languages?.length
    ? bookData.languages
    : Object.keys(bookData.titles || {});

const supportedCodes = SUPPORTED_LANGUAGES.map(l => l.code);

const langs = supportedCodes.filter(l => availableLangs.includes(l));

function annotateBookmarkAnchors(html: string): string {
  const counters = { p: 0, h: 0 };
  return html.replace(/<(p|h2|h3)(\s[^>]*)?>/gi, (_, tagRaw: string, attrsRaw?: string) => {
    const tag = tagRaw.toLowerCase();
    const attrs = attrsRaw || '';
    if (/\sdata-bm-anchor=/.test(attrs)) {
      return `<${tag}${attrs}>`;
    }
    const key = tag === 'p' ? 'p' : 'h';
    const n = ++counters[key];
    return `<${tag}${attrs} data-bm-anchor="${key}-${n}">`;
  });
}

async function loadContent(lang: string): Promise<string> {
  const fileSlug =
    (current as any).file_slug ||
    (typeof chapterId === 'string'
      ? chapterId
      : `chapter-${String(chapterId).padStart(2, '0')}`);
  const filename = `${fileSlug}.${lang}.md`;

  const path = resolve(`output/${book}`, filename);

  try {
    const md = readFileSync(path, 'utf-8');
    let html = await marked(md);
    html = html.replaceAll('src="../assets/', `src="/${book}/assets/`);
    // Remove leading <h1>...</h1> if present (to avoid duplicate chapter title)
    html = html.replace(/^<h1[^>]*>.*?<\/h1>/s, '');
    html = annotateBookmarkAnchors(html);
    return html;
  } catch {
    return `<h2 data-bm-anchor="h-1">${getLocalized(current.titles, lang)}</h2>`;
  }
}

const contentByLang = Object.fromEntries(
  await Promise.all(
    langs.map(async l => [l, await loadContent(l)])
  )
) as Record<string, string>;

const language = (langs.includes(SOURCE_LANGUAGE) ? SOURCE_LANGUAGE : langs[0] || SOURCE_LANGUAGE) as Language;
---

<ReadingLayout
  title={getLocalized(current.titles, language)}
  language={language}
  availableLanguages={langs as Language[]}
>

  <ChapterSidebars
    slot="sidebars"
    chapters={chapters}
    currentChapterId={chapterId}
    bookSlug={book || ''}
    language={language}
  />
  {/* Region 1 - Top strip: slim band between the two sidebars.
      Breadcrumb is intentionally hidden (readers arrive from TOC and
      know the context). Only a lightweight meta row remains. */}
  <div id="chapter-top-strip" class="chapter-top-strip">
    <div id="chapter-meta-bar" class="chapter-meta-bar">
      {langs.map(l => (
        <div
          data-lang={l}
          class={l === language ? 'visible meta-bar-row' : 'hidden meta-bar-row'}
          dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
        >
          <div class="meta-bar-stats">
            <ChapterMeta
              wordCount={current.word_count}
              readingTimeMinutes={Math.ceil(current.word_count / 200)}
              sections={current.sections}
              language={l}
            />
          </div>
          <span class="progress-badge" id={`progress-badge-${l}`}>0%</span>
        </div>
      ))}
    </div>
  </div>

  {/* Region 2 - Chapter title block: own component below the strip.
      Only the title lives here. No shared container, no shared framing.
      Retains id="chapter-header" as a stable contract for language-switcher,
      highlighter, and client-side nav consumers. */}
  <div id="chapter-header" class="chapter-title-block">
    {langs.map(l => {
      const hasNumber = typeof chapterId === 'number';
      const chapterWord = t('chapter.label', l);
      return (
        <div
          data-lang={l}
          class={l === language ? 'visible' : 'hidden'}
          dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
        >
          <div class="chapter-title-card">
            {hasNumber && (
              <div class="chapter-title-pill" aria-hidden="true">
                <span class="pill-number">{String(chapterId).padStart(2, '0')}</span>
              </div>
            )}
            <div class="chapter-title-body">
              {hasNumber && (
                <span class="chapter-eyebrow-text" aria-hidden="true">{chapterWord}</span>
              )}
              <h1 class="chapter-title">
                <span class="chapter-title-text">{getLocalized(current.titles, l)}</span>
              </h1>
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <div id="chapter-container" data-book={book} data-chapter-id={chapterId}>
    {langs.map(l => (
      <div
        data-lang={l}
        class={l === language ? 'visible' : 'hidden'}
        dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
      >
        <div class="chapter-content prose prose-lg">
          <Fragment set:html={contentByLang[l]} />
        </div>
      </div>
    ))}

    <ChapterNavigation
      currentChapterId={chapterId}
      chapters={chapters}
      bookSlug={book || ''}
      language={language}
    />
  </div>
</ReadingLayout>

<style>
.hidden { display: none !important; }
.visible { display: block; }

/* ─────────────────────────────────────────────────────────────
   REGION 1 - TOP STRIP
   Independent full-width band between sidebars. Not attached to,
   not parent of, the chapter title. Sticky so it stays visible
   while scrolling.
   ───────────────────────────────────────────────────────────── */
/* The article wraps content with px-4 / sm:px-6 / lg:px-8. The top strip
   must escape that padding and sit edge-to-edge between sidebars. We cancel
   the article's inline padding with equal negative margins, then zero our
   own inline padding. */
.chapter-top-strip {
  /* Sticky so stats + progress badge stay on-screen while the reader
     scrolls. Stack above the title block (z-index 46 > title's 45) so
     the strip wins the overlap zone. No negative inline margin — the
     strip stays inside the article's padded area, which already sits
     between the fixed sidebars, so the progress badge can't slip
     under the outline card. */
  position: sticky;
  top: var(--reading-sticky-top, 4rem);
  z-index: 46;
  width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 0.35rem 0 0.5rem;
  background:
    linear-gradient(to bottom,
      color-mix(in srgb, var(--yuval-reading-bg) 96%, transparent),
      color-mix(in srgb, var(--yuval-reading-bg) 88%, transparent 12%));
  backdrop-filter: blur(14px);
  border-bottom: 1px solid color-mix(in srgb, var(--gold-500) 12%, var(--yuval-border));
}

.chapter-top-strip.scrolled {
  box-shadow: 0 8px 20px rgba(17, 24, 39, 0.06);
}

.chapter-meta-bar {
  width: 100%;
  margin: 0;
  padding: 0;
}

/* Meta row — mobile-first flex:
   stats take remaining width and are allowed to shrink/wrap,
   progress badge is pinned to the end (logical: inline-end in RTL/LTR).
   On wider screens we upgrade to a centered grid (see 768px block). */
.meta-bar-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  width: 100%;
  padding: 0;
  min-width: 0;
}

.meta-bar-row.hidden {
  display: none !important;
}

.meta-bar-stats {
  flex: 1 1 auto;
  min-width: 0;
  /* Allow the inner .chapter-meta (flex-wrap: wrap) to spill over
     to a second line on cramped viewports instead of crashing into
     the progress badge. */
}

.meta-bar-row .progress-badge {
  flex: 0 0 auto;
  margin-inline-start: auto;
}

/* ≥ sm: restore the centered-stats grid so desktop layout is unchanged. */
@media (min-width: 768px) {
  .meta-bar-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.75rem;
  }
  .meta-bar-stats {
    grid-column: 2;
    flex: initial;
  }
  .meta-bar-row .progress-badge {
    grid-column: 3;
    justify-self: end;
    margin-inline-start: 0;
  }
}

/* ─────────────────────────────────────────────────────────────
   REGION 2 - CHAPTER TITLE BLOCK
   Own component below the strip. No shared wrapper, no shared
   framing. Only the title lives here.
   ───────────────────────────────────────────────────────────── */
.chapter-title-block {
  /* Title stays pinned below the top strip. The block itself is
     invisible chrome — the visible presence comes from .chapter-title-card
     inside, which mirrors the TOC's "active chapter" card styling so
     the reading page reads as a zoomed-in continuation of the menu. */
  position: sticky;
  top: calc(var(--reading-sticky-top, 4rem) + 2.5rem);
  z-index: 45;
  width: 100%;
  max-width: 100%;
  margin: 0 0 1.5rem;
  padding: 0.6rem 0 0.75rem;
  background: var(--yuval-reading-bg);
}

/* Title's inner wrapper mirrors .chapter-content exactly so the
   title's end edge lines up with the body's end edge. Same width
   tokens, same centered margin - title reads as the first element
   of the content container, not a page-level heading. */
.chapter-title-block > [data-lang] {
  width: 100%;
  max-width: var(--reading-content-width);
  margin: 0 auto;
}

@media (min-width: 1024px) {
  .chapter-title-block > [data-lang] {
    max-width: min(100%, 1040px);
    padding-inline-start: 20px;
  }
}
@media (min-width: 1280px) {
  .chapter-title-block > [data-lang] {
    max-width: min(100%, 1160px);
    padding-inline-start: 20px;
  }
}
@media (min-width: 1536px) {
  .chapter-title-block > [data-lang] {
    max-width: min(100%, 1280px);
    padding-inline-start: 20px;
  }
}

/* Chapter title card — a zoomed-in version of the TOC sidebar's
   "active chapter" card. Same gold-tinted gradient, same 3px gold
   accent bar, same rounded-rect gradient number pill. The page
   becomes a continuation of the menu rather than a different world. */
.chapter-title-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.95rem 1.1rem;
  border-radius: 14px;
  background: linear-gradient(135deg,
    rgba(201, 162, 39, 0.12) 0%,
    rgba(201, 162, 39, 0.06) 100%
  );
  box-shadow:
    0 2px 12px rgba(201, 162, 39, 0.15),
    inset 0 0 0 1px rgba(201, 162, 39, 0.25);
  overflow: hidden;
}

/* 3px gold accent bar mirrors .toc-item-active::before. Lives on the
   inline-start edge so it flips automatically for RTL/LTR. */
.chapter-title-card::before {
  content: '';
  position: absolute;
  inset-inline-start: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  background: linear-gradient(to bottom, #e8c547, #c9a227, #a8852a);
}

:global(.dark) .chapter-title-card {
  background: linear-gradient(145deg, rgba(90, 80, 65, 0.95), rgba(70, 60, 50, 0.98));
  box-shadow:
    0 4px 16px rgba(139, 115, 85, 0.3),
    inset 0 0 0 1px #8b7355;
}

:global(.dark) .chapter-title-card::before {
  background: linear-gradient(to bottom, #a8956d, #8b7355, #6d5a42);
}

/* Number pill — large version of .toc-number active state (same
   145deg gold gradient, same ring-shadow, white numerals).
   Reads as the twin sibling of the sidebar's active number pill. */
.chapter-title-pill {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 3.25rem;
  height: 3.25rem;
  border-radius: 12px;
  background: linear-gradient(145deg, #c9a227, #ddb52f);
  box-shadow:
    0 0 0 3px rgba(201, 162, 39, 0.2),
    0 3px 10px rgba(201, 162, 39, 0.4),
    inset 0 1px 2px rgba(255, 255, 255, 0.3);
}

:global(.dark) .chapter-title-pill {
  background: linear-gradient(145deg, #8b7355, #9d8463);
  box-shadow:
    0 0 0 3px rgba(139, 115, 85, 0.25),
    0 3px 10px rgba(139, 115, 85, 0.45),
    inset 0 1px 2px rgba(255, 255, 255, 0.12);
}

.pill-number {
  font-family: var(--reading-font-family);
  font-size: 1.35rem;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.01em;
  direction: ltr;
}

/* Text column: small eyebrow label + title, stacked. */
.chapter-title-body {
  flex: 1 1 auto;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.chapter-eyebrow-text {
  font-family: var(--reading-font-family);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: color-mix(in srgb, var(--gold-700) 85%, var(--yuval-text-tertiary));
  line-height: 1;
  user-select: none;
}

:global(.dark) .chapter-eyebrow-text {
  color: color-mix(in srgb, #a8956d 80%, var(--yuval-text-tertiary));
}

/* Chapter title itself — tightened typography to sit beside the pill
   without the line-height dominating the card height. */
.chapter-title {
  margin: 0;
  display: block;
  font-family: var(--reading-font-family);
  font-size: clamp(1.55rem, 1.15rem + 1.6vw, 2.4rem);
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.015em;
  color: var(--yuval-chapter-title);
  text-align: start;
  text-wrap: balance;
}

.chapter-title-text {
  flex: 1 1 auto;
  min-width: 0;
}

/* Progress chip - sits in the top strip eyebrow row */
.progress-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 2.5rem;
  height: 1.5rem;
  padding-inline: 0.55rem;
  flex-shrink: 0;
  border-radius: 2px;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--gold-500) 22%, var(--yuval-border));
  color: var(--gold-700);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  line-height: 1;
}

/* Meta row stats - no pill, centered cluster */
#chapter-meta-bar :global(.chapter-meta) {
  margin: 0;
  padding: 0.4rem 0;
  width: auto;
  max-width: none;
  background: transparent;
  border: 0;
  justify-content: center;
  flex-wrap: nowrap;
}

@media (min-width: 1024px) {
  .chapter-top-strip {
    padding: 0.45rem 0 0.6rem;
  }
  .chapter-title-block {
    margin: 0 0 1.5rem;
    padding: 0.8rem 0 0.9rem;
  }
}

/* Mobile tap-to-top affordance on the chapter title block.
   Subtle by design - no button styling, no background, no outline ring.
   Just a whisper of interactivity: a gentle press-in on tap.
   Activated only when JS has added .chapter-title-tap-enabled (mobile MQ). */
@media (max-width: 1023px) {
  .chapter-title-block.chapter-title-tap-enabled {
    cursor: default;
    -webkit-tap-highlight-color: transparent;
    transition:
      opacity 180ms var(--ease-standard, ease-out),
      transform 180ms var(--ease-standard, ease-out);
    will-change: opacity, transform;
  }

  /* Tap feedback - barely-there press-in. Opacity nudge + micro-scale.
     No background, no border, no ring. Reads as a responsive surface,
     not a button. */
  .chapter-title-block.chapter-title-tap-enabled:active {
    opacity: 0.72;
    transform: scale(0.995);
    transition-duration: 80ms;
  }

  /* Keyboard focus remains accessible but understated:
     a thin gold underline on the title text, not a boxed outline. */
  .chapter-title-block.chapter-title-tap-enabled:focus {
    outline: none;
  }
  .chapter-title-block.chapter-title-tap-enabled:focus-visible .chapter-title-text {
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--gold-500) 55%, transparent);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .chapter-title-block.chapter-title-tap-enabled {
      transition: opacity 120ms linear;
    }
    .chapter-title-block.chapter-title-tap-enabled:active {
      transform: none;
    }
  }
}

@media (max-width: 639px) {
  .chapter-top-strip {
    padding: 0.3rem 0 0.4rem;
  }

  .meta-bar-row {
    gap: 0.5rem;
  }

  #chapter-meta-bar :global(.chapter-meta) {
    font-size: 0.72rem;
    gap: 0.35rem 0.5rem;
    padding: 0.3rem 0;
  }

  #chapter-meta-bar :global(.meta-icon) {
    width: 0.95rem;
    height: 0.95rem;
  }

  .progress-badge {
    min-width: 2.25rem;
    height: 1.35rem;
    padding-inline: 0.4rem;
    font-size: 0.66rem;
  }

  .chapter-title-block {
    margin: 0 0 0.85rem;
    padding: 0.5rem 0 0.6rem;
  }

  .chapter-title {
    font-size: clamp(1.3rem, 0.95rem + 1.8vw, 1.7rem);
    line-height: 1.22;
  }

  .chapter-title-card {
    gap: 0.75rem;
    padding: 0.7rem 0.85rem;
    border-radius: 12px;
  }

  .chapter-title-pill {
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 10px;
  }

  .pill-number {
    font-size: 1.05rem;
  }

  .chapter-eyebrow-text {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
  }
}
</style>

<script>
import '../../../scripts/reading-page.ts';
</script>