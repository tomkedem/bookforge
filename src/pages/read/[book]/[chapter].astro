---
import ReadingLayout from '../../../layouts/ReadingLayout.astro';
import ChapterNavigation from '../../../components/ChapterNavigation.astro';
import ChapterSidebars from '../../../components/ChapterSidebars.astro';
import ChapterMeta from '../../../components/ChapterMeta.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import type { Language, Chapter } from '../../../types/index';
import { SUPPORTED_LANGUAGES, SOURCE_LANGUAGE } from '../../../utils/language';
import { readFileSync } from 'fs';
import { resolve } from 'path';
import { marked } from '../../../utils/markdown';
import { discoverAllBooks } from '../../../utils/book-discovery';
import { t } from '../../../i18n';

type LocalizedMap = Record<string, string | undefined>;

function getLocalized(value: LocalizedMap | undefined, lang: string): string {
  if (!value) return '';
  return value[lang] ?? value[SOURCE_LANGUAGE] ?? Object.values(value)[0] ?? '';
}

export async function getStaticPaths() {
  const books = discoverAllBooks();
  return books.flatMap(book =>
    book.chapters.map(ch => ({
      params: { book: book.slug, chapter: String(ch.id) }
    }))
  );
}

const { book, chapter: chapterIdStr } = Astro.params;
const chapterId = parseInt(chapterIdStr || '0', 10);

const books = discoverAllBooks();
const bookData = books.find(b => b.slug === book);

if (!bookData) {
  return new Response('Book not found', { status: 404 });
}

const chapters: Chapter[] = bookData.chapters ?? [];
const current = chapters.find(ch => ch.id === chapterId);

if (!current) {
  return new Response('Chapter not found', { status: 404 });
}

const availableLangs =
  bookData.languages?.length
    ? bookData.languages
    : Object.keys(bookData.titles || {});

const supportedCodes = SUPPORTED_LANGUAGES.map(l => l.code);

const langs = supportedCodes.filter(l => availableLangs.includes(l));

async function loadContent(lang: string): Promise<string> {
  const filename =
    chapterId === 0
      ? `intro.${lang}.md`
      : `chapter-${String(chapterId).padStart(2, '0')}.${lang}.md`;

  const path = resolve(`output/${book}`, filename);

  try {
    const md = readFileSync(path, 'utf-8');
    let html = await marked(md);
    html = html.replaceAll('src="../assets/', `src="/${book}/assets/`);
    // Remove leading <h1>...</h1> if present (to avoid duplicate chapter title)
    html = html.replace(/^<h1[^>]*>.*?<\/h1>/s, '');
    return html;
  } catch {
    return `<h2>${getLocalized(current.titles, lang)}</h2>`;
  }
}

const contentByLang = Object.fromEntries(
  await Promise.all(
    langs.map(async l => [l, await loadContent(l)])
  )
) as Record<string, string>;

const language = (langs.includes(SOURCE_LANGUAGE) ? SOURCE_LANGUAGE : langs[0] || SOURCE_LANGUAGE) as Language;
---

<ReadingLayout
  title={getLocalized(current.titles, language)}
  language={language}
  availableLanguages={langs as Language[]}
>

  <ChapterSidebars
    slot="sidebars"
    chapters={chapters}
    currentChapterId={chapterId}
    bookSlug={book || ''}
    language={language}
  />
  <div id="chapter-sticky-stack" class="chapter-sticky-stack">
    <div id="chapter-meta-bar" class="chapter-meta-bar">
      {langs.map(l => (
        <div
          data-lang={l}
          class={l === language ? 'visible' : 'hidden'}
          dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
        >
          <ChapterMeta
            wordCount={current.word_count}
            readingTimeMinutes={Math.ceil(current.word_count / 200)}
            sections={current.sections}
            language={l}
          />
        </div>
      ))}
    </div>

    <div id="breadcrumb-container" class="breadcrumb-container">
      {langs.map(l => (
        <div
          data-lang={l}
          class={l === language ? 'visible' : 'hidden'}
          dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
        >
          <Breadcrumbs
            language={l}
            items={[
              { key: 'breadcrumb.books', href: '/' },
              { label: bookData.titles, href: `/books/${book}` },
              { label: current.titles }
            ]}
          />
        </div>
      ))}
    </div>

    <div id="chapter-header" class="chapter-header">
      <div class="chapter-header-card">
        {langs.map(l => (
          <div
            data-lang={l}
            class={l === language ? 'visible' : 'hidden'}
            dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
          >
            <div class="header-title-row">
              <div class="chapter-number-badge">
                <span class="chapter-number">{chapterId}</span>
              </div>

              <div class="chapter-title-group">
                <span class="chapter-label">
                  {t('chapter.label', l) || 'Chapter'}
                </span>
                <h1 class="chapter-title">
                  {getLocalized(current.titles, l)}
                </h1>
              </div>

              <span class="progress-badge" id={`progress-badge-${l}`}>0%</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div id="chapter-container">
    {langs.map(l => (
      <div
        data-lang={l}
        class={l === language ? 'visible' : 'hidden'}
        dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
      >
        <div class="chapter-content prose prose-lg">
          <Fragment set:html={contentByLang[l]} />
        </div>
      </div>
    ))}

    <ChapterNavigation
      currentChapterId={chapterId}
      chapters={chapters}
      bookSlug={book || ''}
      language={language}
    />
  </div>
</ReadingLayout>

<style>
.hidden { display: none !important; }
.visible { display: block; }

.chapter-sticky-stack {
  position: sticky;
  top: var(--reading-sticky-top, 4rem);
  z-index: 40;
  margin-inline: -1rem;
  padding: 0.2rem 0 0.75rem;
  margin-bottom: 1rem;
  background:
    linear-gradient(to bottom, color-mix(in srgb, var(--yuval-reading-bg) 96%, transparent), color-mix(in srgb, var(--yuval-reading-bg) 88%, transparent 12%));
  backdrop-filter: blur(14px);
}

.chapter-sticky-stack::after {
  content: '';
  position: absolute;
  inset-inline: 0;
  bottom: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, var(--yuval-border) 12%, var(--yuval-border) 88%, transparent 100%);
  opacity: 0.85;
  pointer-events: none;
}

.chapter-sticky-stack.scrolled {
  box-shadow: 0 12px 28px rgba(17, 24, 39, 0.08);
}

.chapter-meta-bar,
.breadcrumb-container,
.chapter-header {
  width: 100%;
}

.chapter-meta-bar {
  margin-bottom: 0.125rem;
}

.breadcrumb-container {
  margin-bottom: 0;
  margin-top: 0;
  padding-inline: 0.125rem;
  padding-top: 0;
  padding-bottom: 0;
}

.chapter-header {
  margin: 0;
}

.chapter-header-card {
  padding: 0.9rem 1rem;
  border-radius: 0;
  border: 1px solid color-mix(in srgb, var(--yuval-border) 85%, transparent);
  background: color-mix(in srgb, var(--yuval-bg) 92%, transparent 8%);
  box-shadow: 0 10px 26px rgba(15, 23, 42, 0.06);
}

.header-title-row {
  display: flex;
  align-items: center;
  gap: 0.875rem;
}

.chapter-number-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 3rem;
  height: 3rem;
  flex-shrink: 0;
  border-radius: 0;
  background: color-mix(in srgb, var(--yuval-accent) 12%, var(--yuval-bg));
  color: var(--yuval-chapter-title);
  border: 1px solid color-mix(in srgb, var(--yuval-accent) 20%, transparent);
}

.chapter-number {
  font-size: 1rem;
  font-weight: 700;
  line-height: 1;
}

.chapter-title-group {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: start;
}

.chapter-label {
  display: block;
  margin-bottom: 0.2rem;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--yuval-text-tertiary);
  text-align: start;
}

.chapter-title {
  margin: 0;
  font-size: 1.15rem;
  line-height: 1.25;
  color: var(--yuval-chapter-title);
  text-align: start;
}

.progress-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 3rem;
  height: 2.25rem;
  padding-inline: 0.75rem;
  flex-shrink: 0;
  border-radius: 0;
  background: var(--yuval-meta-bg);
  border: 1px solid var(--yuval-meta-border);
  color: var(--yuval-progress-badge);
  font-size: 0.9rem;
  font-weight: 700;
}

#chapter-meta-bar :global(.chapter-meta) {
  margin-bottom: 0;
  justify-content: center;
}

#breadcrumb-container :global(.breadcrumbs),
#breadcrumb-container :global(.breadcrumbs-nav) {
  margin-bottom: 0;
  max-width: none;
}

@media (min-width: 640px) {
  .chapter-sticky-stack {
    margin-inline: -1.5rem;
    padding-inline: 0;
  }

  .chapter-sticky-stack::after {
    inset-inline: 0;
  }

  .chapter-header-card {
    padding: 1rem 1.25rem;
  }

  .chapter-title {
    font-size: 1.35rem;
  }
}

@media (min-width: 1024px) {
  .chapter-sticky-stack {
    margin-inline: -2rem;
    padding-inline: 0;
  }

  .chapter-sticky-stack::after {
    inset-inline: 0;
  }

  .chapter-title {
    font-size: 1.5rem;
  }
}

@media (max-width: 639px) {
  .chapter-sticky-stack {
    padding-top: 0.15rem;
    padding-bottom: 0.6rem;
  }

  .breadcrumb-container {
    display: none !important;
  }

  .header-title-row {
    gap: 0.35rem;
    flex-wrap: nowrap;
  }

  .chapter-title-group {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: 0.3rem;
    min-width: 0;
    flex: 1;
    overflow: hidden;
  }

  .chapter-number-badge {
    width: 2.5rem;
    height: 2.5rem;
  }

  .progress-badge {
    min-width: 1.8rem;
    height: 1.3rem;
    padding-inline: 0.3rem;
    font-size: 0.5rem;
  }

  .chapter-number-badge {
    width: 1.6rem;
    height: 1.6rem;
  }

  .chapter-number {
    font-size: 1rem;
  }

  .chapter-title {
    font-size: 1rem;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chapter-label {
    font-size: 0.45rem;
    margin-bottom: 0.05rem;
  }

  .chapter-header-card {
    padding: 0.5rem 0.65rem;
  }
}
</style>

<script>
import '../../../scripts/reading-page.ts';
</script>