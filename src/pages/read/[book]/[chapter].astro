---
import ReadingLayout from '../../../layouts/ReadingLayout.astro';
import ChapterNavigation from '../../../components/ChapterNavigation.astro';
import ChapterSidebars from '../../../components/ChapterSidebars.astro';
import ChapterMeta from '../../../components/ChapterMeta.astro';
import type { Language, Chapter } from '../../../types/index';
import { SUPPORTED_LANGUAGES, SOURCE_LANGUAGE } from '../../../utils/language';
import { t } from '../../../i18n';
import { readFileSync } from 'fs';
import { resolve } from 'path';
import { marked } from '../../../utils/markdown';
import { discoverAllBooks } from '../../../utils/book-discovery';

type LocalizedMap = Record<string, string | undefined>;

function getLocalized(value: LocalizedMap | undefined, lang: string): string {
  if (!value) return '';
  return value[lang] ?? value[SOURCE_LANGUAGE] ?? Object.values(value)[0] ?? '';
}

export async function getStaticPaths() {
  const books = discoverAllBooks();
  return books.flatMap(book =>
    book.chapters.map(ch => ({
      params: { book: book.slug, chapter: String(ch.id) }
    }))
  );
}

const { book, chapter: chapterIdStr } = Astro.params;
const rawChapterId = chapterIdStr || '0';
const parsedNum = parseInt(rawChapterId, 10);
const chapterId: number | string =
  !Number.isNaN(parsedNum) && String(parsedNum) === rawChapterId ? parsedNum : rawChapterId;

const books = discoverAllBooks();
const bookData = books.find(b => b.slug === book);

if (!bookData) {
  return new Response('Book not found', { status: 404 });
}

const chapters: Chapter[] = bookData.chapters ?? [];
const current = chapters.find(ch => String(ch.id) === String(chapterId));

if (!current) {
  return new Response('Chapter not found', { status: 404 });
}

const availableLangs =
  bookData.languages?.length
    ? bookData.languages
    : Object.keys(bookData.titles || {});

const supportedCodes = SUPPORTED_LANGUAGES.map(l => l.code);

const langs = supportedCodes.filter(l => availableLangs.includes(l));

function annotateBookmarkAnchors(html: string): string {
  const counters = { p: 0, h: 0 };
  return html.replace(/<(p|h2|h3)(\s[^>]*)?>/gi, (_, tagRaw: string, attrsRaw?: string) => {
    const tag = tagRaw.toLowerCase();
    const attrs = attrsRaw || '';
    if (/\sdata-bm-anchor=/.test(attrs)) {
      return `<${tag}${attrs}>`;
    }
    const key = tag === 'p' ? 'p' : 'h';
    const n = ++counters[key];
    return `<${tag}${attrs} data-bm-anchor="${key}-${n}">`;
  });
}

async function loadContent(lang: string): Promise<string> {
  const fileSlug =
    (current as any).file_slug ||
    (typeof chapterId === 'string'
      ? chapterId
      : `chapter-${String(chapterId).padStart(2, '0')}`);
  const filename = `${fileSlug}.${lang}.md`;

  const path = resolve(`output/${book}`, filename);

  try {
    const md = readFileSync(path, 'utf-8');
    let html = await marked(md);
    html = html.replaceAll('src="../assets/', `src="/${book}/assets/`);
    // Remove leading <h1>...</h1> if present (to avoid duplicate chapter title)
    html = html.replace(/^<h1[^>]*>.*?<\/h1>/s, '');
    html = annotateBookmarkAnchors(html);
    return html;
  } catch {
    return `<h2 data-bm-anchor="h-1">${getLocalized(current.titles, lang)}</h2>`;
  }
}

const contentByLang = Object.fromEntries(
  await Promise.all(
    langs.map(async l => [l, await loadContent(l)])
  )
) as Record<string, string>;

const language = (langs.includes(SOURCE_LANGUAGE) ? SOURCE_LANGUAGE : langs[0] || SOURCE_LANGUAGE) as Language;
---

<ReadingLayout
  title={getLocalized(current.titles, language)}
  language={language}
  availableLanguages={langs as Language[]}
>

  <ChapterSidebars
    slot="sidebars"
    chapters={chapters}
    currentChapterId={chapterId}
    bookSlug={book || ''}
    language={language}
  />
  {/* Unified top strip: sticky band between the sidebars that merges what
      used to be three stacked regions — title card, meta stats, progress
      chip — into a single compact row. Nested IDs are preserved so every
      consumer keeps working:
        #chapter-top-strip  → sticky shadow + ResizeObserver (sticky-header.ts)
        #chapter-header     → language-switcher + tap-to-top (chapter-title-tap.ts)
        #chapter-meta-bar   → language-switcher
      All [data-lang] blocks live once inside the same DOM subtree; the
      switcher toggles them once per ID it scans, which is idempotent. */}
  <div id="chapter-top-strip" class="chapter-top-strip">
    <div id="chapter-header" class="chapter-strip-inner">
      <div id="chapter-meta-bar" class="chapter-strip-rows">
        {langs.map(l => {
          const hasNumber = typeof chapterId === 'number';
          const chapterWord = t('chapter.label', l);
          return (
            <div
              data-lang={l}
              class={l === language ? 'visible strip-row' : 'hidden strip-row'}
              dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
            >
              {hasNumber && (
                <div class="strip-pill" aria-hidden="true">
                  <span class="pill-number">{String(chapterId).padStart(2, '0')}</span>
                </div>
              )}
              <div class="strip-title-wrap">
                {hasNumber && (
                  <span class="strip-eyebrow" aria-hidden="true">{chapterWord}</span>
                )}
                <h1 class="chapter-title strip-title">
                  <span class="chapter-title-text">{getLocalized(current.titles, l)}</span>
                </h1>
              </div>
              <div class="strip-meta">
                <ChapterMeta
                  wordCount={current.word_count}
                  readingTimeMinutes={Math.ceil(current.word_count / 200)}
                  sections={current.sections}
                  language={l}
                />
              </div>
              <span class="progress-badge" id={`progress-badge-${l}`}>0%</span>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <div id="chapter-container" data-book={book} data-chapter-id={chapterId}>
    {langs.map(l => (
      <div
        data-lang={l}
        class={l === language ? 'visible' : 'hidden'}
        dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
      >
        <div class="chapter-content prose prose-lg">
          <Fragment set:html={contentByLang[l]} />
        </div>
      </div>
    ))}

    <ChapterNavigation
      currentChapterId={chapterId}
      chapters={chapters}
      bookSlug={book || ''}
      language={language}
    />
  </div>
</ReadingLayout>

<style>
.hidden { display: none !important; }
.visible { display: block; }

/* ─────────────────────────────────────────────────────────────
   UNIFIED TOP STRIP
   Sticky band between sidebars that holds chapter number + title
   + meta stats + progress badge in a single row. Replaces what
   used to be a separate large title card sitting below the strip.
   ───────────────────────────────────────────────────────────── */
.chapter-top-strip {
  position: sticky;
  top: var(--reading-sticky-top, 4rem);
  z-index: 46;
  width: 100%;
  max-width: 100%;
  margin: 0 0 1.25rem;
  padding: 0.4rem 0 0.5rem;
  background:
    linear-gradient(to bottom,
      color-mix(in srgb, var(--yuval-reading-bg) 96%, transparent),
      color-mix(in srgb, var(--yuval-reading-bg) 88%, transparent 12%));
  backdrop-filter: blur(14px);
  border-bottom: 1px solid color-mix(in srgb, var(--gold-500) 12%, var(--yuval-border));
}

.chapter-top-strip.scrolled {
  box-shadow: 0 8px 20px rgba(17, 24, 39, 0.06);
}

.chapter-strip-inner,
.chapter-strip-rows {
  width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 0;
}

/* One row per language (language-switcher toggles .hidden/.visible).
   Gold-tinted surface with a 3px inline-start accent — a compressed
   echo of the TOC sidebar's "active chapter" card so the reading page
   reads as a continuation of the menu. */
.strip-row {
  position: relative;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem 0.75rem;
  padding: 0.5rem 0.9rem 0.55rem;
  padding-inline-start: 1rem;
  border-radius: 12px;
  background: linear-gradient(135deg,
    rgba(201, 162, 39, 0.10) 0%,
    rgba(201, 162, 39, 0.04) 100%
  );
  box-shadow:
    0 1px 8px rgba(201, 162, 39, 0.12),
    inset 0 0 0 1px rgba(201, 162, 39, 0.22);
  overflow: hidden;
}

.strip-row.hidden {
  display: none !important;
}

.strip-row::before {
  content: '';
  position: absolute;
  inset-inline-start: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  background: linear-gradient(to bottom, #e8c547, #c9a227, #a8852a);
}

:global(.dark) .strip-row {
  background: linear-gradient(145deg, rgba(90, 80, 65, 0.9), rgba(70, 60, 50, 0.95));
  box-shadow:
    0 3px 12px rgba(139, 115, 85, 0.25),
    inset 0 0 0 1px #8b7355;
}

:global(.dark) .strip-row::before {
  background: linear-gradient(to bottom, #a8956d, #8b7355, #6d5a42);
}

/* Compact number pill — small version of the old 3.25rem title pill.
   Keeps the 145deg gold gradient and ring-shadow so the visual link to
   the TOC active-chapter pill is preserved. */
.strip-pill {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2.1rem;
  height: 2.1rem;
  border-radius: 9px;
  background: linear-gradient(145deg, #c9a227, #ddb52f);
  box-shadow:
    0 0 0 2px rgba(201, 162, 39, 0.22),
    0 2px 6px rgba(201, 162, 39, 0.35),
    inset 0 1px 1.5px rgba(255, 255, 255, 0.3);
}

:global(.dark) .strip-pill {
  background: linear-gradient(145deg, #8b7355, #9d8463);
  box-shadow:
    0 0 0 2px rgba(139, 115, 85, 0.25),
    0 2px 6px rgba(139, 115, 85, 0.45),
    inset 0 1px 1.5px rgba(255, 255, 255, 0.12);
}

.pill-number {
  font-family: var(--reading-font-family);
  font-size: 0.92rem;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.01em;
  direction: ltr;
}

/* Eyebrow + title stacked vertically; takes the remaining row width. */
.strip-title-wrap {
  flex: 1 1 12rem;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 0.05rem;
  line-height: 1.15;
}

.strip-eyebrow {
  font-family: var(--reading-font-family);
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: color-mix(in srgb, var(--gold-700) 85%, var(--yuval-text-tertiary));
  line-height: 1;
  user-select: none;
}

:global(.dark) .strip-eyebrow {
  color: color-mix(in srgb, #a8956d 80%, var(--yuval-text-tertiary));
}

/* Title — the class .chapter-title is preserved (highlighter depends on
   it at highlighter.ts:820). Typography compressed for inline use. */
.strip-title {
  margin: 0;
  display: block;
  font-family: var(--reading-font-family);
  font-size: clamp(1rem, 0.85rem + 0.55vw, 1.2rem);
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: -0.01em;
  color: var(--yuval-chapter-title);
  text-align: start;
  text-wrap: balance;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chapter-title-text {
  flex: 1 1 auto;
  min-width: 0;
}

/* Meta stats pushed to the trailing edge; ChapterMeta's own styles are
   overridden in this context so it renders as a thin icon+text row. */
.strip-meta {
  flex: 0 1 auto;
  min-width: 0;
  margin-inline-start: auto;
}

#chapter-meta-bar :global(.chapter-meta) {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  font-size: 0.72rem;
  gap: 0.25rem 0.5rem;
  justify-content: flex-end;
  flex-wrap: nowrap;
  color: var(--yuval-text-secondary);
}

#chapter-meta-bar :global(.meta-icon) {
  width: 0.9rem;
  height: 0.9rem;
  opacity: 0.85;
}

#chapter-meta-bar :global(.meta-dot) {
  font-size: 0.9rem;
  opacity: 0.5;
}

/* Progress chip — pinned to the trailing edge of the strip row. */
.progress-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 2.4rem;
  height: 1.4rem;
  padding-inline: 0.5rem;
  flex-shrink: 0;
  border-radius: 3px;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--gold-500) 25%, var(--yuval-border));
  color: var(--gold-700);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

:global(.dark) .progress-badge {
  border-color: color-mix(in srgb, #a8956d 40%, var(--yuval-border));
  color: #d4c098;
}

@media (min-width: 1024px) {
  .chapter-top-strip {
    padding: 0.5rem 0 0.6rem;
    margin-bottom: 1.5rem;
  }
}

/* Mobile tap-to-top affordance — chapter-title-tap.ts adds the
   .chapter-title-tap-enabled class to #chapter-header (our strip inner),
   so we target that. Subtle press-in feedback, no button chrome. */
@media (max-width: 1023px) {
  #chapter-header.chapter-title-tap-enabled {
    cursor: default;
    -webkit-tap-highlight-color: transparent;
    transition:
      opacity 180ms var(--ease-standard, ease-out),
      transform 180ms var(--ease-standard, ease-out);
    will-change: opacity, transform;
  }

  #chapter-header.chapter-title-tap-enabled:active {
    opacity: 0.82;
    transform: scale(0.997);
    transition-duration: 80ms;
  }

  #chapter-header.chapter-title-tap-enabled:focus {
    outline: none;
  }
  #chapter-header.chapter-title-tap-enabled:focus-visible .chapter-title-text {
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--gold-500) 55%, transparent);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    #chapter-header.chapter-title-tap-enabled {
      transition: opacity 120ms linear;
    }
    #chapter-header.chapter-title-tap-enabled:active {
      transform: none;
    }
  }
}

/* Narrow tablets and below: meta and progress wrap below the title
   so the title has room to breathe. The strip stays one sticky band. */
@media (max-width: 767px) {
  .strip-row {
    padding: 0.45rem 0.7rem 0.5rem;
    padding-inline-start: 0.85rem;
    gap: 0.3rem 0.5rem;
    border-radius: 10px;
  }

  .strip-pill {
    width: 1.85rem;
    height: 1.85rem;
    border-radius: 8px;
  }

  .pill-number {
    font-size: 0.8rem;
  }

  .strip-title-wrap {
    flex: 1 1 calc(100% - 2.5rem);
  }

  .strip-title {
    font-size: clamp(0.92rem, 0.8rem + 0.8vw, 1.05rem);
  }

  .strip-eyebrow {
    font-size: 0.55rem;
    letter-spacing: 0.18em;
  }

  /* Meta and progress drop to a second line under the title, aligned
     to the trailing edge for a clean right/left rag in RTL/LTR. */
  .strip-meta {
    flex: 1 1 auto;
    margin-inline-start: 0;
    order: 2;
  }

  .progress-badge {
    order: 3;
    min-width: 2.2rem;
    height: 1.25rem;
    padding-inline: 0.4rem;
    font-size: 0.64rem;
  }

  #chapter-meta-bar :global(.chapter-meta) {
    font-size: 0.68rem;
    gap: 0.2rem 0.4rem;
    justify-content: flex-start;
  }

  #chapter-meta-bar :global(.meta-icon) {
    width: 0.82rem;
    height: 0.82rem;
  }
}

@media (max-width: 380px) {
  /* Ultra-narrow: allow title to wrap to two lines and hide meta dots
     so the icon+value groups pack tighter. */
  .strip-title {
    white-space: normal;
    line-height: 1.2;
  }
  #chapter-meta-bar :global(.meta-dot) {
    display: none;
  }
}
</style>

<script>
import '../../../scripts/reading-page.ts';
</script>