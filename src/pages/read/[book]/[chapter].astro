---
import ReadingLayout from '../../../layouts/ReadingLayout.astro';
import ChapterNavigation from '../../../components/ChapterNavigation.astro';
import ChapterSidebars from '../../../components/ChapterSidebars.astro';
import ChapterMeta from '../../../components/ChapterMeta.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import type { Language, Chapter } from '../../../types/index';
import { SUPPORTED_LANGUAGES, SOURCE_LANGUAGE } from '../../../utils/language';
import { readFileSync } from 'fs';
import { resolve } from 'path';
import { marked } from '../../../utils/markdown';
import { discoverAllBooks } from '../../../utils/book-discovery';
import { t } from '../../../i18n';

type LocalizedMap = Record<string, string | undefined>;

function getLocalized(value: LocalizedMap | undefined, lang: string): string {
  if (!value) return '';
  return value[lang] ?? value[SOURCE_LANGUAGE] ?? Object.values(value)[0] ?? '';
}

export async function getStaticPaths() {
  const books = discoverAllBooks();
  return books.flatMap(book =>
    book.chapters.map(ch => ({
      params: { book: book.slug, chapter: String(ch.id) }
    }))
  );
}

const { book, chapter: chapterIdStr } = Astro.params;
const chapterId = parseInt(chapterIdStr || '0', 10);

const books = discoverAllBooks();
const bookData = books.find(b => b.slug === book);

if (!bookData) {
  return new Response('Book not found', { status: 404 });
}

const chapters: Chapter[] = bookData.chapters ?? [];
const current = chapters.find(ch => ch.id === chapterId);

if (!current) {
  return new Response('Chapter not found', { status: 404 });
}

const availableLangs =
  bookData.languages?.length
    ? bookData.languages
    : Object.keys(bookData.titles || {});

const supportedCodes = SUPPORTED_LANGUAGES.map(l => l.code);

const langs = supportedCodes.filter(l => availableLangs.includes(l));

function annotateBookmarkAnchors(html: string): string {
  const counters = { p: 0, h: 0 };
  return html.replace(/<(p|h2|h3)(\s[^>]*)?>/gi, (_, tagRaw: string, attrsRaw?: string) => {
    const tag = tagRaw.toLowerCase();
    const attrs = attrsRaw || '';
    if (/\sdata-bm-anchor=/.test(attrs)) {
      return `<${tag}${attrs}>`;
    }
    const key = tag === 'p' ? 'p' : 'h';
    const n = ++counters[key];
    return `<${tag}${attrs} data-bm-anchor="${key}-${n}">`;
  });
}

async function loadContent(lang: string): Promise<string> {
  const filename =
    chapterId === 0
      ? `intro.${lang}.md`
      : `chapter-${String(chapterId).padStart(2, '0')}.${lang}.md`;

  const path = resolve(`output/${book}`, filename);

  try {
    const md = readFileSync(path, 'utf-8');
    let html = await marked(md);
    html = html.replaceAll('src="../assets/', `src="/${book}/assets/`);
    // Remove leading <h1>...</h1> if present (to avoid duplicate chapter title)
    html = html.replace(/^<h1[^>]*>.*?<\/h1>/s, '');
    html = annotateBookmarkAnchors(html);
    return html;
  } catch {
    return `<h2 data-bm-anchor="h-1">${getLocalized(current.titles, lang)}</h2>`;
  }
}

const contentByLang = Object.fromEntries(
  await Promise.all(
    langs.map(async l => [l, await loadContent(l)])
  )
) as Record<string, string>;

const language = (langs.includes(SOURCE_LANGUAGE) ? SOURCE_LANGUAGE : langs[0] || SOURCE_LANGUAGE) as Language;
---

<ReadingLayout
  title={getLocalized(current.titles, language)}
  language={language}
  availableLanguages={langs as Language[]}
>

  <ChapterSidebars
    slot="sidebars"
    chapters={chapters}
    currentChapterId={chapterId}
    bookSlug={book || ''}
    language={language}
  />
  {/* Region 1 — Top strip: full-width band between the two sidebars.
      Independent from the chapter title. Contains meta, breadcrumb,
      chapter number eyebrow, and progress. */}
  <div id="chapter-top-strip" class="chapter-top-strip">
    {/* 1. Breadcrumb row */}
    <div id="breadcrumb-container" class="breadcrumb-container">
      {langs.map(l => (
        <div
          data-lang={l}
          class={l === language ? 'visible' : 'hidden'}
          dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
        >
          <Breadcrumbs
            language={l}
            items={[
              { key: 'breadcrumb.books', href: '/' },
              { label: bookData.titles, href: `/books/${book}` },
              { label: current.titles }
            ]}
          />
        </div>
      ))}
    </div>

    {/* 2. Metadata / reading stats row — full-width, stats on start side, progress at end */}
    <div id="chapter-meta-bar" class="chapter-meta-bar">
      {langs.map(l => (
        <div
          data-lang={l}
          class={l === language ? 'visible meta-bar-row' : 'hidden meta-bar-row'}
          dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
        >
          <div class="meta-bar-stats">
            <ChapterMeta
              wordCount={current.word_count}
              readingTimeMinutes={Math.ceil(current.word_count / 200)}
              sections={current.sections}
              language={l}
            />
          </div>
          <span class="progress-badge" id={`progress-badge-${l}`}>0%</span>
        </div>
      ))}
    </div>
  </div>

  {/* Region 2 — Chapter title block: own component below the strip.
      Only the title lives here. No shared container, no shared framing.
      Retains id="chapter-header" as a stable contract for language-switcher,
      highlighter, and client-side nav consumers. */}
  <div id="chapter-header" class="chapter-title-block">
    {langs.map(l => (
      <div
        data-lang={l}
        class={l === language ? 'visible' : 'hidden'}
        dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
      >
        <h1 class="chapter-title">
          <span class="chapter-number-stack" aria-hidden="true">
            <span class="chapter-number-label">{t('chapter.label', l) || 'Chapter'}</span>
            <span class="chapter-number-badge">{chapterId}</span>
          </span>
          <span class="chapter-title-text">{getLocalized(current.titles, l)}</span>
        </h1>
      </div>
    ))}
  </div>

  <div id="chapter-container" data-book={book} data-chapter-id={chapterId}>
    {langs.map(l => (
      <div
        data-lang={l}
        class={l === language ? 'visible' : 'hidden'}
        dir={SUPPORTED_LANGUAGES.find(x => x.code === l)?.dir || 'ltr'}
      >
        <div class="chapter-content prose prose-lg">
          <Fragment set:html={contentByLang[l]} />
        </div>
      </div>
    ))}

    <ChapterNavigation
      currentChapterId={chapterId}
      chapters={chapters}
      bookSlug={book || ''}
      language={language}
    />
  </div>
</ReadingLayout>

<style>
.hidden { display: none !important; }
.visible { display: block; }

/* ─────────────────────────────────────────────────────────────
   REGION 1 — TOP STRIP
   Independent full-width band between sidebars. Not attached to,
   not parent of, the chapter title. Sticky so it stays visible
   while scrolling.
   ───────────────────────────────────────────────────────────── */
/* The article wraps content with px-4 / sm:px-6 / lg:px-8. The top strip
   must escape that padding and sit edge-to-edge between sidebars. We cancel
   the article's inline padding with equal negative margins, then zero our
   own inline padding. */
.chapter-top-strip {
  position: sticky;
  top: var(--reading-sticky-top, 4rem);
  z-index: 40;
  width: auto;
  max-width: none;
  margin-inline: -1rem;
  margin-bottom: 0;
  padding: 0.35rem 0 0.5rem;
  background:
    linear-gradient(to bottom,
      color-mix(in srgb, var(--yuval-reading-bg) 96%, transparent),
      color-mix(in srgb, var(--yuval-reading-bg) 88%, transparent 12%));
  backdrop-filter: blur(14px);
  border-bottom: 1px solid color-mix(in srgb, var(--gold-500) 12%, var(--yuval-border));
}

@media (min-width: 640px) {
  .chapter-top-strip { margin-inline: -1.5rem; }
}
@media (min-width: 1024px) {
  .chapter-top-strip { margin-inline: -2rem; }
}

.chapter-top-strip.scrolled {
  box-shadow: 0 8px 20px rgba(17, 24, 39, 0.06);
}

.chapter-meta-bar,
.breadcrumb-container {
  width: 100%;
  margin: 0;
  padding: 0;
}

/* Meta row — full-width grid: stats centered, progress pinned to end */
.meta-bar-row {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 0.75rem;
  width: 100%;
  padding: 0;
}

.meta-bar-row.hidden {
  display: none !important;
}

.meta-bar-stats {
  grid-column: 2;
  min-width: 0;
}

.meta-bar-row .progress-badge {
  grid-column: 3;
  justify-self: end;
}

/* ─────────────────────────────────────────────────────────────
   REGION 2 — CHAPTER TITLE BLOCK
   Own component below the strip. No shared wrapper, no shared
   framing. Only the title lives here.
   ───────────────────────────────────────────────────────────── */
.chapter-title-block {
  position: sticky;
  top: calc(var(--reading-sticky-top, 4rem) + var(--top-strip-h, 0px));
  z-index: 39;
  width: 100%;
  max-width: 100%;
  margin: 0 0 1.25rem;
  padding: 0.6rem 0 0.7rem;
  background: var(--yuval-reading-bg);
  border-bottom: 1px solid color-mix(in srgb, var(--gold-500) 10%, var(--yuval-border));
}

/* Title's inner wrapper mirrors .chapter-content exactly so the
   title's end edge lines up with the body's end edge. Same width
   tokens, same centered margin — title reads as the first element
   of the content container, not a page-level heading. */
.chapter-title-block > [data-lang] {
  width: 100%;
  max-width: var(--reading-content-width);
  margin: 0 auto;
}

@media (min-width: 1024px) {
  .chapter-title-block > [data-lang] {
    max-width: min(100%, 1040px);
  }
}
@media (min-width: 1280px) {
  .chapter-title-block > [data-lang] {
    max-width: min(100%, 1160px);
  }
}
@media (min-width: 1536px) {
  .chapter-title-block > [data-lang] {
    max-width: min(100%, 1280px);
  }
}

/* Chapter title — lives only inside .chapter-title-block.
   Number stack + title sit in the same flow as one unified
   heading group, aligned to the content container's start edge. */
.chapter-title {
  margin: 0;
  display: flex;
  align-items: center;
  gap: 0.75em;
  font-family: var(--reading-font-family);
  font-size: clamp(1.6rem, 1.2rem + 1.6vw, 2.4rem);
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: -0.015em;
  color: var(--yuval-chapter-title);
  text-align: start;
}

.chapter-title-text {
  flex: 1 1 auto;
  min-width: 0;
}

/* Vertical micro-component: small label above the gold number
   badge. Tight, compact, aligned with the title as one group. */
.chapter-number-stack {
  flex: 0 0 auto;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15em;
  line-height: 1;
}

.chapter-number-label {
  font-size: 0.32em;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: color-mix(in srgb, var(--gold-700) 75%, var(--yuval-text-tertiary));
  line-height: 1;
  white-space: nowrap;
}

.chapter-number-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.55em;
  height: 1.55em;
  font-size: 0.6em;
  font-weight: 600;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  color: var(--gold-700);
  background: color-mix(in srgb, var(--gold-500) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--gold-500) 35%, var(--yuval-border));
  border-radius: 3px;
  letter-spacing: 0;
}

/* Progress chip — sits in the top strip eyebrow row */
.progress-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 2.5rem;
  height: 1.5rem;
  padding-inline: 0.55rem;
  flex-shrink: 0;
  border-radius: 2px;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--gold-500) 22%, var(--yuval-border));
  color: var(--gold-700);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  line-height: 1;
}

/* Meta row stats — no pill, centered cluster */
#chapter-meta-bar :global(.chapter-meta) {
  margin: 0;
  padding: 0.4rem 0;
  width: auto;
  max-width: none;
  background: transparent;
  border: 0;
  justify-content: center;
  flex-wrap: nowrap;
}

/* Breadcrumb row — full width, edge-flush */
#breadcrumb-container :global(.breadcrumbs),
#breadcrumb-container :global(.breadcrumbs-nav) {
  margin: 0 !important;
  padding: 0 !important;
  max-width: none !important;
  width: 100%;
}

@media (min-width: 1024px) {
  .chapter-top-strip {
    padding: 0.45rem 0 0.6rem;
  }
  .chapter-title-block {
    margin: 0 0 1.5rem;
    padding: 0.8rem 0 0.9rem;
  }
}

@media (max-width: 639px) {
  .chapter-top-strip {
    padding: 0.3rem 0 0.4rem;
  }

  .breadcrumb-container {
    display: none !important;
  }

  .meta-bar-row {
    gap: 0.5rem;
  }

  #chapter-meta-bar :global(.chapter-meta) {
    font-size: 0.72rem;
    gap: 0.35rem 0.5rem;
    padding: 0.3rem 0;
  }

  #chapter-meta-bar :global(.meta-icon) {
    width: 0.95rem;
    height: 0.95rem;
  }

  .progress-badge {
    min-width: 2.25rem;
    height: 1.35rem;
    padding-inline: 0.4rem;
    font-size: 0.66rem;
  }

  .chapter-title-block {
    margin: 0 0 0.85rem;
    padding: 0.45rem 0 0.55rem;
  }

  .chapter-title {
    gap: 0.6em;
    font-size: clamp(1.25rem, 0.9rem + 2vw, 1.6rem);
    line-height: 1.25;
  }

  .chapter-number-label {
    font-size: 0.36em;
    letter-spacing: 0.14em;
  }

  .chapter-number-badge {
    width: 1.5em;
    height: 1.5em;
    font-size: 0.64em;
  }
}
</style>

<script>
import '../../../scripts/reading-page.ts';
</script>