---
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';
import ReadingProgress from '../../components/sample-book/ReadingProgress.astro';
import TableOfContents from '../../components/sample-book/TableOfContents.astro';
import ChapterNav from '../../components/sample-book/ChapterNav.astro';

export async function getStaticPaths() {
  return [
    { params: { chapter: 'chapter-01' } },
    { params: { chapter: 'chapter-02' } },
    { params: { chapter: 'chapter-03' } },
  ];
}

const CHAPTERS = [
  { id: 'chapter-01', title: { he: 'פרק 1: מבוא לנושא', en: 'Chapter 1: Introduction' }, order: 1 },
  { id: 'chapter-02', title: { he: 'פרק 2: עקרונות מתקדמים', en: 'Chapter 2: Advanced Principles' }, order: 2 },
  { id: 'chapter-03', title: { he: 'פרק 3: סיכום ומסקנות', en: 'Chapter 3: Summary' }, order: 3 },
] as const;

const { chapter } = Astro.params;
const lang = (Astro.url.searchParams.get('lang') ?? 'he') as 'he' | 'en';

const currentIndex = CHAPTERS.findIndex((c) => c.id === chapter);
const current = CHAPTERS[currentIndex];
const prevChapter = currentIndex > 0 ? CHAPTERS[currentIndex - 1] : undefined;
const nextChapter = currentIndex < CHAPTERS.length - 1 ? CHAPTERS[currentIndex + 1] : undefined;

const outputDir = join(process.cwd(), 'output', 'sample-book');
const fileName = `${chapter}.${lang}.md`;
const filePath = join(outputDir, fileName);

let rawContent = '';
try {
  rawContent = await readFile(filePath, 'utf-8');
} catch {
  rawContent = lang === 'he' ? 'הפרק לא נמצא.' : 'Chapter not found.';
}

// Simple MD → HTML for headings, paragraphs, lists (no external dep)
function mdToHtml(md: string): string {
  return md
    .split('\n')
    .map((line) => {
      if (line.startsWith('## ')) return `<h2 class="text-2xl font-semibold mt-8 mb-3">${line.slice(3)}</h2>`;
      if (line.startsWith('# '))  return `<h1 class="text-3xl font-bold mb-6">${line.slice(2)}</h1>`;
      if (line.startsWith('- '))  return `<li class="mr-5 mb-1">${line.slice(2)}</li>`;
      if (line.trim() === '')     return '<br>';
      return `<p class="mb-4 leading-relaxed">${line}</p>`;
    })
    .join('\n')
    .replace(/(<li[^>]*>.*<\/li>\n)+/g, (m) => `<ul class="list-disc mb-4">${m}</ul>`);
}

const htmlContent = mdToHtml(rawContent);
const pageTitle = lang === 'he' ? current?.title.he : current?.title.en;
---

<!doctype html>
<html lang={lang} dir={lang === 'he' ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle} — ספר לדוגמה</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@400;700&family=Heebo:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      body { font-family: 'Heebo', system-ui, sans-serif; }
      h1, h2, h3 { font-family: 'Frank Ruhl Libre', serif; }
    </style>
  </head>
  <body class="bg-white text-gray-900 min-h-screen">
    <ReadingProgress
      bookId="sample-book"
      chapterIndex={currentIndex}
      totalChapters={CHAPTERS.length}
    />

    <div class="flex flex-col md:flex-row min-h-screen">
      <!-- TOC sidebar — hidden on mobile -->
      <TableOfContents
        chapters={CHAPTERS as unknown as Array<{ id: string; title: { he: string; en: string }; order: number }>}
        currentChapterId={chapter ?? ''}
        lang={lang}
      />

      <!-- Main reading area -->
      <main class="flex-1 max-w-[68ch] mx-auto px-4 py-10 md:py-16 w-full">
        <article set:html={htmlContent} />

        <ChapterNav
          prevChapter={prevChapter ? { id: prevChapter.id, title: lang === 'he' ? prevChapter.title.he : prevChapter.title.en } : undefined}
          nextChapter={nextChapter ? { id: nextChapter.id, title: lang === 'he' ? nextChapter.title.he : nextChapter.title.en } : undefined}
          lang={lang}
        />
      </main>
    </div>
  </body>
</html>
