---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import type { Language } from '../../types/index';
import { SOURCE_LANGUAGE, DEFAULT_LANGUAGE, getLanguageDirection, isValidLanguage } from '../../utils/language';
import { discoverCourses, type DiscoveredCourse, type DiscoveredBook } from '../../utils/book-discovery';
import { t } from '../../i18n';

interface Props {
  language?: Language;
  courseData: DiscoveredCourse;
}

type LocalizedMap = Record<string, string | undefined>;

function pickLocalized(map: LocalizedMap | undefined, lang: string): string {
  if (!map) return '';
  return map[lang] || map[SOURCE_LANGUAGE] || map[DEFAULT_LANGUAGE] || Object.values(map).find(Boolean) || '';
}

export async function getStaticPaths() {
  const courses = discoverCourses();
  return courses.map((course) => ({
    params: { slug: course.slug },
    props: { courseData: course },
  }));
}

const { language: propLanguage, courseData } = Astro.props;
const { slug } = Astro.params;

if (!courseData) return Astro.redirect('/404');

const availableLanguagesSet = new Set<Language>();
courseData.lessons.forEach((lesson: DiscoveredBook) => {
  const langs = lesson.languages?.length ? lesson.languages : Object.keys(lesson.titles || {});
  langs.forEach((l: string) => { if (l) availableLanguagesSet.add(l as Language); });
});
const availableLanguages = Array.from(availableLanguagesSet);
if (availableLanguages.length === 0) availableLanguages.push(SOURCE_LANGUAGE);

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const requestedLanguage =
  (urlLang && availableLanguages.includes(urlLang) && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && availableLanguages.includes(propLanguage) ? propLanguage : undefined);

const language = (requestedLanguage ?? (availableLanguages.includes(SOURCE_LANGUAGE) ? SOURCE_LANGUAGE : availableLanguages[0] ?? SOURCE_LANGUAGE)) as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

const courseTitle = pickLocalized(courseData.titles, language) || courseData.slug;
const courseDescription = pickLocalized(courseData.descriptions, language);
const lecturer = pickLocalized(courseData.lecturer, language);
const summaryAuthor = pickLocalized(courseData.summaryAuthor, language);

// Build lesson rows for all 12 slots — placeholders for not-yet-published.
const lessonsByNumber = new Map<number, DiscoveredBook>();
courseData.lessons.forEach((lesson: DiscoveredBook) => {
  if (typeof lesson.lessonNumber === 'number') {
    lessonsByNumber.set(lesson.lessonNumber, lesson);
  }
});

const allLessonRows = Array.from({ length: courseData.totalLessons }, (_, i) => {
  const number = i + 1;
  const lesson = lessonsByNumber.get(number);
  return {
    number,
    lesson,
    available: !!lesson,
  };
});

const availablePct = Math.round((courseData.availableLessons / courseData.totalLessons) * 100);

const breadcrumbItems = [
  { key: 'home.title', href: '/' },
  { label: { [SOURCE_LANGUAGE]: courseTitle, [language]: courseTitle }, href: `/courses/${slug}` },
];
---

<BaseLayout
  title={courseTitle}
  description={courseDescription}
  language={language}
  availableLanguages={availableLanguages}
>
  <div class="course-page" dir={isRtl ? 'rtl' : 'ltr'}>
    <div class="course-page-inner">

      <Breadcrumbs items={breadcrumbItems} language={language} />

      <!-- ── Course header ────────────────────────────────────────────── -->
      <header class="course-hero">
        <div class="course-hero-badge">
          <span class="course-hero-badge-dot"></span>
          <span data-i18n="courses.inProgress">{t('courses.inProgress', language)}</span>
        </div>

        <h1 class="course-hero-title">{courseTitle}</h1>

        <div class="course-hero-credits">
          {lecturer && (
            <p class="course-hero-lecturer">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              <span class="course-hero-lecturer-label" data-i18n="courses.lecturer">{t('courses.lecturer', language)}</span>
              <span class="course-hero-lecturer-name">{lecturer}</span>
            </p>
          )}

          {summaryAuthor && (
            <p class="course-hero-lecturer course-hero-summary-author">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 20h9"/>
                <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
              </svg>
              <span class="course-hero-lecturer-label" data-i18n="courses.summaryBy">{t('courses.summaryBy', language)}</span>
              <span class="course-hero-lecturer-name">{summaryAuthor}</span>
            </p>
          )}
        </div>

        {courseDescription && (
          <p class="course-hero-description">{courseDescription}</p>
        )}

        <!-- Progress -->
        <div class="course-hero-progress" data-course-slug={slug} data-total-lessons={courseData.totalLessons}>
          <div class="course-hero-progress-row">
            <span class="course-hero-progress-text">
              <span class="course-hero-available">{courseData.availableLessons}</span>
              <span class="course-hero-divider">/</span>
              <span class="course-hero-total">{courseData.totalLessons}</span>
              <span data-i18n="courses.lessons">{t('courses.lessons', language)}</span>
            </span>
            <span class="course-hero-percent" data-progress-percent>{availablePct}%</span>
          </div>
          <div class="course-hero-progress-track">
            <div class="course-hero-progress-fill" style={`width:${availablePct}%`} data-progress-fill></div>
          </div>
        </div>
      </header>

      <!-- ── Lesson list ──────────────────────────────────────────────── -->
      <section class="lessons-section" aria-label={courseTitle}>
        <h2 class="lessons-heading" data-i18n="courses.lessons">{t('courses.lessons', language)}</h2>

        <ol class="lessons-list">
          {allLessonRows.map((row) => {
            if (!row.available || !row.lesson) {
              return (
                <li class="lesson-row lesson-row-disabled">
                  <span class="lesson-number">{String(row.number).padStart(2, '0')}</span>
                  <div class="lesson-body">
                    <span class="lesson-title-placeholder">
                      {t('courses.lessonNumber', language, { n: String(row.number) })}
                    </span>
                    <span class="lesson-status">
                      <span class="lesson-status-dot lesson-status-dot-pending"></span>
                      <span data-i18n="courses.notAvailableYet">{t('courses.notAvailableYet', language)}</span>
                    </span>
                  </div>
                </li>
              );
            }

            const lesson = row.lesson;
            const lessonTitle = pickLocalized(lesson.titles, language) || lesson.slug;
            const lessonSubtitle = pickLocalized(lesson.subtitles, language);
            const lessonHref = `/books/${lesson.slug}`;

            return (
              <li class="lesson-row" data-lesson-slug={lesson.slug}>
                <a href={lessonHref} class="lesson-link">
                  <span class="lesson-number lesson-number-active">{String(row.number).padStart(2, '0')}</span>
                  <div class="lesson-body">
                    <div class="lesson-meta">
                      <span class="lesson-badge" data-i18n="courses.lessonBadge">{t('courses.lessonBadge', language)}</span>
                      <span class="lesson-progress-dot" data-lesson-progress-dot hidden></span>
                    </div>
                    <span class="lesson-title">{lessonTitle}</span>
                    {lessonSubtitle && <span class="lesson-subtitle">{lessonSubtitle}</span>}
                    <div class="lesson-progress-track" data-lesson-progress-track hidden>
                      <div class="lesson-progress-fill" data-lesson-progress-fill></div>
                    </div>
                  </div>
                  <svg class="lesson-arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14"/>
                    <path d="m12 5 7 7-7 7"/>
                  </svg>
                </a>
              </li>
            );
          })}
        </ol>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .course-page {
    min-height: 100vh;
    background: var(--yuval-bg);
    padding: 24px 16px 80px;
  }

  @media (min-width: 768px) { .course-page { padding: 36px 32px 96px; } }

  .course-page-inner {
    max-width: 880px;
    margin: 0 auto;
  }

  /* ── Hero ──────────────────────────────────────────────────────── */
  .course-hero {
    margin-top: 16px;
    padding: 28px;
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.06), rgba(139, 92, 246, 0.04) 60%, transparent);
    border: 1px solid rgba(99, 102, 241, 0.18);
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.06);
    margin-bottom: 36px;
  }

  :global(.dark) .course-hero {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.12), rgba(139, 92, 246, 0.06) 60%, transparent);
    border-color: rgba(139, 92, 246, 0.28);
  }

  .course-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(139, 92, 246, 0.1));
    color: #6366f1;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid rgba(99, 102, 241, 0.25);
    margin-bottom: 18px;
  }

  :global(.dark) .course-hero-badge { color: #a78bfa; border-color: rgba(139, 92, 246, 0.4); }

  .course-hero-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #6366f1;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
    animation: course-hero-pulse 2s ease-in-out infinite;
  }

  :global(.dark) .course-hero-badge-dot { background: #a78bfa; box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.3); }

  @keyframes course-hero-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.25); opacity: 0.65; }
  }

  .course-hero-title {
    font-family: var(--yuval-font-heading, inherit);
    font-size: 2rem;
    font-weight: 800;
    color: var(--yuval-text);
    line-height: 1.2;
    margin: 0 0 12px;
  }

  @media (min-width: 768px) { .course-hero-title { font-size: 2.5rem; } }

  .course-hero-credits {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 0 0 16px;
  }

  .course-hero-lecturer {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--yuval-text-tertiary);
    margin: 0;
  }

  .course-hero-summary-author {
    color: var(--yuval-text-tertiary);
    opacity: 0.9;
  }

  .course-hero-summary-author svg { color: #6366f1; opacity: 0.8; }
  :global(.dark) .course-hero-summary-author svg { color: #a78bfa; }

  .course-hero-lecturer-label {
    font-weight: 600;
    color: var(--yuval-text-secondary);
  }

  .course-hero-lecturer-label::after { content: ':'; margin-inline-end: 2px; }

  .course-hero-lecturer-name {
    font-style: italic;
    color: var(--yuval-text);
  }

  .course-hero-description {
    font-size: 15px;
    line-height: 1.65;
    color: var(--yuval-text-secondary);
    margin: 0 0 24px;
    max-width: 70ch;
  }

  /* Progress block */
  .course-hero-progress { margin-top: 8px; }

  .course-hero-progress-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 8px;
    font-size: 13px;
  }

  .course-hero-progress-text {
    color: var(--yuval-text-secondary);
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
  }

  .course-hero-available {
    font-weight: 700;
    color: #6366f1;
    font-size: 1.125rem;
  }

  :global(.dark) .course-hero-available { color: #a78bfa; }

  .course-hero-divider { color: var(--yuval-text-muted); }
  .course-hero-total { color: var(--yuval-text); font-weight: 600; }

  .course-hero-percent {
    font-weight: 700;
    color: #6366f1;
    font-size: 1.125rem;
    font-variant-numeric: tabular-nums;
  }

  :global(.dark) .course-hero-percent { color: #a78bfa; }

  .course-hero-progress-track {
    height: 8px;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.1);
    overflow: hidden;
  }

  :global(.dark) .course-hero-progress-track { background: rgba(139, 92, 246, 0.2); }

  .course-hero-progress-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #6366f1, #8b5cf6, #a78bfa);
    box-shadow: 0 0 12px rgba(139, 92, 246, 0.45);
    transition: width 600ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1));
  }

  /* ── Lessons list ──────────────────────────────────────────────── */
  .lessons-heading {
    font-family: var(--yuval-font-heading, inherit);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--yuval-text);
    margin: 0 0 18px;
    padding-inline-start: 12px;
    border-inline-start: 4px solid #6366f1;
    line-height: 1.2;
  }

  .lessons-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .lesson-row {
    border-radius: 14px;
    background: var(--yuval-surface);
    border: 1px solid var(--yuval-border);
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }

  .lesson-row:hover {
    border-color: rgba(99, 102, 241, 0.4);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(99, 102, 241, 0.1);
  }

  .lesson-link {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 16px 18px;
    text-decoration: none;
    color: inherit;
  }

  .lesson-row-disabled {
    background: transparent;
    border-style: dashed;
    border-color: var(--yuval-border);
    opacity: 0.65;
  }

  .lesson-row-disabled:hover {
    transform: none;
    box-shadow: none;
    border-color: var(--yuval-border);
  }

  .lesson-row-disabled {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 16px;
    padding: 14px 18px;
  }

  .lesson-number {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: var(--yuval-bg-secondary, #f3f4f6);
    color: var(--yuval-text-muted);
    font-weight: 700;
    font-size: 14px;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  :global(.dark) .lesson-number {
    background: rgba(99, 102, 241, 0.08);
  }

  .lesson-number-active {
    background: linear-gradient(145deg, #6366f1, #8b5cf6);
    color: #fff;
    box-shadow: 0 4px 10px rgba(99, 102, 241, 0.3);
  }

  .lesson-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .lesson-meta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 2px;
  }

  .lesson-badge {
    display: inline-flex;
    padding: 2px 8px;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.12);
    color: #6366f1;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  :global(.dark) .lesson-badge {
    background: rgba(139, 92, 246, 0.2);
    color: #a78bfa;
  }

  .lesson-progress-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.2);
  }

  .lesson-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--yuval-text);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .lesson-subtitle {
    font-size: 12px;
    color: var(--yuval-text-tertiary);
    line-height: 1.4;
  }

  .lesson-title-placeholder {
    font-size: 14px;
    font-weight: 600;
    color: var(--yuval-text-tertiary);
    font-style: italic;
  }

  .lesson-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--yuval-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .lesson-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .lesson-status-dot-pending {
    background: var(--yuval-text-muted);
    opacity: 0.5;
  }

  .lesson-progress-track {
    height: 3px;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.1);
    overflow: hidden;
    margin-top: 6px;
  }

  .lesson-progress-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #6366f1, #a78bfa);
    transition: width 400ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1));
  }

  .lesson-arrow {
    color: var(--yuval-text-muted);
    transition: transform 200ms ease, color 200ms ease;
    flex-shrink: 0;
  }

  [dir='rtl'] .lesson-arrow { transform: scaleX(-1); }

  .lesson-row:hover .lesson-arrow {
    color: #6366f1;
    transform: translateX(3px);
  }

  [dir='rtl'] .lesson-row:hover .lesson-arrow {
    transform: scaleX(-1) translateX(3px);
  }
</style>

<script>
  function updateLessonProgress() {
    document.querySelectorAll<HTMLElement>('.lesson-row[data-lesson-slug]').forEach((row) => {
      const slug = row.dataset.lessonSlug;
      if (!slug) return;

      let bestPct = 0;
      let completed = false;

      try {
        const completedList = JSON.parse(localStorage.getItem(`yuval_ch_complete_${slug}`) || '[]');
        if (Array.isArray(completedList) && completedList.length > 0) completed = true;
      } catch {}

      for (let i = 0; i < localStorage.length; i++) {
        const key = localStorage.key(i);
        if (!key || !key.includes(`yuval_reading_progress_${slug}_`)) continue;
        try {
          const data = JSON.parse(localStorage.getItem(key) || '{}');
          const pct = typeof data.percentage === 'number' ? data.percentage : 0;
          if (pct > bestPct) bestPct = pct;
        } catch {}
      }

      if (completed) bestPct = 100;

      const dot = row.querySelector<HTMLElement>('[data-lesson-progress-dot]');
      const track = row.querySelector<HTMLElement>('[data-lesson-progress-track]');
      const fill = row.querySelector<HTMLElement>('[data-lesson-progress-fill]');

      if (bestPct >= 5) {
        if (track) track.hidden = false;
        if (fill) fill.style.width = `${bestPct}%`;
        if (dot) dot.hidden = false;
      }
    });
  }

  function updateCourseHeroProgress() {
    const hero = document.querySelector<HTMLElement>('.course-hero-progress[data-course-slug]');
    if (!hero) return;

    const totalLessons = Number(hero.dataset.totalLessons || '0');
    if (!totalLessons) return;

    let weighted = 0;
    document.querySelectorAll<HTMLElement>('.lesson-row[data-lesson-slug]').forEach((row) => {
      const slug = row.dataset.lessonSlug;
      if (!slug) return;

      let bestPct = 0;
      try {
        const completedList = JSON.parse(localStorage.getItem(`yuval_ch_complete_${slug}`) || '[]');
        if (Array.isArray(completedList) && completedList.length > 0) bestPct = 100;
      } catch {}

      if (bestPct < 100) {
        for (let i = 0; i < localStorage.length; i++) {
          const key = localStorage.key(i);
          if (!key || !key.includes(`yuval_reading_progress_${slug}_`)) continue;
          try {
            const data = JSON.parse(localStorage.getItem(key) || '{}');
            const pct = typeof data.percentage === 'number' ? data.percentage : 0;
            if (pct > bestPct) bestPct = pct;
          } catch {}
        }
      }

      weighted += bestPct;
    });

    const coursePct = Math.round(weighted / totalLessons);
    const fill = hero.querySelector<HTMLElement>('[data-progress-fill]');
    const pctLabel = hero.querySelector<HTMLElement>('[data-progress-percent]');

    if (fill) fill.style.width = `${coursePct}%`;
    if (pctLabel) pctLabel.textContent = `${coursePct}%`;
  }

  function init() {
    updateLessonProgress();
    updateCourseHeroProgress();
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
