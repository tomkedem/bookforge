---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import type { Language, Chapter } from '../../types/index';
import { SOURCE_LANGUAGE, getLanguageDirection, isValidLanguage } from '../../utils/language';
import { discoverAllBooks } from '../../utils/book-discovery';
import { t } from '../../i18n';

interface Props {
  language?: Language;
}

type LocalizedMap = Record<string, string | undefined>;

function getLocalizedText(
  value: LocalizedMap | undefined,
  lang: string,
  fallback = SOURCE_LANGUAGE
): string {
  if (!value) return '';
  return value[lang] ?? value[fallback] ?? Object.values(value).find(Boolean) ?? '';
}

function getCreditText(
  value: string | Record<string, string> | undefined,
  lang: string,
  fallback = SOURCE_LANGUAGE
): string {
  if (!value) return '';
  if (typeof value === 'string') return value;
  return value[lang] ?? value[fallback] ?? Object.values(value).find(Boolean) ?? '';
}

function creditDataAttr(value: string | Record<string, string> | undefined): string {
  if (!value) return '';
  if (typeof value === 'string') return JSON.stringify({ [SOURCE_LANGUAGE]: value });
  return JSON.stringify(value);
}

function formatWordCount(count: number, lang: string): string {
  return t('book.words', lang, { n: count.toString() });
}

function formatChapterCount(count: number, lang: string): string {
  if (count === 1) return t('book.chapterOne', lang);
  return t('book.chapters', lang, { n: count.toString() });
}

// Reading time estimate at ~200 wpm; min 1 minute.
function formatReadingTime(wordCount: number, lang: string): string {
  const minutes = Math.max(1, Math.ceil(wordCount / 200));
  if (lang === 'he') return `${minutes} דקות קריאה`;
  if (lang === 'es') return `${minutes} min de lectura`;
  return `${minutes} min read`;
}

function formatSectionsLabel(sections: number, lang: string): string {
  return sections === 1
    ? t('book.sectionOne', lang)
    : t('book.sections', lang, { n: sections.toString() });
}

/**
 * Convert a small subset of inline markdown to safe HTML.
 *
 * Supports the markers that show up in book descriptions written in Word:
 *   **text**  ->  <strong>text</strong>
 *   *text*    ->  <em>text</em>
 *   `text`    ->  <code>text</code>
 *
 * Everything else is escaped so there's no risk of injecting arbitrary
 * HTML from manifest data. The pattern order matters — ** must be
 * processed before * so "*" inside "**...**" isn't consumed first.
 */
function renderInlineMarkdown(text: string): string {
  // Escape HTML first so user content can't break out. We intentionally
  // do NOT escape backticks, asterisks, or underscores here — they're
  // markdown syntax we'll consume in the next step.
  const escaped = text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');

  return escaped
    // Bold: **text**
    .replace(/\*\*([^*\n]+?)\*\*/g, '<strong>$1</strong>')
    // Italic: *text* (single asterisks, not consumed by bold)
    .replace(/(^|[^*])\*([^*\n]+?)\*(?!\*)/g, '$1<em>$2</em>')
    // Inline code: `text`
    .replace(/`([^`\n]+?)`/g, '<code>$1</code>');
}

export async function getStaticPaths() {
  const books = discoverAllBooks();
  return books.map(book => ({
    params: { slug: book.slug },
    props: { bookData: book }
  }));
}

const { language: propLanguage } = Astro.props;
const { slug } = Astro.params;

const books = discoverAllBooks();
const bookData = books.find(b => b.slug === slug);

if (!bookData) {
  return Astro.redirect('/404');
}

// Get available languages - prefer bookData.languages, fallback to titles keys
const availableLanguages = (
  (Array.isArray(bookData.languages) && bookData.languages.length > 0)
    ? bookData.languages
    : Object.keys(bookData.titles || {})
) as Language[];

// Ensure we have at least the source language
if (!availableLanguages.includes(SOURCE_LANGUAGE)) {
  availableLanguages.unshift(SOURCE_LANGUAGE);
}

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();

const requestedLanguage =
  (urlLang && availableLanguages.includes(urlLang) && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && availableLanguages.includes(propLanguage) ? propLanguage : undefined);

const language = (requestedLanguage ?? (availableLanguages.includes(SOURCE_LANGUAGE) ? SOURCE_LANGUAGE : availableLanguages[0] ?? SOURCE_LANGUAGE)) as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

const book = {
  slug: bookData.slug,
  titles: bookData.titles ?? {},
  subtitles: bookData.subtitles ?? {},
  descriptions: bookData.descriptions ?? {},
  coverImage: bookData.coverImage,
  dominantColor: bookData.dominantColor,
  chapters: bookData.chapters ?? [],
  credits: bookData.credits,
  languages: availableLanguages,
};


const title = getLocalizedText(book.titles, language);
const description = getLocalizedText(book.descriptions, language);
---

<BaseLayout
  title={title}
  description={description}
  language={language}
  availableLanguages={book.languages}
>
  <div
    class:list={[
      'min-h-screen',
      'bg-yuval-bg',
      'pt-2',
      'sm:pt-3',
      'pb-12',
      'sm:pb-16',
      'lg:pb-20',
      'px-4',
      'sm:px-6',
      'lg:px-8',
    ]}
  >
    <div class="w-full mx-auto">
      <Breadcrumbs
        language={language}
        items={[
          { key: 'breadcrumb.books', href: '/' },
          { label: book.titles },
        ]}
      />

      <!--
        Layout strategy:
        - Mobile (default): stacked — content (with image), then chapters
        - Desktop (lg+): 2 columns side-by-side
          * Chapters column (smaller, ~1fr)
          * Content column (larger, ~2.5fr) — includes title, subtitle,
            cover image (as figure), description paragraphs, meta stats
        - Source order: chapters first, so in RTL chapters render on the
          right (reading start), and in LTR on the left. Same principle
          both ways.
        - Cover image floats inside the content column: opposite side
          from the reading start, so description text wraps around it.
      -->
      <div
        class:list={[
          'grid',
          'grid-cols-1',
          'lg:grid-cols-[minmax(0,1fr)_minmax(0,2.5fr)]',
          'gap-6',
          'sm:gap-8',
          'lg:gap-10',
          'xl:gap-14',
          'mt-8',
          'sm:mt-10',
          'lg:mt-12',
          'mb-6',
          'sm:mb-8',
          'items-start',
        ]}
      >
        <!-- Chapters sidebar -->
        <div class:list={[
          'lg:sticky',
          'lg:top-4',
          isRtl && 'text-right',
        ]}>
          <!-- Gold-accented chapters header to match the reading pane's
               "CHAPTERS" typography. Thin bar underneath echoes the
               accent line used in ReadingLayout. -->
          <div class="mb-3 sm:mb-4 flex items-center gap-3">
            <h2 class="font-heading font-bold text-xl sm:text-2xl text-yuval-text">
              {t('sidebar.chapters', language)}
            </h2>
            <span
              class="flex-1 h-px"
              style="background: linear-gradient(to left, rgba(201,162,39,0.5), transparent);"
              aria-hidden="true"
            ></span>
          </div>

          <div class="space-y-2 lg:max-h-[calc(100vh-8rem)] lg:overflow-y-auto lg:pr-1">
            {
              book.chapters.map((chapter: Chapter, idx: number) => {
                const chapterTitle = getLocalizedText(chapter.titles, language);
                const chapterNum = idx + 1;

                return (
                  <a
                    href={`/read/${slug}/${chapter.id}`}
                    class:list={[
                      'chapter-link',
                      `chapter-link-${chapter.id}`,
                      'block',
                      'p-3',
                      'rounded-lg',
                      'border',
                      'border-yuval-border',
                      'hover:border-[rgba(201,162,39,0.55)]',
                      'hover:shadow-sm',
                      'transition-all',
                      'duration-200',
                      'focus:outline-none',
                      'focus:ring-2',
                      'focus:ring-offset-2',
                      'focus:ring-yuval-highlight',
                      'relative',
                      'overflow-hidden',
                      'bg-yuval-surface',
                    ]}
                    data-chapter-id={chapter.id}
                    data-book-slug={slug}
                  >
                    <div class="chapter-progress-bar absolute bottom-0 left-0 right-0 h-0.5 bg-yuval-border">
                      <div
                        class="chapter-progress-fill h-full bg-green-500 w-0 transition-all duration-700"
                        style="border-radius: 0 2px 2px 0"
                      ></div>
                    </div>

                    <div
                      class:list={[
                        'flex',
                        'items-center',
                        'justify-between',
                        'gap-3',
                        isRtl && 'flex-row-reverse',
                      ]}
                    >
                      <div class:list={[isRtl && 'text-right', 'flex-1', 'min-w-0', 'flex', 'items-start', 'gap-3']}>
                        <!-- Gold-tinted chapter number badge. No "Chapter"
                             label here — the list sits under a "Chapters"
                             header so repeating the word on every row is
                             just noise. -->
                        <span
                          class="chapter-number-badge flex-shrink-0 inline-flex items-center justify-center min-w-[44px] h-9 px-2.5 rounded-md font-bold text-base tabular-nums"
                          aria-hidden="true"
                        >
                          {chapterNum.toString().padStart(2, '0')}
                        </span>

                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-2">
                            <svg class="chapter-status-check w-4 h-4 flex-shrink-0 text-green-600 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                              <circle cx="12" cy="12" r="10" stroke-width="1.8" fill="rgba(34,197,94,0.12)" />
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M8 12.5l2.5 2.5L16 9.5" />
                            </svg>
                            <h3 class="font-heading font-semibold text-sm sm:text-base text-yuval-text line-clamp-2">
                              {chapterTitle}
                            </h3>
                          </div>

                          <p class="text-xs text-yuval-text-tertiary mt-1 flex flex-wrap items-center gap-x-3 gap-y-1">
                            <span class="inline-flex items-center gap-1">
                              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <circle cx="12" cy="12" r="9" stroke-width="1.8" />
                                <path stroke-linecap="round" stroke-width="1.8" d="M12 7v5l3 2" />
                              </svg>
                              <span>{formatReadingTime(chapter.word_count ?? 0, language)}</span>
                            </span>

                            <span class="text-yuval-text-muted" aria-hidden="true">·</span>

                            <span class="inline-flex items-center gap-1">
                              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <rect x="4" y="4" width="16" height="16" rx="2" stroke-width="1.8" />
                                <path stroke-width="1.8" d="M4 10h16M4 15h16M10 4v16" />
                              </svg>
                              <span>{formatSectionsLabel(chapter.sections ?? 0, language)}</span>
                            </span>
                          </p>
                        </div>
                      </div>
                    </div>
                  </a>
                );
              })
            }
          </div>
        </div>

        <!-- Content column: title, subtitle, cover, description, meta -->
        <div class:list={[isRtl && 'text-right']}>
          <!-- Title row: heading + inline "listen to description" trigger.
               Wired to the TTS engine by the page script. The icon is
               injected at init; the label stays translated here. -->
          <div class:list={['flex', 'items-start', 'gap-3', 'flex-wrap', 'mb-4', 'sm:mb-5']}>
            <h1 class="font-heading font-bold text-2xl sm:text-3xl lg:text-4xl leading-tight text-yuval-text flex-1 min-w-0">
              {title}
            </h1>
            <button
              id="tts-inline-trigger"
              class="tts-inline-btn"
              type="button"
              aria-label={t('tts.listenToDescription', language)}
              aria-pressed="false"
            >
              <span class="tts-inline-icon" aria-hidden="true"></span>
              <span class="tts-inline-label">{t('tts.listenToDescription', language)}</span>
            </button>
          </div>

          {getLocalizedText(book.subtitles, language) && (
            <p class="text-sm sm:text-base text-yuval-text-tertiary leading-relaxed mb-5 sm:mb-6">
              {getLocalizedText(book.subtitles, language)}
            </p>
          )}

          <!-- Cover image inside content flow, floated so text wraps around it -->
          <figure class:list={[
            'mb-5',
            'sm:mb-6',
            'lg:mb-3',
            'lg:max-w-[380px]',
            'xl:max-w-[440px]',
            isRtl ? 'lg:float-left lg:mr-6 xl:mr-8' : 'lg:float-right lg:ml-6 xl:ml-8',
          ]}>
            {book.credits && (
              <figcaption class="mb-2 text-sm text-yuval-text-secondary">
                {book.credits.type === 'lecture_summary' ? (
                  <div class="space-y-1.5">
                    <!-- Lecturer — person-outline icon -->
                    <p class="inline-flex items-center gap-1.5">
                      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <circle cx="12" cy="8" r="4" stroke-width="1.8" />
                        <path stroke-linecap="round" stroke-width="1.8" d="M4 20c0-4 4-6 8-6s8 2 8 6" />
                      </svg>
                      <span>
                        <span class="font-medium text-yuval-text">{t('book.lecturer', language)}:</span>{' '}
                        <span data-credit-localized={creditDataAttr(book.credits.lecturer)}>{getCreditText(book.credits.lecturer, language)}</span>
                      </span>
                    </p>
                    <!-- Editor — pencil/edit icon -->
                    <p class="inline-flex items-center gap-1.5">
                      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
                      </svg>
                      <span>
                        <span class="font-medium text-yuval-text">{t('book.editedBy', language)}:</span>{' '}
                        <span data-credit-localized={creditDataAttr(book.credits.editor)}>{getCreditText(book.credits.editor, language)}</span>
                      </span>
                    </p>
                  </div>
                ) : (
                  <!-- Author — person-outline icon -->
                  <p class="inline-flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <circle cx="12" cy="8" r="4" stroke-width="1.8" />
                      <path stroke-linecap="round" stroke-width="1.8" d="M4 20c0-4 4-6 8-6s8 2 8 6" />
                    </svg>
                    <span>
                      <span>{t('book.by', language)}</span> {' '}<span data-credit-localized={creditDataAttr(book.credits.author)}>{getCreditText(book.credits.author, language)}</span>
                    </span>
                  </p>
                )}
              </figcaption>
            )}

            <!-- Chapter count with book icon. Sits above the cover so the
                 metadata reads like a caption/heading to the image. -->
            <p class="mb-3 inline-flex items-center gap-1.5 text-sm text-yuval-text-tertiary">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
              </svg>
              <span>{formatChapterCount(book.chapters.length, language)}</span>
            </p>

            <img
              src={book.coverImage}
              alt={title}
              loading="lazy"
              decoding="async"
              class="book-cover-img w-full h-auto rounded-lg shadow-lg object-contain"
            />
          </figure>

          <div class="chapter-content space-y-2 sm:space-y-2.5 mb-3 sm:mb-4">
            {getLocalizedText(book.subtitles, language) && (
              <p class="sr-only">{getLocalizedText(book.subtitles, language)}</p>
            )}
            {description.split(/\n\s*\n/).filter((p: string) => p.trim()).map((para: string) => (
              <p
                class="text-base sm:text-lg text-yuval-text-secondary leading-relaxed"
                set:html={renderInlineMarkdown(para.trim())}
              />
            ))}
          </div>

          <!-- Clear the float so anything below sits after image+text -->
          <div class="lg:clear-both"></div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { t, resolveLanguage } from '../../i18n';
  import { SOURCE_LANGUAGE } from '../../utils/language';

  function updatePageContent(lang: string) {
    // Update chapter titles dynamically
    document.querySelectorAll<HTMLElement>('[data-chapter-title]').forEach(el => {
      const titleData = el.dataset.chapterTitle;
      if (titleData) {
        try {
          const titles = JSON.parse(titleData);
          el.textContent = titles[lang] || titles['he'] || Object.values(titles)[0] || '';
        } catch (e) {
          // Silently fail for invalid title data
        }
      }
    });

    // Update all i18n strings
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n;
      if (key) {
        const translatedText = t(key, lang);
        if (translatedText && translatedText !== key) {
          el.textContent = translatedText;
        }
      }
    });

    // Update localized credits (lecturer, editor, author names)
    document.querySelectorAll<HTMLElement>('[data-credit-localized]').forEach(el => {
      const raw = el.dataset.creditLocalized;
      if (!raw) return;
      try {
        const map = JSON.parse(raw) as Record<string, string>;
        const value = map[lang] ?? map[SOURCE_LANGUAGE] ?? Object.values(map).find(Boolean) ?? '';
        if (value) el.textContent = value;
      } catch { /* skip malformed */ }
    });
  }

  function updateChapterLinks() {
    // Links no longer need ?lang= - language is determined by toggle position
  }

  function updateChapterProgress() {
    document.querySelectorAll<HTMLAnchorElement>('.chapter-link[data-chapter-id][data-book-slug]').forEach(link => {
      const chapterId = link.dataset.chapterId;
      const bookSlug = link.dataset.bookSlug;
      if (!chapterId || !bookSlug) return;

      // Reading progress is saved by src/scripts/progress-tracker.ts under
      // the key `yuval_reading_progress_{slug}_ch{chapterId}`. It stores the
      // real `percentage` (0–100) computed against the chapter container
      // height, plus the raw scrollPosition as a fallback for old entries
      // saved before the percentage field existed.
      const keyFragment = `reading_progress_${bookSlug}_ch${chapterId}`;
      let pct = 0;
      let scrollY = 0;

      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (k && k.includes(keyFragment)) {
          try {
            const d = JSON.parse(localStorage.getItem(k) || '{}');
            if (typeof d.percentage === 'number' && d.percentage > pct) {
              pct = d.percentage;
            }
            if (typeof d.scrollPosition === 'number' && d.scrollPosition > scrollY) {
              scrollY = d.scrollPosition;
            }
          } catch {}
        }
      }

      // If we don't have a stored percentage yet (old entry), estimate from
      // scroll pixels as a rough fallback.
      if (pct === 0 && scrollY > 200) {
        pct = Math.min(95, Math.round((scrollY / 3000) * 100));
      }

      const fill = link.querySelector<HTMLElement>('.chapter-progress-fill');
      const check = link.querySelector<HTMLElement>('.chapter-status-check');

      if (pct > 0) {
        if (fill) fill.style.width = `${pct}%`;
        if (pct >= 85) {
          link.dataset.readStatus = 'completed';
          check?.classList.remove('hidden');
        } else {
          link.dataset.readStatus = 'in-progress';
          check?.classList.add('hidden');
        }
      } else {
        if (fill) fill.style.width = '0%';
        delete link.dataset.readStatus;
        check?.classList.add('hidden');
      }
    });
  }

  updateChapterLinks();
  updateChapterProgress();

  window.addEventListener('language-changed', (e: Event) => {
    const lang = (e as CustomEvent<{ language: string }>).detail?.language || SOURCE_LANGUAGE;
    updatePageContent(lang);
    updateChapterLinks();
    updateChapterProgress();
  });

  // Re-read progress when returning to this page via SPA navigation, and
  // when the tab regains focus after the user finished a chapter in another
  // tab or after background progress saves settle.
  document.addEventListener('astro:after-swap', () => {
    updateChapterLinks();
    updateChapterProgress();
  });
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') updateChapterProgress();
  });
  window.addEventListener('pageshow', () => updateChapterProgress());

  // Text-to-Speech on the book landing page: reads the description
  // aloud. We bind the engine to the inline pill button (#tts-inline-trigger)
  // instead of the floating FAB — on a short landing page the FAB pattern
  // is out of place, and users expect the control next to the title.
  import('../../scripts/text-to-speech').then(({ initTextToSpeech }) => {
    let currentController: AbortController | null = null;

    const boot = () => {
      currentController?.abort();
      const inlineEl = document.getElementById('tts-inline-trigger');
      if (!inlineEl) return;
      const ctrl = new AbortController();
      currentController = ctrl;
      initTextToSpeech(ctrl.signal, { trigger: 'inline', inlineEl });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    } else {
      boot();
    }

    document.addEventListener('astro:after-swap', boot);
  });

  // Image lightbox on the book landing page — lets readers click the
  // cover to view it full-size. Same module used in the reading view;
  // its click handler matches .book-cover-img via ZOOM_SELECTOR.
  import('../../scripts/image-lightbox').then(({ initImageLightbox }) => {
    let lbController: AbortController | null = null;

    const boot = () => {
      lbController?.abort();
      const ctrl = new AbortController();
      lbController = ctrl;
      initImageLightbox(ctrl);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    } else {
      boot();
    }

    document.addEventListener('astro:after-swap', boot);
  });
</script>

<style is:global>
  /* Book cover blends into the page background: the common white/cream
     padding around cover artwork disappears against the reading bg.
     Matches the treatment applied to article images in ReadingLayout. */
  .book-cover-img {
    background-color: transparent;
  }
  html:not(.dark) .book-cover-img {
    mix-blend-mode: multiply;
  }
  html.dark .book-cover-img {
    mix-blend-mode: screen;
  }

  /* Inline TTS trigger — gold pill that sits beside the title.
     Replaces the floating FAB on the landing page: a short description
     doesn't justify a persistent floating control, and the role is
     clearer when the button is adjacent to what it reads. */
  .tts-inline-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    background: linear-gradient(145deg, #c9a227, #ddb52f);
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    line-height: 1;
    border: 0;
    cursor: pointer;
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.18),
      0 0 0 1px rgba(232, 197, 71, 0.5),
      inset 0 1px 1.5px rgba(255, 255, 255, 0.3);
    transition: transform 160ms ease, box-shadow 160ms ease, filter 160ms ease;
    white-space: nowrap;
