---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BookOverviewHero from '../../components/book-overview/BookOverviewHero.astro';
import BookOverviewSummary from '../../components/book-overview/BookOverviewSummary.astro';
import BookOverviewChapters from '../../components/book-overview/BookOverviewChapters.astro';
import { getLocalizedText } from '../../components/book-overview/utils';
import type { Language } from '../../types/index';
import { SOURCE_LANGUAGE, getLanguageDirection, isValidLanguage } from '../../utils/language';
import { discoverAllBooks } from '../../utils/book-discovery';

interface Props {
  language?: Language;
}

export async function getStaticPaths() {
  const books = discoverAllBooks();
  return books.map(book => ({
    params: { slug: book.slug },
    props: { bookData: book }
  }));
}

const { language: propLanguage } = Astro.props;
const { slug } = Astro.params;

const books = discoverAllBooks();
const bookData = books.find(b => b.slug === slug);

if (!bookData) {
  return Astro.redirect('/404');
}

// Get available languages - prefer bookData.languages, fallback to titles keys
const availableLanguages = (
  (Array.isArray(bookData.languages) && bookData.languages.length > 0)
    ? bookData.languages
    : Object.keys(bookData.titles || {})
) as Language[];

// Ensure we have at least the source language
if (!availableLanguages.includes(SOURCE_LANGUAGE)) {
  availableLanguages.unshift(SOURCE_LANGUAGE);
}

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();

const requestedLanguage =
  (urlLang && availableLanguages.includes(urlLang) && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && availableLanguages.includes(propLanguage) ? propLanguage : undefined);

const language = (requestedLanguage ?? (availableLanguages.includes(SOURCE_LANGUAGE) ? SOURCE_LANGUAGE : availableLanguages[0] ?? SOURCE_LANGUAGE)) as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

const book = {
  slug: bookData.slug,
  titles: bookData.titles ?? {},
  subtitles: bookData.subtitles ?? {},
  descriptions: bookData.descriptions ?? {},
  coverImage: bookData.coverImage,
  dominantColor: bookData.dominantColor,
  chapters: bookData.chapters ?? [],
  credits: bookData.credits,
  level: bookData.level,
  languages: availableLanguages,
};


const title = getLocalizedText(book.titles, language);
const subtitle = getLocalizedText(book.subtitles, language);
const description = getLocalizedText(book.descriptions, language);
---

<BaseLayout
  title={title}
  description={description}
  language={language}
  availableLanguages={book.languages}
>
  <div
    class:list={[
      'min-h-screen',
      'bg-yuval-bg',
      'pt-2',
      'sm:pt-3',
      'pb-12',
      'sm:pb-16',
      'lg:pb-20',
      'px-4',
      'sm:px-6',
      'lg:px-8',
    ]}
  >
    <div class="w-full mx-auto">
      <Breadcrumbs
        language={language}
        items={[
          { key: 'breadcrumb.books', href: '/' },
          { label: book.titles },
        ]}
      />

      <!--
        Layout strategy:
        - Mobile (default): stacked — content (with image), then chapters
        - Desktop (lg+): 2 columns side-by-side
          * Chapters column (smaller, ~1fr)
          * Content column (larger, ~2.5fr) — includes title, subtitle,
            cover image (as figure), description paragraphs, meta stats
        - Source order: chapters first, so in RTL chapters render on the
          right (reading start), and in LTR on the left. Same principle
          both ways.
        - Cover image floats inside the content column: opposite side
          from the reading start, so description text wraps around it.
      -->
      <div
        class:list={[
          'grid',
          'grid-cols-1',
          'lg:grid-cols-[minmax(0,1fr)_minmax(0,2.5fr)]',
          'gap-6',
          'sm:gap-8',
          'lg:gap-10',
          'xl:gap-14',
          'mt-8',
          'sm:mt-10',
          'lg:mt-12',
          'mb-6',
          'sm:mb-8',
          'items-start',
        ]}
      >
        <!-- Chapters sidebar. The id is the scroll target for the
             hero's secondary CTA ("View chapters"); scroll-margin keeps
             the heading clear of any sticky chrome above. -->
        <div id="chapters" class="boh-chapters-anchor">
          <BookOverviewChapters
            chapters={book.chapters}
            slug={slug}
            language={language}
            isRtl={isRtl}
          />
        </div>

        <!-- Content column: hero card + summary -->
        <div class:list={[isRtl && 'text-right']}>
          <BookOverviewHero
            title={title}
            subtitle={subtitle}
            coverImage={book.coverImage}
            credits={book.credits}
            chapters={book.chapters}
            slug={slug}
            level={book.level}
            languages={book.languages}
            language={language}
            isRtl={isRtl}
          />

          <div class="mt-6 sm:mt-8">
            <BookOverviewSummary
              description={description}
              subtitle={subtitle}
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { t, resolveLanguage } from '../../i18n';
  import { SOURCE_LANGUAGE } from '../../utils/language';

  function updatePageContent(lang: string) {
    // Update chapter titles dynamically
    document.querySelectorAll<HTMLElement>('[data-chapter-title]').forEach(el => {
      const titleData = el.dataset.chapterTitle;
      if (titleData) {
        try {
          const titles = JSON.parse(titleData);
          el.textContent = titles[lang] || titles['he'] || Object.values(titles)[0] || '';
        } catch (e) {
          // Silently fail for invalid title data
        }
      }
    });

    // Update all i18n strings
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n;
      if (key) {
        const translatedText = t(key, lang);
        if (translatedText && translatedText !== key) {
          el.textContent = translatedText;
        }
      }
    });

    // Update localized credits (lecturer, editor, author names)
    document.querySelectorAll<HTMLElement>('[data-credit-localized]').forEach(el => {
      const raw = el.dataset.creditLocalized;
      if (!raw) return;
      try {
        const map = JSON.parse(raw) as Record<string, string>;
        const value = map[lang] ?? map[SOURCE_LANGUAGE] ?? Object.values(map).find(Boolean) ?? '';
        if (value) el.textContent = value;
      } catch { /* skip malformed */ }
    });
  }

  function updateChapterLinks() {
    // Links no longer need ?lang= - language is determined by toggle position
  }

  function updateChapterProgress() {
    document.querySelectorAll<HTMLAnchorElement>('.chapter-link[data-chapter-id][data-book-slug]').forEach(link => {
      const chapterId = link.dataset.chapterId;
      const bookSlug = link.dataset.bookSlug;
      if (!chapterId || !bookSlug) return;

      // Reading progress is saved by src/scripts/progress-tracker.ts under
      // the key `yuval_reading_progress_{slug}_ch{chapterId}`. It stores the
      // real `percentage` (0–100) computed against the chapter container
      // height, plus the raw scrollPosition as a fallback for old entries
      // saved before the percentage field existed.
      const keyFragment = `reading_progress_${bookSlug}_ch${chapterId}`;
      let pct = 0;
      let scrollY = 0;

      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (k && k.includes(keyFragment)) {
          try {
            const d = JSON.parse(localStorage.getItem(k) || '{}');
            if (typeof d.percentage === 'number' && d.percentage > pct) {
              pct = d.percentage;
            }
            if (typeof d.scrollPosition === 'number' && d.scrollPosition > scrollY) {
              scrollY = d.scrollPosition;
            }
          } catch {}
        }
      }

      // If we don't have a stored percentage yet (old entry), estimate from
      // scroll pixels as a rough fallback.
      if (pct === 0 && scrollY > 200) {
        pct = Math.min(95, Math.round((scrollY / 3000) * 100));
      }

      const fill = link.querySelector<HTMLElement>('.chapter-progress-fill');
      const check = link.querySelector<HTMLElement>('.chapter-status-check');

      if (pct > 0) {
        if (fill) fill.style.width = `${pct}%`;
        if (pct >= 85) {
          link.dataset.readStatus = 'completed';
          check?.classList.remove('hidden');
        } else {
          link.dataset.readStatus = 'in-progress';
          check?.classList.add('hidden');
        }
      } else {
        if (fill) fill.style.width = '0%';
        delete link.dataset.readStatus;
        check?.classList.add('hidden');
      }
    });
  }

  updateChapterLinks();
  updateChapterProgress();

  window.addEventListener('language-changed', (e: Event) => {
    const lang = (e as CustomEvent<{ language: string }>).detail?.language || SOURCE_LANGUAGE;
    updatePageContent(lang);
    updateChapterLinks();
    updateChapterProgress();
  });

  // Re-read progress when returning to this page via SPA navigation, and
  // when the tab regains focus after the user finished a chapter in another
  // tab or after background progress saves settle.
  document.addEventListener('astro:after-swap', () => {
    updateChapterLinks();
    updateChapterProgress();
  });
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') updateChapterProgress();
  });
  window.addEventListener('pageshow', () => updateChapterProgress());

  // Text-to-Speech on the book landing page: reads the description
  // aloud. We bind the engine to the inline pill button (#tts-inline-trigger)
  // instead of the floating FAB — on a short landing page the FAB pattern
  // is out of place, and users expect the control next to the title.
  import('../../scripts/text-to-speech').then(({ initTextToSpeech }) => {
    let currentController: AbortController | null = null;

    const boot = () => {
      currentController?.abort();
      const inlineEl = document.getElementById('tts-inline-trigger');
      if (!inlineEl) return;
      const ctrl = new AbortController();
      currentController = ctrl;
      initTextToSpeech(ctrl.signal, { trigger: 'inline', inlineEl });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    } else {
      boot();
    }

    document.addEventListener('astro:after-swap', boot);
  });

  // Image lightbox on the book landing page — lets readers click the
  // cover to view it full-size. Same module used in the reading view;
  // its click handler matches .book-cover-img via ZOOM_SELECTOR.
  import('../../scripts/image-lightbox').then(({ initImageLightbox }) => {
    let lbController: AbortController | null = null;

    const boot = () => {
      lbController?.abort();
      const ctrl = new AbortController();
      lbController = ctrl;
      initImageLightbox(ctrl);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    } else {
      boot();
    }

    document.addEventListener('astro:after-swap', boot);
  });
</script>

<style is:global>
  /* Book cover on the landing page: render the image as-is with a
     transparent background, keeping any alpha in the source PNG intact.
     No mix-blend-mode — the cover should look identical in light/dark
     instead of multiplying/screening against the page background. */
  .book-cover-img {
    background-color: transparent;
  }

  /* Chapters scroll target. The hero's secondary CTA links to
     #chapters; the inset offset keeps the heading clear of any sticky
     chrome above. */
  .boh-chapters-anchor {
    scroll-margin-top: 5rem;
  }

  /* Inline TTS trigger — gold pill that sits beside the title.
     Replaces the floating FAB on the landing page: a short description
     doesn't justify a persistent floating control, and the role is
     clearer when the button is adjacent to what it reads. */
  .tts-inline-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    background: linear-gradient(145deg, #c9a227, #ddb52f);
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    line-height: 1;
    border: 0;
    cursor: pointer;
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.18),
      0 0 0 1px rgba(232, 197, 71, 0.5),
      inset 0 1px 1.5px rgba(255, 255, 255, 0.3);
    transition: transform 160ms ease, box-shadow 160ms ease, filter 160ms ease;
    white-space: nowrap;
    align-self: flex-start;
  }
  .tts-inline-btn:hover {
    transform: translateY(-1px);
    filter: brightness(1.06);
    box-shadow:
      0 4px 14px rgba(0, 0, 0, 0.22),
      0 0 0 1px rgba(232, 197, 71, 0.65),
      0 0 20px rgba(232, 197, 71, 0.35),
      inset 0 1px 1.5px rgba(255, 255, 255, 0.4);
  }
  .tts-inline-btn:focus-visible {
    outline: 2px solid #e8c547;
    outline-offset: 3px;
  }
  .tts-inline-btn.is-active {
    background: linear-gradient(145deg, #a8876b, #c9a227);
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.25),
      0 0 0 1px rgba(232, 197, 71, 0.7),
      0 0 18px rgba(232, 197, 71, 0.4),
      inset 0 1px 1.5px rgba(255, 255, 255, 0.3);
  }
  .tts-inline-btn .tts-inline-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
  }
  .tts-inline-btn .tts-inline-icon svg {
    width: 18px;
    height: 18px;
  }

  /* Live-playback waves — two staggered rings expanding outward from the
     pill border give a clear "now reading" affordance. Rendered as
     pseudo-elements so they sit behind the button's real shadow without
     disturbing layout; pointer-events disabled so the button still
     receives clicks. Gold/amber tones match the platform accent. */
  .tts-inline-btn::before,
  .tts-inline-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    opacity: 0;
  }
  .tts-inline-btn.is-active::before,
  .tts-inline-btn.is-active::after {
    opacity: 1;
    border: 2px solid rgba(232, 197, 71, 0.55);
    animation: ttsInlineWave 2.4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  .tts-inline-btn.is-active::after {
    border-color: rgba(255, 180, 64, 0.5);
    animation-delay: 1.2s;
  }
  @keyframes ttsInlineWave {
    0%   { transform: scale(1);    opacity: 0.85; }
    70%  { transform: scale(1.32); opacity: 0; }
    100% { transform: scale(1.32); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tts-inline-btn,
    .tts-inline-btn:hover {
      transition: none;
      transform: none;
    }
    .tts-inline-btn.is-active::before,
    .tts-inline-btn.is-active::after {
      animation: none;
      opacity: 0;
    }
  }

  /* Chapter cards on the landing page mirror the reading-view sidebar
     identity: cyan/blue accent over a dark slate card in dark mode,
     blue accent over a soft slate card in light mode. Tokens are
     duplicated from src/styles/chapter-sidebar.css so this page stays
     visually in sync without pulling in the full sidebar stylesheet. */
  :root {
    --landing-card-bg:           #0e1a26;
    --landing-card-bg-completed: #102438;
    --landing-card-border:       #374151;
    --landing-card-border-completed: #1a3850;
    --landing-card-border-hover: #4DA8E0;
    --landing-circle-bg:         #102230;
    --landing-circle-border:     #6b7280;
    --landing-text-accent:       #4DA8E0;
    --landing-text-completed:    #5DCAA5;
    --landing-completion-green:  #5DCAA5;
    --landing-progress-track:    rgba(255, 255, 255, 0.06);
  }
  :root:not(.dark) {
    --landing-card-bg:           #f1f5f9;
    --landing-card-bg-completed: #ECFDF5;
    --landing-card-border:       #e2e8f0;
    --landing-card-border-completed: #BBF7D0;
    --landing-card-border-hover: #2563EB;
    --landing-circle-bg:         #f8fafc;
    --landing-circle-border:     #9ca3af;
    --landing-text-accent:       #2563EB;
    --landing-text-completed:    #059669;
    --landing-completion-green:  #10b981;
    --landing-progress-track:    rgba(15, 23, 42, 0.08);
  }

  /* Slim accent rule beside the "Chapters" heading. Mirrors the soft
     gradient feeder used in the sidebar header. */
  .chapters-heading-rule {
    background: linear-gradient(
      to var(--rule-direction, left),
      color-mix(in srgb, var(--landing-text-accent) 55%, transparent),
      transparent
    );
  }
  [dir="ltr"] .chapters-heading-rule {
    --rule-direction: right;
  }

  .chapter-link {
    background: var(--landing-card-bg);
    border: 1px solid var(--landing-card-border);
    border-radius: 10px;
  }
  .chapter-link:hover {
    border-color: var(--landing-card-border-hover);
    transform: translateY(-1px);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--landing-card-border-hover) 12%, transparent);
  }
  .chapter-link:focus-visible {
    outline: 2px solid var(--landing-card-border-hover);
    outline-offset: 2px;
  }

  .chapter-number-badge {
    background: var(--landing-circle-bg);
    border: 1.5px solid var(--landing-circle-border);
    color: var(--landing-text-accent);
    line-height: 1;
  }
  .chapter-link:hover .chapter-number-badge {
    border-color: var(--landing-card-border-hover);
    color: var(--landing-card-border-hover);
  }

  /* Bottom progress fill: in-progress = accent cyan/blue,
     completed = green. Track is a low-contrast wash. */
  .chapter-progress-bar {
    background: var(--landing-progress-track);
  }
  .chapter-progress-fill {
    background: var(--landing-text-accent);
    border-radius: 0 2px 2px 0;
  }

  /* Read-status states. Completed leans green (action confirmed),
     in-progress keeps the cyan accent on the border and the badge
     so the active reading thread feels continuous with the sidebar. */
  .chapter-link[data-read-status="completed"] {
    background: var(--landing-card-bg-completed);
    border-color: var(--landing-card-border-completed);
  }
  .chapter-link[data-read-status="completed"] .chapter-number-badge {
    border-color: var(--landing-completion-green);
    color: var(--landing-text-completed);
  }
  .chapter-link[data-read-status="completed"] .chapter-progress-fill {
    background: var(--landing-completion-green);
  }
  .chapter-link[data-read-status="in-progress"] {
    border-color: var(--landing-text-accent);
  }
  .chapter-link[data-read-status="in-progress"] .chapter-number-badge {
    border-color: var(--landing-text-accent);
  }
</style>