---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import type { Language, Chapter } from '../../types/index';
import { LANGUAGES } from '../../utils/language';
import { discoverAllBooks } from '../../utils/book-discovery';

interface Props {
  language?: Language;
}

export async function getStaticPaths() {
  const books = discoverAllBooks();
  return books.map(book => ({
    params: { slug: book.slug },
    props: { bookData: book }
  }));
}

const { language = LANGUAGES.EN } = Astro.props;
const { slug } = Astro.params;
const { bookData } = Astro.props as any;
const isRtl = language === LANGUAGES.HE;

const book = {
  slug: bookData.slug,
  title_he: bookData.title_he,
  title_en: bookData.title_en,
  description_he: bookData.description_he,
  description_en: bookData.description_en,
  coverImage: bookData.coverImage,
  dominantColor: bookData.dominantColor,
  chapters: bookData.chapters,
};

const title = language === LANGUAGES.HE ? book.title_he : book.title_en;
const description =
  language === LANGUAGES.HE ? book.description_he : book.description_en;
---

<BaseLayout
  title={title}
  description={description}
  language={language}
>
  <div
    class:list={[
      'min-h-screen',
      'bg-yuval-bg',
      'py-12',
      'sm:py-16',
      'lg:py-20',
      'px-4',
      'sm:px-6',
      'lg:px-8',
    ]}
  >
    <div class="max-w-4xl mx-auto">
      <!-- Breadcrumbs -->
      <Breadcrumbs
        items={[
          { label_he: 'ספרים', label_en: 'Books', label_es: 'Libros', href: '/' },
          { label_he: book.title_he, label_en: book.title_en, label_es: book.title_es },
        ]}
        class="mb-8"
      />

      <!-- Book Header -->
      <div
        class:list={[
          'grid',
          'grid-cols-1',
          'md:grid-cols-3',
          'gap-8',
          'mb-12',
          'items-start',
        ]}
      >
        <!-- Cover Image -->
        <div class="md:col-span-1">
          <img
            src={book.coverImage}
            alt={title}
            loading="lazy"
            decoding="async"
            class="w-full rounded-lg shadow-lg bg-yuval-bg-secondary object-contain"
          />
        </div>

        <!-- Book Info -->
        <div class:list={['md:col-span-2', isRtl && 'text-right']}>
          <h1
            class="font-heading font-bold text-2xl sm:text-4xl lg:text-5xl leading-tight mb-3 sm:mb-4 text-yuval-text"
            data-he={book.title_he}
            data-en={book.title_en}
          >
            {book.title_en}
          </h1>

          <p class="text-base sm:text-lg text-yuval-text-secondary leading-relaxed mb-4 sm:mb-6"
            data-he={book.description_he}
            data-en={book.description_en}
          >
            {book.description_en}
          </p>

          <div class="space-y-2 mb-6">
            <p class="text-sm text-yuval-text-tertiary"
              data-he={`${book.chapters.length} פרקים`}
              data-en={`${book.chapters.length} chapters`}
            >
              {book.chapters.length} chapters
            </p>
            <p class="text-sm text-yuval-text-tertiary"
              data-he={`${book.chapters.reduce((sum: number, ch: Chapter) => sum + ch.word_count, 0)} מילים`}
              data-en={`${book.chapters.reduce((sum: number, ch: Chapter) => sum + ch.word_count, 0)} words`}
            >
              {book.chapters.reduce((sum: number, ch: Chapter) => sum + ch.word_count, 0)} words
            </p>
          </div>
        </div>
      </div>

      <!-- Chapters List -->
      <div class="border-t border-yuval-border pt-12">
        <h2
          class="font-heading font-bold text-2xl mb-6 text-yuval-text"
          data-he="פרקים"
          data-en="Chapters"
        >
          Chapters
        </h2>

        <div class="space-y-3">
          {
            book.chapters.map((chapter: Chapter) => {
              const chapterTitle =
                language === LANGUAGES.HE
                  ? chapter.title_he
                  : chapter.title_en;
              return (
                <a
                  href={`/read/${slug}/${chapter.id}`}
                  class:list={[
                    'chapter-link',
                    `chapter-link-${chapter.id}`,
                    'block',
                    'p-4',
                    'rounded-lg',
                    'border',
                    'border-yuval-border',
                    'hover:bg-yuval-bg-secondary',
                    'hover:border-yuval-border-secondary',
                    'transition-all',
                    'duration-200',
                    'focus:outline-none',
                    'focus:ring-2',
                    'focus:ring-offset-2',
                    'focus:ring-yuval-highlight',
                    'relative',
                    'overflow-hidden',
                  ]}
                  data-chapter-id={chapter.id}
                  data-book-slug={slug}
                >
                  {/* Progress bar at bottom of card — filled by JS */}
                  <div class="chapter-progress-bar absolute bottom-0 left-0 right-0 h-0.5 bg-yuval-border">
                    <div class="chapter-progress-fill h-full bg-green-500 w-0 transition-all duration-700"
                      style="border-radius: 0 2px 2px 0"></div>
                  </div>

                  <div
                    class:list={[
                      'flex',
                      'items-center',
                      'justify-between',
                      'gap-4',
                      isRtl && 'flex-row-reverse',
                    ]}
                  >
                    <div class:list={[isRtl && 'text-right', 'flex-1', 'min-w-0']}>
                      <div class="flex items-center gap-2">
                        <span class="chapter-status-icon text-base hidden" aria-hidden="true"></span>
                        <h3
                          class="font-heading font-semibold text-base sm:text-lg text-yuval-text line-clamp-2"
                          data-he={chapter.title_he}
                          data-en={chapter.title_en}
                        >
                          {chapter.title_en}
                        </h3>
                      </div>
                      <p class="text-sm text-yuval-text-tertiary mt-1"
                        data-he={`${chapter.sections > 1 ? `${chapter.sections} סעיפים` : 'סעיף אחד'} • ${chapter.word_count} מילים`}
                        data-en={`${chapter.sections > 1 ? `${chapter.sections} sections` : '1 section'} • ${chapter.word_count} words`}
                      >
                        {chapter.sections > 1 ? `${chapter.sections} sections` : '1 section'} • {chapter.word_count} words
                      </p>
                    </div>
                    <svg
                      class="w-5 h-5 text-yuval-text-tertiary flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width={2}
                        d={isRtl ? 'M15 19l-7-7 7-7' : 'M9 5l7 7-7 7'}
                      />
                    </svg>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  function updateChapterLinks() {
    const lang = localStorage.getItem('yuval_language') || 'en';
    document.querySelectorAll<HTMLAnchorElement>('.chapter-link').forEach(link => {
      const href = link.getAttribute('href') || '';
      const base = href.split('?')[0];
      link.href = lang === 'he' ? `${base}?lang=he` : base;
    });
  }

  function updateChapterProgress() {
    document.querySelectorAll<HTMLAnchorElement>('.chapter-link[data-chapter-id][data-book-slug]').forEach(link => {
      const chapterId = link.dataset.chapterId;
      const bookSlug  = link.dataset.bookSlug;
      if (!chapterId || !bookSlug) return;

      const key = `yuval_reading_progress_${bookSlug}_ch${chapterId}`;
      const altKey = `yuval_reading_progress_${bookSlug}_ch${chapterId}`;

      let scrollY = 0;
      // Try both key formats
      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (k && k.includes(`_${bookSlug}_ch${chapterId}`)) {
          try {
            const d = JSON.parse(localStorage.getItem(k) || '{}');
            if (d.scrollPosition > scrollY) scrollY = d.scrollPosition;
          } catch { /* skip */ }
        }
      }

      const fill   = link.querySelector<HTMLElement>('.chapter-progress-fill');
      const icon   = link.querySelector<HTMLElement>('.chapter-status-icon');

      if (scrollY > 200) {
        // Estimate percentage: scrollY / (estimated page height ~3000px)
        const estPct = Math.min(95, Math.round((scrollY / 3000) * 100));
        if (fill) { fill.style.width = `${estPct}%`; }
        if (icon) { icon.textContent = estPct >= 85 ? '✅' : '📖'; icon.classList.remove('hidden'); }
      }
    });
  }

  updateChapterLinks();
  updateChapterProgress();
  window.addEventListener('language-changed', updateChapterLinks);
</script>
