---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import type { Language, Chapter } from '../../types/index';
import { getLanguageDirection, isValidLanguage } from '../../utils/language';
import { discoverAllBooks } from '../../utils/book-discovery';
import { t } from '../../i18n';

interface Props {
  language?: Language;
}

type LocalizedMap = Record<string, string | undefined>;

function getLocalizedText(
  value: LocalizedMap | undefined,
  lang: string,
  fallback = 'en'
): string {
  if (!value) return '';
  return value[lang] ?? value[fallback] ?? Object.values(value).find(Boolean) ?? '';
}

function formatChapterCount(count: number): string {
  return `${count} chapters`;
}

function formatWordCount(count: number): string {
  return `${count} words`;
}

function getChapterMetaText(chapter: Chapter): string {
  const sections = chapter.sections ?? 0;
  const wordCount = chapter.word_count ?? 0;
  const sectionLabel = sections === 1 ? '1 section' : `${sections} sections`;
  return `${sectionLabel} • ${wordCount} words`;
}

export async function getStaticPaths() {
  const books = discoverAllBooks();
  return books.map(book => ({
    params: { slug: book.slug },
    props: { bookData: book }
  }));
}

const { language: propLanguage } = Astro.props;
const { slug } = Astro.params;

const books = discoverAllBooks();
const bookData = books.find(b => b.slug === slug);

if (!bookData) {
  return Astro.redirect('/404');
}

const availableLanguages = Array.isArray(bookData.languages) && bookData.languages.length > 0
  ? bookData.languages
  : Object.keys(bookData.titles || {});

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();

const requestedLanguage =
  (urlLang && availableLanguages.includes(urlLang) && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && availableLanguages.includes(propLanguage) ? propLanguage : undefined);

const language = (requestedLanguage ?? (availableLanguages.includes('en') ? 'en' : availableLanguages[0] ?? 'en')) as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

const book = {
  slug: bookData.slug,
  titles: bookData.titles ?? {},
  subtitles: bookData.subtitles ?? {},
  descriptions: bookData.descriptions ?? {},
  coverImage: bookData.coverImage,
  dominantColor: bookData.dominantColor,
  chapters: bookData.chapters ?? [],
  credits: bookData.credits,
  languages: availableLanguages,
};

const title = getLocalizedText(book.titles, language);
const description = getLocalizedText(book.descriptions, language);
const totalWords = book.chapters.reduce((sum: number, ch: Chapter) => sum + (ch.word_count ?? 0), 0);
---

<BaseLayout
  title={title}
  description={description}
  language={language}
>
  <div
    class:list={[
      'min-h-screen',
      'bg-yuval-bg',
      'py-12',
      'sm:py-16',
      'lg:py-20',
      'px-4',
      'sm:px-6',
      'lg:px-8',
    ]}
  >
    <div class="max-w-4xl mx-auto">
      <Breadcrumbs
        language={language}
        items={[
          { key: 'breadcrumb.books', href: '/' },
          { label: book.titles },
        ]}
        class="mb-8"
      />

      <div
        class:list={[
          'grid',
          'grid-cols-1',
          'md:grid-cols-3',
          'gap-8',
          'mb-12',
          'items-start',
        ]}
      >
        <div class="md:col-span-1">
          <img
            src={book.coverImage}
            alt={title}
            loading="lazy"
            decoding="async"
            class="w-full rounded-lg shadow-lg bg-yuval-bg-secondary object-contain"
          />

          {book.credits && (
            <div class:list={[
              'mt-3',
              'text-sm',
              'text-yuval-text-secondary',
              isRtl && 'text-right',
            ]}>
              {book.credits.type === 'lecture_summary' ? (
                <p>
                  <span>Lecturer:</span> {' '}{book.credits.lecturer}
                  <br />
                  <span>Summarized and edited by:</span> {' '}{book.credits.editor}
                </p>
              ) : (
                <p>
                  <span>By:</span> {' '}{book.credits.author}
                </p>
              )}
            </div>
          )}
        </div>

        <div class:list={['md:col-span-2', isRtl && 'text-right']}>
          <h1 class="font-heading font-bold text-xl sm:text-3xl lg:text-4xl leading-tight mb-3 sm:mb-4 text-yuval-text">
            {title}
          </h1>

          {getLocalizedText(book.subtitles, language) && (
            <p class="text-sm sm:text-base text-yuval-text-tertiary leading-relaxed mb-3">
              {getLocalizedText(book.subtitles, language)}
            </p>
          )}

          <p class="text-base sm:text-lg text-yuval-text-secondary leading-relaxed mb-4 sm:mb-6">
            {description}
          </p>

          <div class="space-y-2 mb-6">
            <p class="text-sm text-yuval-text-tertiary">
              {formatChapterCount(book.chapters.length)}
            </p>

            <p class="text-sm text-yuval-text-tertiary">
              {formatWordCount(totalWords)}
            </p>
          </div>
        </div>
      </div>

      <div class="border-t border-yuval-border pt-12">
        <h2 class="font-heading font-bold text-2xl mb-6 text-yuval-text">
          {t('sidebar.chapters', language)}
        </h2>

        <div class="space-y-3">
          {
            book.chapters.map((chapter: Chapter) => {
              const chapterTitle = getLocalizedText(chapter.titles, language);

              return (
                <a
                  href={`/read/${slug}/${chapter.id}`}
                  class:list={[
                    'chapter-link',
                    `chapter-link-${chapter.id}`,
                    'block',
                    'p-4',
                    'rounded-lg',
                    'border',
                    'border-yuval-border',
                    'hover:bg-yuval-bg-secondary',
                    'hover:border-yuval-border-secondary',
                    'transition-all',
                    'duration-200',
                    'focus:outline-none',
                    'focus:ring-2',
                    'focus:ring-offset-2',
                    'focus:ring-yuval-highlight',
                    'relative',
                    'overflow-hidden',
                  ]}
                  data-chapter-id={chapter.id}
                  data-book-slug={slug}
                >
                  <div class="chapter-progress-bar absolute bottom-0 left-0 right-0 h-0.5 bg-yuval-border">
                    <div
                      class="chapter-progress-fill h-full bg-green-500 w-0 transition-all duration-700"
                      style="border-radius: 0 2px 2px 0"
                    ></div>
                  </div>

                  <div
                    class:list={[
                      'flex',
                      'items-center',
                      'justify-between',
                      'gap-4',
                      isRtl && 'flex-row-reverse',
                    ]}
                  >
                    <div class:list={[isRtl && 'text-right', 'flex-1', 'min-w-0']}>
                      <div class="flex items-center gap-2">
                        <span class="chapter-status-icon text-base hidden" aria-hidden="true"></span>
                        <h3 class="font-heading font-semibold text-base sm:text-lg text-yuval-text line-clamp-2">
                          {chapterTitle}
                        </h3>
                      </div>

                      <p class="text-sm text-yuval-text-tertiary mt-1">
                        {getChapterMetaText(chapter)}
                      </p>
                    </div>

                    <svg
                      class="w-5 h-5 text-yuval-text-tertiary flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width={2}
                        d={isRtl ? 'M15 19l-7-7 7-7' : 'M9 5l7 7-7 7'}
                      />
                    </svg>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  function updateChapterLinks() {
    // Links no longer need ?lang= - language is determined by toggle position
  }

  function updateChapterProgress() {
    document.querySelectorAll<HTMLAnchorElement>('.chapter-link[data-chapter-id][data-book-slug]').forEach(link => {
      const chapterId = link.dataset.chapterId;
      const bookSlug = link.dataset.bookSlug;
      if (!chapterId || !bookSlug) return;

      let scrollY = 0;

      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (k && k.includes(`_${bookSlug}_ch${chapterId}`)) {
          try {
            const d = JSON.parse(localStorage.getItem(k) || '{}');
            if (d.scrollPosition > scrollY) scrollY = d.scrollPosition;
          } catch {}
        }
      }

      const fill = link.querySelector<HTMLElement>('.chapter-progress-fill');
      const icon = link.querySelector<HTMLElement>('.chapter-status-icon');

      if (scrollY > 200) {
        const estPct = Math.min(95, Math.round((scrollY / 3000) * 100));
        if (fill) {
          fill.style.width = `${estPct}%`;
        }
        if (icon) {
          icon.textContent = estPct >= 85 ? '✅' : '📖';
          icon.classList.remove('hidden');
        }
      }
    });
  }

  updateChapterLinks();
  updateChapterProgress();
  window.addEventListener('language-changed', updateChapterLinks);
</script>