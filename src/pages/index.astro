---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookCard from '../components/BookCard.astro';
import type { Language } from '../types/index';
import { LANGUAGES } from '../utils/language';
import { discoverAllBooks } from '../utils/book-discovery';

interface Props {
  language?: Language;
}

const { language = LANGUAGES.EN } = Astro.props;
const isRtl = language === LANGUAGES.HE;

const books = discoverAllBooks();
const categories = ['All', ...Array.from(new Set(books.map(b => b.category).filter(Boolean))).sort()];
---

<BaseLayout
  title={language === LANGUAGES.HE ? 'ספרים' : 'Books'}
  description={
    language === LANGUAGES.HE
      ? 'הרשימה המלאה של ספרים ב-Yuval'
      : 'Complete list of books on Yuval'
  }
  language={language}
>
  <div
    class:list={[
      'min-h-screen',
      'bg-yuval-bg',
      'px-4',
      'sm:px-6',
      'lg:px-8',
      'py-12',
      'sm:py-16',
      'lg:py-20',
    ]}
  >
    <!-- Hero Section -->
    <div
      class:list={[
        'max-w-4xl',
        'mx-auto',
        'mb-16',
        'text-center',
        isRtl && 'text-right',
      ]}
    >
      <h1
        class="font-heading font-bold text-3xl sm:text-4xl lg:text-6xl leading-tight mb-3 sm:mb-4 text-yuval-text"
        data-i18n="home.title"
      >
        Books
      </h1>
      <p
        class="text-lg sm:text-xl text-yuval-text-secondary font-light leading-relaxed"
        data-i18n="home.subtitle"
      >
        Explorations of deep knowledge and practical application
      </p>
    </div>

    <!-- Continue Reading Banner (populated by JS from localStorage) -->
    <div id="continue-reading-banner" class="max-w-4xl mx-auto mb-10 hidden"></div>

    <!-- Category Filter -->
    {categories.length > 1 && (
      <div class="max-w-7xl mx-auto mb-10 flex flex-wrap gap-2 justify-center" id="category-filters">
        {categories.map(cat => (
          <button
            type="button"
            class:list={[
              'category-filter-btn',
              'px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200',
              'border border-yuval-border text-yuval-text-secondary',
              'hover:bg-yuval-surface hover:text-yuval-text',
            ]}
            data-category={cat}
            data-active={cat === 'All' ? 'true' : 'false'}
          >
            {cat}
          </button>
        ))}
      </div>
    )}

    <!-- Books Grid -->
    <div
      class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 sm:gap-5"
      id="books-grid"
    >
      {
        books.map((book) => (
          <BookCard
            slug={book.slug}
            title_he={book.title_he}
            title_en={book.title_en}
            description_he={book.description_he}
            description_en={book.description_en}
            coverImage={book.coverImage}
            dominantColor={book.dominantColor}
            category={book.category}
          />
        ))
      }
    </div>

    <!-- Empty State -->
    {
      books.length === 0 && (
        <div
          class={`max-w-md mx-auto py-16 text-center ${isRtl ? 'text-right' : ''}`}
        >
          <svg class="mx-auto w-16 h-16 text-yuval-text-muted mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          <p
            class="text-lg text-yuval-text-secondary font-medium"
            data-i18n="home.noBooks"
          >
            No books available yet
          </p>
          <p class="mt-2 text-sm text-yuval-text-tertiary"
            data-i18n="home.noBooksHint"
          >
            Add books to the output/ folder to get started
          </p>
        </div>
      )
    }
  </div>
</BaseLayout>

<script>
  function initCategoryFilter() {
    const btns = document.querySelectorAll<HTMLButtonElement>('.category-filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('[data-book-category]');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const selected = btn.dataset.category || 'All';

        // Update button styles
        btns.forEach(b => {
          const isActive = b.dataset.category === selected;
          b.dataset.active = isActive ? 'true' : 'false';
          b.classList.toggle('bg-yuval-text', isActive);
          b.classList.toggle('text-yuval-bg', isActive);
          b.classList.toggle('border-yuval-text', isActive);
          b.classList.toggle('text-yuval-text-secondary', !isActive);
          b.classList.toggle('border-yuval-border', !isActive);
        });

        // Show/hide cards
        cards.forEach(card => {
          const cat = card.dataset.bookCategory || '';
          card.style.display = (selected === 'All' || cat === selected) ? '' : 'none';
        });
      });
    });

    // Set initial active style for "All"
    btns.forEach(b => {
      if (b.dataset.category === 'All') {
        b.classList.add('bg-yuval-text', 'text-yuval-bg', 'border-yuval-text');
        b.classList.remove('text-yuval-text-secondary', 'border-yuval-border');
      }
    });
  }

  initCategoryFilter();
  document.addEventListener('astro:after-swap', initCategoryFilter);

  // ── i18n helper (mirrors src/i18n/index.ts for inline scripts) ───────────
  function yuvalT(key: string, lang: string, params?: Record<string, string | number>): string {
    const map: Record<string, Record<string, string>> = {
      'home.continueReading': { he: 'המשך קריאה', en: 'Continue Reading', es: 'Continuar leyendo' },
      'home.chapter':         { he: 'פרק',         en: 'Chapter',          es: 'Capítulo' },
    };
    const entry = map[key];
    if (!entry) return key;
    let text = entry[lang] ?? entry['en'] ?? key;
    if (params) text = text.replace(/\{\{(\w+)\}\}/g, (_, n) => params[n] !== undefined ? String(params[n]) : `{{${n}}}`);
    return text;
  }

  // ── Continue Reading ──────────────────────────────────────────────────────
  function buildContinueReading() {
    const banner = document.getElementById('continue-reading-banner');
    if (!banner) return;

    const lang = localStorage.getItem('yuval_language') || 'en';
    const isHe = lang === 'he';
    const isEs = lang === 'es';

    // Find the most recently read chapter across all books
    let bestKey = '';
    let bestTime = 0;
    let bestScroll = 0;

    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i);
      if (!key?.startsWith('yuval_reading_progress_')) continue;
      try {
        const d = JSON.parse(localStorage.getItem(key) || '{}');
        const t = d.lastUpdated || d.timestamp || 0;
        if (t > bestTime && (d.scrollPosition || 0) > 50) {
          bestTime = t;
          bestKey = key;
          bestScroll = d.scrollPosition || 0;
        }
      } catch { /* skip */ }
    }

    if (!bestKey) return;

    // Parse key: yuval_reading_progress_{book}_ch{chapter}
    const match = bestKey.match(/yuval_reading_progress_(.+?)_ch(\d+)$/);
    if (!match) return;
    const bookSlug = match[1];
    const chapterId = match[2];

    // Find book title from a card on the page — if book no longer exists, abort
    const bookCard = document.querySelector<HTMLElement>(`[data-book-slug="${bookSlug}"]`);
    if (!bookCard) return;
    const titleEl  = bookCard?.querySelector<HTMLElement>('[data-he][data-en]');
    const bookTitle = titleEl
      ? (isHe ? titleEl.dataset.he : isEs ? titleEl.dataset.es : titleEl.dataset.en) || bookSlug
      : bookSlug;

    const url = `/read/${bookSlug}/${chapterId}${lang !== 'en' ? `?lang=${lang}` : ''}`;

    const estPct = Math.min(95, Math.round((bestScroll / 3000) * 100));

    banner.innerHTML = `
      <a href="${url}" id="cr-link" style="
        display:flex; align-items:center; gap:16px;
        padding:16px 20px;
        background:var(--yuval-surface,#fff);
        border:1px solid var(--yuval-border,#e5e7eb);
        border-radius:16px;
        text-decoration:none;
        box-shadow:0 2px 12px rgba(0,0,0,0.06);
        transition:box-shadow 0.2s, transform 0.2s;
        direction:${isHe ? 'rtl' : 'ltr'};
      ">
        <span style="font-size:28px;flex-shrink:0">📖</span>
        <div style="flex:1;min-width:0">
          <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;
            color:var(--yuval-text-muted,#999);margin-bottom:3px">
            ${yuvalT('home.continueReading', lang)}
          </div>
          <div style="font-size:15px;font-weight:700;color:var(--yuval-text,#1a1a1a);
            white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
            ${bookTitle} · ${yuvalT('home.chapter', lang)} ${chapterId}
          </div>
          <div style="margin-top:6px;height:3px;border-radius:99px;background:var(--yuval-border,#e5e7eb);overflow:hidden">
            <div style="height:100%;width:${estPct}%;border-radius:99px;
              background:linear-gradient(90deg,#6366f1,#8b5cf6);
              transition:width 0.8s ease"></div>
          </div>
        </div>
        <span style="font-size:20px;color:var(--yuval-text-muted,#999);flex-shrink:0">
          ${isHe ? '←' : '→'}
        </span>
      </a>
    `;

    banner.classList.remove('hidden');

    // Hover effect
    const link = document.getElementById('cr-link');
    link?.addEventListener('mouseenter', () => {
      (link as HTMLElement).style.boxShadow = '0 6px 24px rgba(0,0,0,0.12)';
      (link as HTMLElement).style.transform = 'translateY(-2px)';
    });
    link?.addEventListener('mouseleave', () => {
      (link as HTMLElement).style.boxShadow = '0 2px 12px rgba(0,0,0,0.06)';
      (link as HTMLElement).style.transform = '';
    });
  }

  buildContinueReading();
  document.addEventListener('astro:after-swap', buildContinueReading);
  window.addEventListener('language-changed', buildContinueReading);
</script>

