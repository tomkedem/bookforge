---
/**
 * /library — Living Library, dual layout.
 *
 *   MOBILE (<1024px) — vertical discovery flow between the sticky
 *   global header and the page bottom (no fixed mobile footer yet):
 *     1. Compact hero (LibraryHero)
 *     2. Mobile discovery carousel (MobileGalaxyCarousel)
 *     3. Quick actions (LibraryQuickActions)
 *   ContinueLearningCard, LibraryStatsPanel and FloatingSidebar are
 *   all hidden on mobile from inside their own component CSS, so they
 *   do not participate in the mobile flow.
 *
 *   DESKTOP (≥1024px) — single immersive dashboard viewport.
 *     ┌──────────┬──────────────────────────────┬──────────┐
 *     │ Continue │  Hero (floats over galaxy)   │          │
 *     │ Knowledge│  Galaxy stage (core + cards) │   Rail   │
 *     │ Stats    │  — large negative space      │  (pill)  │
 *     │          │    below the core            │          │
 *     └──────────┴──────────────────────────────┴──────────┘
 *
 *   Composition fits inside ~100dvh after the global header — no long
 *   stacked page on desktop.
 *
 * Same components, same data, same i18n. Only CSS varies by breakpoint.
 *
 * Featured items are filtered OUT of recent items so cards never appear
 * twice on a single screen.
 */

import LibraryLayout from '../layouts/LibraryLayout.astro';
import LibraryHero from '../components/library/LibraryHero.astro';
import LibraryStatsPanel from '../components/library/LibraryStatsPanel.astro';
import ContinueLearningCard from '../components/library/ContinueLearningCard.astro';
import LibraryCard from '../components/library/LibraryCard.astro';
import LibraryQuickActions from '../components/library/LibraryQuickActions.astro';
import FloatingSidebar from '../components/library/FloatingSidebar.astro';

import type { Language } from '../types/index';
import type { LibraryItem } from '../types/library';
import { DEFAULT_LANGUAGE, LANGUAGE_CODES, getLanguageDirection, isValidLanguage } from '../utils/language';
import { t } from '../i18n';
import {
  getLibraryItems,
  getLibraryStats,
  getContinueReadingItem,
} from '../utils/library-catalog';
import { getCourseProgressList } from '../utils/library-adapter';
import { isReadableLibraryItem, isSafeLibraryHref } from '../utils/library-display';
import { getEvenOrbitAngle } from '../utils/library/universe-angle-utils';
import {
  getKnowledgeCardAssets,
  getKnowledgeCardAssetsOrPlaceholder,
} from '../utils/library/knowledge-cards';

// ── Language ──────────────────────────────────────────────────────────────
const { language: propLanguage } = Astro.props as { language?: Language };

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const requestedLanguage =
  (urlLang && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && isValidLanguage(propLanguage) ? propLanguage : DEFAULT_LANGUAGE);
const language = requestedLanguage as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

// ── Data ──────────────────────────────────────────────────────────────────
// Primary source = real BookForge content (via library-adapter); falls
// back to mock when output/ is empty (CI / fresh checkout).
const items = getLibraryItems();
const stats = getLibraryStats(items);
// Per-course progress (X of Y lesson summaries available) — empty when
// no real catalog is in play (mock fallback returns []).
const courseProgress = getCourseProgressList();

// Continue ONLY considers readable items so that we never surface the
// synthetic ai-engineering course (no /courses route yet) as a
// clickable-looking suggestion.
const readableItems = items.filter(isReadableLibraryItem);
const continueItem = getContinueReadingItem(readableItems);

// ── Galaxy orbit — every item visible at once ────────────────────────────
// Every readable item sits on its own point along an elliptical orbit
// around the central glowing core. The arrangement is dynamic over
// `readableItems`: 7 items → 7 evenly-spaced angles, 12 items → 12.
// No carousel, no queue, no pager — adding a book to output/ simply
// adds a new station on the orbit.
//
// Books occupy the inline-start arc (visual-left in LTR, visual-right
// in RTL — matches the existing convention via --galaxy-dir).
// Lessons occupy the inline-end arc.
// Series sit at the top (12 o'clock), where the two arcs meet — they
// are organizing entities that bridge books and lessons and don't
// belong on either arc.
// Cards retain their type tint (gold for books, cyan for lessons,
// violet for series) so the groups stay visually distinguishable
// even without columns.
//
// Click-to-center still works: a clicked card flies to the middle and
// the rest dim under the backdrop.
//
// Orbit eligibility — two distinct gates:
//   1. Series capsules MUST have a real per-slug artifact. The series
//      capsule is the parent visual; replacing it with a placeholder
//      would hide the editorial identity of the series itself, so it's
//      gated on `hasOrbitArtifact`. (See `_placeholders/` rationale in
//      `knowledge-cards.ts`.)
//   2. Every other orbit card (books, lessons, generic content) is
//      allowed onto the orbit without a per-slug `front.png`. When the
//      asset is missing the shared placeholder
//      (`_placeholders/book-front.png`) is used — the title, type, and
//      metadata still come from the real LibraryItem, only the image
//      is generic. Visibility / readability rules are unchanged: an
//      item that fails `isReadableLibraryItem` is still excluded, so
//      hidden / archived / unrelated items never become visible just
//      because a placeholder exists.
// Mobile views (e.g. MobileGalaxyCarousel) keep their unfiltered
// `readableItems` source and are not affected by these filters.
const hasOrbitArtifact = (slug: string) => getKnowledgeCardAssets(slug) !== undefined;

// Visual-only orbit visibility predicate. Distinct from
// `isReadableLibraryItem` (which gates clickability for the rest of
// the page). Series bypass the readable-href requirement here;
// books/lessons still need it so links never 404.
const isOrbitVisible = (it: LibraryItem): boolean => {
  if (it.type === 'series') {
    // Series capsules require the real folder asset, never the
    // placeholder. A series with no asset is suppressed from the orbit.
    return hasOrbitArtifact(it.slug);
  }
  // Non-series items rely on the readability gate; their image will
  // come from `getKnowledgeCardAssetsOrPlaceholder` below, so a missing
  // per-slug front.png no longer disqualifies them from the orbit.
  return isReadableLibraryItem(it);
};
const orbitItemsSource = items.filter(isOrbitVisible);

/**
 * Resolve the artifact bundle to render on the orbit for `it`. Series
 * capsules MUST keep using their real folder asset — the placeholder
 * is never substituted for a series. Every other content type uses
 * the placeholder helper so a missing per-slug front.png falls back to
 * `_placeholders/book-front.png` instead of producing a no-art card.
 */
const resolveOrbitArtifact = (it: LibraryItem) =>
  it.type === 'series'
    ? getKnowledgeCardAssets(it.slug)
    : getKnowledgeCardAssetsOrPlaceholder(it.slug);

// Build-time match report — printed alongside the discovery report
// in `knowledge-cards.ts` so it's clear which catalog slugs landed
// on the orbit, which got the shared placeholder, and which were
// filtered out (currently: series capsules without a real folder).
console.log(
  `[knowledge-cards] orbit match report: ${orbitItemsSource.length} of ${readableItems.length} items on the orbit.`,
);
for (const it of readableItems) {
  const real = hasOrbitArtifact(it.slug);
  const onOrbit = isOrbitVisible(it);
  let status: string;
  if (real) status = 'MATCH       ';
  else if (it.type === 'series') status = 'no-match    ';
  else if (onOrbit) status = 'PLACEHOLDER ';
  else status = 'no-match    ';
  console.log(`[knowledge-cards]   [${status}] slug="${it.slug}" type=${it.type}`);
}
// One unified array fed to a single distribution pass. Item TYPE drives
// CSS only (badge colour, fallback artwork, click affordance) — never
// orbit position. Books, lessons, series and any future kinds share one
// global index space, so adding a single new item shifts everyone by a
// small even fraction instead of piling onto a per-type cluster.
//
// DOM order is preserved exactly as the catalog produced (books, then
// lessons, then series) so the natural source order remains stable
// across runs. Layout is driven by `--orbit-angle`, not by DOM order;
// the hydrator reapplies the same `getEvenOrbitAngle` over the live
// post-filter set so SSR and client always agree.
type OrbitItem = {
  item: typeof readableItems[number];
  angle: number;
  kind: 'book' | 'lesson' | 'series';
};
const orbitKindOf = (it: typeof readableItems[number]): OrbitItem['kind'] =>
  it.type === 'book' ? 'book'
  : it.type === 'course_lesson' ? 'lesson'
  : 'series';
const orbitItems: OrbitItem[] = orbitItemsSource.map((item, i) => ({
  item,
  angle: getEvenOrbitAngle(i, orbitItemsSource.length),
  kind: orbitKindOf(item),
}));
// Rotate-orbit controls only make sense with at least 2 stations to
// rotate between. The shared step `360°/N` is computed in JS at click
// time from the live card count; CSS just animates --orbit-rotation.
const showOrbitControls = orbitItems.length > 1;

// ── ContinueLearningCard data ─────────────────────────────────────────────
// Real values are derived from `continueItem` + `courseProgress`. Two modes:
//   - lesson mode: course title at top, "Lesson N" line, then the lesson
//     subtitle. Reached when continueItem is a course_lesson whose
//     courseSlug matches a known course in courseProgress.
//   - book mode: book title at top, blank metaLine1, subtitle as metaLine2.
// When continueItem is undefined (mock fallback), no props are passed and
// the component's own placeholder defaults render.
const isLesson =
  continueItem?.type === 'course_lesson' && Boolean(continueItem?.courseSlug);
const matchingCourse = isLesson
  ? courseProgress.find((c) => c.slug === continueItem!.courseSlug)
  : undefined;

let courseTitleForCard: string | undefined;
let metaLine1ForCard: string | undefined;
let metaLine2ForCard: string | undefined;

if (isLesson && matchingCourse && continueItem?.orderInSeries) {
  courseTitleForCard =
    matchingCourse.titles[language]
    ?? matchingCourse.titles.en
    ?? matchingCourse.titles.he
    ?? matchingCourse.slug;
  metaLine1ForCard = t('courses.lessonNumber', language, { n: continueItem.orderInSeries });
  metaLine2ForCard =
    continueItem.subtitles?.[language]
    ?? continueItem.subtitles?.en
    ?? continueItem.subtitles?.he
    ?? '';
} else if (continueItem) {
  courseTitleForCard =
    continueItem.titles?.[language]
    ?? continueItem.titles?.en
    ?? continueItem.titles?.he;
  metaLine1ForCard = '';
  metaLine2ForCard =
    continueItem.subtitles?.[language]
    ?? continueItem.subtitles?.en
    ?? continueItem.subtitles?.he
    ?? '';
}

---

<LibraryLayout
  title={t('library.galaxy.title', language)}
  description={t('library.galaxy.subtitle', language)}
  language={language}
  availableLanguages={LANGUAGE_CODES}
  allowClientLanguageOverride={true}
  useGlobeLanguageSelector={true}
>
  <div
    class="library-dark-showcase library-root"
    lang={language}
    dir={isRtl ? 'rtl' : 'ltr'}
    style={`--page-direction: ${isRtl ? 'rtl' : 'ltr'};`}
  >

    {/* Cosmic scene background — full-viewport, fixed, behind every
        UI layer. The same galaxy PNG that used to sit centered inside
        the orbit stage now spans the entire screen so the dashboard
        feels embedded in an infinite knowledge universe. The radial
        overlay on top is a soft viewport-vignette that darkens the
        edges (improving contrast for the floating cards + side
        panels) while keeping the central glow undisturbed. */}
    <div class="knowledge-scene-background" aria-hidden="true">
      <img
        src="/assets/library/galaxy-stage-core-medium.png"
        alt=""
        decoding="async"
      />
      <div class="knowledge-scene-overlay"></div>
    </div>

    {/* Decorative ambient backdrop — starfield on top of the cosmic
        scene background. Stars stay crisp because they're a CSS
        gradient pattern that doesn't scale with the bg image. */}
    <div class="library-ambient" aria-hidden="true">
      <div class="library-starfield"></div>
    </div>

    <div class="library-body">

      {/* ── Center stage: hero floats over galaxy ── */}
      <main class="lb-area-stage">

        <div class="lb-area-hero">
          <LibraryHero language={language} />
        </div>

        {/* MobileGalaxyCarousel was removed: the galaxy orbit below now
            renders on mobile too, matching CLAUDE.md's "same composition,
            scaled down" rule. A separate horizontal rail above the orbit
            duplicated the same items without series functionality, so
            removing it gives mobile feature parity with desktop. */}

        <section class="lb-area-featured" aria-label={t('library.galaxy.welcome', language)}>
          <div
            class="library-galaxy"
            data-galaxy-stage
            data-series-badge={t('library.itemType.series', language)}
            data-series-items-label={t('library.series.itemsLabel', language)}
            data-series-available-label={t('library.series.availableLabel', language)}
            data-other-knowledge-label={t('library.series.otherKnowledge', language)}
            data-items-short-label={t('library.series.itemsShort', language)}
            data-close-label={t('library.galaxy.closeItem', language)}
            data-series-actions-show-items={t('library.series.actions.showItems', language)}
            data-series-actions-hide-items={t('library.series.actions.hideItems', language)}
            data-series-actions-details={t('library.series.actions.details', language)}
            data-series-details-title={t('library.series.details.title', language)}
            data-series-details-close={t('library.series.details.close', language)}
            data-series-details-short-description={t('library.series.details.shortDescription', language)}
            data-series-details-full-description={t('library.series.details.fullDescription', language)}
            data-series-details-assigned-items={t('library.series.details.assignedItems', language)}
            data-series-details-planned-items={t('library.series.details.plannedItems', language)}
            data-series-details-status={t('library.series.details.status', language)}
            data-series-details-asset-folder={t('library.series.details.assetFolder', language)}
            data-series-details-visible-in-universe={t('library.series.details.visibleInUniverse', language)}
            data-series-details-visible-yes={t('library.series.details.visibleYes', language)}
            data-series-details-visible-no={t('library.series.details.visibleNo', language)}
            data-series-details-no-description={t('library.series.details.noDescription', language)}
            data-series-details-no-assigned-items={t('library.series.details.noAssignedItems', language)}
            data-series-children-empty={t('library.series.children.empty', language)}
            data-series-children-region={t('library.series.children.region', language)}
            data-series-children-placeholder-type={t('library.series.children.placeholderType', language)}
            data-status-active={t('library.status.ready', language)}
            data-status-draft={t('library.status.new', language)}
            data-status-hidden={t('library.status.archived', language)}
            style={`--galaxy-dir: ${isRtl ? -1 : 1};`}
          >

            {/* The galaxy PNG used to sit centered here as the stage's
                visual core. It now lives at the page root as a
                full-viewport scene background (`.knowledge-scene-background`
                above), so the orbit stage holds only the floating
                cards + backdrop. */}

            {/* Backdrop — appears only when a card is focused into the
                center. Click anywhere on it closes the focus state. */}
            <div class="galaxy-backdrop" data-galaxy-backdrop aria-hidden="true"></div>

            {/* Orbit cards — every readable item gets one station on
                the elliptical orbit around the central core. Position
                is set per-card via inline `--orbit-angle`; CSS handles
                the rest with cos()/sin(). No queue, no carousel —
                everything is on screen at once. */}
            {orbitItems.map(({ item, angle, kind }) => (
              <div
                class="galaxy-card"
                data-galaxy-card
                data-kind={kind}
                data-slug={item.slug}
                data-series-id={item.seriesId}
                data-series-name={item.seriesName}
                style={`--orbit-angle: ${angle}deg;`}
              >
                <LibraryCard
                  item={item}
                  language={language}
                  variant="orbit"
                  artifact={resolveOrbitArtifact(item)}
                  suppressOrbitCaption={isSafeLibraryHref(item.href)}
                />
                {/* Reading-entry overlay (phase 1).
                    Replaces the visual side open orb (`.galaxy-cta-open`)
                    with an internal premium panel that appears only when
                    the card is centered (`[data-pos="center"]`). The
                    `<a href={item.href}>` for the orb is still rendered
                    inside `.galaxy-cta` below (hidden via CSS) so the
                    href stays in the DOM. Routing is NOT touched yet:
                    clicking this overlay logs slug + href and is wired
                    to bypass capture-phase click handling in
                    `universe-layout.ts` via the `data-reading-entry`
                    attribute. */}
                {isSafeLibraryHref(item.href) && (
                  <span class="reading-entry-opening" aria-hidden="true">
                    <span class="reading-entry-bloom"></span>
                    <span class="reading-entry-cover reading-entry-cover-left"></span>
                    <span class="reading-entry-cover reading-entry-cover-right"></span>
                    <span class="reading-entry-spine"></span>
                  </span>
                )}
                {/* Reading-entry overlay (image-based, in-card).
                    Premium glass-style asset (PNG, no baked text) sits
                    inside the centered card. All visible text is live,
                    localized HTML rendered on top — never embedded in
                    the image. The <a> preserves native link behavior
                    (Ctrl/Cmd-click, middle-click, right-click); plain
                    left-click and Enter are intercepted by the launch
                    handler in `universe-layout.ts` via the
                    `data-reading-entry` attribute. */}
                {isSafeLibraryHref(item.href) && (
                  <a
                    class="reading-entry-overlay"
                    href={item.href}
                    data-reading-entry
                    data-reading-entry-href={item.href}
                    data-reading-entry-slug={item.slug}
                    aria-label={t('library.readingEntry.ariaLabel', language)}
                  >
                    <span class="reading-entry-asset" aria-hidden="true"></span>
                    <span class="reading-entry-text">
                      <span class="reading-entry-title">
                        {t('library.readingEntry.title', language)}
                      </span>
                    </span>
                  </a>
                )}
                {/* `.galaxy-cta` slot is now only rendered for series
                    capsules — the open-orb (`.galaxy-cta-open`) was
                    superseded by `.reading-entry-overlay`, and the X
                    close button was retired in favour of backdrop-tap
                    and Esc-key closing. Books / lessons / articles
                    therefore emit no `.galaxy-cta` markup at all. */}
                {kind === 'series' && (
                  <div class="galaxy-cta">
                    <div class="galaxy-cta-series-actions" data-series-action-panel>
                      <button
                        type="button"
                        class="galaxy-cta-series-btn"
                        data-series-action="toggle-items"
                        aria-pressed="false"
                        aria-label={t('library.series.actions.showItems', language)}
                      >
                        <span class="galaxy-cta-series-btn-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="6" width="6" height="12" rx="1"></rect>
                            <rect x="11" y="4" width="5" height="14" rx="1"></rect>
                            <rect x="18" y="8" width="3" height="10" rx="1"></rect>
                          </svg>
                        </span>
                        <span class="galaxy-cta-series-btn-label" data-series-action-label="toggle-items">
                          {t('library.series.actions.showItems', language)}
                        </span>
                      </button>
                      <button
                        type="button"
                        class="galaxy-cta-series-btn"
                        data-series-action="details"
                        aria-label={t('library.series.actions.details', language)}
                      >
                        <span class="galaxy-cta-series-btn-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="9"></circle>
                            <path d="M12 8h.01"></path>
                            <path d="M11 12h1v4h1"></path>
                          </svg>
                        </span>
                        <span class="galaxy-cta-series-btn-label">
                          {t('library.series.actions.details', language)}
                        </span>
                      </button>
                    </div>
                  </div>
                )}
              </div>
            ))}

            {/* Local children fan — created and populated by JS when a
                focused series capsule's "Show items" button is clicked.
                Lives inside the stage so it positions naturally relative
                to the centered capsule. Hidden until populated; nothing
                permanently mixes into the main universe. */}
            <div
              class="series-children-fan"
              data-series-children-fan
              role="region"
              aria-label={t('library.series.children.region', language)}
              hidden
            ></div>

          </div>
        </section>

      </main>

      {/* ── Mobile-only quick-actions panel ──
            Desktop is owned by <FloatingSidebar> below, which lives
            outside the grid as `position: fixed`. On mobile this aside
            stays as `display: contents` and contributes its child as a
            flex item of `.library-body` at order 6. */}
      <aside class="lb-area-right">
        <div class="lb-area-quick lb-area-quick-mobile">
          <LibraryQuickActions language={language} />
        </div>
      </aside>

    </div>

    {/* ── Desktop fixed support panels (≥769px) ──
          Both panels are `position: fixed` from inside their own
          component CSS, anchored to the inline-start edge of the
          viewport (right in RTL, left in LTR). Stacked: ContinueLearningCard
          above, LibraryStatsPanel below it. Hidden at ≤768px from inside
          each component. Live outside `.library-body` so they never
          claim a column or contribute to the grid. */}
    <ContinueLearningCard
      language={language}
      courseTitle={courseTitleForCard}
      metaLine1={metaLine1ForCard}
      metaLine2={metaLine2ForCard}
      lessonsAvailable={isLesson ? courseProgress[0]?.available : undefined}
      lessonsTotal={isLesson ? courseProgress[0]?.total : undefined}
      href={continueItem?.href}
      readableBooks={readableItems
        .filter((it) => (it.chapterCount ?? 0) > 0)
        .map((it) => ({
          slug: it.slug,
          title:
            it.titles?.[language]
            ?? it.titles?.en
            ?? it.titles?.he
            ?? it.slug,
          subtitle:
            it.subtitles?.[language]
            ?? it.subtitles?.en
            ?? it.subtitles?.he
            ?? '',
          href: it.href,
          chapterCount: it.chapterCount ?? 0,
        }))}
    />
    <LibraryStatsPanel stats={stats} language={language} courseProgress={courseProgress} />

    {/* ── Desktop floating rail (≥769px) ──
          Pinned to the inline-end edge via `position: fixed` from the
          component itself; sits outside the grid so it never claims a
          column. Hidden at ≤768px — mobile is served by the aside above. */}
    <FloatingSidebar
      language={language}
      aiAssistantHref="#ai-assistant"
      bookmarksHref="#bookmarks"
      historyHref="#history"
    />

    {/* ── Series details drawer ──
          Same-page modal/drawer that opens when the focused series
          capsule's "Series details" action is clicked. The body fields
          are filled in by the JS controller from SeriesMetadata; static
          labels come straight from i18n via `t()` so SSR ships the right
          chrome in every language. The drawer stays hidden via [hidden]
          until the controller opens it. */}
    <div
      class="series-details-overlay"
      data-series-details-overlay
      hidden
      aria-hidden="true"
    ></div>
    <aside
      class="series-details-drawer"
      data-series-details-drawer
      role="dialog"
      aria-modal="true"
      aria-labelledby="series-details-title"
      dir={isRtl ? 'rtl' : 'ltr'}
      hidden
    >
      <header class="series-details-header">
        <h2 id="series-details-title" class="series-details-title" data-series-details-name>
          {t('library.series.details.title', language)}
        </h2>
        <button
          type="button"
          class="series-details-close"
          data-series-details-close
          aria-label={t('library.series.details.close', language)}
        >×</button>
      </header>
      <div class="series-details-body">
        <section class="series-details-section">
          <p class="series-details-summary" data-series-details-summary></p>
          <p class="series-details-full" data-series-details-full></p>
        </section>
        <dl class="series-details-meta">
          <div class="series-details-meta-row">
            <dt>{t('library.series.details.assignedItems', language)}</dt>
            <dd data-series-details-assigned-count>0</dd>
          </div>
          <div class="series-details-meta-row" data-series-details-planned-row hidden>
            <dt>{t('library.series.details.plannedItems', language)}</dt>
            <dd data-series-details-planned-count></dd>
          </div>
          <div class="series-details-meta-row">
            <dt>{t('library.series.details.status', language)}</dt>
            <dd data-series-details-status-value></dd>
          </div>
          <div class="series-details-meta-row">
            <dt>{t('library.series.details.assetFolder', language)}</dt>
            <dd>
              <code data-series-details-asset-folder></code>
            </dd>
          </div>
          <div class="series-details-meta-row">
            <dt>{t('library.series.details.visibleInUniverse', language)}</dt>
            <dd data-series-details-visible></dd>
          </div>
        </dl>
        <section class="series-details-section">
          <h3 class="series-details-list-title">{t('library.series.details.assignedItems', language)}</h3>
          <ul class="series-details-list" data-series-details-list></ul>
        </section>
      </div>
    </aside>

    {/* Orbit rotation controls — chevron pair pinned to the bottom of
        the viewport, OUTSIDE the orbit stage so they never overlap the
        focused card. The click handler in universe-layout.ts attaches
        a document-level delegate for [data-galaxy-rotate], so the
        buttons stay functional even though they live outside the stage. */}
    {showOrbitControls && (
      <div class="galaxy-orbit-controls" aria-hidden="false">
        <button
          type="button"
          class="galaxy-orbit-btn"
          data-galaxy-rotate
          data-direction="prev"
          aria-label={t('library.galaxy.rotatePrev', language)}
        ><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
        <button
          type="button"
          class="galaxy-orbit-btn"
          data-galaxy-rotate
          data-direction="next"
          aria-label={t('library.galaxy.rotateNext', language)}
        ><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
      </div>
    )}

  </div>
</LibraryLayout>

<style>
  /* ──────────────────────────────────────────────────────────────────
     /library — page shell + galaxy stage geometry
     Hard rules:
       - All colour/effect via --yuval-galaxy-*  (no hex anywhere)
       - All visible text via t()
       - RTL via inset-inline-* (logical properties)
     ────────────────────────────────────────────────────────────────── */

  /* ── Page-level lock: dark cosmic shell + no scroll ────────────────
     Two intentions in one rule:
       1. The body / html background-color is forced to match the
          cosmic floor `#00010d`, so iOS Safari rubber-band and
          URL-bar morph never expose a cream sliver above the dark
          header.
       2. `overflow: hidden` + `height: 100dvh` lock the page to the
          viewport in BOTH axes on every device. Per the user's
          request this screen never scrolls — the orbit dashboard
          (desktop) and the cleared hero+orbit-placeholder (mobile)
          are designed to fit inside a single viewport. Anything
          beyond is intentionally clipped rather than scrollable.
     Scoped via `:global()` + the page-root class so every other
     route keeps its native scroll. `:has()` is widely supported
     (Safari 15.4+, Chrome 105+, Firefox 121+); older engines fall
     back to normal page scroll. */
  :global(html:has(.library-dark-showcase)),
  :global(body:has(.library-dark-showcase)) {
    background-color: #00010d;
    height: 100dvh;
    overflow: hidden;
  }

  .library-root {
    position: relative;
    /* 100dvh tracks the dynamic viewport so iOS Safari's collapsing
       URL bar does not leave a strip of empty cosmic backdrop below
       the content on mobile. Falls back to 100vh in older browsers. */
    min-height: 100vh;
    min-height: 100dvh;
    width: 100%;
    /* Whole-screen unified backdrop. Mobile uses the two main layers;
       desktop adds side accents + vignette so the entire dashboard
       (sidebar + center + rail + recs) reads as one cosmic field.

       Background-color sampled directly from the dark outer pixels of
       galaxy-stage-core-medium.png (corners read RGB(0,1,13)). The
       earlier #0a0a1f estimate was ~3× brighter than reality and left
       a visible seam between the image edges and the page. With the
       sampled value, the image's outer dark pixels are continuous
       with the page bg. Scoped to .library-root via Astro style
       scoping — does not affect any other route. */
    background-color: #00010d;
    background-image:
      var(--yuval-galaxy-bg-radial-primary),
      var(--yuval-galaxy-bg-radial-secondary);
    color: var(--yuval-galaxy-text);
    /* Top padding kept tight (0.25rem) so the hero text sits close to
       the header line, per the user's preference. Side + bottom keep
       their original breathing room. Tablet + desktop overrides below
       follow the same rule — small top, generous sides/bottom. */
    padding: 0.25rem 1rem 4rem;
    box-sizing: border-box;
    isolation: isolate;
    overflow-x: hidden;
  }

  /* ── Cosmic scene background — full-viewport fixed layer ─────────
     This is the global "knowledge universe" canvas. It is anchored
     to the viewport (not the page) so it never scrolls out, never
     leaves visible margins, and is never clipped by sidebars or the
     stats panel. Every UI layer (hero, orbit, side panels, rail)
     stacks on top via `position: relative; z-index: 1` (see the
     `.library-root > :not(...)` rule below). */
  .knowledge-scene-background {
    /* Anchored 50px ABOVE the header's bottom edge so the cosmic
       image extends visually higher into the chrome. The header has
       its own opaque background and sits at z-index above this layer
       (z-index: 0), so the part of the image that tucks under the
       header is naturally covered — what you see is the image
       reaching higher into the screen relative to the previous
       `top: 4rem` (header-bottom) value. */
    position: fixed;
    top: calc(4rem - 130px);
    inset-inline: 0;
    bottom: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .knowledge-scene-background img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    user-select: none;
    -webkit-user-drag: none;
  }
  /* Soft radial vignette — keeps the central glow untouched and
     darkens only the edges so floating cards + side panels read
     cleanly against the bg without losing the cosmic atmosphere. */
  .knowledge-scene-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 0%,
      transparent 35%,
      rgba(0, 0, 0, 0.45) 80%,
      rgba(0, 0, 0, 0.65) 100%);
  }

  /* Lightning overlay — SVG injected by `universe-core-effects.ts`.
     Each strike draws a multi-layer jagged bolt with branching forks
     from stage centre to the hovered card's centre.

     z-index: 25 — sits ABOVE orbit cards (z-index 3) so the bolt
     reaches the card's centre visibly, but BELOW the focused card
     (z-index 30) so a click-to-centered card never gets struck.

     mix-blend-mode: screen — the bolt is additive over whatever
     paints below it. White cores stay punchy on the dark cosmic
     scene, and accent-coloured glow tints (rather than overwrites)
     the card content it crosses. Stays non-interactive (clicks fall
     through to the cards underneath). */
  .library-galaxy svg[data-core-lightning] {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
    z-index: 25;
    mix-blend-mode: screen;
  }

  /* Ambient backdrop — sits ABOVE the scene background, BELOW the UI.
     Self-contained starfield. */
  .library-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  /* `.library-aurora` and `.library-nebula-*` rules removed: their
     markup nodes were retired when the unified page-level backdrop
     system in `.library-root` took over atmospheric coloring. */
  /* Starfield — a CSS-only matrix of tiny bright pixels rendered as
     a single repeating radial-gradient pattern. No DOM nodes, no JS.
     Two layers (small + medium) at slightly different offsets for
     parallax-like depth. */
  .library-starfield {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 12%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 65% 24%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 35% 38%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 82% 47%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 12% 58%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 73% 67%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 28% 78%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 88% 88%, var(--yuval-galaxy-text) 50%, transparent 100%),
      /* Accent stars — all violet now. Cyan accents were swapped to
         purple to align with the page's violet-led palette and avoid
         out-of-key cyan dots on the cosmic field. */
      radial-gradient(1.5px 1.5px at 50% 18%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 92% 32%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 8% 72%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 58% 92%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%);
    opacity: 0.40;
  }
  .library-root > :not(.library-ambient):not(.knowledge-scene-background) {
    position: relative;
    z-index: 1;
  }

  /* ── Mobile baseline: linear stack, ordered to the spec.
        The desktop wrapper aside/main elements are passthrough on mobile —
        their children unfurl in the natural document order, then `order:`
        re-shuffles them into the discovery sequence. ─────────────────── */
  .library-body {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* On mobile the wrapper aside/main elements are not layout containers;
     reset their flex behaviour and let their children act as siblings. */
  .lb-area-stage,
  .lb-area-right {
    display: contents;
  }

  /* ── Mobile content area ──────────────────────────────────────────
     `.lb-area-featured` (galaxy orbit stage) is visible on mobile too,
     scaled down proportionally — see CLAUDE.md "same orbit composition
     on mobile". The mobile-specific orbit sizing lives in the
     `@media (max-width: 1023px)` block further below.
     `.lb-area-quick-mobile` is a legacy slot for an AI assistant /
     quick-actions row that is currently suppressed. */
  .lb-area-quick-mobile {
    display: none;
  }

  /* ── LibraryHero — strip the legacy card chrome ─────────────────
     The legacy mobile + tablet LibraryHero rendered as a discrete
     card with border, panel background, blur and overflow:hidden
     (which clipped the nowrap title when the central area got
     narrow and a fixed side panel encroached on the right edge).
     The user wants only the welcome text (eyebrow + title +
     subtitle) framed by the cosmic page, not by a panel — the same
     identity as the desktop hero strip. Override applies at every
     viewport below the desktop dashboard (≤1023px). Desktop
     (≥1024px) strips chrome via LibraryHero's own @media rule. */
  /* ── Series glow pulse ────────────────────────────────────────────
        One-shot 3-second multi-colour border + halo applied to every
        card that belongs to a series. Triggered (1) when the user
        clicks "Show series items" inside the focused series capsule,
        and (2) when the user hovers a series capsule in the resting
        orbit without focusing it. Works on every viewport because the
        keyframes live outside any @media block. */
  @keyframes yuval-series-glow {
    0%, 100% {
      box-shadow: var(--yuval-galaxy-card-shadow);
      border-color: var(--yuval-galaxy-card-border);
    }
    12% {
      box-shadow:
        0 0 0 2px rgba(250, 204, 21, 0.95),
        0 0 28px 6px rgba(250, 204, 21, 0.55);
      border-color: rgba(250, 204, 21, 0.95);
    }
    37% {
      box-shadow:
        0 0 0 2px rgba(34, 197, 94, 0.95),
        0 0 28px 6px rgba(34, 197, 94, 0.55);
      border-color: rgba(34, 197, 94, 0.95);
    }
    62% {
      box-shadow:
        0 0 0 2px rgba(168, 85, 247, 0.95),
        0 0 28px 6px rgba(168, 85, 247, 0.55);
      border-color: rgba(168, 85, 247, 0.95);
    }
    87% {
      box-shadow:
        0 0 0 2px rgba(249, 115, 22, 0.95),
        0 0 28px 6px rgba(249, 115, 22, 0.55);
      border-color: rgba(249, 115, 22, 0.95);
    }
  }
  .galaxy-card.is-series-glow :global(.lc) {
    animation: yuval-series-glow 3s ease-out 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .galaxy-card.is-series-glow :global(.lc) { animation: none; }
  }

  @media (max-width: 1023px) {
    :global(.lb-area-hero .lh) {
      /* No top padding — the hero text should land right under the
         header line. Side + bottom paddings keep modest breathing
         around the text block. */
      padding: 0 0.5rem 0.75rem;
      background-color: transparent;
      border: 0;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      box-shadow: none;
      overflow: visible;
      text-align: center;
    }
    :global(.lb-area-hero .lh-halo) {
      display: none;
    }
    :global(.lb-area-hero .lh-header) {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0;
      margin-block-end: 0.25rem;
    }
    :global(.lb-area-hero .lh-text) {
      text-align: center;
    }
    /* Eyebrow: cyan→violet gradient text in mixed case, matching the
       desktop hero. Overrides the mobile baseline (uppercase + grey)
       which clashed with the cosmic look once the panel chrome was
       removed. */
    :global(.lb-area-hero .lh-eyebrow) {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      text-transform: none;
      font-weight: 500;
      font-size: 0.8125rem;
      letter-spacing: 0.06em;
      margin-block-end: 0.3125rem;
      background: linear-gradient(
        90deg,
        var(--yuval-galaxy-accent-cyan) 0%,
        var(--yuval-galaxy-accent-purple) 100%);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }
    :global(.lb-area-hero .lh-title) {
      line-height: 1.05;
      margin-block-end: 0.375rem;
    }
    :global(.lb-area-hero .lh-subtitle) {
      margin-inline: auto;
      font-size: 0.9rem;
      line-height: 1.4;
    }

    /* ── Mobile orbit — same composition as desktop, scaled down ─────
       The user asked for the SAME orbit (every readable item on its
       own station around the central core) on phone + tablet, just
       smaller. We re-show the featured section (hidden globally by the
       base reset), then re-declare the orbit positioning rules with
       smaller card width + smaller ellipse radii. The math is identical
       to the desktop rule inside `@media (min-width: 1024px)`. */
    /* Orbit always centered on the viewport's central book icon.
       The icon lives in `.knowledge-scene-background` (position:fixed)
       and sits a few pixels above the viewport's exact middle. To
       guarantee the orbit center (`.galaxy-card { top: 50% }` of
       `.library-galaxy`) lands ON that icon at EVERY screen size, we
       pin the galaxy box to the viewport with position:fixed and
       center it with top:50% + transform translate(-50%, -50%). The
       orbit cards are inside this fixed box, so they automatically
       sit in concentric ellipses around the icon — regardless of how
       tall the hero text grew or what other content stacks above. */
    .lb-area-featured {
      display: block;
      /* This wrapper no longer needs to host the orbit — it just
         remains in flow as a placeholder so the hero text spacing
         doesn't collapse. The actual galaxy lives in a fixed layer. */
    }

    .library-galaxy {
      position: fixed;
      /* Match the visual center of the background galaxy image. The
         image is fixed top:calc(4rem - 130px) with bottom:0 and
         object-position:center center → its vertical center sits at
         (50dvh - 33px). Anchoring the orbit center to the same
         coordinate guarantees the book icon is always at the carousel
         center, regardless of header height, hero text length or
         viewport size. */
      top: calc(50dvh - 33px);
      left: 50%;
      transform: translate(-50%, -50%);
      display: block;
      width: 100%;
      max-width: 100vw;
      min-height: clamp(320px, 60vw, 480px);
      margin: 0;
      overflow: visible;
      padding: 0;
      z-index: 1;
      /* Drag-to-rotate uses pointermove on the stage. Without
         `touch-action: none` the browser keeps ownership of horizontal
         swipes (treats them as pan / overscroll), and pointermove never
         fires on touch devices — so rotating cards by dragging silently
         fails on mobile. The page is overflow:hidden anyway, so we lose
         nothing by claiming the gesture for JS. Taps/clicks still fire
         normally on the cards and rotate buttons. */
      touch-action: none;
      /* The orbit math (cos/sin) is direction-agnostic via --galaxy-dir
         (set inline on the element in markup). Setting `direction: ltr`
         here keeps absolute positioning consistent; per-card content
         still picks up page direction via `.galaxy-card { direction: var(--page-direction, ltr); }` below. */
      direction: ltr;
    }

    .galaxy-card {
      position: absolute;
      flex: initial;
      max-width: none;
      /* Card width shrinks proportionally to viewport. Sized 25% larger
         than the previous mobile values per Tomer's request: the cover
         art now carries baked-in mobile typography (front-mobile.png),
         and the larger cards let that artwork read clearly without an
         overlay label. Floor: 120px (legible on 360px phones). Cap:
         175px (still safely under the desktop 190px peer at 1024px).
         Exposed as `--card-base-width` so the focused-state scale rule
         below can target an exact viewport-relative size (70vw) without
         re-deriving the clamp by hand. The series capsule overrides
         this variable for its slightly wider footprint. */
      --card-base-width: clamp(120px, 27.5vw, 175px);
      width: var(--card-base-width);
      cursor: pointer;
      top: 50%;
      left: 50%;
      /* Tighter ellipse on mobile so the orbit's lower edge clears
         the rotate-controls pill at the viewport bottom with a clear
         safety gap (not just touching). orbit-ry shrunk again from
         18vh→13vh, and the floor/ceiling tightened in tandem. */
      --orbit-rx: clamp(110px, 38vw, 220px);
      --orbit-ry: clamp(70px, 13vh, 105px);
      --orbit-active-angle: calc(var(--orbit-angle, 0deg) + var(--orbit-rotation, 0deg));
      --orbit-depth: calc((sin(var(--orbit-active-angle, 0deg)) + 1) / 2);
      --slot-scale: calc(0.88 + 0.12 * var(--orbit-depth));
      --slot-opacity: calc(0.86 + 0.14 * var(--orbit-depth));
      --tilt: calc(cos(var(--orbit-active-angle, 0deg)) * 4deg * var(--galaxy-dir, 1) * -1);
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry))
        )
        rotate(var(--tilt))
        scale(var(--slot-scale));
      opacity: var(--slot-opacity);
      transition:
        transform 0.55s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.3s ease;
      z-index: 2;
      direction: var(--page-direction, ltr);
    }

    /* Series capsule a touch wider than a book card, same ratio as desktop.
       Scaled 25% alongside the book/lesson cards above. Overrides
       `--card-base-width` so the focused-scale math below uses the
       series footprint rather than the book/lesson one. */
    .galaxy-card[data-role="series"] {
      --card-base-width: clamp(135px, 31.25vw, 195px);
      --series-color-resolved: var(--series-color, var(--yuval-galaxy-accent-gold, #c9a96e));
    }

    /* Per-kind accent tint — books gold, lessons cyan, series violet.
       Sets a CSS variable that the inner LibraryCard reads for its
       accent strip; same contract as desktop. */
    .galaxy-card[data-kind="book"]   { --card-accent-slot: var(--yuval-galaxy-accent-gold); }
    .galaxy-card[data-kind="lesson"] { --card-accent-slot: var(--yuval-galaxy-accent-cyan); }
    .galaxy-card[data-kind="series"] { --card-accent-slot: var(--yuval-galaxy-accent-purple); }

    /* Drag-to-rotate: kill the transform transition while a drag is
       in flight so the carousel tracks the cursor in real time. */
    .library-galaxy[data-galaxy-dragging] .galaxy-card {
      transition: none;
      cursor: grabbing;
    }

    /* Block the browser's native image-drag ghost on every card and
       on its descendant artwork so pointermove tracking stays smooth. */
    .galaxy-card,
    .galaxy-card *,
    .galaxy-card img,
    .galaxy-card svg {
      -webkit-user-drag: none;
    }

    /* Galaxy orbit controls (rotate ←/→ buttons) on mobile — pinned
       to the bottom of the viewport so they stay clear of the orbit /
       carousel and remain easy to tap. Self-contained pill styling
       (flex + background + border + blur) lives here because the
       desktop @media block below isn't reached on phones; without it
       the wrapper falls back to display:block and stretches across
       the viewport. z-index sits above the focused card (z:30) so the
       buttons never get covered by an enlarged centered card. */
    .galaxy-orbit-controls {
      /* Always pinned to the very bottom of the viewport on mobile.
         Only the iOS home-indicator safe-area-inset-bottom is added
         on top — no extra cosmetic offset — so the buttons hug the
         screen edge as the user requested. */
      position: fixed !important;
      inset-block-end: auto;
      bottom: env(safe-area-inset-bottom, 0px) !important;
      left: 0;
      right: 0;
      margin-inline: auto;
      display: flex;
      width: max-content;
      align-items: center;
      gap: 0.5rem;
      padding: 0.3125rem;
      border-radius: 999px;
      background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 55%, transparent);
      border: 1px solid color-mix(in srgb, var(--yuval-galaxy-border, #1a1a3a) 75%, transparent);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      z-index: 40;
      direction: ltr;
    }
    .galaxy-orbit-btn {
      width: 44px;
      height: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      color: var(--yuval-galaxy-text-soft);
      background: var(--yuval-galaxy-surface-muted);
      border: 1px solid var(--yuval-galaxy-border);
      cursor: pointer;
      padding: 0;
      transition: color 0.15s ease, background-color 0.15s ease,
                  border-color 0.15s ease, transform 0.15s ease;
    }
    .galaxy-orbit-btn:hover,
    .galaxy-orbit-btn:focus-visible {
      color: var(--yuval-galaxy-text);
      background: var(--yuval-galaxy-card-surface-hover);
      border-color: var(--yuval-galaxy-border-strong);
      outline: none;
    }
    [dir="rtl"] .galaxy-orbit-btn svg { transform: scaleX(-1); }

    /* ── Mobile focus state (mirror of desktop) ────────────────────
       All the focus-state CSS — centered card scaling, galaxy CTA
       slot, reading-entry overlay panel — lives inside the desktop
       `@media (min-width: 1024px)` block below, so on mobile none of
       those rules apply. Without this duplication a tap on a mobile
       orbit card doesn't visibly scale it, and the reading-entry
       `<a>` + close `<button>` render at default styling, polluting
       the screen with their text under every card.

       This block replays just enough of the desktop rules to give
       mobile the same "tap card → scales up, X close button appears,
       reading-entry panel sits flush below the cover" behavior. */

    /* Focused card flies to viewport center, scaled to render at exactly
       70% of the viewport width regardless of phone/tablet size. The
       formula `70vw / var(--card-base-width)` evaluates the resting card
       width (`clamp(120px, 27.5vw, 175px)` for books/lessons, larger for
       series) and produces the unitless multiplier that hits the target.
       The reading-entry pill below counter-scales against this same
       variable so it keeps its previous visual size (~scale 2.34) on
       every viewport instead of growing/shrinking with the new card
       math. */
    .galaxy-card[data-pos="center"] {
      transform:
        translate(-50%, -50%)
        scale(calc(70vw / var(--card-base-width)));
      opacity: 1;
      z-index: 30;
      cursor: default;
    }

    /* On mobile we drop the open-orb + X-close cluster — Tomer asked to
       remove the X next to the focused card. Closing is handled by
       tapping outside the card / tapping another orbit station. The
       `.galaxy-cta` wrapper itself stays visible so its only remaining
       contents — the series action pills (Show items / Details) — can
       sit at the bottom of the focused series card on mobile too. */
    .galaxy-cta-open,
    .galaxy-cta-open-label,
    .galaxy-cta-close {
      display: none !important;
    }
    /* Mobile placement for the series action pills — mirrors the desktop
       rules at the bottom of this stylesheet so the wrapper has the same
       positioning context on every viewport. Lifted into the mobile block
       because the desktop `.galaxy-cta` rule lives inside
       `@media (min-width: 1024px)` and would otherwise leave the mobile
       wrapper unstyled (in-flow, always visible). */
    .galaxy-cta {
      position: absolute;
      top: 66%;
      left: 50%;
      bottom: auto;
      right: auto;
      transform: translate(-50%, -50%);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      justify-content: center;
      align-items: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease 0.15s;
      z-index: 2;
    }
    .galaxy-card[data-pos="center"] .galaxy-cta {
      opacity: 1;
      pointer-events: auto;
      /* Counter-scale against the focused card's mobile scale
         (`scale(70vw / var(--card-base-width))`). Without this the
         pills inherit the card magnification and render ~1.7× too
         big with oversized font. Multiplying by the inverse keeps
         the pills at their authored visual size on every phone. */
      transform: translate(-50%, -50%) scale(calc(var(--card-base-width) / 70vw));
    }
    /* Mobile-only shrink for the series action pills. The counter-scale
       above keeps them at authored size, but authored is still too tall
       for a phone (Tomer reported huge / out-of-proportion buttons on
       mobile). Tighten padding, font and icon dimensions specifically
       inside the mobile block so the pills read as compact chips under
       the focused series card. */
    .galaxy-cta-series-actions { gap: 0.3rem; }
    .galaxy-cta-series-btn {
      padding: 0.25rem 0.55rem;
      font-size: 0.625rem;
      gap: 0.3rem;
      letter-spacing: 0;
    }
    .galaxy-cta-series-btn-icon {
      width: 12px;
      height: 12px;
    }
    /* Reading-entry panel below the focused card. On mobile Tomer
       asked for a wider + shorter pill (the desktop 66%×108px shape
       was too tall for a phone), then +25% on both axes so the CTA
       reads clearly under the scaled-up centered card. */
    .reading-entry-overlay {
      position: absolute;
      left: 50%;
      /* Pill anchors to the visible bottom edge of the cover, not the
         .galaxy-card element's bottom — the card carries ~28px of
         transparent padding below the cover (see LibraryCard
         `.lc-orbit` padding-bottom + artifact margin), so top:100%
         lands 28px under the visible art. Multiplied by the centered
         card's 3.042× scale that's an ~85px visual gap. The negative
         offset closes that gap so the pill sits flush against the
         cover. */
      top: calc(100% - 32px);
      width: 120%;
      height: 80px;
      /* Counter-scale to preserve the pill's previous visual size
         (≈ scale 2.34) while the centered card scale is now derived
         from 70vw. The math: pill_scale = 2.34 / card_scale, where
         card_scale = 70vw / var(--card-base-width). Substituting and
         simplifying gives `2.34 * var(--card-base-width) / 70vw`.
         transform-origin anchors the shrink to the pill's top-center
         so it doesn't drift up. */
      transform:
        translate(-50%, 0)
        scale(calc(2.34 * var(--card-base-width) / 70vw));
      transform-origin: top center;
      display: block;
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
      color: inherit;
      cursor: pointer;
      text-decoration: none;
      -webkit-tap-highlight-color: transparent;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      z-index: 30;
      transition:
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        transform 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 240ms;
    }
    .galaxy-card[data-pos="center"] .reading-entry-overlay {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition:
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        transform 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 0s;
    }
    .reading-entry-overlay:focus-visible {
      outline: none;
    }
    .reading-entry-asset {
      position: absolute;
      inset: 0;
      border-radius: 24px;
      background-image: url('/assets/ui/reading-entry/reading-entry-card.png');
      background-size: 100% 100%;
      background-repeat: no-repeat;
      background-position: center;
      pointer-events: none;
      transition:
        transform 220ms cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 220ms ease,
        filter 220ms ease;
    }
    .reading-entry-text {
      position: absolute;
      left: 50%;
      top: calc(60% + 2px);
      width: 92%;
      transform: translate(-50%, -50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      pointer-events: none;
      font-family:
        'Heebo', 'Inter', system-ui, -apple-system,
        'Segoe UI', 'Noto Sans Hebrew', sans-serif;
    }
    .reading-entry-title {
      /* Mobile-only smaller text. The centered card scales 2.34×, so
         even 7px renders at ~16px effective — readable but no longer
         overpowering the pill. */
      font-size: 7px;
      font-weight: 700;
      line-height: 1.1;
      white-space: nowrap;
      color: rgba(248, 252, 255, 0.98);
      text-shadow:
        0 0 10px rgba(90, 160, 255, 0.35),
        0 2px 4px rgba(0, 0, 0, 0.65);
    }
    .reading-entry-overlay:hover .reading-entry-asset,
    .reading-entry-overlay:focus-visible .reading-entry-asset {
      filter: brightness(1.06) saturate(1.05);
    }
    .reading-entry-overlay:active .reading-entry-asset {
      transform: scale(0.985);
    }
  }

  /* Small-screen baseline for the orbit scene's vertical offset. The
     orbit itself is hidden below 1024px (see `.lb-area-featured` above),
     but the variable is defined here so the responsive ladder
     (32 → 56 → 72) is complete at every breakpoint. The transform is
     applied on `.library-galaxy` inside the 1024+ query, so a parent
     transform never affects mobile layout. */
  .library-galaxy { --orbit-vertical-offset: 32px; }

  /* ── Tablet (≥640px): same mobile flow, more inline padding ──
        Top padding kept tight so the hero text remains close to the
        header line. Inline + bottom paddings grow for breathing
        room around the wider viewport. */
  @media (min-width: 640px) {
    .library-root { padding: 0.5rem 1.5rem 4rem; }
  }

  /* ── Desktop (≥1024px): ONE viewport dashboard, no long scroll ───── */
  @media (min-width: 1024px) {
    .library-root {
      /* Block padding owns top/bottom rhythm. Inline padding is
         SYMMETRIC so `.library-body` (max-width + margin: 0 auto)
         centers ITSELF on the viewport — that gives the galaxy core
         (which sits at the visual center of the body) a perfectly
         viewport-centered anchor. The clamp value also clears the
         FloatingSidebar at the inline-end side (rail width ~92px
         + ~16px gap from edge). Independent from this: the two
         support panels (ContinueLearningCard + LibraryStatsPanel)
         are `position: fixed` from inside their own components and
         anchor directly to the viewport edge via `inset-inline-start: 20px`,
         so their 20px gap stays constant regardless of this padding. */
      /* Top padding tightened (1.25rem → 0.25rem) so the desktop
         hero strip sits right under the sticky header line — same
         preference applied on mobile. The galaxy stage below the
         hero now picks up the freed vertical space and the central
         core's vertical position is governed by --orbit-vertical-
         offset rather than by this padding. */
      padding-block-start: 0.25rem;
      padding-block-end: 1.5rem;
      padding-inline: clamp(60px, 8vw, 120px);
      /* Viewport math is owned by LibraryLayout — the layout sets
         --library-dashboard-min-height = calc(100dvh - --library-header-offset)
         on the slot wrapper, so the page does not have to know the
         header's pixel height. */
      min-height: var(--library-dashboard-min-height, 100dvh);
      /* Desktop layered backdrop, FIRST listed = TOP of the stack.
         Calibrated to the sampled asset palette: every layer either
         uses one of the sampled navy tones or stays a small violet
         accent centered on the stage. Hero + side accents were
         removed (asset isn't violet there).
         1. vignette        — corner darkening with sampled #000010
         2. primary accent  — small violet halo at the stage center
         3. secondary fade  — bottom navy continuation (#000010)
         The base color var(--yuval-galaxy-bg) (#01051b) sits beneath. */
      background-image:
        var(--yuval-galaxy-bg-vignette),
        var(--yuval-galaxy-bg-radial-primary),
        var(--yuval-galaxy-bg-radial-secondary);
    }

    /* Full-page atmospheric underlay removed: it placed a blurred copy
       of the asset under the whole page, which created a non-uniform
       halo right under where the central image sits — the eye then
       read the contrast between halo-area and rest as a rectangle
       outline, even after the asset's edges were faded. The flat
       page-bg color (#0a0a1f on .library-root above) plus the
       existing radial gradients + vignette are now the only
       atmospheric layers. */

    /* Re-enable real flex container on the center stage main.
       `.lb-area-right` stays as `display: contents` (inherited from the
       mobile baseline) — its only child `.lb-area-quick-mobile` is
       `display: none` on desktop, so the aside contributes nothing
       to the grid. The desktop floating rail lives outside the grid
       entirely (`<FloatingSidebar>` with `position: fixed`). The two
       support panels (ContinueLearningCard + LibraryStatsPanel) also
       live outside the grid via `position: fixed` from inside their
       own components. */
    .lb-area-stage {
      display: flex;
      flex-direction: column;
    }

    /* Reset mobile order — explicit grid placement takes over. */
    .lb-area-hero,
    .lb-area-featured,
    .lb-area-quick-mobile { order: initial; }

    /* Restore the orbit stage that the mobile baseline hid above.
       `.lb-area-hero` no longer needs an explicit restore here
       because the mobile baseline keeps it visible (the hero text
       is shown on mobile too — see the override block below). */
    .lb-area-featured     { display: block; }

    /* 2-column dashboard with LANGUAGE-AWARE column placement:
         column 1 = inline-start  → outer support sidebar (continue +
                                    stats), on the side WHERE reading
                                    starts (visual-right in RTL Hebrew,
                                    visual-left in LTR English)
         column 2 = inline-end    → galaxy stage (center of the page),
                                    on the side opposite to where the
                                    document flow starts
       The narrow rail no longer claims a grid column — the desktop
       FloatingSidebar lives outside the grid as `position: fixed`,
       pinned to the inline-end edge of the viewport. The body adds
       a `padding-inline-end` gutter so the support sidebar doesn't
       collide with the floating rail.
       In LTR: support is visual-left, floating rail is visual-right
               (stage sits between sidebar and rail).
       In RTL: support is visual-right, floating rail is visual-left
               (same relationship, mirrored).
       No physical-direction lock. Grid resolves natively to the
       page's `dir` attribute. */
    .library-body {
      /* Single-column body — the two support panels are taken OUT of
         the body's flow (each is `position: fixed` from inside its
         own component CSS). No inline padding here: the SYMMETRIC
         inline padding lives on `.library-root` instead, so the body's
         max-width + margin: 0 auto centers it perfectly on the
         viewport. The galaxy core (image centered at left:50% of
         `.library-galaxy` inside the body) thus lands exactly at the
         viewport's center — independent of where the fixed support
         panels sit. */
      display: block;
      min-height: calc(var(--library-dashboard-min-height, 100dvh) - 2.75rem);
      max-width: 1440px;
      margin: 0 auto;
      padding: 0;
    }
    /* Galaxy stage still uses physical left/right for the absolute
       orbit slots so the TL/TR/ML/MR/BL/BR placement of the floating
       cards is language-independent (the slots target visual corners,
       not reading-flow corners). Cards inside re-apply page direction
       so Hebrew titles still read RTL. */
    .library-galaxy { direction: ltr; }
    .galaxy-card    { direction: var(--page-direction, ltr); }

    /* The two support panels (ContinueLearningCard + LibraryStatsPanel)
       are anchored individually via `position: fixed` from inside
       their own component CSS (inset-inline-start: 20px,
       top: header-offset + 20px, stacked via --continue-learning-card-height).
       No wrapper needed here. */

    /* ── Center stage: hero + galaxy ──────────────────────────────── */
    .lb-area-stage {
      /* Zero stage-gap: the hero now lives as the title strip of the
         galaxy, not a separate block. .galaxy-stage provides its own
         interior padding for the orbits. */
      gap: 0;
      min-width: 0;
      position: relative;
      /* No background layer here. The page-level unified system
         (--yuval-galaxy-bg-radial-primary on .library-root) is centered
         right under this column and provides the violet field for both
         hero and stage. Adding a column-level layer here used to
         compound the violet and produce a "block within a block" feel. */
    }
    .lb-area-hero {
      flex: 0 0 auto;
      max-width: 680px;
      margin-inline: auto;
      width: 100%;
    }
    /* Galaxy stage takes the remaining vertical space — with the
       recommendations strip removed, the orbit owns the entire lower
       half of the viewport so the central knowledge core can breathe. */
    .lb-area-featured {
      flex: 1 1 auto;
      min-height: 0;
      position: relative;
    }

    /* ── Mobile quick-actions aside: hidden on desktop ──
       The aside stays as `display: contents` (mobile baseline). Its
       only child `.lb-area-quick-mobile` is `display: none` on desktop,
       so the aside contributes nothing visible to the grid. The
       desktop floating rail is `<FloatingSidebar>` rendered outside
       `.library-body` with `position: fixed`. */
    .lb-area-quick-mobile { display: none; }

    /* Galaxy stage on desktop: absolute canvas anchored to the stage.
       Min-height bumped to 540 so the ML/MR orbit cards have enough
       vertical room not to overlap the central core at the narrowest
       desktop widths (1024-1199px).

       Background tuned to match the asset palette: a soft violet
       radial glow at the center fading to the page's deep navy at
       the edges. This is the primary fix for the "rectangle pasted
       in" look — the stage no longer has hard color contrast where
       the asset ends; the violet center seamlessly continues the
       asset's own glow, and the dark edges seamlessly continue the
       page background. */
    .library-galaxy {
      position: relative;
      display: block;
      height: 100%;
      min-height: 540px;
      margin: 0;
      overflow: visible;
      flex-direction: initial;
      scroll-snap-type: none;
      padding: 0;
      scrollbar-width: auto;
      scrollbar-color: auto;
      /* Vertical offset of the entire orbit scene (rings, central core,
         floating cards, glow, rotation controls) so rotated carousel
         items never overlap the page title above. Lives on the orbit
         container only — page title, breadcrumb, side panels and grid
         shell are unaffected. Responsive steps below override the value
         per breakpoint; the transform itself stays the same.
         Bumped to 90px (was 36px) so the TOP of the top-of-orbit cards
         always has at least ~20px of breathing room from the hero
         subtitle on every common 1024px+ viewport. */
      --orbit-vertical-offset: 90px;
      transform: translateY(var(--orbit-vertical-offset));
    }
    /* The earlier `.library-galaxy::before` underlay halo and
       `.galaxy-stage-veil` overlay were experimental edge-blending
       layers. Both removed: the new full-page actual-asset underlay
       on `.library-root::before` propagates the asset's visual
       language across the entire screen, so per-asset edge blending
       layers are no longer necessary. */
    .library-galaxy::-webkit-scrollbar { height: auto; }

    /* `.galaxy-core` and its child rules (.galaxy-core-pool,
       .galaxy-core-aura) were removed alongside their markup nodes:
       they were sized for a 240×240 CSS-rendered core, but the asset
       is 760-820px wide and covered them entirely. They contributed
       nothing visible. The asset + page-level unified backdrop is
       the entire central composition. */

    /* The galaxy PNG no longer lives inside the orbit stage; it is
       now rendered once at the page root as `.knowledge-scene-background`
       (full-viewport fixed). Edge mask, max-width, focus-dim and
       reduced-motion rules that targeted `.galaxy-stage-image` were
       removed alongside the markup. */

    /* ── Floating cards: elliptical orbit.
          Every readable item has its own station along an ellipse around
          the central area. Position is computed in CSS via cos()/sin()
          from each card's `--orbit-angle` (set inline per card in the
          markup). --galaxy-dir mirrors the X axis so the inline-start
          arc stays visual-left in LTR and visual-right in RTL.
          Depth is angle-derived: cards at the bottom of the orbit
          (sin > 0) read as nearer (slightly larger, fully opaque); cards
          at the top read as farther (smaller, slightly dimmed). All
          cards are visible at once — no carousel, no queue. */
    .galaxy-card {
      position: absolute;
      flex: initial;
      max-width: none;
      /* 190px × 1.2 = 228px (Tomer asked for +20% on desktop). The orbit
         radii below were nudged proportionally so the larger cards don't
         crowd the orbit center or the rotate-controls. */
      width: 228px;
      cursor: pointer;
      top: 50%;
      left: 50%;
      /* Ellipse radii — clamped so the orbit shrinks gracefully on
         narrow desktop widths and grows on wide ones. Bumped to keep
         pace with the +20% card width. */
      --orbit-rx: clamp(310px, 34vw, 410px);
      --orbit-ry: clamp(200px, 28vh, 250px);
      /* Effective angle = base angle (set inline per card) + the
         stage-level rotation that the rotate-orbit controls drive.
         All trigonometry below reads from this so a single CSS-var
         change on the stage moves every card around the ellipse in
         lockstep, animated via the existing transform transition. */
      --orbit-active-angle: calc(var(--orbit-angle, 0deg) + var(--orbit-rotation, 0deg));
      /* Depth from angle: --orbit-depth ranges 0 (top of orbit, farthest)
         to 1 (bottom, nearest). sin(angle) is -1 at the top and +1 at
         the bottom; remap to [0, 1]. */
      --orbit-depth: calc((sin(var(--orbit-active-angle, 0deg)) + 1) / 2);
      --slot-scale: calc(0.9 + 0.12 * var(--orbit-depth));
      --slot-opacity: calc(0.86 + 0.14 * var(--orbit-depth));
      /* Subtle perpendicular tilt: cards on the inline-start arc
         (cos < 0 in default LTR, after dir flip) lean inward. */
      --tilt: calc(cos(var(--orbit-active-angle, 0deg)) * 4deg * var(--galaxy-dir, 1) * -1);
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry))
        )
        rotate(var(--tilt))
        scale(var(--slot-scale));
      opacity: var(--slot-opacity);
      transition:
        transform 0.55s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.3s ease;
      z-index: 2;
      will-change: transform, opacity;
    }

    /* Type tint — books pick the gold accent rotation, lessons the
       cyan one, series the violet one. Keeps the groups visually
       distinct on the orbit without needing column-based layout.
       Series capsules sit at the top of the orbit and pick up the
       purple accent already defined in the cosmic palette so they
       read as part of the family without competing with the
       gold/cyan pairing of books and lessons. */
    .galaxy-card[data-kind="book"]   { --card-accent-slot: var(--yuval-galaxy-accent-gold); }
    .galaxy-card[data-kind="lesson"] { --card-accent-slot: var(--yuval-galaxy-accent-cyan); }
    .galaxy-card[data-kind="series"] { --card-accent-slot: var(--yuval-galaxy-accent-purple); }

    /* Linked-glow halo ─────────────────────────────────────────────
       The artifact PNG (the visible book-card art) has transparent
       margins around the painted card pixels, so `box-shadow` on
       any container draws a rectangle far from the visible card
       edge. Solution: `filter: drop-shadow` on the artifact image
       itself — drop-shadow follows the alpha channel and lands on
       the actual painted silhouette of the card, regardless of the
       transparent padding around it.

       Three stacked drop-shadows per keyframe — a tight inner ring
       plus two soft outer blooms — produce a luminous halo that
       reads as a deliberate accent rather than a hard outline.
       The 3-stop cycle (gold → orange → turquoise → gold) repeats
       twice over the 3-second window. z-index on the wrapper rises
       during the pulse so highlighted cards float above neighbours.
       */
    .galaxy-card.is-linked-glow {
      z-index: 5;
    }
    :global(.galaxy-card.is-linked-glow .lc-orbit-artifact-face-front) {
      animation: yuval-linked-glow 1.5s ease-in-out infinite;
    }
    @keyframes yuval-linked-glow {
      0% {
        filter:
          drop-shadow(0 0 2px  rgba(255, 215, 0, 1))
          drop-shadow(0 0 8px  rgba(255, 215, 0, 0.85))
          drop-shadow(0 0 18px rgba(255, 215, 0, 0.55));
      }
      33% {
        filter:
          drop-shadow(0 0 2px  rgba(255, 140, 0, 1))
          drop-shadow(0 0 8px  rgba(255, 140, 0, 0.85))
          drop-shadow(0 0 18px rgba(255, 140, 0, 0.55));
      }
      66% {
        filter:
          drop-shadow(0 0 2px  rgba(64, 224, 208, 1))
          drop-shadow(0 0 8px  rgba(64, 224, 208, 0.85))
          drop-shadow(0 0 18px rgba(64, 224, 208, 0.55));
      }
      100% {
        filter:
          drop-shadow(0 0 2px  rgba(255, 215, 0, 1))
          drop-shadow(0 0 8px  rgba(255, 215, 0, 0.85))
          drop-shadow(0 0 18px rgba(255, 215, 0, 0.55));
      }
    }
    @media (prefers-reduced-motion: reduce) {
      :global(.galaxy-card.is-linked-glow .lc-orbit-artifact-face-front) {
        animation: none;
        filter:
          drop-shadow(0 0 2px  rgba(255, 215, 0, 1))
          drop-shadow(0 0 12px rgba(64, 224, 208, 0.55));
      }
    }

    /* Drag-to-rotate — while the user is actively dragging the orbit
       we drop the transform transition so the carousel tracks the
       cursor in real time (no easing lag). The transition is restored
       the moment the drag ends, which lets the snap-to-station read
       as a smooth animated move. The grabbing cursor + user-select
       reset prevent accidental text selection mid-drag. */
    .library-galaxy[data-galaxy-dragging],
    .library-galaxy[data-galaxy-dragging] .galaxy-card {
      cursor: grabbing;
      user-select: none;
      -webkit-user-select: none;
    }
    .library-galaxy[data-galaxy-dragging] .galaxy-card {
      transition: none;
    }
    /* Block the browser's native image/link drag on every card and on
       its descendant images. Without this, mousedown on the inner <a>
       starts a drag-and-drop "ghost" that prevents our pointermove
       handler from tracking the cursor. The pointerdown handler also
       calls preventDefault, but the CSS hint catches stragglers (e.g.
       SVG/IMG nodes that opt themselves into drag separately). */
    .galaxy-card,
    .galaxy-card *,
    .galaxy-card img,
    .galaxy-card svg {
      -webkit-user-drag: none;
    }

    /* ── Series capsule —
          Built client-side as a separate node when ≥2 visible items
          share a seriesName. The wrapper .galaxy-card carries the
          orbit positioning machinery so the capsule lives at a real
          station on the ellipse, exactly like a single-book card.
          Capsules are clickable: they enter series mode, expanding
          the series's books into a carousel and collapsing the rest
          of the universe into "Other Knowledge". */
    .galaxy-card[data-role="series"] {
      cursor: pointer;
      /* A capsule is wider than a regular book card on the orbit so the
         shape proportions alone signal "container, not item" — even
         before reading the badge or label. Scaled to keep the +10%
         ratio over the +20%-larger book card (228px → 252px). */
      width: 252px;
      /* Resolve series colour at the wrapper level so the deck pseudos
         (below) and the inner capsule both read the same value without
         each redefining it. */
      --series-color-resolved: var(--series-color, var(--yuval-galaxy-accent-gold, #c9a96e));
    }
    /* Stacked deck — two ghost rectangles peeking out behind the capsule,
       narrower and offset downward so the capsule reads as a stack of
       grouped knowledge, not as a single tile. Pure decoration via
       wrapper pseudo-elements; muted/active state animations on the
       wrapper carry the deck along automatically. */
    .galaxy-card[data-role="series"]::before,
    .galaxy-card[data-role="series"]::after {
      content: "";
      position: absolute;
      pointer-events: none;
      border-radius: 18px;
      border-end-start-radius: 12px;
      background: color-mix(in srgb, var(--series-color-resolved) 8%, var(--yuval-galaxy-card-surface, rgba(20, 22, 36, 0.78)));
      border: 1px solid color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
      z-index: 0;
    }
    /* Middle layer — peeks 4 px below, narrower by 8 px each side. */
    .galaxy-card[data-role="series"]::after {
      inset-block-start: 4px;
      inset-block-end: -4px;
      inset-inline-start: 8px;
      inset-inline-end: 8px;
      opacity: 0.85;
    }
    /* Back layer — peeks 8 px below, narrower by 18 px each side. */
    .galaxy-card[data-role="series"]::before {
      inset-block-start: 7px;
      inset-block-end: -8px;
      inset-inline-start: 18px;
      inset-inline-end: 18px;
      opacity: 0.6;
    }
    .galaxy-card[data-role="series"]:focus-visible {
      outline: none;
    }
    .galaxy-card[data-role="series"]:focus-visible .galaxy-series-capsule {
      box-shadow:
        0 14px 38px -14px color-mix(in srgb, var(--series-color-resolved) 70%, transparent),
        0 0 0 2px color-mix(in srgb, var(--series-color-resolved) 70%, transparent),
        inset 0 1px 0 color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
    }

    /* ── Series members —
          Every individual book inside a multi-item series is kept in
          the DOM as an orbit card, but tagged with data-series-member
          so it stays hidden in universe mode. Series mode reveals the
          members of the active series via .is-active-series-member
          (added by the hydrator JS). */
    .galaxy-card[data-series-member] {
      display: none;
    }

    /* ── Series mode — stage-level state.
          Activated by clicking a SeriesCapsule. The hydrator sets
          data-stage-mode="series" + data-active-series="<name>" on
          the stage element, then class-tags individual cards. */

    /* Mute every station that isn't the active series's books or
       the synthesized Other Knowledge pill. Premium fade — opacity
       and scale only, no jarring movement. */
    [data-stage-mode="series"] .galaxy-card.is-muted {
      opacity: 0;
      pointer-events: none;
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1) * 0.85),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry) * 0.85)
        )
        rotate(var(--tilt))
        scale(0.7);
    }

    /* The active series's own capsule is replaced by its books, so
       hide the capsule in series mode. */
    [data-stage-mode="series"] .galaxy-card.is-active-series-capsule {
      opacity: 0;
      pointer-events: none;
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry))
        )
        rotate(var(--tilt))
        scale(0.85);
    }

    /* Members of the active series — revealed and laid out in a
       horizontal carousel centered on the stage. The horizontal
       offset per card is computed from the index/total custom
       properties set by the hydrator. */
    [data-stage-mode="series"] .galaxy-card.is-active-series-member {
      display: block;
      --series-step: clamp(195px, 22vw, 230px);
      --series-row-x: calc(
        (var(--series-active-index, 0)
          - (var(--series-active-total, 1) - 1) / 2)
        * var(--series-step)
        * var(--galaxy-dir, 1)
      );
      transform:
        translate(-50%, -50%)
        translate(var(--series-row-x), 0)
        scale(1.12);
      opacity: 1;
      z-index: 5;
      cursor: pointer;
    }

    /* Hover lift on a carousel book — gentle vertical bump only,
       overrides the default radial-bump hover so cards don't fly
       off the row. */
    [data-stage-mode="series"]
      .galaxy-card.is-active-series-member:hover:not([data-pos="center"]),
    [data-stage-mode="series"]
      .galaxy-card.is-active-series-member:focus-visible:not([data-pos="center"]) {
      transform:
        translate(-50%, -50%)
        translate(var(--series-row-x), -6px)
        scale(1.16);
      opacity: 1;
    }

    /* ── Other Knowledge capsule —
          Synthesized by JS on series-mode entry, removed on exit.
          Sits at the inline-end top of the stage as a compact pill
          summarising "everything else". Clicking it exits series
          mode and restores the universe. */
    .galaxy-card[data-role="other-knowledge"] {
      /* Reset the orbit-card absolute geometry. */
      top: 0;
      left: auto;
      inset-block-start: 12px;
      inset-inline-end: 12px;
      width: auto;
      transform: none;
      opacity: 0;
      cursor: pointer;
      z-index: 6;
      transition:
        opacity 0.32s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .galaxy-card[data-role="other-knowledge"].is-visible {
      opacity: 1;
    }
    .galaxy-card[data-role="other-knowledge"]:hover .galaxy-other-knowledge,
    .galaxy-card[data-role="other-knowledge"]:focus-visible .galaxy-other-knowledge {
      border-color: color-mix(in srgb, var(--yuval-galaxy-text, #ececea) 30%, transparent);
      background: var(--yuval-galaxy-card-surface-hover, rgba(28, 30, 44, 0.82));
    }
    .galaxy-card[data-role="other-knowledge"]:focus-visible {
      outline: none;
    }

    .galaxy-other-knowledge {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.55rem 0.85rem 0.55rem 0.65rem;
      border-radius: 999px;
      background: var(--yuval-galaxy-card-surface, rgba(20, 22, 36, 0.78));
      border: 1px solid color-mix(in srgb, var(--yuval-galaxy-text-muted, #6e6e6c) 40%, transparent);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 8px 22px -10px rgba(0, 0, 0, 0.5);
      transition: background 0.2s ease, border-color 0.2s ease;
    }

    .galaxy-other-knowledge-icon {
      width: 26px;
      height: 26px;
      border-radius: 8px;
      display: grid;
      place-items: center;
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--yuval-galaxy-text-muted, #6e6e6c) 20%, transparent),
        color-mix(in srgb, var(--yuval-galaxy-text-muted, #6e6e6c) 8%, transparent)
      );
      color: var(--yuval-galaxy-text, #ececea);
      font-size: 1.15rem;
      line-height: 1;
      letter-spacing: 0.06em;
      font-weight: 600;
    }

    .galaxy-other-knowledge-text {
      display: flex;
      flex-direction: column;
      gap: 1px;
      line-height: 1.25;
      padding-inline-end: 0.15rem;
    }

    .galaxy-other-knowledge-label {
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--yuval-galaxy-text, #ececea);
      letter-spacing: 0.005em;
    }

    .galaxy-other-knowledge-count {
      font-size: 0.66rem;
      color: var(--yuval-galaxy-text-secondary, var(--yuval-galaxy-text-muted, #a8a8a4));
      letter-spacing: 0.02em;
    }

    .galaxy-other-knowledge-count strong {
      color: var(--yuval-galaxy-text, #ececea);
      font-weight: 600;
      margin-inline-end: 0.2rem;
    }

    .galaxy-series-capsule {
      position: relative;
      /* Stacked above the wrapper's deck pseudo-elements. */
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      padding: 1.05rem 1.1rem 0.85rem;
      padding-inline-start: 1.2rem;
      /* Restrained asymmetry — the inline-start/block-end corner is
         tighter so the capsule reads as a grounded container, not as
         a floating chip. Logical so RTL flips automatically. */
      border-radius: 22px;
      border-end-start-radius: 14px;
      background:
        /* Atmospheric inner glow from the top, painted with the series
           color. Lives in the background stack (not a pseudo-element)
           so children render above it without z-index gymnastics. */
        radial-gradient(
          ellipse 70% 55% at 50% 0%,
          color-mix(in srgb, var(--series-color-resolved) 18%, transparent) 0%,
          transparent 65%
        ),
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--series-color-resolved) 11%, transparent) 0%,
          color-mix(in srgb, var(--series-color-resolved) 4%, transparent) 55%,
          color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 84%, transparent) 100%
        ),
        var(--yuval-galaxy-card-surface, rgba(20, 22, 36, 0.78));
      /* Two-layer luminous border — hairline outer ring + a slightly
         stronger inner edge — for a refined, lit-from-within feel. */
      border: 1px solid color-mix(in srgb, var(--series-color-resolved) 36%, transparent);
      box-shadow:
        0 10px 26px -16px color-mix(in srgb, var(--series-color-resolved) 38%, transparent),
        0 0 0 1px color-mix(in srgb, var(--series-color-resolved) 14%, transparent),
        inset 0 1px 0 color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
      backdrop-filter: blur(14px) saturate(125%);
      -webkit-backdrop-filter: blur(14px) saturate(125%);
      transition:
        border-color 240ms ease,
        box-shadow 240ms ease;
    }

    /* Capsule edge indicator — a thin luminous bar along the inline-start
       side, painted in the series color. Echoes the series swatch on
       /admin so the same color identifies the same series everywhere. */
    .galaxy-series-capsule::before {
      content: "";
      position: absolute;
      inset-block: 16px;
      inset-inline-start: 0;
      width: 2px;
      border-radius: 0 2px 2px 0;
      background: var(--series-color-resolved);
      opacity: 0.75;
      box-shadow: 0 0 8px color-mix(in srgb, var(--series-color-resolved) 60%, transparent);
    }
    [dir="rtl"] .galaxy-series-capsule::before {
      border-radius: 2px 0 0 2px;
    }

    /* Binder ridge — a hairline horizontal line tucked into the empty
       strip above the badge, like the metal clip at the top of a binder.
       Reads as "container surface" rather than "card top edge". */
    .galaxy-series-capsule::after {
      content: "";
      position: absolute;
      inset-block-start: 7px;
      inset-inline: 16px;
      height: 1px;
      pointer-events: none;
      background: linear-gradient(
        90deg,
        transparent 0%,
        color-mix(in srgb, var(--series-color-resolved) 50%, transparent) 30%,
        color-mix(in srgb, var(--series-color-resolved) 65%, transparent) 50%,
        color-mix(in srgb, var(--series-color-resolved) 50%, transparent) 70%,
        transparent 100%
      );
      opacity: 0.55;
    }

    /* Restrained hover — slightly lift the border luminosity and the
       inner edge, no large bloom. The universe should feel calm. */
    .galaxy-card[data-role="series"]:hover .galaxy-series-capsule {
      border-color: color-mix(in srgb, var(--series-color-resolved) 52%, transparent);
      box-shadow:
        0 12px 30px -16px color-mix(in srgb, var(--series-color-resolved) 48%, transparent),
        0 0 0 1px color-mix(in srgb, var(--series-color-resolved) 20%, transparent),
        inset 0 1px 0 color-mix(in srgb, var(--series-color-resolved) 28%, transparent);
    }

    .galaxy-series-badge {
      align-self: flex-start;
      display: inline-flex;
      align-items: center;
      padding: 2px 10px 2px 8px;
      border-radius: 999px;
      background: color-mix(in srgb, var(--series-color-resolved) 18%, transparent);
      border: 1px solid color-mix(in srgb, var(--series-color-resolved) 55%, transparent);
      color: var(--series-color-resolved);
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 0.66rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      line-height: 1.4;
    }
    /* Stacked-bars glyph rendered purely in CSS — three short horizontal
       lines tucked before the badge text. Reinforces the "stacked
       knowledge" semantic without adding markup. */
    .galaxy-series-badge::before {
      content: "";
      display: inline-block;
      width: 9px;
      height: 9px;
      margin-inline-end: 6px;
      background:
        linear-gradient(currentColor, currentColor) top center / 9px 1.4px no-repeat,
        linear-gradient(currentColor, currentColor) center      / 7px 1.4px no-repeat,
        linear-gradient(currentColor, currentColor) bottom center / 5px 1.4px no-repeat;
      vertical-align: -1px;
      opacity: 0.95;
    }

    .galaxy-series-name {
      margin: 0;
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 1.12rem;
      font-weight: 500;
      line-height: 1.2;
      color: var(--yuval-galaxy-text, #ececea);
      letter-spacing: -0.01em;
      /* Allow up to 2 lines — series names tend to be longer than book titles. */
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .galaxy-series-counts {
      display: flex;
      flex-direction: column;
      gap: 1px;
      margin-top: 2px;
    }

    .galaxy-series-count-line {
      font-size: 0.72rem;
      color: var(--yuval-galaxy-text-secondary, var(--yuval-galaxy-text-muted, #a8a8a4));
      line-height: 1.45;
      letter-spacing: 0.005em;
    }

    .galaxy-series-count-line strong {
      color: var(--yuval-galaxy-text, #ececea);
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 0.95rem;
      font-weight: 500;
      font-feature-settings: 'tnum' 1, 'lnum' 1;
      margin-inline-end: 0.3rem;
    }

    .galaxy-series-count-available strong {
      color: var(--series-color-resolved);
    }

    /* Shelf — the spine row sits in a recessed compartment with a
       luminous bottom edge, so the spines read as "books on a shelf"
       rather than as a chart. Margin pulls the shelf to the inline
       edges of the capsule's inner padding so it spans the full width. */
    .galaxy-series-stack {
      position: relative;
      display: flex;
      align-items: flex-end;
      gap: 3px;
      height: 18px;
      margin-block-start: 6px;
      margin-inline: -0.35rem;
      padding: 4px 0.5rem 5px;
      border-radius: 5px 5px 8px 8px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 22%, transparent) 0%,
          color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 42%, transparent) 100%
        );
      box-shadow:
        inset 0 1px 0 color-mix(in srgb, #000 22%, transparent),
        inset 0 -1px 0 color-mix(in srgb, var(--series-color-resolved) 14%, transparent);
    }
    /* Luminous shelf line — the surface the books are resting on. */
    .galaxy-series-stack::after {
      content: "";
      position: absolute;
      inset-block-end: 1px;
      inset-inline: 8px;
      height: 1px;
      pointer-events: none;
      background: linear-gradient(
        90deg,
        transparent 0%,
        color-mix(in srgb, var(--series-color-resolved) 60%, transparent) 50%,
        transparent 100%
      );
      opacity: 0.7;
    }
    /* Each spine = one book. Capped at 5 in the hydrator. Heights vary
       in a fixed, gentle rhythm — not random — so the row reads as
       "books on a shelf" without visual noise. */
    .galaxy-series-spine {
      display: block;
      width: 3px;
      border-radius: 1px 1px 0 0;
      background: color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
      height: 11px;
    }
    .galaxy-series-spine:nth-child(2) { height: 13px; }
    .galaxy-series-spine:nth-child(3) { height: 12px; }
    .galaxy-series-spine:nth-child(4) { height: 14px; }
    .galaxy-series-spine:nth-child(5) { height: 12px; }
    .galaxy-series-spine.is-filled {
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--series-color-resolved) 92%, white) 0%,
        var(--series-color-resolved) 100%
      );
      opacity: 0.85;
      box-shadow:
        inset 0 -1px 0 color-mix(in srgb, #000 25%, transparent);
    }

    /* Centered focus state — overrides the orbit transform so the card
       flies to the middle, scales up, drops its tilt. Sits above the
       backdrop and other cards.
       The extra `translateY(-90px)` after the scale anchors the focused
       card's TOP edge just below the hero subtitle so the reading
       "title → focused card" flow is continuous (Tomer asked for the
       centered card to start "right below the subtitle line", not
       mid-screen at the orbit center). Note: translateY appears AFTER
       scale(1.5) in the chain, but CSS applies transforms right-to-
       left, so the -90 px is multiplied through the 1.5× scale and
       reads as ~135 px visual upward shift. */
    .galaxy-card[data-pos="center"] {
      transform: translate(-50%, -50%) scale(1.5) translateY(-90px);
      opacity: 1;
      z-index: 30;
      cursor: default;
    }

    /* Hover lift — small bump along the radial direction (cards move
       slightly further from center) plus a brightness/scale bump.
       Skipped when the card is focused to avoid double transforms. */
    .galaxy-card:hover:not([data-pos="center"]),
    .galaxy-card:focus-visible:not([data-pos="center"]) {
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * (var(--orbit-rx) + 8px) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * (var(--orbit-ry) + 8px))
        )
        rotate(calc(var(--tilt) * 0.5))
        scale(calc(var(--slot-scale) * 1.04));
      opacity: 1;
      z-index: 3;
    }
    .galaxy-card:focus-visible {
      outline: none;
    }

    /* CTA overlay — hidden when card is in slot/queue; revealed only
       when data-pos="center". Children stop click propagation so the
       card-level handler never fires for Open/Close. */
    .galaxy-cta {
      position: absolute;
      /* Anchor inside the focused card at its visible bottom — the
         spot where the `.lc-orbit-author` byline used to sit before
         it was retired. Series action pills now read as part of the
         focused-card composition rather than as a side rail.
         Centering uses physical `left: 50%; transform: translateX(-50%)`
         (not logical inset-inline-*) so it stays centered in both
         RTL Hebrew and LTR English without writing-direction quirks. */
      top: 66%;
      left: 50%;
      bottom: auto;
      right: auto;
      transform: translate(-50%, -50%);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      justify-content: center;
      align-items: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease 0.15s;
      /* Above the scaled-up artwork (`transform: scale(1.5)` visually
         bleeds past the card's flow box bottom by ~25%). */
      z-index: 2;
    }
    .galaxy-card[data-pos="center"] .galaxy-cta {
      opacity: 1;
      pointer-events: auto;
    }
    /* ── Knowledge activation orb ─────────────────────────────────────
          Compact circular CTA that replaces the previous pill — feels
          native to the holographic knowledge-card universe rather than
          a generic web button. Layered structure:
            .galaxy-cta-open        — the orb body (translucent glass)
            .galaxy-cta-open-core   — inner radial light
            .galaxy-cta-open-ring   — outer dashed ring (rotates on hover)
            .galaxy-cta-open-icon   — the open/access glyph
            .galaxy-cta-open-label  — hover/focus tooltip
          Real <a> element with `aria-label`, so keyboard + screen-reader
          paths work exactly like the previous button (Enter/Space follow
          the link, focus-visible draws the same activated state). */
    .galaxy-cta-open {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 64px;
      height: 64px;
      border-radius: 50%;
      color: var(--yuval-galaxy-accent, #5eead4);
      cursor: pointer;
      text-decoration: none;
      /* Translucent glass body — inner glow rooted on the accent,
         fading into the page background colour at the edges. The
         core layer (::core span below) handles the brighter centre. */
      background:
        radial-gradient(
          circle at 50% 38%,
          color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 24%, transparent) 0%,
          color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 8%, transparent) 55%,
          transparent 100%
        ),
        color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 55%, transparent);
      border: 1px solid color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 60%, transparent);
      box-shadow:
        0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 18%, transparent) inset,
        0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 50%, transparent) inset,
        0 0 18px -2px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 35%, transparent);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      transition:
        transform 220ms cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 220ms cubic-bezier(0.4, 0, 0.2, 1),
        border-color 220ms cubic-bezier(0.4, 0, 0.2, 1);
      /* Subtle continuous breathing — the orb feels alive even at rest. */
      animation: galaxy-cta-open-pulse 3.6s ease-in-out infinite;
    }
    @keyframes galaxy-cta-open-pulse {
      0%, 100% {
        box-shadow:
          0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 18%, transparent) inset,
          0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 50%, transparent) inset,
          0 0 18px -2px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 35%, transparent);
      }
      50% {
        box-shadow:
          0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 26%, transparent) inset,
          0 0 8px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 60%, transparent) inset,
          0 0 24px -2px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 45%, transparent);
      }
    }
    /* Inner core highlight — small luminous spot toward the upper-left
       of the orb, like a glass marble's reflected light source. */
    .galaxy-cta-open-core {
      position: absolute;
      inset: 18%;
      border-radius: 50%;
      background: radial-gradient(
        circle at 38% 30%,
        color-mix(in srgb, white 35%, transparent) 0%,
        color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 22%, transparent) 28%,
        transparent 70%
      );
      pointer-events: none;
    }
    /* Outer dashed ring — sits just outside the orb. Rotates slowly
       on hover/focus; static + slightly dimmer at rest. */
    .galaxy-cta-open-ring {
      position: absolute;
      inset: -5px;
      border-radius: 50%;
      border: 1px dashed
        color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 45%, transparent);
      opacity: 0.7;
      pointer-events: none;
      transition: opacity 220ms ease;
    }
    @keyframes galaxy-cta-open-ring-rotate {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    /* Open/access glyph — chevron into the inline-end direction. RTL
       mirroring is handled below so "→" stays reading-flow forward. */
    .galaxy-cta-open-icon {
      position: relative;
      width: 22px;
      height: 22px;
      z-index: 1;
      filter: drop-shadow(
        0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 65%, transparent));
      transition: opacity 180ms ease;
    }
    [dir="rtl"] .galaxy-cta-open-icon { transform: scaleX(-1); }

    /* Hover label — floats to the PHYSICAL RIGHT of the orb,
       vertically centered on the orb. Physical `left` + `top` (not
       `inset-inline-*`) so the side stays the same in both RTL and
       LTR — the user explicitly asked for visual-right. The 4px
       inward initial translation gives a small slide-in entry. */
    .galaxy-cta-open-label {
      position: absolute;
      top: 50%;
      left: calc(100% + 0.5rem);
      bottom: auto;
      right: auto;
      inset-block-start: auto;
      inset-block-end: auto;
      inset-inline-start: auto;
      inset-inline-end: auto;
      transform: translateY(-50%) translateX(-4px);
      padding: 0.25rem 0.625rem;
      border-radius: 999px;
      font-family: 'Assistant', system-ui, sans-serif;
      font-size: 0.78125rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: var(--yuval-galaxy-text, #ececea);
      background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 82%, transparent);
      border: 1px solid color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 28%, transparent);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      white-space: nowrap;
      pointer-events: none;
      opacity: 0;
      transition:
        opacity 180ms ease,
        transform 220ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    .galaxy-cta-open:hover,
    .galaxy-cta-open:focus-visible {
      transform: translateY(-2px);
      border-color: color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 80%, transparent);
      box-shadow:
        0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 30%, transparent) inset,
        0 0 8px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 70%, transparent) inset,
        0 0 28px -2px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 55%, transparent),
        0 0 14px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 35%, transparent);
      outline: none;
      /* Pause the rest pulse — hover/focus drives its own glow now. */
      animation-play-state: paused;
    }
    .galaxy-cta-open:hover .galaxy-cta-open-ring,
    .galaxy-cta-open:focus-visible .galaxy-cta-open-ring {
      opacity: 1;
      animation: galaxy-cta-open-ring-rotate 12s linear infinite;
    }
    /* Icon stays visible on hover — the label is its own bubble
       above the orb now, no swap needed. */
    .galaxy-cta-open:hover .galaxy-cta-open-label,
    .galaxy-cta-open:focus-visible .galaxy-cta-open-label {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
    }
    .galaxy-cta-open:active {
      transform: translateY(0);
      transition-duration: 80ms;
    }

    @media (prefers-reduced-motion: reduce) {
      .galaxy-cta-open,
      .galaxy-cta-open-icon,
      .galaxy-cta-open-label,
      .galaxy-cta-open-ring { transition: none; animation: none; }
      .galaxy-cta-open:hover .galaxy-cta-open-ring,
      .galaxy-cta-open:focus-visible .galaxy-cta-open-ring { animation: none; }
    }
    .galaxy-cta-close {
      width: 28px;
      height: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      font-size: 1.125rem;
      line-height: 1;
      color: var(--yuval-galaxy-text-muted);
      background: var(--yuval-galaxy-surface-muted);
      border: 1px solid var(--yuval-galaxy-border);
      cursor: pointer;
      padding: 0;
      transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
    }
    .galaxy-cta-close:hover,
    .galaxy-cta-close:focus-visible {
      color: var(--yuval-galaxy-text);
      background: var(--yuval-galaxy-card-surface-hover);
      border-color: var(--yuval-galaxy-border-strong);
      outline: none;
    }

    /* ── Reading-entry overlay (phase 1) ─────────────────────────────
       Internal premium panel that appears ONLY when the card is
       centered (`[data-pos="center"]`). Sits absolutely over the card
       surface, between the LibraryCard art and the close button.
       Routing is not wired yet — the click handler in
       `initReadingEntry()` (see the page script block) logs slug + href.

       The original side open orb (`.galaxy-cta-open`) is hidden via
       the `display: none` rule below; the underlying <a href> is left
       in the DOM so we keep the link target for future use. */
    .galaxy-cta-open {
      display: none !important;
    }

    /* ── Reading-entry overlay: in-card image-based premium panel ──────
       The entry control sits INSIDE the centered book card (not below
       it). The visual is a textless PNG asset; all visible text is
       live, localized HTML rendered on top — the image never carries
       baked text.

       Stacking inside the overlay <a>:
         .reading-entry-asset  — background-image PNG (decorative)
         .reading-entry-text   — title + subtitle, live i18n

       The <a> itself is the hit area and preserves native link
       behavior (Ctrl/Cmd-click → new tab, middle-click → new tab,
       right-click → context menu). Plain left-click and Enter are
       intercepted by the launch handler in `universe-layout.ts` via
       the `data-reading-entry` attribute.

       Phase-3 launch animation: the overlay's two child layers
       (.reading-entry-asset + .reading-entry-text) fade out cleanly
       when `data-reading-entry-state="opening"` is set on the stage.
       Opacity-only fade keeps the link in the accessibility tree
       until the launch is committed. */
    .reading-entry-overlay {
      position: absolute;
      left: 50%;
      top: calc(100% - 34px);
      width: 66%;
      height: 108px;
      transform: translate(-50%, 0);
      display: block;
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
      color: inherit;
      cursor: pointer;
      text-decoration: none;
      -webkit-tap-highlight-color: transparent;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      /* Sits over the card art, the opening-animation layers
         (.reading-entry-opening at z-index 5), and the LibraryCard
         caption. Centered card already creates a stacking context at
         z-index 30, so this z-index is intra-card only. */
      z-index: 30;
      /* Direction is inherited from the page (rtl for Hebrew, ltr for
         English) so RTL/LTR fall out automatically — no per-language
         override here. */
      transition:
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        transform 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 240ms;
    }
    .galaxy-card[data-pos="center"] .reading-entry-overlay {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition:
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        transform 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 0s;
    }
    .reading-entry-overlay:focus-visible {
      outline: none;
    }
    .reading-entry-overlay:focus-visible .reading-entry-asset {
      box-shadow:
        0 0 0 2px rgba(150, 200, 255, 0.45),
        0 0 22px rgba(112, 87, 255, 0.45);
    }

    /* Decorative PNG asset — the visual card. No baked text. Sized to
       fully cover the overlay and carry its border-radius so the
       focus ring traces the panel's actual shape. */
    .reading-entry-asset {
      position: absolute;
      inset: 0;
      border-radius: 24px;
      background-image: url('/assets/ui/reading-entry/reading-entry-card.png');
      background-size: 100% 100%;
      background-repeat: no-repeat;
      background-position: center;
      pointer-events: none;
      transition:
        transform 220ms cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 220ms ease,
        filter 220ms ease;
    }

    /* Live i18n text rendered over the lower text area of the asset.
       Single title line — sits below the asset's built-in icon and
       above the card's author area. The i18n subtitle key still
       exists in translations.ts for future reuse, but no element
       renders it in this overlay. */
    .reading-entry-text {
      position: absolute;
      left: 50%;
      top: calc(60% + 2px);
      width: 92%;
      transform: translate(-50%, -50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      pointer-events: none;
      font-family:
        'Heebo', 'Inter', system-ui, -apple-system,
        'Segoe UI', 'Noto Sans Hebrew', sans-serif;
    }
    .reading-entry-title {
      font-size: 12px;
      font-weight: 700;
      line-height: 1.1;
      white-space: nowrap;
      color: rgba(248, 252, 255, 0.98);
      text-shadow:
        0 0 10px rgba(90, 160, 255, 0.35),
        0 2px 4px rgba(0, 0, 0, 0.65);
    }

    /* Hover / focus — gentle lift on the asset, no jump. */
    .reading-entry-overlay:hover .reading-entry-asset,
    .reading-entry-overlay:focus-visible .reading-entry-asset {
      filter: brightness(1.06) saturate(1.05);
    }
    .reading-entry-overlay:active .reading-entry-asset {
      transform: scale(0.985);
    }

    @media (prefers-reduced-motion: reduce) {
      .reading-entry-overlay,
      .reading-entry-asset {
        transition: none;
      }
    }

    /* ── Phase 3: opening animation ──────────────────────────────────
       Activated only when BOTH conditions hold:
         - the stage carries data-reading-entry-state="opening"
         - the card has data-pos="center"
       so non-centered cards and non-launching stages remain unaffected.

       Tunables (all read off `.library-galaxy`):
         --reading-entry-duration    — total animation length (480ms)
         --reading-entry-ease        — shared easing curve
         --reading-entry-beam-color  — beam mid-tone (blue-violet)
         --reading-entry-glow-color  — beam glow + bloom tint
         --reading-entry-cover-tilt  — outward rotation of each cover */
    .library-galaxy {
      --reading-entry-duration: 600ms;
      --reading-entry-ease: cubic-bezier(0.22, 0.61, 0.36, 1);
      --reading-entry-beam-color: #6f7dff;
      --reading-entry-glow-color: rgba(120, 130, 255, 0.6);
      --reading-entry-cover-tilt: 42deg;
      --reading-entry-cover-shift: 16px;
      /* Dark blue-violet sitting in the centerline gap. Read as the
         "inside" of the opening book — not a black bar. */
      --reading-entry-void-color: #0a0719;
      --reading-entry-edge-color: rgba(220, 226, 255, 0.85);
    }

    /* Opening container — sits between the card art and the
       reading-entry overlay. Stacks above the card image (default
       z-index) and below the overlay panel (z-index: 6). Always
       inert — `pointer-events: none` here AND on every descendant. */
    .reading-entry-opening {
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0;
      overflow: hidden;
      border-radius: 12px;
      z-index: 5;
      perspective: 750px;
      transform-style: preserve-3d;
      transition: opacity 180ms ease-out;
    }
    .reading-entry-opening > * {
      pointer-events: none;
    }

    /* Void — vertical dark blue-violet slit sitting in the seam, behind
       the spine and below the cover halves (::before paints first). At
       rest the covers fully cover it; as they rotate/translate outward
       the void becomes visible inside the opening, so the gap reads as
       depth rather than just a light line on top of the card art.
       Soft radial fade keeps the edges from looking like a black bar. */
    .reading-entry-opening::before {
      content: "";
      position: absolute;
      inset-block: 4%;
      inset-inline-start: 50%;
      width: 14px;
      transform: translateX(-50%) scaleY(0);
      transform-origin: center;
      background:
        radial-gradient(
          ellipse at center,
          var(--reading-entry-void-color) 0%,
          color-mix(in srgb, var(--reading-entry-void-color) 55%, transparent) 40%,
          transparent 80%
        );
      filter: blur(3px);
      opacity: 0;
      pointer-events: none;
      z-index: 0;
    }
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-opening::before {
      animation:
        reading-entry-void
        var(--reading-entry-duration)
        var(--reading-entry-ease)
        forwards;
    }
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-opening {
      opacity: 1;
    }

    /* Bloom — soft radial light that expands behind the spine. Paints
       first (source order) so the spine and covers overlay it. */
    .reading-entry-bloom {
      position: absolute;
      inset: 50% 50% auto auto;
      transform: translate(50%, -50%) scale(0);
      width: 60%;
      aspect-ratio: 1;
      border-radius: 50%;
      background:
        radial-gradient(
          circle at center,
          var(--reading-entry-glow-color) 0%,
          color-mix(in srgb, var(--reading-entry-glow-color) 45%, transparent) 35%,
          transparent 70%
        );
      filter: blur(10px);
      opacity: 0;
      mix-blend-mode: screen;
    }
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-bloom {
      animation:
        reading-entry-bloom
        var(--reading-entry-duration)
        var(--reading-entry-ease)
        forwards;
    }

    /* Glass cover halves — appear during the animation, hinged on the
       outer edge, rotating outward to "open" the card like a book.
       Subtle warm-gold edge keeps the cover halves consistent with the
       Yuval premium palette; the inner gradient mimics translucent
       leaded glass. */
    .reading-entry-cover {
      position: absolute;
      inset-block: 0;
      width: 50%;
      /* Translucent glass: lightly tinted near the spine where the
         light beam catches, fading to near-transparent at the outer
         edge so the original card art reads through. Per-half rules
         below set the gradient direction. */
      border: none;
      backdrop-filter: blur(1px) saturate(115%);
      -webkit-backdrop-filter: blur(1px) saturate(115%);
      box-shadow: none;
      opacity: 0;
      will-change: transform, opacity;
    }
    /* Hinge fix: the covers must open from the CENTER SPINE, so the
       left half is hinged on its RIGHT edge (touching the spine) and
       the right half is hinged on its LEFT edge (also touching the
       spine). The previous values (`left center` / `right center`)
       pinned each half to its outer edge, which would swing the inner
       edges around the outer hinge — the opposite of a book opening.

       Physical `left: 0` / `right: 0` (not logical inline-start/end)
       is intentional: the animation is direction-symmetric (two halves
       meeting at the centerline of the card), so we want the visual
       layout to stay identical in LTR and RTL rather than swap which
       half sits on the inline-start side. The spine itself uses
       `inset-inline-start: 50%` with `translateX(-50%)`, which
       resolves to the visual center in both directions, so spine and
       hinges stay aligned regardless of page direction. */
    /* Per-half box-shadows layer two depth cues on top of the base
       warm-gold inset and drop shadow from `.reading-entry-cover`:
         1. A 1px bright edge on the seam side reads as a backlit page
            edge catching the spine glow.
         2. An inner shadow falling away from the seam makes the gap
            feel recessed, so the eye reads the centerline as depth
            (the inside of the book) instead of a flat highlight. */
    /* Per-half glass cover. Three things keep these from reading as
       dark stripes:
         1. Background gradient is strongest near the spine (right edge
            of the left half / left edge of the right half) and fades
            to ~transparent at the outer edge, so the cover is visibly
            anchored to the seam, not a full rectangle.
         2. mask-image fades the outer edge to fully transparent so
            the cover dissolves into the card art instead of clipping.
         3. Box-shadows are now: a thin luminous spine-side highlight
            and a much softer (-14px spread) seam-side inner shadow.
            No dark stroke around the perimeter. */
    .reading-entry-cover-left {
      left: 0;
      transform-origin: right center;
      transform: rotateY(0deg) translateX(0);
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
      background: linear-gradient(
        90deg,
        rgba(8, 12, 34, 0.04) 0%,
        rgba(20, 26, 64, 0.22) 68%,
        rgba(150, 180, 255, 0.18) 100%
      );
      box-shadow:
        inset -1px 0 0 0 var(--reading-entry-edge-color),
        inset -14px 0 22px -16px rgba(0, 0, 0, 0.45);
      mask-image: linear-gradient(
        90deg,
        transparent 0%,
        rgba(0, 0, 0, 0.35) 22%,
        #000 65%,
        #000 100%
      );
      -webkit-mask-image: linear-gradient(
        90deg,
        transparent 0%,
        rgba(0, 0, 0, 0.35) 22%,
        #000 65%,
        #000 100%
      );
    }
    .reading-entry-cover-right {
      right: 0;
      transform-origin: left center;
      transform: rotateY(0deg) translateX(0);
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
      background: linear-gradient(
        270deg,
        rgba(8, 12, 34, 0.04) 0%,
        rgba(20, 26, 64, 0.22) 68%,
        rgba(150, 180, 255, 0.18) 100%
      );
      box-shadow:
        inset 1px 0 0 0 var(--reading-entry-edge-color),
        inset 14px 0 22px -16px rgba(0, 0, 0, 0.45);
      mask-image: linear-gradient(
        270deg,
        transparent 0%,
        rgba(0, 0, 0, 0.35) 22%,
        #000 65%,
        #000 100%
      );
      -webkit-mask-image: linear-gradient(
        270deg,
        transparent 0%,
        rgba(0, 0, 0, 0.35) 22%,
        #000 65%,
        #000 100%
      );
    }
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-cover-left {
      animation:
        reading-entry-cover-left
        var(--reading-entry-duration)
        var(--reading-entry-ease)
        forwards;
    }
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-cover-right {
      animation:
        reading-entry-cover-right
        var(--reading-entry-duration)
        var(--reading-entry-ease)
        forwards;
    }

    /* Spine — thin vertical beam down the centerline. Paints last so
       the glow reads as the focal point. Two box-shadows produce the
       layered halo (tight inner core, wider outer wash). */
    .reading-entry-spine {
      position: absolute;
      inset-block: 6%;
      inset-inline-start: 50%;
      width: 2px;
      transform: translateX(-50%) scaleY(0);
      transform-origin: center;
      background: linear-gradient(
        180deg,
        transparent 0%,
        color-mix(in srgb, var(--reading-entry-beam-color) 55%, transparent) 12%,
        #cfd4ff 50%,
        color-mix(in srgb, var(--reading-entry-beam-color) 55%, transparent) 88%,
        transparent 100%
      );
      box-shadow:
        0 0 6px var(--reading-entry-glow-color),
        0 0 16px var(--reading-entry-glow-color),
        0 0 28px color-mix(in srgb, var(--reading-entry-glow-color) 55%, transparent);
      border-radius: 4px;
      opacity: 0;
      mix-blend-mode: screen;
      will-change: transform, opacity, width;
    }
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-spine {
      animation:
        reading-entry-spine
        var(--reading-entry-duration)
        var(--reading-entry-ease)
        forwards;
    }

    /* Hide the reading-entry overlay panel during opening — the user
       just activated it, so its job is done and it shouldn't compete
       with the unfolding animation. Opacity-only so the link itself
       stays in the accessibility tree until launch is committed. */
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-asset,
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-text {
      opacity: 0;
      transition: opacity 200ms ease-out;
    }

    /* Camera push — the centered card scales up a touch during opening
       so the user feels pulled into the book rather than just watching
       the covers part. Rides the existing 0.55s transform transition on
       `.galaxy-card`, so no new animation infra is added. Override is
       scoped to opening + center, so resting layout is untouched. */
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"] {
      transform: translate(-50%, -50%) scale(1.56);
    }

    /* Non-centered orbit cards — dim + soft blur so attention shifts
       to the launching card. Limited to the launching stage, so other
       library views and the mobile carousel are unaffected. */
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card:not([data-pos="center"]) {
      filter: blur(2px) saturate(0.78);
      opacity: 0.42;
      transition:
        filter var(--reading-entry-duration) var(--reading-entry-ease),
        opacity var(--reading-entry-duration) var(--reading-entry-ease);
    }

    /* Cosmic scene darkening — only the background image dims, so
       the global header (top app bar), the left sidebar, and the
       narrow right pill toolbar all remain at full opacity / fully
       usable. `:has()` lets the rule live next to the rest of the
       launch styling without a JS-driven body class. */
    .library-root:has(.library-galaxy[data-reading-entry-state="opening"])
      .knowledge-scene-background img {
      filter: brightness(0.68) saturate(0.9);
      transition: filter var(--reading-entry-duration) var(--reading-entry-ease);
    }

    /* Portal beat: in the first ~250ms (≈40% of 600ms) the spine flares
       to 7px and reaches full brightness, reading as a portal cracking
       open. It then narrows back to a 3px settled beam while the covers
       finish rotating outward. The wider settled width (3px vs 2px)
       gives the light line enough body to read against the dark void
       behind it. */
    @keyframes reading-entry-spine {
      0%   { opacity: 0;    transform: translateX(-50%) scaleY(0);    width: 3px; }
      18%  { opacity: 1;    transform: translateX(-50%) scaleY(0.55); width: 7px; }
      40%  { opacity: 1;    transform: translateX(-50%) scaleY(0.9);  width: 5px; }
      100% { opacity: 0.92; transform: translateX(-50%) scaleY(1);    width: 3px; }
    }
    /* Both halves: hinge at the spine, rotate outward, and shift a few
       pixels off-center so the seam visibly parts. Final opacity 0.78
       keeps the original card readable underneath while the covers
       stay clearly legible as opening pages. */
    @keyframes reading-entry-cover-left {
      0%   { opacity: 0;    transform: rotateY(0deg) translateX(0); }
      18%  { opacity: 0.7;                                           }
      100% { opacity: 0.55; transform: rotateY(var(--reading-entry-cover-tilt))
                                       translateX(calc(var(--reading-entry-cover-shift) * -1)); }
    }
    @keyframes reading-entry-cover-right {
      0%   { opacity: 0;    transform: rotateY(0deg) translateX(0); }
      18%  { opacity: 0.7;                                           }
      100% { opacity: 0.55; transform: rotateY(calc(var(--reading-entry-cover-tilt) * -1))
                                       translateX(var(--reading-entry-cover-shift)); }
    }
    /* Void grows in lockstep with the spine, then settles softer than
       peak so the recess hints at depth without dominating. Narrow
       width (14px) + low settle opacity (0.4) keeps it as a soft slit,
       not a dark vertical band. */
    @keyframes reading-entry-void {
      0%   { opacity: 0;    transform: translateX(-50%) scaleY(0);    }
      30%  { opacity: 0.5;                                             }
      100% { opacity: 0.4;  transform: translateX(-50%) scaleY(1);    }
    }
    /* Bloom hits its brightness peak alongside the portal flare (~35%)
       then expands and softens, supporting the spine without competing. */
    @keyframes reading-entry-bloom {
      0%   { opacity: 0;    transform: translate(50%, -50%) scale(0);    }
      35%  { opacity: 0.95;                                              }
      100% { opacity: 0.6;  transform: translate(50%, -50%) scale(1.5);  }
    }

    /* Reduced motion: no rotating doors, no scale-pulses. The spine
       and bloom fade in softly so the user still gets confirmation
       that the launch was acknowledged, but nothing flashes. */
    @media (prefers-reduced-motion: reduce) {
      .reading-entry-opening,
      .reading-entry-opening::before,
      .reading-entry-bloom,
      .reading-entry-cover,
      .reading-entry-spine {
        animation: none !important;
        transition: opacity 200ms linear;
      }
      /* Void requires the cover rotation to make sense; without rotation
         there is no gap to fill, so keep it hidden under reduced motion. */
      .library-galaxy[data-reading-entry-state="opening"]
        .galaxy-card[data-pos="center"]
        .reading-entry-opening::before {
        opacity: 0;
        transform: translateX(-50%) scaleY(0);
      }
      .library-galaxy[data-reading-entry-state="opening"]
        .galaxy-card[data-pos="center"]
        .reading-entry-spine {
        opacity: 0.7;
        transform: translateX(-50%) scaleY(1);
      }
      .library-galaxy[data-reading-entry-state="opening"]
        .galaxy-card[data-pos="center"]
        .reading-entry-bloom {
        opacity: 0.55;
        transform: translate(50%, -50%) scale(1);
      }
      .library-galaxy[data-reading-entry-state="opening"]
        .galaxy-card[data-pos="center"]
        .reading-entry-cover {
        opacity: 0;  /* covers don't appear at all under reduced motion */
      }
      /* No camera push under reduced motion — keep the centered card
         exactly where it rests. The spine/bloom soft-fade alone
         confirms the launch. */
      .library-galaxy[data-reading-entry-state="opening"]
        .galaxy-card[data-pos="center"] {
        transform: translate(-50%, -50%) scale(1.5);
      }
      .library-galaxy[data-reading-entry-state="opening"]
        .galaxy-card:not([data-pos="center"]) {
        transition: none;
      }
      .library-root:has(.library-galaxy[data-reading-entry-state="opening"])
        .knowledge-scene-background img {
        transition: none;
      }
    }

    /* Click-catcher only — covers the stage when a card is focused so
       a click anywhere outside the centered card closes the focus
       state. No visible fill / no blur layer: the focused card is its
       own focal point now (1.5× scale, larger artifact, layered text),
       and the wide blur was reading as a heavy panel behind the
       artifact rather than helping the focal lift. */
    .galaxy-backdrop {
      position: absolute;
      inset: 0;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      opacity: 0;
      pointer-events: none;
      z-index: 15;
    }
    .library-galaxy[data-galaxy-focused] .galaxy-backdrop {
      /* Stays invisible — only its hitbox matters. opacity:1 just lets
         pointer-events register; it has nothing to render. */
      opacity: 1;
      pointer-events: auto;
    }
    /* Focus state used to dim the centered PNG so the focused card
       read as the new focal point. With the galaxy now rendered as
       a full-viewport scene background, the `.galaxy-backdrop` blur+
       darken layer above the orbit already provides that focal lift,
       so no extra dimming is wired here. */

    /* Orbit rotation controls — chevron pair pinned to the bottom of
       the viewport (not the stage), so they sit clear of the orbit
       cards at every breakpoint and remain a large, easy click target.
       Each click bumps --orbit-rotation on the stage by ±360°/N, and
       CSS interpolates the resulting transform on every card
       simultaneously. The wrapper is a flex pill so the two buttons
       read as one control. */
    .galaxy-orbit-controls {
      /* Always pinned to the very bottom of the viewport on desktop
         too. Only the safe-area-inset-bottom is honored on top —
         same hard-edge anchoring as the mobile rule above. */
      position: fixed !important;
      inset-block-end: auto;
      bottom: env(safe-area-inset-bottom, 0px) !important;
      left: 0;
      right: 0;
      margin-inline: auto;
      display: flex;
      width: max-content;
      gap: 0.5rem;
      padding: 0.3125rem;
      border-radius: 999px;
      background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 55%, transparent);
      border: 1px solid color-mix(in srgb, var(--yuval-galaxy-border, #1a1a3a) 75%, transparent);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      z-index: 40;
      direction: ltr;
    }
    .galaxy-orbit-btn {
      width: 44px;
      height: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      color: var(--yuval-galaxy-text-soft);
      background: var(--yuval-galaxy-surface-muted);
      border: 1px solid var(--yuval-galaxy-border);
      cursor: pointer;
      padding: 0;
      transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    }
    .galaxy-orbit-btn:hover,
    .galaxy-orbit-btn:focus-visible {
      color: var(--yuval-galaxy-text);
      background: var(--yuval-galaxy-card-surface-hover);
      border-color: var(--yuval-galaxy-border-strong);
      transform: translateY(-1px);
      outline: none;
    }
    /* Mirror chevrons on RTL pages so "next" still points toward the
       direction reading flows. The stage itself is direction:ltr;
       only the icons need the manual flip. */
    [dir="rtl"] .galaxy-orbit-btn svg { transform: scaleX(-1); }

  }

  /* ── Wide desktop (≥1280px): wider orbit cards + larger orbit. ─── */
  @media (min-width: 1280px) {
    /* Larger orbit scene gets a deeper vertical offset so rotating
       cards along the wider ellipse still clear the page title.
       Wide desktop carries a slightly bigger orbit-ry (up to 250px
       vs the 1024-1279px tier's 230px), so the offset adds another
       +20px on top of the base desktop's new 90px to preserve the
       minimum ~20px top-card clearance Tomer requested. */
    .library-galaxy {
      --orbit-vertical-offset: 110px;
