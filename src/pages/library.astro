---
/**
 * /library — Living Library, static galaxy composition.
 *
 * Desktop (≥1024px) reshapes the page toward the visual reference:
 *
 *   ┌──────────────┬──────────────────────────┬──────────────┐
 *   │  LEFT RAIL   │      CENTER STAGE        │  RIGHT RAIL  │
 *   │              │                          │              │
 *   │  Continue    │  LibraryHero (centered)  │  AI rail     │
 *   │  KnowSpace   │  ┌──────────────────┐    │  (sticky,    │
 *   │  Stats       │  │  ⊙ ORBITS + CORE │    │   slim,      │
 *   │              │  │  + 6 floating    │    │   glassy)    │
 *   │              │  │    LibraryCards  │    │              │
 *   │              │  └──────────────────┘    │              │
 *   ├──────────────┴──────────────────────────┴──────────────┤
 *   │  Recent items grid (full center column on desktop)     │
 *   │  Recommendation strip (full width)                      │
 *   └─────────────────────────────────────────────────────────┘
 *
 * Mobile / tablet: same components stack vertically. The galaxy stage
 * collapses to a normal grid of cards — no absolute positioning, no
 * core, no orbits (display:none). This keeps the phone usable.
 *
 * Composition only. Card rendering, badges, status, hovers all live
 * inside their components. This page picks featured items, places
 * them in the stage, and styles the stage geometry — nothing else.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import LibraryHero from '../components/library/LibraryHero.astro';
import LibraryStatsPanel from '../components/library/LibraryStatsPanel.astro';
import ContinueReadingCard from '../components/library/ContinueReadingCard.astro';
import KnowledgeSpaceCard from '../components/library/KnowledgeSpaceCard.astro';
import LibraryCard from '../components/library/LibraryCard.astro';
import RecommendationStrip from '../components/library/RecommendationStrip.astro';
import LibraryQuickActions from '../components/library/LibraryQuickActions.astro';

import type { Language } from '../types/index';
import type { LibraryItem } from '../types/library';
import { DEFAULT_LANGUAGE, getLanguageDirection, isValidLanguage } from '../utils/language';
import { t } from '../i18n';
import {
  getMockLibraryItems,
  getLibraryStats,
  getRecentlyUpdatedItems,
  getContinueReadingItem,
  getRecommendedItems,
} from '../utils/library-catalog';

// ── Language ──────────────────────────────────────────────────────────────
interface Props {
  language?: Language;
}
const { language: propLanguage } = Astro.props;

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const requestedLanguage =
  (urlLang && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && isValidLanguage(propLanguage) ? propLanguage : DEFAULT_LANGUAGE);
const language = requestedLanguage as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

// ── Data (only this page calls catalog utilities — DI) ────────────────────
const items = getMockLibraryItems();
const stats = getLibraryStats(items);
const continueItem = getContinueReadingItem(items);
const recentItems = getRecentlyUpdatedItems(items, 6);
const recommendedItems = continueItem
  ? getRecommendedItems(items, continueItem.id, 6)
  : [];

// ── Featured items for the galaxy stage ───────────────────────────────────
// Pick 6 items by slug to match the visual reference: a course, three
// books, a course-lesson AI item, and an AI article. Skipped when an
// item is missing (defensive) — the stage shows whatever it finds.
const featuredSlugs = [
  'ai-engineering',                                       // course
  'Building-AI-Systems-with-MCP',                         // book — MCP
  'practical-python-for-ai-engineering',                  // book — Python
  'clean-code',                                           // book — Clean Code
  'Lesson-1-Introduction-To-AI-Engineering-and-Generative-AI', // course_lesson AI
  'mcp-tool-design',                                      // article — AI
];
const featuredItems: LibraryItem[] = featuredSlugs
  .map((slug) => items.find((it) => it.slug === slug))
  .filter((it): it is LibraryItem => Boolean(it));

// Pre-computed slot positions on desktop. Keeping this list as data
// (not in CSS) lets the markup loop stay generic — Open/Closed if the
// stage layout changes.
const FEATURED_SLOTS = [
  'galaxy-card-tl', 'galaxy-card-tr',
  'galaxy-card-ml', 'galaxy-card-mr',
  'galaxy-card-bl', 'galaxy-card-br',
];
---

<BaseLayout
  title={t('library.galaxy.title', language)}
  description={t('library.galaxy.subtitle', language)}
  language={language}
  availableLanguages={['he', 'en', 'es']}
  allowClientLanguageOverride={true}
  showHeader={true}
  showProgress={false}
>
  {/*
    .library-dark-showcase scopes --yuval-galaxy-* dark tokens to this
    subtree only. It does not touch html.dark, the user's global theme
    preference, or any other route. Header above remains controlled by
    the global theme — out of scope for this prompt.
  */}
  <div class="library-dark-showcase library-root" lang={language} dir={isRtl ? 'rtl' : 'ltr'}>

    {/* Decorative ambient backdrop. Aria-hidden, pointer-events:none. */}
    <div class="library-ambient" aria-hidden="true">
      <div class="library-aurora"></div>
    </div>

    <div class="library-body">

      {/* ── LEFT RAIL ─────────────────────────────────────────────── */}
      <aside class="library-col library-col-left">
        <ContinueReadingCard item={continueItem} language={language} />
        <KnowledgeSpaceCard language={language} />
        <LibraryStatsPanel stats={stats} language={language} />
      </aside>

      {/* ── CENTER STAGE ──────────────────────────────────────────── */}
      <div class="library-col library-col-center">

        <LibraryHero language={language} />

        {/*
          Galaxy stage. On desktop this becomes a tall canvas with the
          core centered, three concentric orbit rings, and 6 floating
          LibraryCards positioned around the core via .galaxy-card-*
          slot classes. On mobile it collapses to a simple vertical
          grid of cards (no core, no orbits — display:none).
        */}
        <div class="library-galaxy" aria-label={t('library.galaxy.welcome', language)}>

          {/* Decorative orbits + core (desktop only via CSS). */}
          <div class="galaxy-orbit galaxy-orbit-1" aria-hidden="true"></div>
          <div class="galaxy-orbit galaxy-orbit-2" aria-hidden="true"></div>
          <div class="galaxy-orbit galaxy-orbit-3" aria-hidden="true"></div>

          <div class="galaxy-core" aria-hidden="true">
            <div class="galaxy-core-aura"></div>
            <div class="galaxy-core-orb"></div>
            <div class="galaxy-core-node galaxy-core-node-1"></div>
            <div class="galaxy-core-node galaxy-core-node-2"></div>
            <div class="galaxy-core-node galaxy-core-node-3"></div>
          </div>

          {/* Floating cards. On mobile these are normal grid items;
              on desktop they jump to absolute positions via slot class. */}
          {featuredItems.map((item, i) => (
            <div class={`galaxy-card ${FEATURED_SLOTS[i] ?? ''}`}>
              <LibraryCard item={item} language={language} variant="compact" />
            </div>
          ))}
        </div>

        {/* Recent items — sits below the stage on desktop, normal grid */}
        <section class="library-section">
          <header class="library-section-header">
            <span class="library-section-dot library-section-dot-alt" aria-hidden="true"></span>
            <h2 class="library-section-title">{t('library.sort.recent', language)}</h2>
          </header>
          <div class="library-card-grid">
            {recentItems.map((item) => (
              <LibraryCard item={item} language={language} />
            ))}
          </div>
        </section>

      </div>

      {/* ── RIGHT RAIL ────────────────────────────────────────────── */}
      <div class="library-col library-col-right">
        <LibraryQuickActions language={language} />
      </div>

    </div>

    {/* ── Bottom recommendation strip — full body width ──────────── */}
    <RecommendationStrip items={recommendedItems} language={language} />

  </div>
</BaseLayout>

<style>
  /* ──────────────────────────────────────────────────────────────────
     Page-level shell + galaxy stage geometry.

     The stage is built from FOUR layers (z-order from back to front):
       0. Decorative orbits (1px borders, low opacity)
       1. Decorative core   (radial-gradient orb + aura + 3 nodes)
       2. Floating cards    (real LibraryCard, real link semantics)
       3. Hero text         (above the stage in the column)

     On mobile the stage is a normal flex column — orbits/core hidden,
     cards laid out as a vertical list. No absolute positioning.
     ────────────────────────────────────────────────────────────────── */

  .library-root {
    position: relative;
    min-height: 100vh;
    width: 100%;
    background-color: var(--yuval-galaxy-bg);
    background-image:
      var(--yuval-galaxy-bg-radial-primary),
      var(--yuval-galaxy-bg-radial-secondary);
    color: var(--yuval-galaxy-text);
    padding: 1.5rem 1rem 5rem;
    box-sizing: border-box;
    isolation: isolate;
    overflow: hidden;
  }

  /* Ambient backdrop layer */
  .library-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .library-aurora {
    position: absolute;
    inset-block-start: 8%;
    inset-inline-start: -10%;
    width: 120%;
    height: 280px;
    background: radial-gradient(ellipse at center,
      var(--yuval-galaxy-accent-cyan) 0%,
      transparent 65%);
    opacity: 0.10;
    filter: blur(60px);
  }
  .library-root > :not(.library-ambient) {
    position: relative;
    z-index: 1;
  }

  /* ── Body grid: mobile single column, desktop 3-column ─────────── */
  .library-body {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .library-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-width: 0;
  }

  /* ── Galaxy stage — mobile baseline (normal vertical flow) ─────── */
  .library-galaxy {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
    margin-block: 1rem 0;
  }
  /* Mobile: orbits and core are decorative-desktop-only */
  .galaxy-orbit, .galaxy-core { display: none; }

  /* ── Recent items section ──────────────────────────────────────── */
  .library-section {
    margin-block-start: 1.5rem;
    padding: 1.375rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-panel-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
  }
  .library-section-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.875rem;
  }
  .library-section-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--yuval-galaxy-accent-cyan);
    box-shadow: var(--yuval-galaxy-glow-soft);
  }
  .library-section-dot-alt {
    background-color: var(--yuval-galaxy-accent-purple);
    box-shadow: var(--yuval-galaxy-glow-secondary);
  }
  .library-section-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
    color: var(--yuval-galaxy-text-muted);
  }
  .library-card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }

  /* ── Tablet (≥640px): 2-up cards, more outer padding ───────────── */
  @media (min-width: 640px) {
    .library-root { padding: 2rem 1.5rem 5rem; }
    .library-card-grid,
    .library-galaxy {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* ── Desktop (≥1024px): 3-column rails + tall galaxy stage ─────── */
  @media (min-width: 1024px) {
    .library-root { padding: 2.5rem 2rem 6rem; }

    .library-body {
      grid-template-columns: 240px minmax(0, 1fr) 240px;
      gap: 1.5rem;
      align-items: start;
    }

    /* Each rail keeps a sane min-height anchor without forcing height. */
    .library-col-left,
    .library-col-right { min-height: 100%; }

    /*
      Galaxy stage becomes an absolute canvas. Height is intentional:
      tall enough for hero+core+cards to breathe, capped to keep the
      page navigable. The cards inside use absolute positioning per
      slot class below.
    */
    .library-galaxy {
      position: relative;
      display: block;
      height: 640px;
      margin-block: 1.25rem 0;
      /* Allow the floating cards to extend slightly outside the
         column without causing horizontal scroll — the page-level
         .library-root has overflow:hidden as the safety net. */
      overflow: visible;
    }

    /* ── Decorative orbit rings ─────────────────────────────────── */
    .galaxy-orbit {
      display: block;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      border: 1px solid var(--yuval-galaxy-border-strong);
      pointer-events: none;
    }
    .galaxy-orbit-1 { width: 320px; height: 320px; opacity: 0.45; }
    .galaxy-orbit-2 { width: 480px; height: 480px; opacity: 0.30;
                      border-color: var(--yuval-galaxy-border-glow); }
    .galaxy-orbit-3 { width: 640px; height: 640px; opacity: 0.18; }

    /* ── Central knowledge core ─────────────────────────────────── */
    .galaxy-core {
      display: block;
      position: absolute;
      top: 50%;
      left: 50%;
      width: 240px;
      height: 240px;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }
    .galaxy-core-aura {
      position: absolute;
      inset: -30px;
      border-radius: 50%;
      background: radial-gradient(circle,
        var(--yuval-galaxy-accent-purple) 0%,
        transparent 65%);
      opacity: 0.55;
      filter: blur(28px);
    }
    .galaxy-core-orb {
      position: absolute;
      inset: 25%;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%,
        var(--yuval-galaxy-accent-cyan) 0%,
        var(--yuval-galaxy-accent-purple) 70%);
      box-shadow: var(--yuval-galaxy-glow-core);
    }
    /* Three small "nodes" sitting on the inner orbit. Decorative
       only — they do not represent items. */
    .galaxy-core-node {
      position: absolute;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background-color: var(--yuval-galaxy-accent-cyan);
      box-shadow: var(--yuval-galaxy-glow-soft);
    }
    .galaxy-core-node-1 { top: -2%;   left: 50%; transform: translateX(-50%); }
    .galaxy-core-node-2 { top: 50%;   left: -2%; transform: translateY(-50%); }
    .galaxy-core-node-3 { top: 50%;   right: -2%; transform: translateY(-50%);
                          background-color: var(--yuval-galaxy-accent-purple); }

    /* ── Floating cards: 6 absolute slots around the core ───────── */
    .galaxy-card {
      position: absolute;
      width: 220px;
      transition:
        transform var(--yuval-galaxy-motion-normal) var(--yuval-galaxy-ease-out);
      z-index: 2;
    }
    /* Each slot defines position + tilt via a CSS variable so the
       hover/focus rule below can compose `rotate(var(--tilt)) translateY(-2px)`. */
    .galaxy-card-tl { top: 0;        inset-inline-start: 0;   --tilt: -4deg; transform: rotate(-4deg); }
    .galaxy-card-tr { top: 0;        inset-inline-end:   0;   --tilt:  4deg; transform: rotate( 4deg); }
    .galaxy-card-ml { top: 38%;      inset-inline-start: -2%; --tilt: -2deg; transform: rotate(-2deg); }
    .galaxy-card-mr { top: 42%;      inset-inline-end:   -2%; --tilt:  3deg; transform: rotate( 3deg); }
    .galaxy-card-bl { bottom: 0;     inset-inline-start: 12%; --tilt: -3deg; transform: rotate(-3deg); }
    .galaxy-card-br { bottom: 0;     inset-inline-end:   12%; --tilt:  3deg; transform: rotate( 3deg); }

    /* On hover/focus a floating card straightens slightly and lifts —
       reads as "this is real and interactive". Token-based motion. */
    .galaxy-card:hover,
    .galaxy-card:focus-within {
      transform: rotate(calc(var(--tilt) * 0.4)) translateY(-3px);
      z-index: 3;
    }
  }

  /* ── Wide desktop (≥1280px): bigger stage, wider cards ─────────── */
  @media (min-width: 1280px) {
    .library-body {
      grid-template-columns: 260px minmax(0, 1fr) 260px;
      gap: 1.75rem;
    }
    .library-galaxy {
      height: 720px;
    }
    .galaxy-card { width: 240px; }
    .galaxy-orbit-1 { width: 360px; height: 360px; }
    .galaxy-orbit-2 { width: 520px; height: 520px; }
    .galaxy-orbit-3 { width: 700px; height: 700px; }
    .galaxy-core    { width: 280px; height: 280px; }

    .library-card-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  /* ── Reduced motion: drop the hover transform animation ────────── */
  @media (prefers-reduced-motion: reduce) {
    .galaxy-card { transition: none; }
    .galaxy-card:hover,
    .galaxy-card:focus-within {
      /* Keep tilt at rest, no lift; the tilt itself is static, not
         animated, so this is just disabling the hover settle. */
      transform: rotate(var(--tilt, 0deg));
    }
  }
</style>
