---
// /library — kept as a stable URL for the many internal links that
// still point here (Header, sidebars, language selector, admin, etc.).
// The canonical Galaxy view now lives at /, so redirect there and
// preserve any ?lang= query so language choice survives the bounce.
const langParam = Astro.url.searchParams.get('lang');
const target = langParam ? `/?lang=${encodeURIComponent(langParam)}` : '/';
return Astro.redirect(target, 301);
---
