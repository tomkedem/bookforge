---
/**
 * /library — Living Library, dual layout.
 *
 *   MOBILE (<1024px) — vertical knowledge discovery flow:
 *     1. Compact hero            4. Stats (fixed)
 *     2. Featured carousel       5. Quick actions
 *     3. Continue reading (fixed)
 *
 *   DESKTOP (≥1024px) — single immersive dashboard viewport.
 *     ┌──────────┬──────────────────────────────┬──────────┐
 *     │ Continue │  Hero (floats over galaxy)   │          │
 *     │ Knowledge│  Galaxy stage (core + cards) │   Rail   │
 *     │ Stats    │  — large negative space      │  (pill)  │
 *     │          │    below the core            │          │
 *     └──────────┴──────────────────────────────┴──────────┘
 *
 *   Composition fits inside ~100dvh after the global header — no long
 *   stacked page on desktop.
 *
 * Same components, same data, same i18n. Only CSS varies by breakpoint.
 *
 * Featured items are filtered OUT of recent items so cards never appear
 * twice on a single screen.
 */

import LibraryLayout from '../layouts/LibraryLayout.astro';
import LibraryHero from '../components/library/LibraryHero.astro';
import LibraryStatsPanel from '../components/library/LibraryStatsPanel.astro';
import ContinueLearningCard from '../components/library/ContinueLearningCard.astro';
import LibraryCard from '../components/library/LibraryCard.astro';
import MobileGalaxyCarousel from '../components/library/MobileGalaxyCarousel.astro';
import LibraryQuickActions from '../components/library/LibraryQuickActions.astro';
import FloatingSidebar from '../components/library/FloatingSidebar.astro';

import type { Language } from '../types/index';
import { DEFAULT_LANGUAGE, getLanguageDirection, isValidLanguage } from '../utils/language';
import { t } from '../i18n';
import {
  getLibraryItems,
  getLibraryStats,
  getContinueReadingItem,
} from '../utils/library-catalog';
import { getCourseProgressList } from '../utils/library-adapter';
import { isReadableLibraryItem } from '../utils/library-display';

// ── Language ──────────────────────────────────────────────────────────────
const { language: propLanguage } = Astro.props as { language?: Language };

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const requestedLanguage =
  (urlLang && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && isValidLanguage(propLanguage) ? propLanguage : DEFAULT_LANGUAGE);
const language = requestedLanguage as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

// ── Data ──────────────────────────────────────────────────────────────────
// Primary source = real BookForge content (via library-adapter); falls
// back to mock when output/ is empty (CI / fresh checkout).
const items = getLibraryItems();
const stats = getLibraryStats(items);
// Per-course progress (X of Y lesson summaries available) — empty when
// no real catalog is in play (mock fallback returns []).
const courseProgress = getCourseProgressList();

// Continue ONLY considers readable items so that we never surface the
// synthetic ai-engineering course (no /courses route yet) as a
// clickable-looking suggestion.
const readableItems = items.filter(isReadableLibraryItem);
const continueItem = getContinueReadingItem(readableItems);

// ── Galaxy stage carousels ──────────────────────────────────────────────
// The orbit on desktop is split into two columns. Visual sides flip with
// page direction; --galaxy-dir handles the mirror in CSS:
//   inline-start side → books   (data-column="book")
//   inline-end side   → lessons (data-column="lesson")
// Each column shows up to VISIBLE_PER_COLUMN cards at a time. Items
// beyond that sit in a hidden "queue" and rotate in via the small
// pagination arrows next to each column. Click on a slot card brings it
// to a centered "focus" state with an explicit Open CTA — the central
// PNG dims behind it, a backdrop catches outside clicks.
//
// This is dynamic over `readableItems`. Adding a new book under output/
// automatically surfaces it here — no edit to this file required. The
// synthetic ai-engineering course meta (type 'course' with a /courses/
// href) is filtered out by `readableItems` already, so it never appears
// on the stage as a non-clickable tile.
const bookItems = readableItems.filter((it) => it.type === 'book');
const lessonItems = readableItems.filter((it) => it.type === 'course_lesson');
const VISIBLE_PER_COLUMN = 3;
const hasBookPagination = bookItems.length > VISIBLE_PER_COLUMN;
const hasLessonPagination = lessonItems.length > VISIBLE_PER_COLUMN;

// ── ContinueLearningCard data ─────────────────────────────────────────────
// Real values are derived from `continueItem` + `courseProgress`. Two modes:
//   - lesson mode: course title at top, "Lesson N" line, then the lesson
//     subtitle. Reached when continueItem is a course_lesson whose
//     courseSlug matches a known course in courseProgress.
//   - book mode: book title at top, blank metaLine1, subtitle as metaLine2.
// When continueItem is undefined (mock fallback), no props are passed and
// the component's own placeholder defaults render.
const isLesson =
  continueItem?.type === 'course_lesson' && Boolean(continueItem?.courseSlug);
const matchingCourse = isLesson
  ? courseProgress.find((c) => c.slug === continueItem!.courseSlug)
  : undefined;

let courseTitleForCard: string | undefined;
let metaLine1ForCard: string | undefined;
let metaLine2ForCard: string | undefined;

if (isLesson && matchingCourse && continueItem?.orderInSeries) {
  courseTitleForCard =
    matchingCourse.titles[language]
    ?? matchingCourse.titles.en
    ?? matchingCourse.titles.he
    ?? matchingCourse.slug;
  metaLine1ForCard = t('courses.lessonNumber', language, { n: continueItem.orderInSeries });
  metaLine2ForCard =
    continueItem.subtitles?.[language]
    ?? continueItem.subtitles?.en
    ?? continueItem.subtitles?.he
    ?? '';
} else if (continueItem) {
  courseTitleForCard =
    continueItem.titles?.[language]
    ?? continueItem.titles?.en
    ?? continueItem.titles?.he;
  metaLine1ForCard = '';
  metaLine2ForCard =
    continueItem.subtitles?.[language]
    ?? continueItem.subtitles?.en
    ?? continueItem.subtitles?.he
    ?? '';
}

---

<LibraryLayout
  title={t('library.galaxy.title', language)}
  description={t('library.galaxy.subtitle', language)}
  language={language}
  availableLanguages={['he', 'en', 'es']}
  allowClientLanguageOverride={true}
>
  <div
    class="library-dark-showcase library-root"
    lang={language}
    dir={isRtl ? 'rtl' : 'ltr'}
    style={`--page-direction: ${isRtl ? 'rtl' : 'ltr'};`}
  >

    {/* Cosmic scene background — full-viewport, fixed, behind every
        UI layer. The same galaxy PNG that used to sit centered inside
        the orbit stage now spans the entire screen so the dashboard
        feels embedded in an infinite knowledge universe. The radial
        overlay on top is a soft viewport-vignette that darkens the
        edges (improving contrast for the floating cards + side
        panels) while keeping the central glow undisturbed. */}
    <div class="knowledge-scene-background" aria-hidden="true">
      <img
        src="/assets/library/galaxy-stage-core-medium.png"
        alt=""
        decoding="async"
      />
      <div class="knowledge-scene-overlay"></div>
    </div>

    {/* Decorative ambient backdrop — starfield on top of the cosmic
        scene background. Stars stay crisp because they're a CSS
        gradient pattern that doesn't scale with the bg image. */}
    <div class="library-ambient" aria-hidden="true">
      <div class="library-starfield"></div>
    </div>

    <div class="library-body">

      {/* ── Center stage: hero floats over galaxy ── */}
      <main class="lb-area-stage">

        <div class="lb-area-hero">
          <LibraryHero language={language} />
        </div>

        {/*
          Mobile-only discovery slot. Lives directly inside .lb-area-stage
          so on mobile (where .lb-area-stage is display:contents) it
          becomes its own flex item of .library-body with explicit
          `order: 3` — placed right after the recommended starting card.
          Hidden on desktop, where the orbit stage below takes over.
        */}
        <div class="lb-area-mobile-discovery">
          <MobileGalaxyCarousel items={readableItems} language={language} />
        </div>

        <section class="lb-area-featured" aria-label={t('library.galaxy.welcome', language)}>
          <div
            class="library-galaxy"
            data-galaxy-stage
            style={`--galaxy-dir: ${isRtl ? -1 : 1};`}
          >

            {/* The galaxy PNG used to sit centered here as the stage's
                visual core. It now lives at the page root as a
                full-viewport scene background (`.knowledge-scene-background`
                above), so the orbit stage holds only the floating
                cards + backdrop. */}

            {/* Backdrop — appears only when a card is focused into the
                center. Click anywhere on it closes the focus state. */}
            <div class="galaxy-backdrop" data-galaxy-backdrop aria-hidden="true"></div>

            {/* Books column. Every readable book gets a card; the first
                VISIBLE_PER_COLUMN sit in slots 0/1/2, the rest start in
                "queue" (hidden). Pagination arrows below cycle the
                queue. data-pos is the single source of truth for state
                and is mutated by the page-level orbit script. */}
            {bookItems.map((item, i) => (
              <div
                class="galaxy-card"
                data-galaxy-card
                data-column="book"
                data-index={i}
                data-pos={i < VISIBLE_PER_COLUMN ? `slot-${i}` : 'queue'}
                inert={i < VISIBLE_PER_COLUMN ? undefined : true}
              >
                <LibraryCard item={item} language={language} variant="orbit" />
                <div class="galaxy-cta" aria-hidden="true">
                  <a
                    class="galaxy-cta-open"
                    href={item.href}
                    data-galaxy-cta-open
                  >{t('library.galaxy.openItem', language)}</a>
                  <button
                    type="button"
                    class="galaxy-cta-close"
                    data-galaxy-cta-close
                    aria-label={t('library.galaxy.closeItem', language)}
                  >×</button>
                </div>
              </div>
            ))}

            {/* Lessons column. Same machinery, opposite side of stage. */}
            {lessonItems.map((item, i) => (
              <div
                class="galaxy-card"
                data-galaxy-card
                data-column="lesson"
                data-index={i}
                data-pos={i < VISIBLE_PER_COLUMN ? `slot-${i}` : 'queue'}
                inert={i < VISIBLE_PER_COLUMN ? undefined : true}
              >
                <LibraryCard item={item} language={language} variant="orbit" />
                <div class="galaxy-cta" aria-hidden="true">
                  <a
                    class="galaxy-cta-open"
                    href={item.href}
                    data-galaxy-cta-open
                  >{t('library.galaxy.openItem', language)}</a>
                  <button
                    type="button"
                    class="galaxy-cta-close"
                    data-galaxy-cta-close
                    aria-label={t('library.galaxy.closeItem', language)}
                  >×</button>
                </div>
              </div>
            ))}

            {/* Pagination — one pair per column, only when count > 3.
                Buttons are square chips at the bottom of each column.
                Hidden on mobile (whole .library-galaxy is). */}
            {hasBookPagination && (
              <div class="galaxy-pager galaxy-pager-book" aria-hidden="false">
                <button
                  type="button"
                  class="galaxy-pager-btn"
                  data-galaxy-pager="book"
                  data-direction="prev"
                  aria-label={t('library.galaxy.prevBooks', language)}
                ><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
                <button
                  type="button"
                  class="galaxy-pager-btn"
                  data-galaxy-pager="book"
                  data-direction="next"
                  aria-label={t('library.galaxy.nextBooks', language)}
                ><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
              </div>
            )}
            {hasLessonPagination && (
              <div class="galaxy-pager galaxy-pager-lesson" aria-hidden="false">
                <button
                  type="button"
                  class="galaxy-pager-btn"
                  data-galaxy-pager="lesson"
                  data-direction="prev"
                  aria-label={t('library.galaxy.prevLessons', language)}
                ><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
                <button
                  type="button"
                  class="galaxy-pager-btn"
                  data-galaxy-pager="lesson"
                  data-direction="next"
                  aria-label={t('library.galaxy.nextLessons', language)}
                ><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
              </div>
            )}
          </div>
        </section>

      </main>

      {/* ── Mobile-only quick-actions panel ──
            Desktop is owned by <FloatingSidebar> below, which lives
            outside the grid as `position: fixed`. On mobile this aside
            stays as `display: contents` and contributes its child as a
            flex item of `.library-body` at order 6. */}
      <aside class="lb-area-right">
        <div class="lb-area-quick lb-area-quick-mobile">
          <LibraryQuickActions language={language} />
        </div>
      </aside>

    </div>

    {/* ── Desktop fixed support panels (≥769px) ──
          Both panels are `position: fixed` from inside their own
          component CSS, anchored to the inline-start edge of the
          viewport (right in RTL, left in LTR). Stacked: ContinueLearningCard
          above, LibraryStatsPanel below it. Hidden at ≤768px from inside
          each component. Live outside `.library-body` so they never
          claim a column or contribute to the grid. */}
    <ContinueLearningCard
      language={language}
      courseTitle={courseTitleForCard}
      metaLine1={metaLine1ForCard}
      metaLine2={metaLine2ForCard}
      lessonsAvailable={isLesson ? courseProgress[0]?.available : undefined}
      lessonsTotal={isLesson ? courseProgress[0]?.total : undefined}
      href={continueItem?.href}
    />
    <LibraryStatsPanel stats={stats} language={language} courseProgress={courseProgress} />

    {/* ── Desktop floating rail (≥769px) ──
          Pinned to the inline-end edge via `position: fixed` from the
          component itself; sits outside the grid so it never claims a
          column. Hidden at ≤768px — mobile is served by the aside above. */}
    <FloatingSidebar
      language={language}
      aiAssistantHref="#ai-assistant"
      bookmarksHref="#bookmarks"
      historyHref="#history"
    />

  </div>
</LibraryLayout>

<style>
  /* ──────────────────────────────────────────────────────────────────
     /library — page shell + galaxy stage geometry
     Hard rules:
       - All colour/effect via --yuval-galaxy-*  (no hex anywhere)
       - All visible text via t()
       - RTL via inset-inline-* (logical properties)
     ────────────────────────────────────────────────────────────────── */

  .library-root {
    position: relative;
    min-height: 100vh;
    width: 100%;
    /* Whole-screen unified backdrop. Mobile uses the two main layers;
       desktop adds side accents + vignette so the entire dashboard
       (sidebar + center + rail + recs) reads as one cosmic field.

       Background-color sampled directly from the dark outer pixels of
       galaxy-stage-core-medium.png (corners read RGB(0,1,13)). The
       earlier #0a0a1f estimate was ~3× brighter than reality and left
       a visible seam between the image edges and the page. With the
       sampled value, the image's outer dark pixels are continuous
       with the page bg. Scoped to .library-root via Astro style
       scoping — does not affect any other route. */
    background-color: #00010d;
    background-image:
      var(--yuval-galaxy-bg-radial-primary),
      var(--yuval-galaxy-bg-radial-secondary);
    color: var(--yuval-galaxy-text);
    padding: 1rem 1rem 4rem;
    box-sizing: border-box;
    isolation: isolate;
    overflow-x: hidden;
  }

  /* ── Cosmic scene background — full-viewport fixed layer ─────────
     This is the global "knowledge universe" canvas. It is anchored
     to the viewport (not the page) so it never scrolls out, never
     leaves visible margins, and is never clipped by sidebars or the
     stats panel. Every UI layer (hero, orbit, side panels, rail)
     stacks on top via `position: relative; z-index: 1` (see the
     `.library-root > :not(...)` rule below). */
  .knowledge-scene-background {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .knowledge-scene-background img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    user-select: none;
    -webkit-user-drag: none;
  }
  /* Soft radial vignette — keeps the central glow untouched and
     darkens only the edges so floating cards + side panels read
     cleanly against the bg without losing the cosmic atmosphere. */
  .knowledge-scene-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 0%,
      transparent 35%,
      rgba(0, 0, 0, 0.45) 80%,
      rgba(0, 0, 0, 0.65) 100%);
  }

  /* Ambient backdrop — sits ABOVE the scene background, BELOW the UI.
     Self-contained starfield. */
  .library-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  /* `.library-aurora` and `.library-nebula-*` rules removed: their
     markup nodes were retired when the unified page-level backdrop
     system in `.library-root` took over atmospheric coloring. */
  /* Starfield — a CSS-only matrix of tiny bright pixels rendered as
     a single repeating radial-gradient pattern. No DOM nodes, no JS.
     Two layers (small + medium) at slightly different offsets for
     parallax-like depth. */
  .library-starfield {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 12%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 65% 24%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 35% 38%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 82% 47%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 12% 58%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 73% 67%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 28% 78%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 88% 88%, var(--yuval-galaxy-text) 50%, transparent 100%),
      /* Accent stars — all violet now. Cyan accents were swapped to
         purple to align with the page's violet-led palette and avoid
         out-of-key cyan dots on the cosmic field. */
      radial-gradient(1.5px 1.5px at 50% 18%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 92% 32%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 8% 72%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 58% 92%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%);
    opacity: 0.40;
  }
  .library-root > :not(.library-ambient):not(.knowledge-scene-background) {
    position: relative;
    z-index: 1;
  }

  /* ── Mobile baseline: linear stack, ordered to the spec.
        The desktop wrapper aside/main elements are passthrough on mobile —
        their children unfurl in the natural document order, then `order:`
        re-shuffles them into the discovery sequence. ─────────────────── */
  .library-body {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* On mobile the wrapper aside/main elements are not layout containers;
     reset their flex behaviour and let their children act as siblings. */
  .lb-area-stage,
  .lb-area-right {
    display: contents;
  }

  /* Mobile order — discovery-first.
       1 hero
       2 mobile-discovery (MobileGalaxyCarousel — readable AI content)
       6 quick actions
     ContinueLearningCard + LibraryStatsPanel are now position: fixed
     and hidden on mobile (≤768px) from inside each component, so they
     no longer participate in this flex chain.
     The desktop-only `.lb-area-featured` is hidden on mobile via
     `display: none` below. */
  .lb-area-hero              { order: 1; }
  .lb-area-mobile-discovery  { order: 2; display: block; width: 100%; }
  .lb-area-quick-mobile      { order: 6; }

  /* Desktop-only slots — completely hidden on mobile so they cannot
     contribute to layout, height, or accidental visibility. */
  .lb-area-featured     { display: none; }

  /* ── Tablet (≥640px): same mobile flow, more padding ── */
  @media (min-width: 640px) {
    .library-root { padding: 1.75rem 1.5rem 4rem; }
  }

  /* ── Desktop (≥1024px): ONE viewport dashboard, no long scroll ───── */
  @media (min-width: 1024px) {
    .library-root {
      /* Block padding owns top/bottom rhythm. Inline padding is
         SYMMETRIC so `.library-body` (max-width + margin: 0 auto)
         centers ITSELF on the viewport — that gives the galaxy core
         (which sits at the visual center of the body) a perfectly
         viewport-centered anchor. The clamp value also clears the
         FloatingSidebar at the inline-end side (rail width ~92px
         + ~16px gap from edge). Independent from this: the two
         support panels (ContinueLearningCard + LibraryStatsPanel)
         are `position: fixed` from inside their own components and
         anchor directly to the viewport edge via `inset-inline-start: 20px`,
         so their 20px gap stays constant regardless of this padding. */
      padding-block-start: 1.25rem;
      padding-block-end: 1.5rem;
      padding-inline: clamp(60px, 8vw, 120px);
      /* Viewport math is owned by LibraryLayout — the layout sets
         --library-dashboard-min-height = calc(100dvh - --library-header-offset)
         on the slot wrapper, so the page does not have to know the
         header's pixel height. */
      min-height: var(--library-dashboard-min-height, 100dvh);
      /* Desktop layered backdrop, FIRST listed = TOP of the stack.
         Calibrated to the sampled asset palette: every layer either
         uses one of the sampled navy tones or stays a small violet
         accent centered on the stage. Hero + side accents were
         removed (asset isn't violet there).
         1. vignette        — corner darkening with sampled #000010
         2. primary accent  — small violet halo at the stage center
         3. secondary fade  — bottom navy continuation (#000010)
         The base color var(--yuval-galaxy-bg) (#01051b) sits beneath. */
      background-image:
        var(--yuval-galaxy-bg-vignette),
        var(--yuval-galaxy-bg-radial-primary),
        var(--yuval-galaxy-bg-radial-secondary);
    }

    /* Full-page atmospheric underlay removed: it placed a blurred copy
       of the asset under the whole page, which created a non-uniform
       halo right under where the central image sits — the eye then
       read the contrast between halo-area and rest as a rectangle
       outline, even after the asset's edges were faded. The flat
       page-bg color (#0a0a1f on .library-root above) plus the
       existing radial gradients + vignette are now the only
       atmospheric layers. */

    /* Re-enable real flex container on the center stage main.
       `.lb-area-right` stays as `display: contents` (inherited from the
       mobile baseline) — its only child `.lb-area-quick-mobile` is
       `display: none` on desktop, so the aside contributes nothing
       to the grid. The desktop floating rail lives outside the grid
       entirely (`<FloatingSidebar>` with `position: fixed`). The two
       support panels (ContinueLearningCard + LibraryStatsPanel) also
       live outside the grid via `position: fixed` from inside their
       own components. */
    .lb-area-stage {
      display: flex;
      flex-direction: column;
    }

    /* Reset mobile order — explicit grid placement takes over. */
    .lb-area-hero,
    .lb-area-featured,
    .lb-area-quick-mobile { order: initial; }

    /* Mobile-only discovery slot is hidden on desktop — the orbit
       stage in .lb-area-featured takes over there. */
    .lb-area-mobile-discovery { display: none; }

    /* Re-enable the desktop-only slot that was hidden on mobile. */
    .lb-area-featured     { display: block; }

    /* 2-column dashboard with LANGUAGE-AWARE column placement:
         column 1 = inline-start  → outer support sidebar (continue +
                                    stats), on the side WHERE reading
                                    starts (visual-right in RTL Hebrew,
                                    visual-left in LTR English)
         column 2 = inline-end    → galaxy stage (center of the page),
                                    on the side opposite to where the
                                    document flow starts
       The narrow rail no longer claims a grid column — the desktop
       FloatingSidebar lives outside the grid as `position: fixed`,
       pinned to the inline-end edge of the viewport. The body adds
       a `padding-inline-end` gutter so the support sidebar doesn't
       collide with the floating rail.
       In LTR: support is visual-left, floating rail is visual-right
               (stage sits between sidebar and rail).
       In RTL: support is visual-right, floating rail is visual-left
               (same relationship, mirrored).
       No physical-direction lock. Grid resolves natively to the
       page's `dir` attribute. */
    .library-body {
      /* Single-column body — the two support panels are taken OUT of
         the body's flow (each is `position: fixed` from inside its
         own component CSS). No inline padding here: the SYMMETRIC
         inline padding lives on `.library-root` instead, so the body's
         max-width + margin: 0 auto centers it perfectly on the
         viewport. The galaxy core (image centered at left:50% of
         `.library-galaxy` inside the body) thus lands exactly at the
         viewport's center — independent of where the fixed support
         panels sit. */
      display: block;
      min-height: calc(var(--library-dashboard-min-height, 100dvh) - 2.75rem);
      max-width: 1440px;
      margin: 0 auto;
      padding: 0;
    }
    /* Galaxy stage still uses physical left/right for the absolute
       orbit slots so the TL/TR/ML/MR/BL/BR placement of the floating
       cards is language-independent (the slots target visual corners,
       not reading-flow corners). Cards inside re-apply page direction
       so Hebrew titles still read RTL. */
    .library-galaxy { direction: ltr; }
    .galaxy-card    { direction: var(--page-direction, ltr); }

    /* The two support panels (ContinueLearningCard + LibraryStatsPanel)
       are anchored individually via `position: fixed` from inside
       their own component CSS (inset-inline-start: 20px,
       top: header-offset + 20px, stacked via --continue-learning-card-height).
       No wrapper needed here. */

    /* ── Center stage: hero + galaxy ──────────────────────────────── */
    .lb-area-stage {
      /* Zero stage-gap: the hero now lives as the title strip of the
         galaxy, not a separate block. .galaxy-stage provides its own
         interior padding for the orbits. */
      gap: 0;
      min-width: 0;
      position: relative;
      /* No background layer here. The page-level unified system
         (--yuval-galaxy-bg-radial-primary on .library-root) is centered
         right under this column and provides the violet field for both
         hero and stage. Adding a column-level layer here used to
         compound the violet and produce a "block within a block" feel. */
    }
    .lb-area-hero {
      flex: 0 0 auto;
      max-width: 680px;
      margin-inline: auto;
      width: 100%;
    }
    /* Galaxy stage takes the remaining vertical space — with the
       recommendations strip removed, the orbit owns the entire lower
       half of the viewport so the central knowledge core can breathe. */
    .lb-area-featured {
      flex: 1 1 auto;
      min-height: 0;
      position: relative;
    }

    /* ── Mobile quick-actions aside: hidden on desktop ──
       The aside stays as `display: contents` (mobile baseline). Its
       only child `.lb-area-quick-mobile` is `display: none` on desktop,
       so the aside contributes nothing visible to the grid. The
       desktop floating rail is `<FloatingSidebar>` rendered outside
       `.library-body` with `position: fixed`. */
    .lb-area-quick-mobile { display: none; }

    /* Galaxy stage on desktop: absolute canvas anchored to the stage.
       Min-height bumped to 540 so the ML/MR orbit cards have enough
       vertical room not to overlap the central core at the narrowest
       desktop widths (1024-1199px).

       Background tuned to match the asset palette: a soft violet
       radial glow at the center fading to the page's deep navy at
       the edges. This is the primary fix for the "rectangle pasted
       in" look — the stage no longer has hard color contrast where
       the asset ends; the violet center seamlessly continues the
       asset's own glow, and the dark edges seamlessly continue the
       page background. */
    .library-galaxy {
      position: relative;
      display: block;
      height: 100%;
      min-height: 540px;
      margin: 0;
      overflow: visible;
      flex-direction: initial;
      scroll-snap-type: none;
      padding: 0;
      scrollbar-width: auto;
      scrollbar-color: auto;
    }
    /* The earlier `.library-galaxy::before` underlay halo and
       `.galaxy-stage-veil` overlay were experimental edge-blending
       layers. Both removed: the new full-page actual-asset underlay
       on `.library-root::before` propagates the asset's visual
       language across the entire screen, so per-asset edge blending
       layers are no longer necessary. */
    .library-galaxy::-webkit-scrollbar { height: auto; }

    /* `.galaxy-core` and its child rules (.galaxy-core-pool,
       .galaxy-core-aura) were removed alongside their markup nodes:
       they were sized for a 240×240 CSS-rendered core, but the asset
       is 760-820px wide and covered them entirely. They contributed
       nothing visible. The asset + page-level unified backdrop is
       the entire central composition. */

    /* The galaxy PNG no longer lives inside the orbit stage; it is
       now rendered once at the page root as `.knowledge-scene-background`
       (full-viewport fixed). Edge mask, max-width, focus-dim and
       reduced-motion rules that targeted `.galaxy-stage-image` were
       removed alongside the markup. */

    /* ── Floating cards: dynamic carousel.
          Cards live at the stage center (top:50%, left:50%) and are
          shifted into one of three slot anchor points per column via
          `left`/`top` percentages. --galaxy-dir flips the X sign so
          the books column stays on the inline-start side regardless
          of page direction (visual-right in RTL Hebrew, visual-left
          in LTR English). N>3 cards are routed to the hidden "queue"
          state and rotate into slots via the pager arrows. */
    .galaxy-card {
      position: absolute;
      flex: initial;
      max-width: none;
      width: 220px;
      cursor: pointer;
      /* Animate position (left/top) AND the composite transform
         together so the click-to-center flight reads as one motion. */
      transition:
        left 0.5s cubic-bezier(0.4, 0, 0.2, 1),
        top  0.5s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.3s ease;
      z-index: 2;
      /* Composite transform: center + slot rotation + slot depth scale.
         --slot-scale defaults to 1 so cards without a per-slot rule
         (queue / center) still render correctly. */
      transform: translate(-50%, -50%) rotate(var(--tilt, 0deg)) scale(var(--slot-scale, 1));
      opacity: var(--slot-opacity, 1);
      will-change: transform, left, top, opacity;
    }

    /* Per-slot variation rules.
       Each of the six visible slots carries its own:
         - position (some pulled tighter to the core, others held back)
         - rotation (alternating tilts so no two adjacent cards mirror)
         - scale + opacity (depth: front cards bigger/brighter, back
           cards slightly smaller and softer so the central scene
           background stays readable)
         - --card-accent-slot (a unique glow hue rotation across the
           palette). Each .galaxy-card composes this with its --tilt
           via the shared transform on `.galaxy-card`.

       Tighter-orbit slots (book-0, lesson-2) sit at 26% from the
       center; the rest stay at 32%/36% so the composition has visible
       depth instead of a flat ring. The 6th outer accent uses the
       lavender/cyan/gold/mint/magenta/blue rotation defined in
       galaxy.css — calling them by name keeps the palette token-
       driven (no hex here).

       --galaxy-dir is +1 in LTR (visual-left) and -1 in RTL
       (visual-right); books column stays on the inline-start side. */

    /* Books column — inline-start side. */
    .galaxy-card[data-column="book"][data-pos="slot-0"] {
      left: calc(50% - (26% * var(--galaxy-dir, 1)));
      top: 16%;
      --tilt: calc(-6deg * var(--galaxy-dir, 1));
      --slot-scale: 1;
      --slot-opacity: 1;
      --card-accent-slot: var(--yuval-galaxy-accent-gold);
    }
    .galaxy-card[data-column="book"][data-pos="slot-1"] {
      left: calc(50% - (36% * var(--galaxy-dir, 1)));
      top: 50%;
      --tilt: calc(-1deg * var(--galaxy-dir, 1));
      --slot-scale: 0.96;
      --slot-opacity: 0.94;
      --card-accent-slot: var(--yuval-galaxy-accent-purple);
    }
    .galaxy-card[data-column="book"][data-pos="slot-2"] {
      left: calc(50% - (30% * var(--galaxy-dir, 1)));
      top: 84%;
      --tilt: calc(-4deg * var(--galaxy-dir, 1));
      --slot-scale: 0.92;
      --slot-opacity: 0.88;
      --card-accent-slot: var(--yuval-galaxy-accent-blue);
    }
    /* Lessons column — inline-end side. */
    .galaxy-card[data-column="lesson"][data-pos="slot-0"] {
      left: calc(50% + (32% * var(--galaxy-dir, 1)));
      top: 18%;
      --tilt: calc(4deg * var(--galaxy-dir, 1));
      --slot-scale: 0.95;
      --slot-opacity: 0.92;
      --card-accent-slot: var(--yuval-galaxy-type-lesson_summary);
    }
    .galaxy-card[data-column="lesson"][data-pos="slot-1"] {
      left: calc(50% + (36% * var(--galaxy-dir, 1)));
      top: 50%;
      --tilt: calc(2deg * var(--galaxy-dir, 1));
      --slot-scale: 1;
      --slot-opacity: 1;
      --card-accent-slot: var(--yuval-galaxy-type-series);
    }
    .galaxy-card[data-column="lesson"][data-pos="slot-2"] {
      left: calc(50% + (26% * var(--galaxy-dir, 1)));
      top: 82%;
      --tilt: calc(5deg * var(--galaxy-dir, 1));
      --slot-scale: 0.94;
      --slot-opacity: 0.9;
      --card-accent-slot: var(--yuval-galaxy-accent-cyan);
    }

    /* Queue — collapsed at center, transparent, no pointer events.
       Cards stay in the DOM so the pager can rotate them into slots
       without re-rendering. */
    .galaxy-card[data-pos="queue"] {
      left: 50%;
      top: 50%;
      --tilt: 0deg;
      transform: translate(-50%, -50%) scale(0.6);
      opacity: 0;
      pointer-events: none;
      z-index: 1;
    }

    /* Centered focus state — card flies to the middle, scales up,
       drops its tilt, sits above the dimmed PNG and the backdrop. */
    .galaxy-card[data-pos="center"] {
      left: 50%;
      top: 50%;
      --tilt: 0deg;
      transform: translate(-50%, -50%) scale(1.35);
      z-index: 30;
      cursor: default;
    }

    .galaxy-card:hover:not([data-pos="queue"]):not([data-pos="center"]),
    .galaxy-card:focus-visible:not([data-pos="queue"]):not([data-pos="center"]) {
      /* On hover the slot's depth-scale gives a small extra lift so the
         back cards still feel like they push forward (not just brighten). */
      transform:
        translate(-50%, -50%)
        rotate(calc(var(--tilt, 0deg) * 0.4))
        translateY(-3px)
        scale(calc(var(--slot-scale, 1) * 1.04));
      opacity: 1;
      z-index: 3;
    }
    .galaxy-card:focus-visible {
      outline: none;
    }

    /* CTA overlay — hidden when card is in slot/queue; revealed only
       when data-pos="center". Children stop click propagation so the
       card-level handler never fires for Open/Close. */
    .galaxy-cta {
      position: absolute;
      inset-inline: 0;
      inset-block-end: -3.25rem;
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      align-items: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease 0.15s;
    }
    .galaxy-card[data-pos="center"] .galaxy-cta {
      opacity: 1;
      pointer-events: auto;
    }
    .galaxy-cta-open {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.5rem 1.125rem;
      border-radius: 999px;
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--yuval-galaxy-bg, #00010d);
      background: var(--yuval-galaxy-accent, #5eead4);
      border: 1px solid color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 70%, transparent);
      box-shadow: 0 6px 20px -6px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 60%, transparent);
      text-decoration: none;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .galaxy-cta-open:hover,
    .galaxy-cta-open:focus-visible {
      transform: translateY(-1px);
      box-shadow: 0 10px 24px -6px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 75%, transparent);
      outline: none;
    }
    .galaxy-cta-close {
      width: 28px;
      height: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      font-size: 1.125rem;
      line-height: 1;
      color: var(--yuval-galaxy-text-muted);
      background: var(--yuval-galaxy-surface-muted);
      border: 1px solid var(--yuval-galaxy-border);
      cursor: pointer;
      padding: 0;
      transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
    }
    .galaxy-cta-close:hover,
    .galaxy-cta-close:focus-visible {
      color: var(--yuval-galaxy-text);
      background: var(--yuval-galaxy-card-surface-hover);
      border-color: var(--yuval-galaxy-border-strong);
      outline: none;
    }

    /* Backdrop — covers the stage when a card is focused. Click closes. */
    .galaxy-backdrop {
      position: absolute;
      inset: 0;
      background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 65%, transparent);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      opacity: 0;
      pointer-events: none;
      z-index: 15;
      transition: opacity 0.3s ease;
    }
    .library-galaxy[data-galaxy-focused] .galaxy-backdrop {
      opacity: 1;
      pointer-events: auto;
    }
    /* Focus state used to dim the centered PNG so the focused card
       read as the new focal point. With the galaxy now rendered as
       a full-viewport scene background, the `.galaxy-backdrop` blur+
       darken layer above the orbit already provides that focal lift,
       so no extra dimming is wired here. */

    /* Pagination chips — one pair per column, anchored to the bottom
       inline-start / inline-end corners of the stage. The wrapper isn't
       rendered when the column has ≤VISIBLE_PER_COLUMN items. */
    .galaxy-pager {
      position: absolute;
      inset-block-end: -1.5rem;
      display: flex;
      gap: 0.375rem;
      z-index: 4;
    }
    .galaxy-pager-book   { inset-inline-start: 4%; }
    .galaxy-pager-lesson { inset-inline-end:   4%; }
    .galaxy-pager-btn {
      width: 32px;
      height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      color: var(--yuval-galaxy-text-soft);
      background: var(--yuval-galaxy-surface-muted);
      border: 1px solid var(--yuval-galaxy-border);
      cursor: pointer;
      padding: 0;
      transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    }
    .galaxy-pager-btn:hover:not(:disabled),
    .galaxy-pager-btn:focus-visible:not(:disabled) {
      color: var(--yuval-galaxy-text);
      background: var(--yuval-galaxy-card-surface-hover);
      border-color: var(--yuval-galaxy-border-strong);
      transform: translateY(-1px);
      outline: none;
    }
    .galaxy-pager-btn:disabled {
      opacity: 0.35;
      cursor: not-allowed;
    }
    /* Mirror chevrons on RTL pages so "next" still points toward where
       new items come from. The stage itself is direction:ltr; only the
       icons need the manual flip. */
    [dir="rtl"] .galaxy-pager-btn svg { transform: scaleX(-1); }
  }

  /* ── Wide desktop (≥1280px): wider orbit cards. ─── */
  @media (min-width: 1280px) {
    .galaxy-card { width: 240px; }
  }

  /* ── Reduced motion — drop transitions, keep state changes instant ── */
  @media (prefers-reduced-motion: reduce) {
    .galaxy-card,
    .galaxy-cta,
    .galaxy-backdrop,
    .galaxy-pager-btn { transition: none; }
    .galaxy-card:hover:not([data-pos="queue"]):not([data-pos="center"]),
    .galaxy-card:focus-visible:not([data-pos="queue"]):not([data-pos="center"]) {
      transform: translate(-50%, -50%) rotate(var(--tilt, 0deg)) scale(var(--slot-scale, 1));
    }
  }
</style>

<script>
  /**
   * Galaxy stage interactions — click-to-center carousel.
   *
   * Pure DOM machinery, no framework. Runs once per page load. State
   * lives entirely on data-attributes (data-pos / data-galaxy-focused),
   * which is what the CSS reads — no inline styles, no React/Astro
   * round-trips.
   *
   * Per-column state is the offset into a sorted item list. Slot N
   * displays item at (offset + N). Items outside [offset, offset+3) get
   * data-pos="queue" and are visually collapsed at center with opacity 0.
   *
   * Click on a slot card  → that card becomes data-pos="center", stage
   *                         gets [data-galaxy-focused] (CSS shows the
   *                         backdrop and dims the central PNG).
   * Click on backdrop / × → return centered card to its previous slot.
   * Esc                   → same.
   * Click on Open CTA     → propagate normally; the <a> navigates.
   * Pager prev/next       → recompute data-pos for every card in that
   *                         column based on the new offset.
   */
  (() => {
    const VISIBLE = 3;

    /** Scope every operation to a single stage. The page only renders
     *  one stage today, but coding it like a component keeps it safe
     *  if `/library` ever embeds two. */
    function initStage(stage: HTMLElement) {
      const cards = Array.from(
        stage.querySelectorAll<HTMLElement>('[data-galaxy-card]'),
      );

      // Column → sorted card list (by data-index). Cards rendered with
      // higher data-index are later in the queue.
      const byColumn: Record<string, HTMLElement[]> = { book: [], lesson: [] };
      for (const card of cards) {
        const col = card.dataset.column;
        if (col === 'book' || col === 'lesson') byColumn[col].push(card);
      }
      for (const col of Object.keys(byColumn)) {
        byColumn[col].sort(
          (a, b) => Number(a.dataset.index) - Number(b.dataset.index),
        );
      }

      // Per-column carousel offset (start index for the visible window).
      const offset: Record<string, number> = { book: 0, lesson: 0 };
      // Card currently in center, plus the slot it returns to on close.
      let focused: { card: HTMLElement; column: string; slot: number } | null = null;

      // Apply offset → set data-pos for every card in the column. Cards
      // currently in "center" are skipped so a paginate doesn't yank a
      // focused card back to a slot mid-flight.
      function applyColumn(column: string) {
        const list = byColumn[column];
        const off = offset[column];
        for (let i = 0; i < list.length; i++) {
          const card = list[i];
          if (focused && focused.card === card) continue;
          const slot = i - off;
          if (slot >= 0 && slot < VISIBLE) {
            card.dataset.pos = `slot-${slot}`;
            card.removeAttribute('inert');
          } else {
            card.dataset.pos = 'queue';
            card.setAttribute('inert', '');
          }
        }
        updatePagerDisabled(column);
      }

      function updatePagerDisabled(column: string) {
        const list = byColumn[column];
        const max = Math.max(0, list.length - VISIBLE);
        const buttons = stage.querySelectorAll<HTMLButtonElement>(
          `[data-galaxy-pager="${column}"]`,
        );
        for (const btn of buttons) {
          const dir = btn.dataset.direction;
          if (dir === 'prev') btn.disabled = offset[column] <= 0;
          else if (dir === 'next') btn.disabled = offset[column] >= max;
        }
      }

      function openCenter(card: HTMLElement) {
        if (focused && focused.card === card) return;
        if (focused) closeCenter();
        const column = card.dataset.column;
        if (!column) return;
        // Slot index relative to the column at the time of click.
        const list = byColumn[column];
        const idx = list.indexOf(card);
        const slot = idx - offset[column];
        focused = { card, column, slot };
        card.dataset.pos = 'center';
        stage.dataset.galaxyFocused = 'true';
      }

      function closeCenter() {
        if (!focused) return;
        const { card, column, slot } = focused;
        // Restore the card to a slot only if its slot is still in the
        // visible window. Otherwise it returns to the queue.
        if (slot >= 0 && slot < VISIBLE) {
          card.dataset.pos = `slot-${slot}`;
          card.removeAttribute('inert');
        } else {
          card.dataset.pos = 'queue';
          card.setAttribute('inert', '');
        }
        focused = null;
        delete stage.dataset.galaxyFocused;
        // Also re-apply the column in case the offset moved while the
        // card was centered (pager click while focused first closes,
        // then advances — but defensive replay is cheap).
        applyColumn(column);
      }

      // Card click — capture phase so we beat the inner <a>'s native
      // navigation. We preventDefault unless the click came from the
      // Open CTA (which carries [data-galaxy-cta-open]).
      stage.addEventListener('click', (e) => {
        const target = e.target as Element | null;
        if (!target) return;

        // Open CTA — let it navigate.
        if (target.closest('[data-galaxy-cta-open]')) return;

        // Close button.
        if (target.closest('[data-galaxy-cta-close]')) {
          e.preventDefault();
          closeCenter();
          return;
        }

        // Backdrop.
        if (target.closest('[data-galaxy-backdrop]')) {
          e.preventDefault();
          closeCenter();
          return;
        }

        // Pager.
        const pagerBtn = target.closest<HTMLButtonElement>('[data-galaxy-pager]');
        if (pagerBtn) {
          e.preventDefault();
          const column = pagerBtn.dataset.galaxyPager!;
          const dir = pagerBtn.dataset.direction;
          const max = Math.max(0, byColumn[column].length - VISIBLE);
          if (dir === 'next') offset[column] = Math.min(max, offset[column] + 1);
          else if (dir === 'prev') offset[column] = Math.max(0, offset[column] - 1);
          // If something is centered when the user paginates, close it.
          if (focused && focused.column === column) closeCenter();
          applyColumn(column);
          return;
        }

        // Card click.
        const card = target.closest<HTMLElement>('[data-galaxy-card]');
        if (!card) return;
        // The inner LibraryCard renders an <a>. We swallow that nav and
        // run our own behavior instead.
        e.preventDefault();
        if (card.dataset.pos === 'center') {
          // Click on card body while focused = close (acts as a second
          // tap to dismiss the spotlight). The Open CTA is the only way
          // to actually navigate.
          closeCenter();
        } else if (card.dataset.pos !== 'queue') {
          openCenter(card);
        }
      }, true);

      // Keyboard: Enter on the inner <a> bubbles up as a click and is
      // handled by the click listener above (preventDefault + open).
      // We only need Esc here to close a focused card. Document-level
      // because focus may be on the close button or open CTA when Esc
      // is pressed, both of which sit inside the stage.
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && focused) closeCenter();
      });

      // Initialize disabled state for pagers (starting offsets are 0).
      updatePagerDisabled('book');
      updatePagerDisabled('lesson');
    }

    document.querySelectorAll<HTMLElement>('[data-galaxy-stage]').forEach(initStage);

    /**
     * Hydrate orbit-card progress bars from localStorage.
     *
     * Reading progress is stored per-chapter as
     *   yuval_reading_progress_{bookSlug}_ch{n}
     * with a `percentage` field (see scripts/progress-tracker.ts).
     * Book-level progress on the orbit card is the average percentage
     * across all chapters [1..chapterCount]; chapters with no entry
     * count as 0%, so a brand-new book reads 0% — never "no data".
     *
     * SSR ships every bar at 0%; this hydrator updates the
     * `--progress` CSS variable + the inline percentage text. Bars
     * with chapterCount=0 (defensive) are left at 0% as well.
     */
    function hydrateOrbitProgress() {
      const bars = document.querySelectorAll<HTMLElement>('[data-orbit-progress]');
      bars.forEach((bar) => {
        const slug = bar.dataset.bookSlug;
        const total = Number(bar.dataset.chapterCount || '0');
        if (!slug || !Number.isFinite(total) || total <= 0) return;

        let sum = 0;
        for (let i = 1; i <= total; i++) {
          const raw = localStorage.getItem(`yuval_reading_progress_${slug}_ch${i}`);
          if (!raw) continue;
          try {
            const parsed = JSON.parse(raw);
            const pct = Number(parsed?.percentage);
            if (Number.isFinite(pct)) sum += Math.max(0, Math.min(100, pct));
          } catch {
            /* malformed entry — treat as 0 */
          }
        }

        const avg = Math.round(sum / total);
        bar.style.setProperty('--progress', `${avg}%`);
        const pctEl = bar.querySelector<HTMLElement>('[data-orbit-progress-pct]');
        if (pctEl) pctEl.textContent = `${avg}%`;
      });
    }

    // Defer one frame so the layout pass settles before we paint the
    // progress fills — avoids a brief 0% → real% flash on slow boots.
    requestAnimationFrame(hydrateOrbitProgress);
  })();
</script>
