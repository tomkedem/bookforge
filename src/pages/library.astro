---
/**
 * /library — Living Library, dual layout.
 *
 *   MOBILE (<1024px) — vertical knowledge discovery flow:
 *     1. Compact hero            5. Stats
 *     2. Continue reading        6. Recommendations
 *     3. Featured carousel       7. Quick actions
 *     4. Knowledge-space card
 *
 *   DESKTOP (≥1024px) — single immersive dashboard viewport.
 *     ┌──────────┬──────────────────────────────┬──────────┐
 *     │ Continue │  Hero (floats over galaxy)   │          │
 *     │ Knowledge│  Galaxy stage (core + cards) │   Rail   │
 *     │ Stats    │                              │  (pill)  │
 *     │          ├──────────────────────────────┤          │
 *     │          │  Recommendations strip       │          │
 *     └──────────┴──────────────────────────────┴──────────┘
 *
 *   Composition fits inside ~100dvh after the global header — no long
 *   stacked page on desktop.
 *
 * Same components, same data, same i18n. Only CSS varies by breakpoint.
 *
 * Featured items are filtered OUT of recent items so cards never appear
 * twice on a single screen.
 */

import LibraryLayout from '../layouts/LibraryLayout.astro';
import LibraryHero from '../components/library/LibraryHero.astro';
import LibraryStatsPanel from '../components/library/LibraryStatsPanel.astro';
import ContinueReadingCard from '../components/library/ContinueReadingCard.astro';
import KnowledgeSpaceCard from '../components/library/KnowledgeSpaceCard.astro';
import LibraryCard from '../components/library/LibraryCard.astro';
import RecommendationStrip from '../components/library/RecommendationStrip.astro';
import LibraryQuickActions from '../components/library/LibraryQuickActions.astro';

import type { Language } from '../types/index';
import type { LibraryItem } from '../types/library';
import { DEFAULT_LANGUAGE, getLanguageDirection, isValidLanguage } from '../utils/language';
import { t } from '../i18n';
import {
  getMockLibraryItems,
  getLibraryStats,
  getContinueReadingItem,
  getRecommendedItems,
} from '../utils/library-catalog';

// ── Language ──────────────────────────────────────────────────────────────
const { language: propLanguage } = Astro.props as { language?: Language };

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const requestedLanguage =
  (urlLang && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && isValidLanguage(propLanguage) ? propLanguage : DEFAULT_LANGUAGE);
const language = requestedLanguage as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

// ── Data ──────────────────────────────────────────────────────────────────
const items = getMockLibraryItems();
const stats = getLibraryStats(items);
const continueItem = getContinueReadingItem(items);
const recommendedItems = continueItem
  ? getRecommendedItems(items, continueItem.id, 6)
  : [];

// ── Featured items for the galaxy stage / mobile carousel ────────────────
const featuredSlugs = [
  'ai-engineering',
  'Building-AI-Systems-with-MCP',
  'practical-python-for-ai-engineering',
  'clean-code',
  'Lesson-1-Introduction-To-AI-Engineering-and-Generative-AI',
  'mcp-tool-design',
];
const featuredItems: LibraryItem[] = featuredSlugs
  .map((slug) => items.find((it) => it.slug === slug))
  .filter((it): it is LibraryItem => Boolean(it));

// Pre-computed slot classes for desktop absolute positioning.
const FEATURED_SLOTS = [
  'galaxy-card-tl', 'galaxy-card-tr',
  'galaxy-card-ml', 'galaxy-card-mr',
  'galaxy-card-bl', 'galaxy-card-br',
];
---

<LibraryLayout
  title={t('library.galaxy.title', language)}
  description={t('library.galaxy.subtitle', language)}
  language={language}
  availableLanguages={['he', 'en', 'es']}
  allowClientLanguageOverride={true}
>
  <div class="library-dark-showcase library-root" lang={language} dir={isRtl ? 'rtl' : 'ltr'}>

    {/* Decorative ambient backdrop. */}
    <div class="library-ambient" aria-hidden="true">
      <div class="library-aurora"></div>
    </div>

    <div class="library-body">

      {/* ── Left sidebar (desktop) / mid-flow blocks (mobile) ── */}
      <aside class="lb-area-left">
        <div class="lb-area-continue">
          <ContinueReadingCard item={continueItem} language={language} />
        </div>
        <div class="lb-area-knowledge">
          <KnowledgeSpaceCard language={language} />
        </div>
        <div class="lb-area-stats">
          <LibraryStatsPanel stats={stats} language={language} />
        </div>
      </aside>

      {/* ── Center stage: hero floats over galaxy ── */}
      <main class="lb-area-stage">

        <div class="lb-area-hero">
          <LibraryHero language={language} />
        </div>

        <section class="lb-area-featured" aria-label={t('library.galaxy.welcome', language)}>
          <div class="library-galaxy">

            {/* Decorative orbits — desktop only via CSS display rules. */}
            <div class="galaxy-orbit galaxy-orbit-1" aria-hidden="true"></div>
            <div class="galaxy-orbit galaxy-orbit-2" aria-hidden="true"></div>
            <div class="galaxy-orbit galaxy-orbit-3" aria-hidden="true"></div>

            {/* Decorative orbit nodes (desktop only). */}
            <div class="galaxy-orbit-node galaxy-orbit-node-1" aria-hidden="true"></div>
            <div class="galaxy-orbit-node galaxy-orbit-node-2" aria-hidden="true"></div>
            <div class="galaxy-orbit-node galaxy-orbit-node-3" aria-hidden="true"></div>
            <div class="galaxy-orbit-node galaxy-orbit-node-4" aria-hidden="true"></div>

            {/* Central knowledge core (desktop only). Layered: pool ▸ aura ▸
                three concentric rings ▸ orb ▸ refined book glyph. */}
            <div class="galaxy-core" aria-hidden="true">
              <div class="galaxy-core-pool"></div>
              <div class="galaxy-core-aura"></div>
              <div class="galaxy-core-ring galaxy-core-ring-outer"></div>
              <div class="galaxy-core-ring galaxy-core-ring-mid"></div>
              <div class="galaxy-core-ring galaxy-core-ring-inner"></div>
              <div class="galaxy-core-orb">
                <span class="galaxy-core-orb-highlight" aria-hidden="true"></span>
                <svg
                  class="galaxy-core-symbol"
                  viewBox="0 0 32 32"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  {/* Open book — refined: covers, spine, pages, ribbon */}
                  <path d="M16 8.5C13.5 7 10.5 6 6 6.2v17C10.5 23 13.5 24 16 25.5"></path>
                  <path d="M16 8.5C18.5 7 21.5 6 26 6.2v17c-4.5-.2-7.5.8-10 2.3"></path>
                  <path d="M16 8.5v17"></path>
                  {/* Page lines on each side */}
                  <path d="M9 11.5h4M9 14.5h4M9 17.5h4"></path>
                  <path d="M19 11.5h4M19 14.5h4M19 17.5h4"></path>
                  {/* Ribbon */}
                  <path d="M16 25.5l-1.5 2 1.5-1 1.5 1z" fill="currentColor"></path>
                </svg>
              </div>
            </div>

            {/* Floating cards — orbit variant on desktop, compact on mobile. */}
            {featuredItems.map((item, i) => (
              <div class={`galaxy-card ${FEATURED_SLOTS[i] ?? ''}`}>
                {/* Two LibraryCards in one slot: only one is visible at a
                    given breakpoint. Cheaper than runtime branching and
                    keeps the variant choice purely declarative. */}
                <div class="galaxy-card-mobile">
                  <LibraryCard item={item} language={language} variant="compact" />
                </div>
                <div class="galaxy-card-desktop">
                  <LibraryCard item={item} language={language} variant="orbit" />
                </div>
              </div>
            ))}
          </div>
        </section>

        {/* Recommendations strip lives inside the center stage on desktop
            so it sits at the bottom of the viewport, not past the fold. */}
        <div class="lb-area-recs">
          <RecommendationStrip items={recommendedItems} language={language} />
        </div>

      </main>

      {/* ── Right rail (desktop pill) / quick-actions panel (mobile) ── */}
      <aside class="lb-area-right">
        <div class="lb-area-quick lb-area-quick-mobile">
          <LibraryQuickActions language={language} />
        </div>
        <div class="lb-area-quick lb-area-quick-rail">
          <LibraryQuickActions language={language} variant="rail" />
        </div>
      </aside>

    </div>

  </div>
</LibraryLayout>

<style>
  /* ──────────────────────────────────────────────────────────────────
     /library — page shell + galaxy stage geometry
     Hard rules:
       - All colour/effect via --yuval-galaxy-*  (no hex anywhere)
       - All visible text via t()
       - RTL via inset-inline-* (logical properties)
     ────────────────────────────────────────────────────────────────── */

  .library-root {
    position: relative;
    min-height: 100vh;
    width: 100%;
    background-color: var(--yuval-galaxy-bg);
    background-image:
      var(--yuval-galaxy-bg-radial-primary),
      var(--yuval-galaxy-bg-radial-secondary);
    color: var(--yuval-galaxy-text);
    padding: 1rem 1rem 4rem;
    box-sizing: border-box;
    isolation: isolate;
    overflow-x: hidden;
  }

  /* Ambient backdrop — self-contained */
  .library-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .library-aurora {
    position: absolute;
    inset-block-start: 6%;
    inset-inline-start: -10%;
    width: 120%;
    height: 280px;
    background: radial-gradient(ellipse at center,
      var(--yuval-galaxy-accent-cyan) 0%,
      transparent 65%);
    opacity: 0.10;
    filter: blur(60px);
  }
  .library-root > :not(.library-ambient) {
    position: relative;
    z-index: 1;
  }

  /* ── Mobile baseline: linear stack, ordered to the spec.
        The desktop wrapper aside/main elements are passthrough on mobile —
        their children unfurl in the natural document order, then `order:`
        re-shuffles them into the discovery sequence. ─────────────────── */
  .library-body {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* On mobile the wrapper aside/main elements are not layout containers;
     reset their flex behaviour and let their children act as siblings. */
  .lb-area-left,
  .lb-area-stage,
  .lb-area-right {
    display: contents;
  }

  /* Mobile order — Hero, Continue, Featured, Knowledge, Stats, Recs, Quick */
  .lb-area-hero      { order: 1; }
  .lb-area-continue  { order: 2; }
  .lb-area-featured  { order: 3; }
  .lb-area-knowledge { order: 4; }
  .lb-area-stats     { order: 5; }
  .lb-area-recs      { order: 6; }
  .lb-area-quick-mobile { order: 7; }
  /* Rail variant is desktop-only; suppress on mobile */
  .lb-area-quick-rail   { display: none; }

  /* Desktop-only galaxy variant of each floating card. Mobile gets the
     compact variant in a horizontal scroll-snap rail. */
  .galaxy-card-desktop { display: none; }
  .galaxy-card-mobile  { display: block; }

  /* ── Galaxy stage — mobile baseline: horizontal scroll-snap rail ── */
  .library-galaxy {
    display: flex;
    flex-direction: row;
    gap: 0.875rem;
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-block-end: 0.5rem;
    margin-inline: -0.25rem;
    padding-inline: 0.25rem;
    scrollbar-width: thin;
    scrollbar-color: var(--yuval-galaxy-accent-cyan) transparent;
  }
  .library-galaxy::-webkit-scrollbar { height: 6px; }
  .library-galaxy::-webkit-scrollbar-track { background: transparent; }
  .library-galaxy::-webkit-scrollbar-thumb {
    background-color: var(--yuval-galaxy-accent-cyan);
    border-radius: 999px;
    opacity: 0.5;
  }

  /* Mobile: orbits, core and orbit-nodes are decorative-desktop-only */
  .galaxy-orbit,
  .galaxy-orbit-node,
  .galaxy-core { display: none; }

  /* Mobile carousel item sizing */
  .galaxy-card {
    flex: 0 0 78%;
    max-width: 320px;
    min-width: 0;
    scroll-snap-align: start;
  }

  /* ── Tablet (≥640px): same flow, more padding, bigger carousel cards ── */
  @media (min-width: 640px) {
    .library-root { padding: 1.75rem 1.5rem 4rem; }
    .galaxy-card { flex-basis: 46%; }
  }

  /* ── Desktop (≥1024px): ONE viewport dashboard, no long scroll ───── */
  @media (min-width: 1024px) {
    .library-root {
      padding: 1.25rem 1.5rem 1.5rem;
      /* Viewport math is owned by LibraryLayout — the layout sets
         --library-dashboard-min-height = calc(100dvh - --library-header-offset)
         on the slot wrapper, so the page does not have to know the
         header's pixel height. */
      min-height: var(--library-dashboard-min-height, 100dvh);
    }

    /* Re-enable real flex containers on the wrapper asides/main. */
    .lb-area-left,
    .lb-area-right {
      display: flex;
      flex-direction: column;
    }
    .lb-area-stage {
      display: flex;
      flex-direction: column;
    }

    /* Reset mobile order — explicit grid placement takes over. */
    .lb-area-hero,
    .lb-area-continue,
    .lb-area-featured,
    .lb-area-knowledge,
    .lb-area-stats,
    .lb-area-recs,
    .lb-area-quick-mobile,
    .lb-area-quick-rail { order: initial; }

    /* 3-column dashboard. Left rail narrow, center stage flexible,
       right rail thin enough to look like a pill. */
    .library-body {
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr) 88px;
      grid-template-rows: 1fr;
      gap: 1.25rem;
      align-items: stretch;
      /* Inner content area accounts for the page padding (1.25rem top +
         1.5rem bottom = ~44px) on top of the header offset. */
      min-height: calc(var(--library-dashboard-min-height, 100dvh) - 2.75rem);
      max-width: 1440px;
    }

    /* ── Left sidebar: glass column with three stacked panels ───── */
    .lb-area-left {
      grid-column: 1;
      grid-row: 1;
      gap: 0.875rem;
      align-self: stretch;
    }
    .lb-area-continue,
    .lb-area-knowledge,
    .lb-area-stats { width: 100%; }

    /* ── Center stage: hero + galaxy + recs ──────────────────────── */
    .lb-area-stage {
      grid-column: 2;
      grid-row: 1;
      gap: 0.5rem;
      min-width: 0;
      position: relative;
    }
    .lb-area-hero {
      flex: 0 0 auto;
      max-width: 720px;
      margin-inline: auto;
      width: 100%;
    }
    /* Galaxy stage takes the remaining vertical space. */
    .lb-area-featured {
      flex: 1 1 auto;
      min-height: 0;
      position: relative;
    }
    .lb-area-recs {
      flex: 0 0 auto;
      width: 100%;
    }

    /* ── Right rail: pill toolbar, vertically centered ──────────── */
    .lb-area-right {
      grid-column: 3;
      grid-row: 1;
      align-items: center;
      justify-content: center;
    }
    .lb-area-quick-mobile { display: none; }
    .lb-area-quick-rail   { display: block; }

    /* Galaxy stage on desktop: absolute canvas anchored to the stage. */
    .library-galaxy {
      position: relative;
      display: block;
      height: 100%;
      min-height: 480px;
      margin: 0;
      overflow: visible;
      flex-direction: initial;
      scroll-snap-type: none;
      padding: 0;
      scrollbar-width: auto;
      scrollbar-color: auto;
    }
    .library-galaxy::-webkit-scrollbar { height: auto; }

    .galaxy-card-desktop { display: block; }
    .galaxy-card-mobile  { display: none; }

    /* ── Decorative orbit rings ─────────────────────────────────────
       Soft horizontal-fade mask so the rings look spatial: brightest
       at the equator (where nodes live) and dimmer at top/bottom,
       which makes them recede into the dark backdrop instead of
       feeling like stamped circles. */
    .galaxy-orbit {
      display: block;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      border: 1px solid var(--yuval-galaxy-border-strong);
      pointer-events: none;
      -webkit-mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        black 30%,
        black 70%,
        transparent 100%);
      mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        black 30%,
        black 70%,
        transparent 100%);
    }
    .galaxy-orbit-1 { width: 280px; height: 280px; opacity: 0.60;
                      border-color: var(--yuval-galaxy-border-glow); }
    .galaxy-orbit-2 { width: 440px; height: 440px; opacity: 0.38; }
    .galaxy-orbit-3 { width: 600px; height: 600px; opacity: 0.22; }

    /* ── Decorative nodes that sit ON the orbit lines ───────────── */
    .galaxy-orbit-node {
      display: block;
      position: absolute;
      top: 50%;
      left: 50%;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      pointer-events: none;
    }
    .galaxy-orbit-node-1 {
      background-color: var(--yuval-galaxy-accent-cyan);
      box-shadow: var(--yuval-galaxy-glow-soft);
      transform: translate(-50%, -50%) translateY(-140px);
    }
    .galaxy-orbit-node-2 {
      background-color: var(--yuval-galaxy-accent-purple);
      box-shadow: var(--yuval-galaxy-glow-secondary);
      transform: translate(-50%, -50%) translateX(220px);
    }
    .galaxy-orbit-node-3 {
      background-color: var(--yuval-galaxy-accent-cyan);
      box-shadow: var(--yuval-galaxy-glow-soft);
      transform: translate(-50%, -50%) translate(-160px, 160px);
    }
    .galaxy-orbit-node-4 {
      background-color: var(--yuval-galaxy-accent-purple);
      box-shadow: var(--yuval-galaxy-glow-secondary);
      transform: translate(-50%, -50%) translateY(300px);
    }

    /* ── Central knowledge core ─────────────────────────────────── */
    .galaxy-core {
      display: block;
      position: absolute;
      top: 50%;
      left: 50%;
      width: 240px;
      height: 240px;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }
    /* Light pool below the core — anchors the core to the stage with
       a soft cyan/purple ground glow. Wider and more luminous than
       before so the core doesn't feel like a circle floating in void. */
    .galaxy-core-pool {
      position: absolute;
      inset-block-start: 60%;
      inset-inline-start: -40%;
      width: 180%;
      height: 110%;
      background:
        radial-gradient(ellipse 60% 55% at center 25%,
          var(--yuval-galaxy-accent-cyan) 0%,
          transparent 70%),
        radial-gradient(ellipse 80% 70% at center 60%,
          var(--yuval-galaxy-accent-purple) 0%,
          transparent 75%);
      opacity: 0.30;
      filter: blur(44px);
    }
    .galaxy-core-aura {
      position: absolute;
      inset: -44px;
      border-radius: 50%;
      background: radial-gradient(circle,
        var(--yuval-galaxy-accent-purple) 0%,
        transparent 65%);
      opacity: 0.72;
      filter: blur(30px);
    }
    /* Three concentric rings around the orb — calm depth, no noise.
       Outer ring is the brightest line, inner is the tightest hairline
       hugging the orb. */
    .galaxy-core-ring {
      position: absolute;
      border-radius: 50%;
      border: 1px solid var(--yuval-galaxy-border-glow);
    }
    .galaxy-core-ring-outer { inset: 0;   opacity: 0.60; }
    .galaxy-core-ring-mid   { inset: 10%; opacity: 0.42;
                              border-color: var(--yuval-galaxy-border-strong); }
    .galaxy-core-ring-inner { inset: 19%; opacity: 0.30;
                              border-color: var(--yuval-galaxy-border-glow); }
    .galaxy-core-orb {
      position: absolute;
      inset: 26%;
      border-radius: 50%;
      background:
        radial-gradient(circle at 32% 30%,
          var(--yuval-galaxy-accent-cyan) 0%,
          var(--yuval-galaxy-accent-purple) 60%,
          var(--yuval-galaxy-accent-secondary) 100%);
      box-shadow:
        var(--yuval-galaxy-glow-core),
        0 0 0 1px var(--yuval-galaxy-border-glow) inset;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    /* Specular highlight on the upper-left of the orb — gives the
       sphere a real lit-from-above feel without animation. */
    .galaxy-core-orb-highlight {
      position: absolute;
      inset-block-start: 8%;
      inset-inline-start: 12%;
      width: 40%;
      height: 30%;
      border-radius: 50%;
      background: radial-gradient(ellipse at center,
        var(--yuval-galaxy-text) 0%,
        transparent 70%);
      opacity: 0.30;
      filter: blur(8px);
      pointer-events: none;
    }
    .galaxy-core-symbol {
      position: relative;
      width: 56%;
      height: 56%;
      color: var(--yuval-galaxy-text);
      opacity: 0.94;
      filter: drop-shadow(0 0 6px color-mix(in srgb, var(--yuval-galaxy-text) 35%, transparent));
      z-index: 1;
    }

    /* ── Floating cards: 6 absolute slots arranged around the core,
          hugging the outer orbit ring rather than the stage edges.
          Three vertical bands (top / middle / bottom) on each side. */
    .galaxy-card {
      position: absolute;
      flex: initial;
      max-width: none;
      width: 220px;
      transition:
        transform var(--yuval-galaxy-motion-normal) var(--yuval-galaxy-ease-out);
      z-index: 2;
    }
    .galaxy-card-tl { top:  4%;  inset-inline-start: 2%;  --tilt: -5deg; transform: rotate(-5deg); }
    .galaxy-card-tr { top:  4%;  inset-inline-end:   2%;  --tilt:  5deg; transform: rotate( 5deg); }
    .galaxy-card-ml { top: 40%;  inset-inline-start: 0;   --tilt: -2deg; transform: rotate(-2deg); }
    .galaxy-card-mr { top: 40%;  inset-inline-end:   0;   --tilt:  2deg; transform: rotate( 2deg); }
    .galaxy-card-bl { bottom: 6%; inset-inline-start: 6%; --tilt: -3deg; transform: rotate(-3deg); }
    .galaxy-card-br { bottom: 6%; inset-inline-end:   6%; --tilt:  3deg; transform: rotate( 3deg); }

    .galaxy-card:hover,
    .galaxy-card:focus-within {
      transform: rotate(calc(var(--tilt) * 0.4)) translateY(-3px);
      z-index: 3;
    }
  }

  /* ── Wide desktop (≥1280px): bigger stage, wider cards, orbits ──── */
  @media (min-width: 1280px) {
    .library-body {
      grid-template-columns: 320px minmax(0, 1fr) 96px;
      gap: 1.5rem;
    }
    .galaxy-card    { width: 240px; }
    .galaxy-orbit-1 { width: 320px; height: 320px; }
    .galaxy-orbit-2 { width: 480px; height: 480px; }
    .galaxy-orbit-3 { width: 660px; height: 660px; }
    .galaxy-core    { width: 280px; height: 280px; }
  }

  /* ── Reduced motion — drop the hover transform, keep tilt static ── */
  @media (prefers-reduced-motion: reduce) {
    .galaxy-card { transition: none; }
    .galaxy-card:hover,
    .galaxy-card:focus-within {
      transform: rotate(var(--tilt, 0deg));
    }
  }
</style>
