---
/**
 * /library — Living Library, dual layout.
 *
 *   MOBILE (<1024px) — vertical knowledge discovery flow:
 *     1. Compact hero            5. Stats
 *     2. Continue reading        6. Recommendations
 *     3. Featured carousel       7. Quick actions
 *     4. Knowledge-space card
 *
 *   DESKTOP (≥1024px) — single immersive dashboard viewport.
 *     ┌──────────┬──────────────────────────────┬──────────┐
 *     │ Continue │  Hero (floats over galaxy)   │          │
 *     │ Knowledge│  Galaxy stage (core + cards) │   Rail   │
 *     │ Stats    │                              │  (pill)  │
 *     │          ├──────────────────────────────┤          │
 *     │          │  Recommendations strip       │          │
 *     └──────────┴──────────────────────────────┴──────────┘
 *
 *   Composition fits inside ~100dvh after the global header — no long
 *   stacked page on desktop.
 *
 * Same components, same data, same i18n. Only CSS varies by breakpoint.
 *
 * Featured items are filtered OUT of recent items so cards never appear
 * twice on a single screen.
 */

import LibraryLayout from '../layouts/LibraryLayout.astro';
import LibraryHero from '../components/library/LibraryHero.astro';
import LibraryStatsPanel from '../components/library/LibraryStatsPanel.astro';
import ContinueReadingCard from '../components/library/ContinueReadingCard.astro';
import KnowledgeSpaceCard from '../components/library/KnowledgeSpaceCard.astro';
import LibraryCard from '../components/library/LibraryCard.astro';
import RecommendationStrip from '../components/library/RecommendationStrip.astro';
import RecommendedSidebarList from '../components/library/RecommendedSidebarList.astro';
import MobileGalaxyCarousel from '../components/library/MobileGalaxyCarousel.astro';
import LibraryQuickActions from '../components/library/LibraryQuickActions.astro';

import type { Language } from '../types/index';
import type { LibraryItem } from '../types/library';
import { DEFAULT_LANGUAGE, getLanguageDirection, isValidLanguage } from '../utils/language';
import { t } from '../i18n';
import {
  getLibraryItems,
  getLibraryStats,
  getContinueReadingItem,
  getRecommendedItems,
} from '../utils/library-catalog';
import { getCourseProgressList } from '../utils/library-adapter';
import { isReadableLibraryItem } from '../utils/library-display';

// ── Language ──────────────────────────────────────────────────────────────
const { language: propLanguage } = Astro.props as { language?: Language };

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const requestedLanguage =
  (urlLang && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && isValidLanguage(propLanguage) ? propLanguage : DEFAULT_LANGUAGE);
const language = requestedLanguage as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

// ── Data ──────────────────────────────────────────────────────────────────
// Primary source = real BookForge content (via library-adapter); falls
// back to mock when output/ is empty (CI / fresh checkout).
const items = getLibraryItems();
const stats = getLibraryStats(items);
// Per-course progress (X of Y lesson summaries available) — empty when
// no real catalog is in play (mock fallback returns []).
const courseProgress = getCourseProgressList();

// Continue + recommendations ONLY consider readable items so that we
// never surface the synthetic ai-engineering course (no /courses route
// yet) as a clickable-looking suggestion.
const readableItems = items.filter(isReadableLibraryItem);
const continueItem = getContinueReadingItem(readableItems);
const recommendedItems = continueItem
  ? getRecommendedItems(readableItems, continueItem.id, 6)
  : [];

// ── Featured items for the galaxy stage / mobile carousel ────────────────
// Only readable real content. The synthetic ai-engineering course meta
// is NOT featured here — it has no /courses route yet, so it would
// appear as a non-clickable "broken-looking" tile next to clickable
// books. The course still surfaces through the stats panel and through
// the per-course progress line.
//   1. AI-Developer-Fitness                       — real book
//   2. Building-AI-Systems-with-MCP               — real book
//   3. practical-python-for-ai-engineering        — real book
//   4. Lesson-1-...                               — first AI Engineering lesson
//   5. Lesson-2-Machine-Learning                  — second lesson
//   6. Lesson-3-Natural-Language-Processing       — newest lesson
const featuredSlugs = [
  'AI-Developer-Fitness',
  'Building-AI-Systems-with-MCP',
  'practical-python-for-ai-engineering',
  'Lesson-1-Introduction-To-AI-Engineering-and-Generative-AI',
  'Lesson-2-Machine-Learning',
  'Lesson-3-Natural-Language-Processing',
];
const featuredItems: LibraryItem[] = featuredSlugs
  .map((slug) => readableItems.find((it) => it.slug === slug))
  .filter((it): it is LibraryItem => Boolean(it));

// Pre-computed slot classes for desktop absolute positioning.
// Order matches featuredSlugs above so the 3 books (idx 0..2) all land
// in the LEFT column and the 3 lesson summaries (idx 3..5) all land in
// the RIGHT column — matching the approved reference composition.
const FEATURED_SLOTS = [
  'galaxy-card-tl', // 0: AI Developer Fitness        (book, left upper)
  'galaxy-card-ml', // 1: Building AI Systems with MCP (book, left middle)
  'galaxy-card-bl', // 2: Practical Python             (book, left lower)
  'galaxy-card-tr', // 3: Lesson 1                     (lesson, right upper)
  'galaxy-card-mr', // 4: Lesson 2                     (lesson, right middle)
  'galaxy-card-br', // 5: Lesson 3                     (lesson, right lower)
];
---

<LibraryLayout
  title={t('library.galaxy.title', language)}
  description={t('library.galaxy.subtitle', language)}
  language={language}
  availableLanguages={['he', 'en', 'es']}
  allowClientLanguageOverride={true}
>
  <div
    class="library-dark-showcase library-root"
    lang={language}
    dir={isRtl ? 'rtl' : 'ltr'}
    style={`--page-direction: ${isRtl ? 'rtl' : 'ltr'};`}
  >

    {/* Decorative ambient backdrop. The unified page-level bg system
        in `.library-root` (primary / secondary / side / vignette) now
        owns all atmospheric coloring; this layer carries only the
        starfield decoration on top. The previous nebula divs +
        aurora are no longer rendered — they duplicated the page-level
        violet/blue halos and produced compound brightness. */}
    <div class="library-ambient" aria-hidden="true">
      <div class="library-starfield"></div>
    </div>

    <div class="library-body">

      {/* ── Left sidebar (desktop) / mid-flow blocks (mobile) ── */}
      <aside class="lb-area-left">
        <div class="lb-area-continue">
          <ContinueReadingCard item={continueItem} language={language} />
        </div>
        <div class="lb-area-knowledge">
          <KnowledgeSpaceCard language={language} />
        </div>
        <div class="lb-area-stats">
          <LibraryStatsPanel stats={stats} language={language} courseProgress={courseProgress} />
        </div>
        {/* Compact recommendation hint — desktop sidebar only.
            Mobile suppresses this via CSS to avoid duplicating the
            featured carousel + bottom RecommendationStrip already in
            the mobile flow. */}
        <div class="lb-area-sidebar-recs">
          <RecommendedSidebarList items={recommendedItems.slice(0, 4)} language={language} />
        </div>
      </aside>

      {/* ── Center stage: hero floats over galaxy ── */}
      <main class="lb-area-stage">

        <div class="lb-area-hero">
          <LibraryHero language={language} />
        </div>

        {/*
          Mobile-only discovery slot. Lives directly inside .lb-area-stage
          so on mobile (where .lb-area-stage is display:contents) it
          becomes its own flex item of .library-body with explicit
          `order: 3` — placed right after the recommended starting card.
          Hidden on desktop, where the orbit stage below takes over.
        */}
        <div class="lb-area-mobile-discovery">
          <MobileGalaxyCarousel items={readableItems} language={language} />
        </div>

        <section class="lb-area-featured" aria-label={t('library.galaxy.welcome', language)}>
          <div class="library-galaxy">

            {/* Galaxy stage decorative asset — single PNG containing
                the cosmic backdrop, orbit rings, glowing nodes, and
                glowing open book. The page-level unified background
                system on .library-root provides all atmospheric glow
                around the asset; nothing else is rendered here. */}
            <img
              class="galaxy-stage-image"
              src="/assets/library/galaxy-stage-core-medium.png"
              alt=""
              aria-hidden="true"
              decoding="async"
            />

            {/* Floating cards — orbit variant only. Mobile content
                lives in MobileGalaxyCarousel above; the wrapper
                .library-galaxy is display:none below 1024px. */}
            {featuredItems.map((item, i) => (
              <div class={`galaxy-card ${FEATURED_SLOTS[i] ?? ''}`}>
                <LibraryCard item={item} language={language} variant="orbit" />
              </div>
            ))}
          </div>
        </section>

        {/* Recommendations strip lives inside the center stage on desktop
            so it sits at the bottom of the viewport, not past the fold. */}
        <div class="lb-area-recs">
          <RecommendationStrip items={recommendedItems} language={language} />
        </div>

      </main>

      {/* ── Right rail (desktop pill) / quick-actions panel (mobile) ── */}
      <aside class="lb-area-right">
        <div class="lb-area-quick lb-area-quick-mobile">
          <LibraryQuickActions language={language} />
        </div>
        <div class="lb-area-quick lb-area-quick-rail">
          <LibraryQuickActions language={language} variant="rail" />
        </div>
      </aside>

    </div>

  </div>
</LibraryLayout>

<style>
  /* ──────────────────────────────────────────────────────────────────
     /library — page shell + galaxy stage geometry
     Hard rules:
       - All colour/effect via --yuval-galaxy-*  (no hex anywhere)
       - All visible text via t()
       - RTL via inset-inline-* (logical properties)
     ────────────────────────────────────────────────────────────────── */

  .library-root {
    position: relative;
    min-height: 100vh;
    width: 100%;
    /* Whole-screen unified backdrop. Mobile uses the two main layers;
       desktop adds side accents + vignette so the entire dashboard
       (sidebar + center + rail + recs) reads as one cosmic field. */
    background-color: var(--yuval-galaxy-bg);
    background-image:
      var(--yuval-galaxy-bg-radial-primary),
      var(--yuval-galaxy-bg-radial-secondary);
    color: var(--yuval-galaxy-text);
    padding: 1rem 1rem 4rem;
    box-sizing: border-box;
    isolation: isolate;
    overflow-x: hidden;
  }

  /* Ambient backdrop — self-contained */
  .library-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  /* `.library-aurora` and `.library-nebula-*` rules removed: their
     markup nodes were retired when the unified page-level backdrop
     system in `.library-root` took over atmospheric coloring. */
  /* Starfield — a CSS-only matrix of tiny bright pixels rendered as
     a single repeating radial-gradient pattern. No DOM nodes, no JS.
     Two layers (small + medium) at slightly different offsets for
     parallax-like depth. */
  .library-starfield {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 12%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 65% 24%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 35% 38%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 82% 47%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 12% 58%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 73% 67%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 28% 78%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 88% 88%, var(--yuval-galaxy-text) 50%, transparent 100%),
      /* Accent stars — all violet now. Cyan accents were swapped to
         purple to align with the page's violet-led palette and avoid
         out-of-key cyan dots on the cosmic field. */
      radial-gradient(1.5px 1.5px at 50% 18%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 92% 32%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 8% 72%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 58% 92%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%);
    opacity: 0.40;
  }
  .library-root > :not(.library-ambient) {
    position: relative;
    z-index: 1;
  }

  /* ── Mobile baseline: linear stack, ordered to the spec.
        The desktop wrapper aside/main elements are passthrough on mobile —
        their children unfurl in the natural document order, then `order:`
        re-shuffles them into the discovery sequence. ─────────────────── */
  .library-body {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* On mobile the wrapper aside/main elements are not layout containers;
     reset their flex behaviour and let their children act as siblings. */
  .lb-area-left,
  .lb-area-stage,
  .lb-area-right {
    display: contents;
  }

  /* Mobile order — discovery-first.
       1 hero
       2 mobile-discovery (MobileGalaxyCarousel — readable AI content)
       3 continue (recommended starting card — sits AFTER discovery so
                   it never blocks the carousel above the fold)
       4 knowledge
       5 stats
       6 recs (RecommendationStrip)
       7 quick actions
     The desktop-only `.lb-area-featured` and the rail/sidebar-recs
     are hidden on mobile via `display: none` below. */
  .lb-area-hero              { order: 1; }
  .lb-area-mobile-discovery  { order: 2; display: block; width: 100%; }
  .lb-area-continue          { order: 3; }
  .lb-area-knowledge         { order: 4; }
  .lb-area-stats             { order: 5; }
  .lb-area-recs              { order: 6; }
  .lb-area-quick-mobile      { order: 7; }

  /* Desktop-only slots — completely hidden on mobile so they cannot
     contribute to layout, height, or accidental visibility. */
  .lb-area-featured     { display: none; }
  .lb-area-quick-rail   { display: none; }
  .lb-area-sidebar-recs { display: none; }

  /* ── Tablet (≥640px): same mobile flow, more padding ── */
  @media (min-width: 640px) {
    .library-root { padding: 1.75rem 1.5rem 4rem; }
  }

  /* ── Desktop (≥1024px): ONE viewport dashboard, no long scroll ───── */
  @media (min-width: 1024px) {
    .library-root {
      padding: 1.25rem 1.5rem 1.5rem;
      /* Viewport math is owned by LibraryLayout — the layout sets
         --library-dashboard-min-height = calc(100dvh - --library-header-offset)
         on the slot wrapper, so the page does not have to know the
         header's pixel height. */
      min-height: var(--library-dashboard-min-height, 100dvh);
      /* Desktop layered backdrop, FIRST listed = TOP of the stack.
         Calibrated to the sampled asset palette: every layer either
         uses one of the sampled navy tones or stays a small violet
         accent centered on the stage. Hero + side accents were
         removed (asset isn't violet there).
         1. vignette        — corner darkening with sampled #000010
         2. primary accent  — small violet halo at the stage center
         3. secondary fade  — bottom navy continuation (#000010)
         The base color var(--yuval-galaxy-bg) (#01051b) sits beneath. */
      background-image:
        var(--yuval-galaxy-bg-vignette),
        var(--yuval-galaxy-bg-radial-primary),
        var(--yuval-galaxy-bg-radial-secondary);
    }

    /* ── Page-level cosmic texture layer ─────────────────────────
       Inline SVG noise (feTurbulence) tiled seamlessly across the
       whole desktop page. Propagates the dark-cosmic material feel
       of the central asset to the surrounding background, so the
       sidebar/rail/hero/recs areas share the same texture language
       — not just the same color.

       `stitchTiles="stitch"` makes the noise wrap edge-to-edge so
       no seams are visible when the SVG tiles across the viewport.
       Low opacity (0.05) + soft-light blend keeps the texture
       subliminal — it reads as "cosmic material" not "noisy overlay".

       Generated entirely from CSS (no asset file): noise is computed
       by the browser's SVG renderer at paint time, costless once
       cached. Mobile is exempt — the rule lives only inside the
       desktop @media. */
    .library-root::before {
      content: "";
      position: absolute;
      inset: 0;
      /* Two stacked noise layers at different scales:
         1. Fine grain (baseFrequency 0.9) — pixel-level cosmic dust
         2. Coarse grain (baseFrequency 0.35) — broader atmospheric
            variation, suggests gas/dust clouds at a larger scale
         Both stitched seamlessly. The mix gives the texture more
         depth than a single frequency, matching the asset's
         multi-scale cosmic material feel. */
      background-image:
        url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 240 240'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch' seed='7'/></filter><rect width='240' height='240' filter='url(%23n)' opacity='0.55'/></svg>"),
        url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 480 480'><filter id='c'><feTurbulence type='fractalNoise' baseFrequency='0.4' numOctaves='1' stitchTiles='stitch' seed='13'/></filter><rect width='480' height='480' filter='url(%23c)' opacity='0.28'/></svg>");
      background-size: 240px 240px, 480px 480px;
      background-repeat: repeat, repeat;
      opacity: 0.13;
      /* soft-light is gentler than overlay: it modulates lightness
         without distorting hue. The violet halo, navy gradients, and
         vignette underneath stay tonally accurate; the noise only
         adds material texture. */
      mix-blend-mode: soft-light;
      pointer-events: none;
      z-index: 0;
    }

    /* Re-enable real flex containers on the wrapper asides/main. */
    .lb-area-left,
    .lb-area-right {
      display: flex;
      flex-direction: column;
    }
    .lb-area-stage {
      display: flex;
      flex-direction: column;
    }

    /* Reset mobile order — explicit grid placement takes over. */
    .lb-area-hero,
    .lb-area-continue,
    .lb-area-featured,
    .lb-area-knowledge,
    .lb-area-stats,
    .lb-area-sidebar-recs,
    .lb-area-recs,
    .lb-area-quick-mobile,
    .lb-area-quick-rail { order: initial; }

    /* Mobile-only discovery slot is hidden on desktop — the orbit
       stage in .lb-area-featured takes over there. */
    .lb-area-mobile-discovery { display: none; }

    /* Re-enable the desktop-only slots that were hidden on mobile. */
    .lb-area-featured     { display: block; }
    .lb-area-sidebar-recs { display: block; width: 100%; }

    /* 3-column dashboard. Left rail narrow, center stage flexible,
       right rail thin enough to look like a pill. */
    .library-body {
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr) 104px;
      grid-template-rows: 1fr;
      gap: 1.25rem;
      align-items: stretch;
      min-height: calc(var(--library-dashboard-min-height, 100dvh) - 2.75rem);
      max-width: 1440px;
      /* Lock the grid columns to physical positions: column 1 = visual
         left, column 3 = visual right. The page may be `dir="rtl"` for
         Hebrew text, but the dashboard composition itself is fixed
         (sidebar always physical-left, slim rail always physical-right).
         Each immediate child re-applies the page direction below so
         text inside still renders RTL when the page is Hebrew. */
      direction: ltr;
    }
    .library-body > * {
      direction: var(--page-direction, ltr);
    }
    /* Galaxy stage uses physical left/right for absolute orbit slots,
       so the composition (TL/TR/ML/MR/BL/BR card placement) is
       language-independent. Cards inside re-apply page direction so
       Hebrew titles still read RTL. */
    .library-galaxy { direction: ltr; }
    .galaxy-card    { direction: var(--page-direction, ltr); }

    /* ── Left sidebar: glass column with four stacked panels ─────
       (continue → knowledge → stats → recommended). Tighter gap so
       all four panels fit comfortably on common laptop viewport
       heights (768-900px) without forcing the dashboard to scroll. */
    .lb-area-left {
      grid-column: 1;
      grid-row: 1;
      gap: 0.75rem;
      align-self: stretch;
    }
    .lb-area-continue,
    .lb-area-knowledge,
    .lb-area-stats,
    .lb-area-sidebar-recs { width: 100%; }

    /* ── Center stage: hero + galaxy + recs ──────────────────────── */
    .lb-area-stage {
      grid-column: 2;
      grid-row: 1;
      /* Zero stage-gap: the hero now lives as the title strip of the
         galaxy, not a separate block. .galaxy-stage provides its own
         interior padding for the orbits. */
      gap: 0;
      min-width: 0;
      position: relative;
      /* No background layer here. The page-level unified system
         (--yuval-galaxy-bg-radial-primary on .library-root) is centered
         right under this column and provides the violet field for both
         hero and stage. Adding a column-level layer here used to
         compound the violet and produce a "block within a block" feel. */
    }
    .lb-area-hero {
      flex: 0 0 auto;
      max-width: 680px;
      margin-inline: auto;
      width: 100%;
    }
    /* Galaxy stage takes the remaining vertical space. */
    .lb-area-featured {
      flex: 1 1 auto;
      min-height: 0;
      position: relative;
    }
    .lb-area-recs {
      flex: 0 0 auto;
      width: 100%;
    }

    /* ── Right rail: pill toolbar, vertically centered ──────────── */
    .lb-area-right {
      grid-column: 3;
      grid-row: 1;
      align-items: center;
      justify-content: center;
    }
    .lb-area-quick-mobile { display: none; }
    .lb-area-quick-rail   { display: block; }

    /* Galaxy stage on desktop: absolute canvas anchored to the stage.
       Min-height bumped to 540 so the ML/MR orbit cards have enough
       vertical room not to overlap the central core at the narrowest
       desktop widths (1024-1199px).

       Background tuned to match the asset palette: a soft violet
       radial glow at the center fading to the page's deep navy at
       the edges. This is the primary fix for the "rectangle pasted
       in" look — the stage no longer has hard color contrast where
       the asset ends; the violet center seamlessly continues the
       asset's own glow, and the dark edges seamlessly continue the
       page background. */
    .library-galaxy {
      position: relative;
      display: block;
      height: 100%;
      min-height: 540px;
      margin: 0;
      overflow: visible;
      flex-direction: initial;
      scroll-snap-type: none;
      padding: 0;
      scrollbar-width: auto;
      scrollbar-color: auto;
    }
    /* Underlay halo behind the asset — a wide, blurred radial that
       extends BEYOND the asset's bounds so the asset's faded edges
       have something to dissolve INTO instead of stopping at plain
       page bg. The colors are chosen to match the asset's outer-ring
       atmosphere:
         center  → faint violet (continues the asset's central glow
                   beyond its visible edge)
         midring → sampled #000018 navy (matches asset's edge color)
         far     → fully transparent (lets page bg take over)
       Heavy blur (44px) ensures the halo has no perceivable boundary;
       the user sees one continuous cosmic field. */
    .library-galaxy::before {
      content: "";
      position: absolute;
      top: 50%;
      left: 50%;
      width: 125%;
      height: 125%;
      transform: translate(-50%, -50%);
      background:
        /* Continues asset's central violet glow outward — slightly
           reduced range so it doesn't form a competing halo. */
        radial-gradient(
          ellipse 55% 50% at center,
          rgba(124, 58, 237, 0.12) 0%,
          rgba(124, 58, 237, 0.00) 70%
        ),
        /* Bridging navy tint — pulled from sampled asset edge color
           (#000018). Reduced from 0.35 → 0.18 so it's a gentle COLOR
           CONTINUATION, not a perceptible darker ring. Fade extended
           to 95% so the halo dissolves smoothly into page bg. */
        radial-gradient(
          ellipse 75% 68% at center,
          rgba(0, 0, 24, 0.18) 0%,
          rgba(0, 0, 24, 0.00) 95%
        );
      filter: blur(40px);
      pointer-events: none;
      z-index: 0;
    }
    .library-galaxy::-webkit-scrollbar { height: auto; }

    /* `.galaxy-core` and its child rules (.galaxy-core-pool,
       .galaxy-core-aura) were removed alongside their markup nodes:
       they were sized for a 240×240 CSS-rendered core, but the asset
       is 760-820px wide and covered them entirely. They contributed
       nothing visible. The asset + page-level unified backdrop is
       the entire central composition. */

    /* ── Galaxy stage decorative asset ───────────────────────────
       The provided PNG (galaxy-stage-core-medium.png) replaces the
       CSS-generated central composition. `object-fit: contain` keeps
       the open book and orbit rings intact (no crop). Sized to ~95%
       of the stage. A radial mask softens the rectangular edges so
       the image dissolves into the matched dark-navy stage background
       instead of stamping a flat box. */
    .galaxy-stage-image {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 100%;
      /* Bumped 760 → 820 so the central glowing book reads as more
         dominant inside the stage. Cards still cover the corners
         where the mask fades the asset to transparent, so no clash. */
      max-width: 820px;
      height: auto;
      max-height: 100%;
      object-fit: contain;
      pointer-events: none;
      user-select: none;
      z-index: 2;
