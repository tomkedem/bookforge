---
import BaseLayout from '../layouts/BaseLayout.astro';
import { discoverAllBooks } from '../utils/book-discovery';

const books = discoverAllBooks();
---

<BaseLayout title="Knowledge Control Center - Yuval">
  <div class="kcc-shell">
    <div class="kcc-wrap">
      <header class="kcc-header">
        <div class="kcc-eyebrow">
          <span class="kcc-eyebrow-dot"></span>
          <span class="kcc-eyebrow-text">Yuval · Internal</span>
        </div>
        <h1 class="kcc-title">Knowledge Control Center</h1>
        <p class="kcc-subtitle">Manage content, reader state and knowledge metadata.</p>
      </header>

      <section class="kcc-section">
        <div class="kcc-section-head">
          <h2 class="kcc-section-title">Library Content</h2>
          <span class="kcc-section-meta">{books.length} {books.length === 1 ? 'book' : 'books'}</span>
        </div>

        <div class="books-grid" id="books-grid">
          {books.map(book => {
            const initial = (book.title_en || book.slug).trim().charAt(0).toUpperCase();
            return (
              <article class="book-card" data-slug={book.slug}>
                <div class="book-monogram" aria-hidden="true">{initial}</div>
                <div class="book-info">
                  <span class="book-title">{book.title_en}</span>
                  <span class="book-slug">{book.slug}</span>
                </div>
                <div class="book-stats">
                  <span class="stat" id={`stat-${book.slug}`}>…</span>
                </div>
                <div class="book-actions">
                  <button
                    class="edit-btn"
                    data-slug={book.slug}
                    data-title={book.title_en}
                    aria-label={`Edit metadata for ${book.title_en || book.slug}`}
                    title="Edit metadata"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M12 20h9"></path>
                      <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                    </svg>
                    <span class="edit-btn-label">Edit metadata</span>
                  </button>
                  <button class="clean-btn" data-slug={book.slug} title="Clean local reader data for this book">
                    Clean data
                  </button>
                  <button
                    class="delete-btn"
                    data-slug={book.slug}
                    data-title={book.title_en}
                    aria-label={`Delete ${book.title_en}`}
                    title="Delete book"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="3 6 5 6 21 6"></polyline>
                      <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                      <path d="M10 11v6"></path>
                      <path d="M14 11v6"></path>
                      <path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"></path>
                    </svg>
                    <span class="delete-btn-label">Delete</span>
                  </button>
                </div>
              </article>
            );
          })}
        </div>
      </section>

      <section class="kcc-section global-section">
        <div class="kcc-section-head">
          <h2 class="kcc-section-title">Global Settings</h2>
        </div>
        <div class="global-card">
          <div class="global-card-info">
            <p class="global-card-title">Reader preferences</p>
            <p class="global-card-desc">Language, theme, typography, TTS voice &amp; speed, onboarding state.</p>
          </div>
          <button class="clean-btn clean-btn--global" id="clean-global-btn">
            Clean global settings
          </button>
        </div>
      </section>
    </div>

    <div id="toast" class="toast hidden"></div>

    <!-- Edit Metadata Drawer -->
    <aside id="meta-drawer" class="meta-drawer hidden" role="dialog" aria-labelledby="meta-drawer-title" aria-hidden="true">
      <div class="meta-drawer-backdrop" data-meta-close></div>
      <div class="meta-drawer-panel" role="document">
        <header class="meta-drawer-header">
          <div class="meta-drawer-heading">
            <p class="meta-drawer-eyebrow">Edit metadata</p>
            <h2 id="meta-drawer-title" class="meta-drawer-title">—</h2>
            <p class="meta-drawer-slug" id="meta-drawer-slug">—</p>
          </div>
          <button type="button" class="meta-drawer-close" data-meta-close aria-label="Close editor">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </header>

        <form class="meta-form" id="meta-form" autocomplete="off" novalidate>
          <label class="meta-field">
            <span class="meta-label">Display title</span>
            <input class="meta-input" type="text" name="displayTitle" />
            <span class="meta-hint">How this item will appear in the Knowledge Universe.</span>
          </label>

          <label class="meta-field">
            <span class="meta-label">Content type</span>
            <select class="meta-select" name="contentType">
              <option value="book">Book</option>
              <option value="course">Course</option>
              <option value="article">Article</option>
            </select>
          </label>

          <label class="meta-field">
            <span class="meta-label">Category</span>
            <input class="meta-input" type="text" name="category" placeholder="e.g. AI Engineering" />
          </label>

          <label class="meta-field">
            <span class="meta-label">Series name</span>
            <input class="meta-input" type="text" name="seriesName" placeholder="e.g. AI Developer Path" />
          </label>

          <div class="meta-field meta-field--toggle">
            <div class="meta-field-text">
              <span class="meta-label">Visible in universe</span>
              <span class="meta-hint">Off hides this item from the Knowledge Universe.</span>
            </div>
            <label class="meta-toggle" aria-label="Toggle visibility in universe">
              <input type="checkbox" name="isVisibleInUniverse" />
              <span class="meta-toggle-track" aria-hidden="true"></span>
            </label>
          </div>

          <label class="meta-field">
            <span class="meta-label">Visual mode</span>
            <select class="meta-select" name="visualMode">
              <option value="card">Card</option>
              <option value="hidden">Hidden</option>
            </select>
          </label>
        </form>

        <footer class="meta-drawer-footer">
          <button type="button" class="meta-btn meta-btn--ghost" data-meta-close>Cancel</button>
          <button type="button" class="meta-btn meta-btn--primary" id="meta-save">Save metadata</button>
        </footer>
      </div>
    </aside>

    <!-- Delete Confirmation Modal -->
    <div id="delete-modal" class="modal hidden">
      <div class="modal-backdrop"></div>
      <div class="modal-content">
        <h3>⚠️ מחיקת ספר</h3>
        <p>האם אתה בטוח שברצונך למחוק את הספר <strong id="modal-book-title"></strong>?</p>
        <p class="modal-warning">פעולה זו תמחק את כל הקבצים בכל השפות ולא ניתנת לביטול!</p>
        <div class="modal-actions">
          <button class="modal-btn modal-btn--cancel" id="modal-cancel">ביטול</button>
          <button class="modal-btn modal-btn--delete" id="modal-confirm">מחק לצמיתות</button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ─────────────────────────────────────────────────────────────
     Knowledge Control Center — premium dark, warm charcoal + gold.
     Palette intentionally matches LeftSidebar charcoal/gold family
     (#0d0d10 / #16161c / #b8923f / cream-gold) instead of the light
     theme tokens used by the rest of the app.
     ───────────────────────────────────────────────────────────── */

  .kcc-shell {
    --kcc-ink: #0a0a0c;
    --kcc-surface: rgba(28, 28, 34, 0.62);
    --kcc-surface-strong: rgba(34, 34, 40, 0.78);
    --kcc-rim: rgba(255, 255, 255, 0.08);
    --kcc-rim-strong: rgba(255, 255, 255, 0.14);
    --kcc-gold: #c9a96e;
    --kcc-gold-soft: rgba(201, 169, 110, 0.22);
    --kcc-gold-rim: rgba(201, 169, 110, 0.35);
    --kcc-text: #ececea;
    --kcc-text-secondary: #a8a8a4;
    --kcc-text-muted: #6e6e6c;

    position: relative;
    min-height: calc(100vh - 64px);
    background:
      radial-gradient(ellipse 90% 60% at 30% -10%, rgba(201, 169, 110, 0.08) 0%, transparent 55%),
      radial-gradient(ellipse 70% 50% at 80% 110%, rgba(184, 146, 63, 0.06) 0%, transparent 60%),
      linear-gradient(180deg, #121215 0%, #0a0a0c 60%, #08080a 100%);
    color: var(--kcc-text);
    /* No `isolation: isolate` here. The metadata drawer is position:
       fixed with z-index: 10001 so it can paint over the global
       sticky header (z-50). Creating a new stacking context on this
       wrapper would lock the drawer below the header even at huge
       z-indexes — the header would clip the drawer's title. The
       internal z:0/z:1 layering between `.kcc-shell::before`
       (vignette) and `.kcc-wrap` (content) does not need a fresh
       context: position:relative on this element is enough to anchor
       the absolutely-positioned ::before to the shell. */
  }

  /* Subtle film grain / vignette layer */
  .kcc-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 50% 0%, transparent 60%, rgba(0, 0, 0, 0.45) 100%);
    z-index: 0;
  }

  .kcc-wrap {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    padding: 64px 28px 96px;
  }

  /* ── Header ─────────────────────────────────────────────── */

  .kcc-header {
    margin-bottom: 44px;
  }

  .kcc-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px 5px 10px;
    border-radius: 999px;
    background: rgba(201, 169, 110, 0.06);
    border: 1px solid var(--kcc-gold-rim);
    margin-bottom: 18px;
  }

  .kcc-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--kcc-gold);
    box-shadow: 0 0 8px rgba(201, 169, 110, 0.55);
  }

  .kcc-eyebrow-text {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--kcc-gold);
  }

  .kcc-title {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 2.25rem;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--kcc-text);
    margin: 0 0 10px;
  }

  .kcc-subtitle {
    color: var(--kcc-text-secondary);
    font-size: 0.95rem;
    line-height: 1.55;
    max-width: 56ch;
    margin: 0;
  }

  /* ── Sections ───────────────────────────────────────────── */

  .kcc-section {
    margin-top: 36px;
  }

  .kcc-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--kcc-rim);
  }

  .kcc-section-title {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--kcc-text-secondary);
    margin: 0;
  }

  .kcc-section-meta {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.78rem;
    color: var(--kcc-text-muted);
    letter-spacing: 0.04em;
  }

  /* ── Books grid ─────────────────────────────────────────── */

  .books-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .book-card {
    display: flex;
    align-items: center;
    gap: 18px;
    background: var(--kcc-surface);
    border: 1px solid var(--kcc-rim);
    border-radius: 14px;
    padding: 16px 20px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition:
      background 200ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 200ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 200ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .book-card:hover {
    background: var(--kcc-surface-strong);
    border-color: var(--kcc-rim-strong);
    transform: translateY(-1px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.35);
  }

  .book-monogram {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    border-radius: 10px;
    background: linear-gradient(180deg, #1d1d22 0%, #14141a 100%);
    border: 1px solid var(--kcc-gold-rim);
    color: var(--kcc-gold);
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .book-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .book-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--kcc-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: -0.005em;
  }

  .book-slug {
    font-size: 0.7rem;
    color: var(--kcc-text-muted);
    font-family: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
    letter-spacing: 0.02em;
  }

  .book-stats {
    flex-shrink: 0;
  }

  .book-stats .stat {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--kcc-rim);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--kcc-text-secondary);
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  /* ── Actions: ghost buttons, destructive de-emphasised ── */

  .book-actions {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .clean-btn {
    padding: 7px 14px;
    border-radius: 8px;
    border: 1px solid var(--kcc-rim);
    background: rgba(255, 255, 255, 0.02);
    color: var(--kcc-text-secondary);
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition:
      background 160ms cubic-bezier(0.4, 0, 0.2, 1),
      color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .clean-btn:hover {
    background: rgba(201, 169, 110, 0.08);
    color: var(--kcc-gold);
    border-color: var(--kcc-gold-rim);
  }

  /* Edit metadata — PRIMARY safe action.
     The most prominent of the three row actions: gold-tinted fill +
     gold rim signal "this is the everyday editorial control", while
     destructive Delete stays a quiet ghost on the other side. */
  .edit-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border-radius: 8px;
    border: 1px solid var(--kcc-gold-rim);
    background: rgba(201, 169, 110, 0.14);
    color: var(--kcc-gold);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition:
      background 160ms cubic-bezier(0.4, 0, 0.2, 1),
      color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .edit-btn svg {
    flex-shrink: 0;
    opacity: 0.9;
  }

  .edit-btn:hover {
    background: rgba(201, 169, 110, 0.22);
    border-color: rgba(201, 169, 110, 0.55);
    color: #e8d39a;
    box-shadow: 0 4px 12px -4px rgba(184, 146, 63, 0.35);
  }

  .edit-btn:hover svg {
    opacity: 1;
  }

  .edit-btn:focus-visible {
    outline: none;
    border-color: rgba(201, 169, 110, 0.7);
    box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.22);
  }

  .delete-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    border-radius: 8px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--kcc-text-muted);
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition:
      background 160ms cubic-bezier(0.4, 0, 0.2, 1),
      color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .delete-btn svg {
    flex-shrink: 0;
    opacity: 0.75;
  }

  .delete-btn:hover {
    background: rgba(220, 38, 38, 0.08);
    color: #f87171;
    border-color: rgba(220, 38, 38, 0.32);
  }

  .delete-btn:hover svg {
    opacity: 1;
  }

  /* ── Global card ─────────────────────────────────────────── */

  .global-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    background: var(--kcc-surface);
    border: 1px solid var(--kcc-rim);
    border-radius: 14px;
    padding: 18px 20px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .global-card-info {
    flex: 1;
    min-width: 0;
  }

  .global-card-title {
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--kcc-text);
    margin: 0 0 3px;
  }

  .global-card-desc {
    font-size: 0.8rem;
    color: var(--kcc-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .clean-btn--global {
    margin-top: 0;
    flex-shrink: 0;
  }

  /* ── Toast ──────────────────────────────────────────────── */

  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(20, 20, 24, 0.92);
    color: #fff;
    border: 1px solid var(--kcc-gold-rim);
    padding: 10px 22px;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.5);
    z-index: 9999;
    transition: opacity 0.3s;
  }

  .toast.hidden { display: none; }

  /* ── Modal: dark glass version ──────────────────────────── */

  .modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal.hidden { display: none; }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .modal-content {
    position: relative;
    background: linear-gradient(180deg, #1a1a1f 0%, #131318 100%);
    border: 1px solid var(--kcc-rim-strong);
    border-radius: 16px;
    padding: 28px;
    max-width: 420px;
    width: 90%;
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    text-align: center;
    color: #ececea;
  }

  .modal-content h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: #ececea;
    margin: 0 0 12px;
  }

  .modal-content p {
    font-size: 0.9rem;
    color: #a8a8a4;
    margin: 0 0 8px;
    line-height: 1.55;
  }

  .modal-content strong {
    color: #ececea;
  }

  .modal-warning {
    color: #f87171 !important;
    font-weight: 500;
    font-size: 0.85rem !important;
  }

  .modal-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-top: 22px;
  }

  .modal-btn {
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      background 160ms cubic-bezier(0.2, 0, 0, 1),
      color 160ms cubic-bezier(0.2, 0, 0, 1),
      border-color 160ms cubic-bezier(0.2, 0, 0, 1);
  }

  .modal-btn--cancel {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--kcc-rim);
    color: #ececea;
  }

  .modal-btn--cancel:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--kcc-rim-strong);
  }

  .modal-btn--delete {
    background: rgba(220, 38, 38, 0.92);
    border: 1px solid rgba(220, 38, 38, 0.6);
    color: #fff;
  }

  .modal-btn--delete:hover {
    background: rgb(220, 38, 38);
  }

  .modal-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Edit Metadata drawer ───────────────────────────────── */

  .meta-drawer {
    position: fixed;
    /* Start BELOW the global Yuval header (sticky, ~72px — matches
       --library-header-offset elsewhere in the app). Both the panel
       and the backdrop are children of this container, so shifting
       the top here keeps the header fully visible above the drawer
       and stops the eyebrow / title from being clipped. */
    inset-block-start: 72px;
    inset-inline: 0;
    inset-block-end: 0;
    z-index: 10001;
    display: flex;
    justify-content: flex-end;
    pointer-events: none;
  }

  /* Hebrew SOURCE_LANGUAGE makes /admin RTL by default. Flip the
     drawer to slide from the inline-end edge in both directions. */
  [dir="rtl"] .meta-drawer {
    justify-content: flex-start;
  }

  .meta-drawer.hidden { display: none; }

  .meta-drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    transition: background 240ms cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: auto;
  }

  .meta-drawer.is-open .meta-drawer-backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .meta-drawer-panel {
    position: relative;
    width: min(440px, 100%);
    height: 100%;
    background: linear-gradient(180deg, #1a1a1f 0%, #131318 100%);
    border-inline-start: 1px solid var(--kcc-rim-strong);
    box-shadow: -30px 0 80px rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
    pointer-events: auto;
    transform: translateX(100%);
    transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  [dir="rtl"] .meta-drawer-panel {
    transform: translateX(-100%);
    box-shadow: 30px 0 80px rgba(0, 0, 0, 0.5);
  }

  .meta-drawer.is-open .meta-drawer-panel {
    transform: translateX(0);
  }

  .meta-drawer-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 24px 24px 18px;
    border-bottom: 1px solid var(--kcc-rim);
  }

  .meta-drawer-heading {
    flex: 1;
    min-width: 0;
  }

  .meta-drawer-eyebrow {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--kcc-gold);
    margin: 0 0 6px;
  }

  .meta-drawer-title {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--kcc-text);
    margin: 0 0 4px;
    overflow-wrap: break-word;
  }

  .meta-drawer-slug {
    font-family: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
    font-size: 0.72rem;
    color: var(--kcc-text-muted);
    margin: 0;
    letter-spacing: 0.02em;
    overflow-wrap: anywhere;
  }

  .meta-drawer-close {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid var(--kcc-rim);
    background: rgba(255, 255, 255, 0.02);
    color: var(--kcc-text-secondary);
    cursor: pointer;
    transition: background 160ms, color 160ms, border-color 160ms;
  }

  .meta-drawer-close:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--kcc-text);
    border-color: var(--kcc-rim-strong);
  }

  .meta-form {
    flex: 1;
    overflow-y: auto;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .meta-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .meta-field--toggle {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 14px;
    border: 1px solid var(--kcc-rim);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
  }

  .meta-field-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .meta-label {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--kcc-text);
    letter-spacing: 0.01em;
  }

  .meta-hint {
    font-size: 0.72rem;
    color: var(--kcc-text-muted);
    line-height: 1.45;
  }

  .meta-input,
  .meta-select {
    width: 100%;
    padding: 9px 12px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--kcc-rim);
    border-radius: 8px;
    color: var(--kcc-text);
    font-family: inherit;
    font-size: 0.9rem;
    line-height: 1.4;
    transition: border-color 160ms, background 160ms, box-shadow 160ms;
  }

  .meta-input::placeholder {
    color: var(--kcc-text-muted);
  }

  .meta-input:focus,
  .meta-select:focus {
    outline: none;
    border-color: var(--kcc-gold-rim);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.12);
  }

  .meta-select {
    appearance: none;
    -webkit-appearance: none;
    background-image:
      linear-gradient(45deg, transparent 50%, var(--kcc-text-secondary) 50%),
      linear-gradient(-45deg, transparent 50%, var(--kcc-text-secondary) 50%);
    background-position:
      calc(100% - 18px) 50%,
      calc(100% - 13px) 50%;
    background-size: 5px 5px, 5px 5px;
    background-repeat: no-repeat;
    padding-inline-end: 30px;
  }

  [dir="rtl"] .meta-select {
    background-position:
      18px 50%,
      13px 50%;
    padding-inline-end: 12px;
    padding-inline-start: 30px;
  }

  /* Dropdown options — keep them readable when the OS popup opens.
     The closed select already inherits the dark drawer background;
     the OPEN list is what browsers paint with native colors (light
     grey on most platforms), so we override it explicitly here.
     Browser support note: Chrome/Edge/Firefox on Windows and Linux
     honor `option { background, color }`. Safari on macOS uses the
     system picker and ignores these rules — there is no reliable CSS
     fix for that without replacing <select> with a custom widget,
     which the spec for this fix explicitly excludes. The duplicate
     `background` + `background-color` declarations are intentional:
     some engines respect one but not the other depending on the
     widget pipeline. */
  .meta-select option {
    background: #16161c;
    background-color: #16161c;
    color: var(--kcc-text);
    padding: 6px 8px;
  }

  .meta-select option:checked {
    background: rgba(201, 169, 110, 0.22);
    background-color: rgba(201, 169, 110, 0.22);
    color: var(--kcc-gold);
    font-weight: 600;
  }

  /* Hover styling on <option> is honored on Firefox; Chrome/Edge
     paint hover via the native highlight color, but a CSS attempt
     here is harmless when ignored and helps where supported. */
  .meta-select option:hover,
  .meta-select option:focus {
    background: rgba(201, 169, 110, 0.16);
    background-color: rgba(201, 169, 110, 0.16);
    color: var(--kcc-gold);
  }

  .meta-select option:disabled {
    color: var(--kcc-text-muted);
  }

  /* Toggle switch */
  .meta-toggle {
    position: relative;
    display: inline-block;
    width: 40px;
    height: 22px;
    flex-shrink: 0;
    cursor: pointer;
  }

  .meta-toggle input {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    opacity: 0;
    cursor: pointer;
  }

  .meta-toggle-track {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid var(--kcc-rim);
    position: relative;
    transition: background 180ms, border-color 180ms;
  }

  .meta-toggle-track::after {
    content: "";
    position: absolute;
    inset-inline-start: 2px;
    top: 2px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #d6d6d2;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
    transition: inset-inline-start 200ms cubic-bezier(0.4, 0, 0.2, 1), background 180ms;
  }

  .meta-toggle input:checked + .meta-toggle-track {
    background: rgba(201, 169, 110, 0.32);
    border-color: var(--kcc-gold-rim);
  }

  .meta-toggle input:checked + .meta-toggle-track::after {
    inset-inline-start: calc(100% - 18px);
    background: var(--kcc-gold);
  }

  .meta-toggle input:focus-visible + .meta-toggle-track {
    box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.24);
  }

  .meta-drawer-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    padding: 18px 24px 22px;
    border-top: 1px solid var(--kcc-rim);
  }

  .meta-btn {
    padding: 9px 18px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition:
      background 160ms cubic-bezier(0.4, 0, 0.2, 1),
      color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .meta-btn--ghost {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--kcc-rim);
    color: var(--kcc-text-secondary);
  }

  .meta-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--kcc-rim-strong);
    color: var(--kcc-text);
  }

  .meta-btn--primary {
    background: linear-gradient(180deg, #d4ba74 0%, #b8923f 100%);
    border: 1px solid rgba(184, 146, 63, 0.6);
    color: #1d1305;
    font-weight: 600;
    box-shadow: 0 4px 14px rgba(184, 146, 63, 0.25);
  }

  .meta-btn--primary:hover {
    background: linear-gradient(180deg, #e2cf95 0%, #c9a96e 100%);
    box-shadow: 0 6px 18px rgba(184, 146, 63, 0.35);
  }

  .meta-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Responsive ─────────────────────────────────────────── */

  @media (max-width: 640px) {
    .kcc-wrap {
      padding: 36px 18px 64px;
    }

    .kcc-title {
      font-size: 1.75rem;
    }

    .book-card {
      flex-wrap: wrap;
      gap: 12px;
      padding: 14px 16px;
    }

    .book-info {
      flex: 1 1 calc(100% - 56px);
    }

    .book-stats {
      order: 3;
    }

    .book-actions {
      order: 4;
      width: 100%;
      justify-content: flex-end;
      padding-top: 8px;
      border-top: 1px solid var(--kcc-rim);
    }

    .global-card {
      flex-direction: column;
      align-items: stretch;
    }

    .clean-btn--global {
      align-self: flex-start;
    }

    .delete-btn-label,
    .edit-btn-label {
      display: none;
    }

    .meta-drawer-panel {
      width: 100%;
    }

    .meta-drawer-footer {
      padding: 16px 18px 20px;
    }

    .meta-form {
      padding: 18px;
    }
  }
</style>

<script>
  import {
    getMetadata,
    setMetadata,
  } from '../utils/content-metadata';
  import type { ContentMetadata } from '../types/content-metadata';

  const BOOK_PREFIXES = (slug: string) => [
    `yuval_bookmarks_${slug}`,
    `yuval_highlights_${slug}`,   // prefix - will match all chapters
    `yuval_reading_progress_${slug}`,
    `yuval_reading_stats_${slug}`,
    `yuval_reading_goals_${slug}`,
  ];

  const GLOBAL_KEYS = [
    'yuval_language',
    'yuval-theme',
    'yuval-typography',
    'yuval_tts_voice_he',
    'yuval_tts_voice_en',
    'yuval_tts_voice_es',
    'yuval_tts_speed',
    'yuval_onboarded_v1',
    'yuval_reading_goal',
  ];

  function countBookKeys(slug: string): number {
    let count = 0;
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i) || '';
      if (key.includes(`_${slug}`)) count++;
    }
    return count;
  }

  function cleanBook(slug: string): number {
    const toDelete: string[] = [];
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i) || '';
      if (key.includes(`_${slug}`)) toDelete.push(key);
    }
    toDelete.forEach(k => localStorage.removeItem(k));
    return toDelete.length;
  }

  function cleanGlobal(): number {
    let count = 0;
    GLOBAL_KEYS.forEach(k => {
      if (localStorage.getItem(k) !== null) {
        localStorage.removeItem(k);
        count++;
      }
    });
    return count;
  }

  function showToast(msg: string) {
    const toast = document.getElementById('toast')!;
    toast.textContent = msg;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 2800);
  }

  function updateStats() {
    document.querySelectorAll<HTMLElement>('.book-card').forEach(card => {
      const slug = card.dataset.slug!;
      const count = countBookKeys(slug);
      const el = document.getElementById(`stat-${slug}`);
      if (el) el.textContent = count === 0 ? 'No data' : `${count} item${count !== 1 ? 's' : ''}`;
    });
  }

  // Attach clean buttons
  document.querySelectorAll<HTMLButtonElement>('.clean-btn[data-slug]').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.slug!;
      const removed = cleanBook(slug);
      updateStats();
      showToast(removed > 0 ? `Cleaned ${removed} items for "${slug}"` : `No data found for "${slug}"`);
    });
  });

  document.getElementById('clean-global-btn')?.addEventListener('click', () => {
    const removed = cleanGlobal();
    showToast(removed > 0 ? `Cleaned ${removed} global settings` : 'No global settings found');
  });

  // Delete book functionality
  const modal = document.getElementById('delete-modal')!;
  const modalTitle = document.getElementById('modal-book-title')!;
  const modalCancel = document.getElementById('modal-cancel')!;
  const modalConfirm = document.getElementById('modal-confirm')!;
  let pendingDeleteSlug: string | null = null;

  function showModal(slug: string, title: string) {
    pendingDeleteSlug = slug;
    modalTitle.textContent = title;
    modal.classList.remove('hidden');
    modalConfirm.disabled = false;
    modalConfirm.textContent = 'מחק לצמיתות';
  }

  function hideModal() {
    modal.classList.add('hidden');
    pendingDeleteSlug = null;
  }

  // Attach delete buttons
  document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.slug!;
      const title = btn.dataset.title || slug;
      showModal(slug, title);
    });
  });

  modalCancel.addEventListener('click', hideModal);
  modal.querySelector('.modal-backdrop')?.addEventListener('click', hideModal);

  modalConfirm.addEventListener('click', async () => {
    if (!pendingDeleteSlug) return;
    
    const slug = pendingDeleteSlug;
    modalConfirm.disabled = true;
    modalConfirm.textContent = 'מוחק...';

    try {
      const response = await fetch('/api/delete-book', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug })
      });

      const result = await response.json();

      if (result.success) {
        // Remove the book card from the page
        const card = document.querySelector(`.book-card[data-slug="${slug}"]`);
        if (card) {
          card.remove();
        }
        hideModal();
        showToast(`✅ הספר "${slug}" נמחק בהצלחה`);
      } else {
        showToast(`❌ שגיאה: ${result.error || 'לא ניתן למחוק'}`);
        hideModal();
      }
    } catch (error: any) {
      showToast(`❌ שגיאת רשת: ${error.message}`);
      hideModal();
    }
  });

  // Close modal with Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      hideModal();
    }
  });

  updateStats();

  // ─────────────────────────────────────────────────────────────
  // Edit Metadata drawer
  // Reads and writes the editorial layer in src/utils/content-metadata.ts.
  // The metadata storage key (yuval_content_metadata) is intentionally
  // NOT matched by cleanBook() or cleanGlobal() above, so editing a
  // book's metadata never affects reader progress or global prefs —
  // those code paths are unchanged.
  // ─────────────────────────────────────────────────────────────

  const metaDrawer = document.getElementById('meta-drawer')!;
  const metaTitleEl = document.getElementById('meta-drawer-title')!;
  const metaSlugEl = document.getElementById('meta-drawer-slug')!;
  const metaForm = document.getElementById('meta-form') as HTMLFormElement;
  const metaSaveBtn = document.getElementById('meta-save') as HTMLButtonElement;

  const metaFields = {
    displayTitle: metaForm.elements.namedItem('displayTitle') as HTMLInputElement,
    contentType: metaForm.elements.namedItem('contentType') as HTMLSelectElement,
    category: metaForm.elements.namedItem('category') as HTMLInputElement,
    seriesName: metaForm.elements.namedItem('seriesName') as HTMLInputElement,
    isVisibleInUniverse: metaForm.elements.namedItem('isVisibleInUniverse') as HTMLInputElement,
    visualMode: metaForm.elements.namedItem('visualMode') as HTMLSelectElement,
  };

  let editingSlug: string | null = null;
  let returnFocusEl: HTMLElement | null = null;

  function paintCardFromMetadata(slug: string, meta: ContentMetadata) {
    const card = document.querySelector<HTMLElement>(`.book-card[data-slug="${slug}"]`);
    if (!card) return;
    const titleEl = card.querySelector<HTMLElement>('.book-title');
    if (titleEl) titleEl.textContent = meta.displayTitle;
    const monoEl = card.querySelector<HTMLElement>('.book-monogram');
    if (monoEl) {
      const ch = (meta.displayTitle || slug).trim().charAt(0).toUpperCase();
      monoEl.textContent = ch || '·';
    }
  }

  // On boot, overlay each card with its stored metadata (if any).
  // Cards without stored metadata stay as the SSR rendered them.
  document.querySelectorAll<HTMLElement>('.book-card').forEach(card => {
    const slug = card.dataset.slug;
    if (!slug) return;
    const titleEl = card.querySelector<HTMLElement>('.book-title');
    const ssrTitle = titleEl?.textContent?.trim() || slug;
    const meta = getMetadata(slug, ssrTitle);
    paintCardFromMetadata(slug, meta);
  });

  function openMetaDrawer(slug: string, fallbackTitle: string, trigger: HTMLElement | null) {
    editingSlug = slug;
    returnFocusEl = trigger;
    const meta = getMetadata(slug, fallbackTitle);

    metaTitleEl.textContent = meta.displayTitle;
    metaSlugEl.textContent = slug;

    metaFields.displayTitle.value = meta.displayTitle;
    metaFields.contentType.value = meta.contentType;
    metaFields.category.value = meta.category;
    metaFields.seriesName.value = meta.seriesName;
    metaFields.isVisibleInUniverse.checked = meta.isVisibleInUniverse;
    metaFields.visualMode.value = meta.visualMode;

    metaDrawer.classList.remove('hidden');
    metaDrawer.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(() => {
      metaDrawer.classList.add('is-open');
      metaFields.displayTitle.focus();
      metaFields.displayTitle.select();
    });
    document.body.style.overflow = 'hidden';
  }

  function closeMetaDrawer() {
    if (metaDrawer.classList.contains('hidden')) return;
    editingSlug = null;
    metaDrawer.classList.remove('is-open');
    metaDrawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    window.setTimeout(() => {
      metaDrawer.classList.add('hidden');
      if (returnFocusEl && typeof returnFocusEl.focus === 'function') {
        returnFocusEl.focus();
      }
      returnFocusEl = null;
    }, 280);
  }

  document.querySelectorAll<HTMLButtonElement>('.edit-btn[data-slug]').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.slug!;
      const fallback = btn.dataset.title || slug;
      openMetaDrawer(slug, fallback, btn);
    });
  });

  metaDrawer.querySelectorAll<HTMLElement>('[data-meta-close]').forEach(el => {
    el.addEventListener('click', closeMetaDrawer);
  });

  // Esc closes the metadata drawer. The pre-existing Esc handler for
  // the delete modal guards on its own visibility, so the two
  // handlers do not conflict.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && metaDrawer.classList.contains('is-open')) {
      closeMetaDrawer();
    }
  });

  metaForm.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && (e.target as HTMLElement).tagName === 'INPUT') {
      e.preventDefault();
      metaSaveBtn.click();
    }
  });

  metaSaveBtn.addEventListener('click', () => {
    if (!editingSlug) return;
    const slug = editingSlug;
    const fallback = metaFields.displayTitle.value.trim() || slug;

    const patch: Partial<ContentMetadata> = {
      displayTitle: metaFields.displayTitle.value.trim() || slug,
      contentType: metaFields.contentType.value as ContentMetadata['contentType'],
      category: metaFields.category.value.trim(),
      seriesName: metaFields.seriesName.value.trim(),
      isVisibleInUniverse: metaFields.isVisibleInUniverse.checked,
      visualMode: metaFields.visualMode.value as ContentMetadata['visualMode'],
    };

    const saved = setMetadata(slug, patch, fallback);
    paintCardFromMetadata(slug, saved);
    closeMetaDrawer();
    showToast(`Metadata saved for "${saved.displayTitle}"`);
  });
</script>
