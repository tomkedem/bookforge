---
import BaseLayout from '../layouts/BaseLayout.astro';
import { discoverAllBooks } from '../utils/book-discovery';
import { getKnowledgeCardAssets } from '../utils/library/knowledge-cards';
import type { Language } from '../types/index';
import {
  DEFAULT_LANGUAGE,
  LANGUAGE_CODES,
  getLanguageDirection,
  isValidLanguage,
} from '../utils/language';
import { t } from '../i18n';

const books = discoverAllBooks();

/**
 * Pick a localized string from a Record<lang, string> with sensible
 * fallbacks. Returns undefined when nothing is usable, so callers can
 * decide whether to render an em-dash or hide the cell.
 */
function pickLocalized(
  map: Record<string, string> | undefined,
  primary: string,
): string | undefined {
  if (!map) return undefined;
  const candidates = [map[primary], map.en, map.he, map.es];
  for (const c of candidates) {
    if (typeof c === 'string' && c.trim().length > 0) return c.trim();
  }
  return undefined;
}



// Language resolution mirrors the pattern used by /library and the
// chapter pages: ?lang=he|en|es overrides everything; otherwise fall
// back to DEFAULT_LANGUAGE. allowClientLanguageOverride below lets the
// LanguageSelector flip languages via ?lang=X without the URL needing
// to match the server-rendered default.
const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const language: Language = (urlLang && isValidLanguage(urlLang))
  ? urlLang
  : DEFAULT_LANGUAGE;
const isRtl = getLanguageDirection(language) === 'rtl';

// Pre-translate strings that are emitted into client-side data-attrs
// or DOM-built nodes. Toast templates keep their {{n}}/{{slug}} markers
// — the script does the substitution at runtime so a single key serves
// every variant. This is the single source of strings: the i18n table
// in src/i18n/translations.ts. The script must NOT hardcode any user-
// facing copy of its own.
const i18nBundle = {
  statNoData:        t('admin.stat.noData', language),
  statItemsOne:      t('admin.stat.itemsOne', language),
  statItemsManyTpl:  t('admin.stat.itemsMany', language),
  toastCleanedBook:  t('admin.toast.cleanedBook', language),
  toastNoBookData:   t('admin.toast.noBookData', language),
  toastCleanedGlobal:t('admin.toast.cleanedGlobal', language),
  toastNoGlobalData: t('admin.toast.noGlobalData', language),
  toastBookDeleted:  t('admin.toast.bookDeleted', language),
  toastDeleteError:  t('admin.toast.deleteError', language),
  toastDeleteFailed: t('admin.toast.deleteFailed', language),
  toastNetworkError: t('admin.toast.networkError', language),
  toastMetadataSaved:t('admin.toast.metadataSaved', language),
  toastEditorialExportedTpl: t('admin.toast.editorialExported', language),
  toastEditorialImportedTpl: t('admin.toast.editorialImported', language),
  toastEditorialImportInvalidTpl: t('admin.toast.editorialImportInvalid', language),
  importConfirmTpl:  t('admin.global.importConfirm', language),
  modalDeleting:     t('admin.modal.deleting', language),
  modalConfirmText:  t('admin.modal.confirm', language),
  // Per-flow modal copy. The generic `admin.modal.title/warning` keys
  // are the SSR fallback for the modal element itself; the JS calls
  // showConfirmModal({...}) with these flow-specific strings at open
  // time so book delete and series delete each speak in their own
  // terms (different heading, different consequences warning).
  modalHeadingBook:  t('admin.modal.headingBook', language),
  modalBodyBook:     t('admin.modal.bodyBook', language),
  modalWarningBook:  t('admin.modal.warningBook', language),
  modalHeadingSeries:t('admin.modal.headingSeries', language),
  modalBodySeries:   t('admin.modal.bodySeries', language),
  modalWarningSeries:t('admin.modal.warningSeries', language),
  // Series Management labels — used by the JS that renders detected
  // series cards and by the toast emitted after a series is saved.
  seriesEmpty:       t('admin.series.empty', language),
  seriesCountTpl:    t('admin.series.count', language),
  seriesItemsTpl:    t('admin.series.itemsLabel', language),
  seriesAvailableTpl:t('admin.series.availableLabel', language),
  seriesEditAriaTpl: t('admin.series.editAriaLabel', language),
  seriesEditTitle:   t('admin.series.editTitle', language),
  seriesTagCapsule:  t('admin.series.tagCapsule', language),
  toastSeriesSaved:  t('admin.series.toast.saved', language),
  // Rich-card redesign — labels for badges, progress, asset folder
  // and the read-only computed actual-count summary inside the
  // edit drawer.
  seriesCardItemsOfTpl:        t('admin.series.card.itemsOf', language),
  seriesCardItemsOnlyTpl:      t('admin.series.card.itemsOnly', language),
  seriesCardActualLabelTpl:    t('admin.series.card.actualLabel', language),
  seriesCardAssetFolderLabel:  t('admin.series.card.assetFolderLabel', language),
  seriesCardAssetFolderEmpty:  t('admin.series.card.assetFolderEmpty', language),
  seriesCardEditButton:        t('admin.series.card.editButton', language),
  seriesCardNoDescription:     t('admin.series.card.noDescription', language),
  seriesCardProgressAriaTpl:   t('admin.series.card.progressAria', language),
  seriesStatusActive:          t('admin.series.status.active', language),
  seriesStatusDraft:           t('admin.series.status.draft', language),
  seriesStatusHidden:          t('admin.series.status.hidden', language),
  seriesBadgeVisible:          t('admin.series.badge.visible', language),
  seriesBadgeHiddenFromUni:    t('admin.series.badge.hiddenFromUniverse', language),
  seriesOptionCapsule:         t('admin.series.option.capsule', language),
  seriesOptionCard:            t('admin.series.option.card', language),
  seriesOptionOrbitNode:       t('admin.series.option.orbitNode', language),
  seriesActualReadOnlyTpl:     t('admin.series.field.actualReadOnly', language),
  // New / delete a series (Series Management section CTA + per-row
  // delete button). Toasts mirror the book-delete toasts so a glance
  // at the toast queue tells the user which destructive flow ran.
  seriesActionNew:             t('admin.series.action.new', language),
  seriesActionDelete:          t('admin.series.action.delete', language),
  seriesActionDeleteAriaTpl:   t('admin.series.action.deleteAriaLabel', language),
  seriesActionDeleteTitle:     t('admin.series.action.deleteTitle', language),
  seriesDrawerEyebrowNew:      t('admin.series.drawer.eyebrowNew', language),
  seriesFieldName:             t('admin.series.field.name', language),
  seriesFieldNameHint:         t('admin.series.field.nameHint', language),
  seriesToastDeleted:          t('admin.series.toast.deleted', language),
  seriesToastCreated:          t('admin.series.toast.created', language),
  seriesToastRenamed:          t('admin.series.toast.renamed', language),
  seriesToastAlreadyExists:    t('admin.series.toast.alreadyExists', language),
  seriesToastNameRequired:     t('admin.series.toast.nameRequired', language),
  // Table — cell placeholders. Column headers are rendered server-side
  // in the <thead>, so they don't need to be in the runtime bundle.
  seriesCellNotSet:            t('admin.series.cell.notSet', language),
  seriesCellNoFolder:          t('admin.series.cell.noFolder', language),
  seriesCellDash:              t('admin.series.cell.dash', language),
  // Knowledge Catalog table cells — repainted by the metadata script.
  cellEmpty:         t('admin.cell.empty', language),
  cellVisible:       t('admin.cell.visible', language),
  cellHidden:        t('admin.cell.hidden', language),
  cellNoSeries:      t('admin.cell.noSeries', language),
  cellNoCategory:    t('admin.cell.noCategory', language),
  optionBook:        t('admin.option.book', language),
  optionCourse:      t('admin.option.course', language),
  optionArticle:     t('admin.option.article', language),
  // Cover upload — toasts are rendered from the script after the
  // POST /api/upload-cover round-trip. Templates use {{title}} for
  // success and {{msg}} for fetch / server failures.
  coverPlaceholder:        t('admin.cover.placeholder', language),
  coverUpload:             t('admin.cover.upload', language),
  coverUploadAria:         t('admin.cover.uploadAria', language),
  coverReplace:            t('admin.cover.replace', language),
  coverUploading:          t('admin.cover.uploading', language),
  toastCoverUploaded:      t('admin.toast.coverUploaded', language),
  toastCoverUploadFailed:  t('admin.toast.coverUploadFailed', language),
  toastCoverInvalidType:   t('admin.toast.coverInvalidType', language),
  toastCoverTooLarge:      t('admin.toast.coverTooLarge', language),
};
---

<BaseLayout
  title={`${t('admin.title', language)} - Yuval`}
  language={language}
  availableLanguages={LANGUAGE_CODES}
  allowClientLanguageOverride={true}
>
  <div
    class="kcc-shell"
    lang={language}
    dir={isRtl ? 'rtl' : 'ltr'}
    data-i18n-bundle={JSON.stringify(i18nBundle)}
  >
    <div class="kcc-wrap">
      <header class="kcc-header">
        <div class="kcc-eyebrow">
          <span class="kcc-eyebrow-dot"></span>
          <span class="kcc-eyebrow-text">{t('admin.eyebrow', language)}</span>
        </div>
        <h1 class="kcc-title">{t('admin.title', language)}</h1>
        <p class="kcc-subtitle">{t('admin.subtitle', language)}</p>
      </header>

      <section class="kcc-section">
        <div class="kcc-section-head">
          <h2 class="kcc-section-title">{t('admin.section.libraryContent', language)}</h2>
          <span class="kcc-section-meta">{t('admin.section.bookCount', language, { n: books.length })}</span>
        </div>

        <div class="kcc-table-wrap">
          <table class="kcc-table" id="books-table">
            <thead class="kcc-thead">
              <tr>
                <th class="kcc-th col-cover">{t('admin.column.cover', language)}</th>
                <th class="kcc-th col-title">{t('admin.column.item', language)}</th>
                <th class="kcc-th col-type">{t('admin.column.type', language)}</th>
                <th class="kcc-th col-series">{t('admin.column.series', language)}</th>
                <th class="kcc-th col-category">{t('admin.column.category', language)}</th>
                <th class="kcc-th col-visibility">{t('admin.column.visibility', language)}</th>
                <th class="kcc-th col-progress">{t('admin.column.progress', language)}</th>
                <th class="kcc-th col-count">{t('admin.column.chapters', language)}</th>
                <th class="kcc-th col-actions">{t('admin.column.actions', language)}</th>
              </tr>
            </thead>
            <tbody id="books-grid">
              {books.map(book => {
                // The pipeline (ingest.py) is responsible for writing
                // the manifest with the correct title/subtitle layout —
                // including the course-lesson normalization that swaps
                // Word's cover-page placeholders so the lesson title
                // lands in `titles` rather than `subtitles`. The admin
                // then only has to render: title primary, subtitle
                // secondary. Slug is the last-resort fallback.
                const ssrTitle =
                  pickLocalized(book.titles, language) || book.slug;
                const ssrSubtitle = pickLocalized(book.subtitles, language);
                const ssrCategory = pickLocalized(book.category, language);
                const chapterCount = book.chapters.length;
                // Knowledge-card front image — the same artifact the
                // /library orbit renders. We surface it (not the
                // pipeline cover) because the user's mental model of
                // "the book's image" in the knowledge space is the
                // futuristic front card, not the docx-extracted cover.
                // Discovery is case-insensitive (matches the orbit
                // page's behaviour); when no front.png exists the
                // empty placeholder shows and the upload button still
                // works.
                const frontUrl = getKnowledgeCardAssets(book.slug)?.front;
                return (
                  <tr class="book-card kcc-tr" data-slug={book.slug}>
                    <td class="kcc-td col-cover">
                      {/* Front-image thumbnail. The button wraps the
                          image so a click anywhere opens the file
                          picker. The delegated handler in the script
                          picks the slug from data-slug and POSTs to
                          /api/upload-front. */}
                      <button
                        type="button"
                        class="cover-uploader"
                        data-cover-upload="book"
                        data-slug={book.slug}
                        aria-label={t('admin.cover.uploadAria', language, { title: ssrTitle })}
                        title={t('admin.cover.upload', language)}
                      >
                        {frontUrl ? (
                          <img
                            class="cover-thumb"
                            src={frontUrl}
                            alt=""
                            loading="lazy"
                            decoding="async"
                          />
                        ) : (
                          <span class="cover-thumb cover-thumb--empty" aria-hidden="true">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                              <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                              <circle cx="9" cy="9" r="2"></circle>
                              <path d="M21 15l-5-5L5 21"></path>
                            </svg>
                          </span>
                        )}
                        <span class="cover-uploader-overlay" aria-hidden="true">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 5v14"></path>
                            <path d="M5 12h14"></path>
                          </svg>
                        </span>
                      </button>
                    </td>
                    <td class="kcc-td col-title">
                      <div class="kcc-title-stack">
                        <span class="book-title">{ssrTitle}</span>
                        {ssrSubtitle && (
                          <span class="book-subtitle">{ssrSubtitle}</span>
                        )}
                      </div>
                    </td>
                    <td class="kcc-td col-type">
                      <span class="kcc-pill" data-cell="type">
                        {t('admin.option.book', language)}
                      </span>
                    </td>
                    <td class="kcc-td col-series" data-cell="series">
                      <span class="kcc-muted">{t('admin.cell.noSeries', language)}</span>
                    </td>
                    <td class="kcc-td col-category" data-cell="category">
                      {ssrCategory || (
                        <span class="kcc-muted">{t('admin.cell.noCategory', language)}</span>
                      )}
                    </td>
                    <td class="kcc-td col-visibility">
                      <span class="kcc-vis kcc-vis--on" data-cell="visibility">
                        <span class="kcc-vis-dot" aria-hidden="true"></span>
                        <span class="kcc-vis-label">{t('admin.cell.visible', language)}</span>
                      </span>
                    </td>
                    <td class="kcc-td col-progress">
                      <span class="stat" id={`stat-${book.slug}`}>
                        {t('admin.stat.loading', language)}
                      </span>
                    </td>
                    <td class="kcc-td col-count">
                      <span class="kcc-num">{chapterCount}</span>
                    </td>
                    <td class="kcc-td col-actions">
                      <div class="book-actions">
                        <button
                          class="edit-btn"
                          data-slug={book.slug}
                          data-title={ssrTitle}
                          aria-label={t('admin.action.editAriaLabel', language, { title: ssrTitle })}
                          title={t('admin.action.editTitle', language)}
                        >
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 20h9"></path>
                            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                          </svg>
                          <span class="edit-btn-label">{t('admin.action.editMetadata', language)}</span>
                        </button>
                        <button
                          class="clean-btn"
                          data-slug={book.slug}
                          title={t('admin.action.cleanDataTitle', language)}
                        >
                          {t('admin.action.cleanData', language)}
                        </button>
                        <button
                          class="delete-btn"
                          data-slug={book.slug}
                          data-title={ssrTitle}
                          aria-label={t('admin.action.deleteAriaLabel', language, { title: ssrTitle })}
                          title={t('admin.action.deleteTitle', language)}
                        >
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                            <path d="M10 11v6"></path>
                            <path d="M14 11v6"></path>
                            <path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"></path>
                          </svg>
                          <span class="delete-btn-label">{t('admin.action.delete', language)}</span>
                        </button>
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>

      <section class="kcc-section">
        <div class="kcc-section-head series-section-head">
          <div class="series-section-titles">
            <h2 class="kcc-section-title">{t('admin.series.section', language)}</h2>
            <p class="series-section-subtitle">{t('admin.series.subtitle', language)}</p>
          </div>
          {/* Right cluster: series count + "New series" CTA. The
              CTA opens the series drawer in create mode (empty
              fields, name input editable). The script-side handler
              that wires the drawer reads `data-new-series` to
              distinguish the create path from per-row edit. */}
          <div class="series-section-actions">
            <span class="kcc-section-meta" id="series-count">{t('admin.series.count', language, { n: 0 })}</span>
            <button type="button" class="series-new-btn" data-new-series>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 5v14"></path>
                <path d="M5 12h14"></path>
              </svg>
              <span>{t('admin.series.action.new', language)}</span>
            </button>
          </div>
        </div>
        {/* Series Management table — same visual family as the books
            table above (kcc-table-wrap + kcc-table). The <tbody> is
            populated by `renderSeries()` in the script below; on first
            paint it renders the empty-state row. */}
        <div class="kcc-table-wrap series-table-wrap">
          <table class="kcc-table series-table" id="series-table">
            <thead class="kcc-thead">
              <tr>
                <th class="kcc-th col-cover">{t('admin.column.cover', language)}</th>
                <th class="kcc-th col-series-name">{t('admin.series.column.name', language)}</th>
                <th class="kcc-th col-series-desc">{t('admin.series.column.description', language)}</th>
                <th class="kcc-th col-series-status">{t('admin.series.column.status', language)}</th>
                <th class="kcc-th col-series-universe">{t('admin.series.column.universe', language)}</th>
                <th class="kcc-th col-series-actual">{t('admin.series.column.actualItems', language)}</th>
                <th class="kcc-th col-series-planned">{t('admin.series.column.plannedItems', language)}</th>
                <th class="kcc-th col-series-progress">{t('admin.series.column.progress', language)}</th>
                <th class="kcc-th col-series-folder">{t('admin.series.column.assetFolder', language)}</th>
                <th class="kcc-th col-series-order">{t('admin.series.column.order', language)}</th>
                <th class="kcc-th col-series-actions">{t('admin.series.column.actions', language)}</th>
              </tr>
            </thead>
            <tbody id="series-list">
              <tr class="series-empty-row">
                <td class="kcc-td series-empty-cell" colspan="11">
                  {t('admin.series.empty', language)}
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="kcc-section global-section">
        <div class="kcc-section-head">
          <h2 class="kcc-section-title">{t('admin.section.globalSettings', language)}</h2>
        </div>
        <div class="global-card">
          <div class="global-card-info">
            <p class="global-card-title">{t('admin.global.title', language)}</p>
            <p class="global-card-desc">{t('admin.global.description', language)}</p>
          </div>
          <button class="clean-btn clean-btn--global" id="clean-global-btn">
            {t('admin.global.cleanButton', language)}
          </button>
        </div>

        {/* Editorial export — second global card. Reuses the same
            .global-card chrome so no new CSS is required. The button
            reads localStorage on click and downloads an _editorial.json
            file shaped for output/. Pure read; no mutation. */}
        <div class="global-card">
          <div class="global-card-info">
            <p class="global-card-title">{t('admin.global.exportTitle', language)}</p>
            <p class="global-card-desc">{t('admin.global.exportDescription', language)}</p>
          </div>
          <button class="clean-btn clean-btn--global" id="export-editorial-btn">
            {t('admin.global.exportButton', language)}
          </button>
        </div>

        {/* Editorial import — third global card. The hidden file input
            is the one the click handler triggers; the visible button
            opens the OS picker. Replace-mode semantics are explained in
            the description and re-confirmed at runtime via the native
            confirm() prompt before localStorage is touched. */}
        <div class="global-card">
          <div class="global-card-info">
            <p class="global-card-title">{t('admin.global.importTitle', language)}</p>
            <p class="global-card-desc">{t('admin.global.importDescription', language)}</p>
          </div>
          <button class="clean-btn clean-btn--global" id="import-editorial-btn">
            {t('admin.global.importButton', language)}
          </button>
          <input
            type="file"
            id="import-editorial-input"
            accept="application/json,.json"
            hidden
          />
        </div>
      </section>
    </div>

    <div id="toast" class="toast hidden"></div>

    <!-- Edit Metadata Drawer -->
    <aside id="meta-drawer" class="meta-drawer hidden" role="dialog" aria-labelledby="meta-drawer-title" aria-hidden="true">
      <div class="meta-drawer-backdrop" data-meta-close></div>
      <div class="meta-drawer-panel" role="document">
        <header class="meta-drawer-header">
          <div class="meta-drawer-heading">
            <p class="meta-drawer-eyebrow">{t('admin.drawer.eyebrow', language)}</p>
            <h2 id="meta-drawer-title" class="meta-drawer-title">—</h2>
            <p class="meta-drawer-slug" id="meta-drawer-slug">—</p>
          </div>
          <button
            type="button"
            class="meta-drawer-close"
            data-meta-close
            aria-label={t('admin.drawer.close', language)}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </header>

        <form class="meta-form" id="meta-form" autocomplete="off" novalidate>
          <label class="meta-field">
            <span class="meta-label">{t('admin.field.displayTitle', language)}</span>
            <input class="meta-input" type="text" name="displayTitle" />
            <span class="meta-hint">{t('admin.field.displayTitleHint', language)}</span>
          </label>

          <label class="meta-field">
            <span class="meta-label">{t('admin.field.contentType', language)}</span>
            <select class="meta-select" name="contentType">
              <option value="book">{t('admin.option.book', language)}</option>
              <option value="course">{t('admin.option.course', language)}</option>
              <option value="article">{t('admin.option.article', language)}</option>
            </select>
          </label>

          <label class="meta-field">
            <span class="meta-label">{t('admin.field.category', language)}</span>
            <input
              class="meta-input"
              type="text"
              name="category"
              placeholder={t('admin.field.categoryPlaceholder', language)}
            />
          </label>

          <label class="meta-field">
            <span class="meta-label">{t('admin.field.seriesName', language)}</span>
            <input
              class="meta-input"
              type="text"
              name="seriesName"
              placeholder={t('admin.field.seriesPlaceholder', language)}
            />
          </label>

          <div class="meta-field meta-field--toggle">
            <div class="meta-field-text">
              <span class="meta-label">{t('admin.field.visibleInUniverse', language)}</span>
              <span class="meta-hint">{t('admin.field.visibleInUniverseHint', language)}</span>
            </div>
            <label class="meta-toggle" aria-label={t('admin.field.visibleInUniverseAria', language)}>
              <input type="checkbox" name="isVisibleInUniverse" />
              <span class="meta-toggle-track" aria-hidden="true"></span>
            </label>
          </div>

          <label class="meta-field">
            <span class="meta-label">{t('admin.field.visualMode', language)}</span>
            <select class="meta-select" name="visualMode">
              <option value="card">{t('admin.option.card', language)}</option>
              <option value="hidden">{t('admin.option.hidden', language)}</option>
            </select>
          </label>
        </form>

        <footer class="meta-drawer-footer">
          <button type="button" class="meta-btn meta-btn--ghost" data-meta-close>
            {t('admin.button.cancel', language)}
          </button>
          <button type="button" class="meta-btn meta-btn--primary" id="meta-save">
            {t('admin.button.save', language)}
          </button>
        </footer>
      </div>
    </aside>

    <!-- Series Edit Drawer.
         Reuses the .meta-drawer / .meta-form class system from the item
         drawer so the slide-from-inline-end animation, dark glass panel
         and form field styling work without duplication. JS targets this
         drawer by its own #series-drawer id. -->
    <aside id="series-drawer" class="meta-drawer hidden" role="dialog" aria-labelledby="series-drawer-title" aria-hidden="true">
      <div class="meta-drawer-backdrop" data-series-close></div>
      <div class="meta-drawer-panel" role="document">
        <header class="meta-drawer-header">
          <div class="meta-drawer-heading">
            {/* Eyebrow swaps between "Edit series" and "Create
                series" via JS based on the open mode — see
                openSeriesDrawer / openSeriesDrawerForNew. */}
            <p class="meta-drawer-eyebrow" id="series-drawer-eyebrow">{t('admin.series.drawer.eyebrow', language)}</p>
            <h2 id="series-drawer-title" class="meta-drawer-title">—</h2>
            <p class="meta-drawer-slug" id="series-drawer-name">—</p>
          </div>
          <button
            type="button"
            class="meta-drawer-close"
            data-series-close
            aria-label={t('admin.series.drawer.close', language)}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </header>

        <form class="meta-form" id="series-form" autocomplete="off" novalidate>
          <label class="meta-field">
            <span class="meta-label">{t('admin.series.field.displayTitle', language)}</span>
            <input class="meta-input" type="text" name="displayTitle" />
            <span class="meta-hint">{t('admin.series.field.displayTitleHint', language)}</span>
          </label>

          <label class="meta-field">
            <span class="meta-label">{t('admin.series.field.slug', language)}</span>
            <input class="meta-input meta-input--readonly" type="text" name="slug" readonly aria-readonly="true" tabindex="-1" />
            <span class="meta-hint">{t('admin.series.field.slugHint', language)}</span>
          </label>

          <label class="meta-field">
            <span class="meta-label">{t('admin.series.field.shortDescription', language)}</span>
            <input class="meta-input" type="text" name="shortDescription" maxlength="180" />
            <span class="meta-hint">{t('admin.series.field.shortDescriptionHint', language)}</span>
          </label>

          <label class="meta-field">
            <span class="meta-label">{t('admin.series.field.fullDescription', language)}</span>
            <textarea class="meta-input meta-textarea" name="fullDescription" rows="4"></textarea>
            <span class="meta-hint">{t('admin.series.field.fullDescriptionHint', language)}</span>
          </label>

          <label class="meta-field">
            <span class="meta-label">{t('admin.series.field.plannedBooksCount', language)}</span>
            <input class="meta-input" type="number" name="plannedBooksCount" inputmode="numeric" min="0" step="1" placeholder="—" />
            <span class="meta-hint">{t('admin.series.field.plannedBooksCountHint', language)}</span>
          </label>

          <div class="meta-field meta-field--readonly-summary">
            <span class="meta-label">{t('admin.series.field.actualReadOnly', language, { n: 0 })}</span>
            <span class="meta-hint">{t('admin.series.field.actualReadOnlyHint', language)}</span>
            <input type="hidden" name="actualBooksCount" value="0" data-actual-books-count />
          </div>

          <label class="meta-field">
            <span class="meta-label">{t('admin.series.field.assetFolder', language)}</span>
            <input class="meta-input meta-input--mono" type="text" name="assetFolder" placeholder="ai-engineering-series" />
            <span class="meta-hint">{t('admin.series.field.assetFolderHint', language)}</span>
          </label>

          <div class="meta-field">
            <span class="meta-label">{t('admin.series.field.color', language)}</span>
            <div class="meta-color-row">
              <button
                type="button"
                id="series-color-swatch"
                class="meta-color-swatch"
                aria-label={t('admin.series.field.color', language)}
              >
                <span class="meta-color-dot" id="series-color-dot"></span>
              </button>
              <input
                type="color"
                id="series-color-input"
                class="meta-color-input"
                aria-hidden="true"
                tabindex="-1"
              />
              <button
                type="button"
                id="series-color-clear"
                class="meta-color-clear"
              >{t('admin.series.field.colorClear', language)}</button>
            </div>
            <span class="meta-hint">{t('admin.series.field.colorHint', language)}</span>
          </div>

          <label class="meta-field">
            <span class="meta-label">{t('admin.series.field.order', language)}</span>
            <input class="meta-input" type="number" name="order" inputmode="numeric" step="1" placeholder="—" />
            <span class="meta-hint">{t('admin.series.field.orderHint', language)}</span>
          </label>

          <div class="meta-field meta-field--toggle">
            <div class="meta-field-text">
              <span class="meta-label">{t('admin.series.field.visibleInUniverse', language)}</span>
              <span class="meta-hint">{t('admin.series.field.visibleHint', language)}</span>
            </div>
            <label class="meta-toggle" aria-label={t('admin.series.field.visibleAria', language)}>
              <input type="checkbox" name="isVisibleInUniverse" />
              <span class="meta-toggle-track" aria-hidden="true"></span>
            </label>
          </div>

          <label class="meta-field">
            <span class="meta-label">{t('admin.series.field.visualMode', language)}</span>
            <select class="meta-select" name="visualMode">
              <option value="capsule">{t('admin.series.option.capsule', language)}</option>
              <option value="card">{t('admin.series.option.card', language)}</option>
              <option value="orbit-node">{t('admin.series.option.orbitNode', language)}</option>
            </select>
          </label>

          <label class="meta-field">
            <span class="meta-label">{t('admin.series.field.status', language)}</span>
            <select class="meta-select" name="status">
              <option value="active">{t('admin.series.status.active', language)}</option>
              <option value="draft">{t('admin.series.status.draft', language)}</option>
              <option value="hidden">{t('admin.series.status.hidden', language)}</option>
            </select>
            <span class="meta-hint">{t('admin.series.field.statusHint', language)}</span>
          </label>
        </form>

        <footer class="meta-drawer-footer">
          <button type="button" class="meta-btn meta-btn--ghost" data-series-close>
            {t('admin.button.cancel', language)}
          </button>
          <button type="button" class="meta-btn meta-btn--primary" id="series-save">
            {t('admin.series.button.save', language)}
          </button>
        </footer>
      </div>
    </aside>

    <!-- Delete Confirmation Modal — generic across books and series.
         Heading, body, warning, and confirm-label are populated by JS
         at show time (see showConfirmModal). The body element accepts a
         {{title}} placeholder which JS renders as a real <strong> with
         textContent (no HTML injection from user-supplied titles). -->
    <div id="delete-modal" class="modal hidden">
      <div class="modal-backdrop"></div>
      <div class="modal-content">
        <h3 id="modal-heading">⚠️ {t('admin.modal.title', language)}</h3>
        <p id="modal-body"></p>
        <p id="modal-warning" class="modal-warning">{t('admin.modal.warning', language)}</p>
        <div class="modal-actions">
          <button class="modal-btn modal-btn--cancel" id="modal-cancel">
            {t('admin.modal.cancel', language)}
          </button>
          <button class="modal-btn modal-btn--delete" id="modal-confirm">
            {t('admin.modal.confirm', language)}
          </button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ─────────────────────────────────────────────────────────────
     Knowledge Control Center — premium dark, warm charcoal + gold.
     Palette intentionally matches LeftSidebar charcoal/gold family
     (#0d0d10 / #16161c / #b8923f / cream-gold) instead of the light
     theme tokens used by the rest of the app.
     ───────────────────────────────────────────────────────────── */

  /* Hide the global Back-to-Top FAB (rendered by BaseLayout) while
     either edit drawer is open. The drawer slides in from the inline
     edge and the FAB is anchored in the same corner — without this
     rule they overlap, which made it look as if the FAB was attached
     to the drawer. Using `:has()` lets us key off the live drawer
     state (presence of `.meta-drawer` without `.hidden`) without
     touching the drawer's open/close JS. The :global wrapper is
     required because #back-to-top is rendered outside this scoped
     style's component tree.
     Closing the drawer adds `.hidden` back to it, the :has() match
     drops, and the FAB's own scroll handler resumes ownership of
     visibility — so it returns to its place automatically. */
  body:has(.meta-drawer:not(.hidden)) :global(#back-to-top) {
    display: none !important;
  }

  .kcc-shell {
    --kcc-ink: #0a0a0c;
    --kcc-surface: rgba(28, 28, 34, 0.62);
    --kcc-surface-strong: rgba(34, 34, 40, 0.78);
    --kcc-rim: rgba(255, 255, 255, 0.08);
    --kcc-rim-strong: rgba(255, 255, 255, 0.14);
    --kcc-gold: #c9a96e;
    --kcc-gold-soft: rgba(201, 169, 110, 0.22);
    --kcc-gold-rim: rgba(201, 169, 110, 0.35);
    --kcc-text: #ececea;
    --kcc-text-secondary: #a8a8a4;
    --kcc-text-muted: #6e6e6c;

    position: relative;
    min-height: calc(100vh - 64px);
    background:
      radial-gradient(ellipse 90% 60% at 30% -10%, rgba(201, 169, 110, 0.08) 0%, transparent 55%),
      radial-gradient(ellipse 70% 50% at 80% 110%, rgba(184, 146, 63, 0.06) 0%, transparent 60%),
      linear-gradient(180deg, #121215 0%, #0a0a0c 60%, #08080a 100%);
    color: var(--kcc-text);
    /* No `isolation: isolate` here. The metadata drawer is position:
       fixed with z-index: 10001 so it can paint over the global
       sticky header (z-50). Creating a new stacking context on this
       wrapper would lock the drawer below the header even at huge
       z-indexes — the header would clip the drawer's title. The
       internal z:0/z:1 layering between `.kcc-shell::before`
       (vignette) and `.kcc-wrap` (content) does not need a fresh
       context: position:relative on this element is enough to anchor
       the absolutely-positioned ::before to the shell. */
  }

  /* Subtle film grain / vignette layer */
  .kcc-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 50% 0%, transparent 60%, rgba(0, 0, 0, 0.45) 100%);
    z-index: 0;
  }

  .kcc-wrap {
    position: relative;
    z-index: 1;
    /* Knowledge Catalog table needs significantly more horizontal room
       than the previous card list. Cap at 1600px so ultra-wide monitors
       don't stretch every column to absurd widths, but give standard
       desktops the full 9-column width without horizontal scroll. */
    max-width: 1600px;
    margin: 0 auto;
    padding: 64px 28px 96px;
  }

  /* ── Header ─────────────────────────────────────────────── */

  .kcc-header {
    margin-bottom: 44px;
  }

  .kcc-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px 5px 10px;
    border-radius: 999px;
    background: rgba(201, 169, 110, 0.06);
    border: 1px solid var(--kcc-gold-rim);
    margin-bottom: 18px;
  }

  .kcc-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--kcc-gold);
    box-shadow: 0 0 8px rgba(201, 169, 110, 0.55);
  }

  .kcc-eyebrow-text {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--kcc-gold);
  }

  .kcc-title {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 2.25rem;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--kcc-text);
    margin: 0 0 10px;
  }

  .kcc-subtitle {
    color: var(--kcc-text-secondary);
    font-size: 0.95rem;
    line-height: 1.55;
    max-width: 56ch;
    margin: 0;
  }

  /* ── Sections ───────────────────────────────────────────── */

  .kcc-section {
    margin-top: 36px;
  }

  .kcc-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--kcc-rim);
  }

  .kcc-section-title {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--kcc-text-secondary);
    margin: 0;
  }

  .kcc-section-meta {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.78rem;
    color: var(--kcc-text-muted);
    letter-spacing: 0.04em;
  }

  /* ── Knowledge Catalog table ─────────────────────────────
     Wide management table replacing the previous card list. Built on
     <table> so the column widths balance naturally across rows and the
     header can stick under the global Yuval header. The container is
     a glass panel with overflow-x:auto so narrow viewports get a
     horizontal scrollbar instead of crushing the columns.

     Class .book-card is kept on each <tr> on purpose — every JS
     selector in this file (delete, paintCardFromMetadata, series
     detection, updateStats) targets `.book-card[data-slug]`, so
     reusing the class keeps the existing logic untouched.
     ───────────────────────────────────────────────────────── */

  /* The wrap is the visual panel only — NO `overflow-x: auto` here.
     Reason: a wrapper with overflow-x:auto becomes a scroll container,
     which then captures `position: sticky` from the inner <th>s. The
     sticky header would compute its `top: …` relative to the wrapper
     instead of the page, and end up pushed *below* the first row.
     Horizontal scroll on narrow viewports is handled by the page
     itself (or by a future inner scroll container that does not host
     the sticky header). */
  .kcc-table-wrap {
    background: var(--kcc-surface);
    border: 1px solid var(--kcc-rim);
    border-radius: 14px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    /* Inner glow so the table reads as one panel, not a flat rectangle. */
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 8px 28px rgba(0, 0, 0, 0.25);
  }

  .kcc-table {
    width: 100%;
    /* min-width keeps all 9 columns legible. Below this width the
       wrapper scrolls horizontally instead of letting the title cell
       collapse into one tight column. */
    min-width: 1340px;
    /* table-layout: fixed guarantees that <thead> column widths and
       <tbody> column widths stay locked together — without it, the
       first <tr> alone determines the layout and a long subtitle in
       row N can shift later rows out of alignment with the header. */
    table-layout: fixed;
    border-collapse: separate;
    border-spacing: 0;
    color: var(--kcc-text);
  }

  /* ── Sticky header ───────────────────────────────────────
     Stick each <th> under the global Yuval header (~72px). Using
     sticky on the <th>s — not on <thead> — works around the classic
     border-collapse + sticky bug where the row's bottom border
     disappears on scroll. */
  .kcc-thead .kcc-th {
    position: sticky;
    top: 72px;
    z-index: 2;
    background: linear-gradient(180deg, #16161c 0%, #131318 100%);
    color: var(--kcc-text-secondary);
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-align: start;
    padding: 12px 14px;
    border-bottom: 1px solid var(--kcc-rim-strong);
    white-space: nowrap;
  }

  .kcc-thead .kcc-th.col-actions,
  .kcc-thead .kcc-th.col-count,
  .kcc-thead .kcc-th.col-visibility {
    text-align: center;
  }

  /* ── Body cells ──────────────────────────────────────────
     Vertical-align top so the title cell — the only multi-line cell —
     stacks cleanly while the rest of the row sits at the same line
     height as the title. */
  .kcc-td {
    padding: 14px 14px;
    border-bottom: 1px solid var(--kcc-rim);
    font-size: 0.85rem;
    color: var(--kcc-text);
    vertical-align: top;
    line-height: 1.45;
  }

  .kcc-tr:hover .kcc-td {
    background: rgba(255, 255, 255, 0.02);
  }

  .kcc-tr:last-child .kcc-td {
    border-bottom: none;
  }

  /* Column widths — explicit because table-layout:fixed needs them.
     Title takes whatever's left; the rest are content-fit. Both <th>
     and <td> read these widths so the header stays aligned with the
     body on every viewport. */
  .col-cover       { width: 78px;  text-align: center; }
  .col-title       { width: auto; }
  .col-type        { width: 110px; }
  .col-series      { width: 160px; }
  .col-category    { width: 170px; }
  .col-visibility  { width: 120px; text-align: center; }
  .col-progress    { width: 130px; }
  .col-count       { width: 90px;  text-align: center; }

  /* ── Cover uploader cell ────────────────────────────────
     The cover column is the click target for swapping a book's
     thumbnail. The thumbnail and the upload affordance are the same
     element: the entire button is the picker trigger so a click
     anywhere on the image opens the file dialog. The visual rule is
     "image first, affordance second" — the overlay (+ icon) is faint
     by default and only brightens on hover/focus so a populated row
     reads as content, not as a tool. Empty cells flip the priority:
     the placeholder icon is the focal point and the + overlay is
     redundant, so we keep both visible to telegraph the action. */
  .cover-uploader {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* Aspect matches the canonical front.png (1600:2320 ≈ 1:1.45) so
       the thumb shows the artwork at its authored proportions. The
       artwork itself is composition-heavy (top icon, title, subtitle,
       author at the bottom), so we use object-fit: contain on the
       inner img — cropping would chop the title or the author byline. */
    width: 56px;
    height: 80px;
    border-radius: 4px;
    border: 1px solid color-mix(in oklab, currentColor 18%, transparent);
    background: color-mix(in oklab, currentColor 4%, transparent);
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    color: inherit;
    transition: border-color 140ms ease, transform 140ms ease, box-shadow 140ms ease;
  }
  .cover-uploader:hover,
  .cover-uploader:focus-visible {
    border-color: color-mix(in oklab, var(--gold, #c9a96e) 65%, transparent);
    box-shadow: 0 0 0 1px color-mix(in oklab, var(--gold, #c9a96e) 35%, transparent);
    outline: none;
  }
  .cover-uploader[data-uploading="true"] {
    cursor: progress;
    opacity: 0.7;
  }

  .cover-thumb {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 3px;
  }
  .cover-thumb--empty {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: color-mix(in oklab, currentColor 40%, transparent);
  }

  /* Plus-icon affordance pinned to the bottom-end corner. Logical
     properties so RTL flips the corner naturally. */
  .cover-uploader-overlay {
    position: absolute;
    inset-block-end: 2px;
    inset-inline-end: 2px;
    width: 18px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(15, 19, 28, 0.85);
    color: #fff;
    opacity: 0;
    transition: opacity 140ms ease;
    pointer-events: none;
  }
  .cover-uploader:hover .cover-uploader-overlay,
  .cover-uploader:focus-visible .cover-uploader-overlay,
  .cover-uploader .cover-thumb--empty + .cover-uploader-overlay {
    opacity: 1;
  }
  /* Actions column needs to fit all three buttons in Hebrew without
     overflowing into the chapters column. Measured worst case:
     "עריכת מטא-דאטה" + icon (~165px) + 6px gap + "ניקוי נתונים"
     (~115px) + 6px gap + "מחיקה" + icon (~85px) ≈ 380px. */
  .col-actions     { width: 380px; }

  /* ── Title cell stack ────────────────────────────────────
     The first column shows ONLY book title and subtitle. Slug,
     monogram and other file-system identifiers were removed so the
     row reads as editorial content, not an ops dump. Wrapping is
     allowed without ellipsis — wide rows are the whole point of
     this table. */
  .kcc-title-stack {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .book-title {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 1.0rem;
    font-weight: 500;
    color: var(--kcc-text);
    letter-spacing: -0.005em;
    /* Allow wrapping — explicit override of any inherited nowrap. */
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
    overflow-wrap: anywhere;
    line-height: 1.35;
  }

  .book-subtitle {
    font-size: 0.82rem;
    color: var(--kcc-text-secondary);
    line-height: 1.45;
    white-space: normal;
    overflow-wrap: anywhere;
  }

  /* ── Inline cell visuals ─────────────────────────────────
     Each metadata column gets a small dedicated visual treatment so
     the table reads at a glance instead of as a wall of grey text. */
  .kcc-pill {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 999px;
    background: rgba(201, 169, 110, 0.1);
    border: 1px solid var(--kcc-gold-rim);
    color: var(--kcc-gold);
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .kcc-muted {
    color: var(--kcc-text-muted);
    font-style: italic;
    font-size: 0.8rem;
  }

  .kcc-num {
    display: inline-block;
    min-width: 28px;
    padding: 2px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--kcc-rim);
    color: var(--kcc-text);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    font-size: 0.78rem;
    text-align: center;
  }

  .kcc-vis {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 3px 10px 3px 8px;
    border-radius: 999px;
    border: 1px solid var(--kcc-rim);
    background: rgba(255, 255, 255, 0.03);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--kcc-text-secondary);
    white-space: nowrap;
  }

  .kcc-vis-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--kcc-text-muted);
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.4) inset;
  }

  .kcc-vis--on {
    border-color: rgba(120, 200, 130, 0.32);
    background: rgba(120, 200, 130, 0.08);
    color: #9ad6a3;
  }

  .kcc-vis--on .kcc-vis-dot {
    background: #6dd97f;
    box-shadow: 0 0 8px rgba(120, 220, 140, 0.55);
  }

  .kcc-vis--off {
    border-color: rgba(220, 38, 38, 0.28);
    background: rgba(220, 38, 38, 0.06);
    color: #f0a9a9;
  }

  .kcc-vis--off .kcc-vis-dot {
    background: #d96d6d;
  }

  /* Reader-data stat retains the original pill look so existing JS
     that swaps its text content keeps reading as the same widget. */
  .stat {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--kcc-rim);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--kcc-text-secondary);
    white-space: nowrap;
    letter-spacing: 0.02em;
  }


  /* ── Actions: ghost buttons, destructive de-emphasised ── */

  .book-actions {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
    justify-content: flex-end;
    flex-wrap: nowrap;
  }

  .clean-btn {
    padding: 7px 14px;
    border-radius: 8px;
    border: 1px solid var(--kcc-rim);
    background: rgba(255, 255, 255, 0.02);
    color: var(--kcc-text-secondary);
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition:
      background 160ms cubic-bezier(0.4, 0, 0.2, 1),
      color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .clean-btn:hover {
    background: rgba(201, 169, 110, 0.08);
    color: var(--kcc-gold);
    border-color: var(--kcc-gold-rim);
  }

  /* Edit metadata — PRIMARY safe action.
     The most prominent of the three row actions: gold-tinted fill +
     gold rim signal "this is the everyday editorial control", while
     destructive Delete stays a quiet ghost on the other side. */
  .edit-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border-radius: 8px;
    border: 1px solid var(--kcc-gold-rim);
    background: rgba(201, 169, 110, 0.14);
    color: var(--kcc-gold);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition:
      background 160ms cubic-bezier(0.4, 0, 0.2, 1),
      color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .edit-btn svg {
    flex-shrink: 0;
    opacity: 0.9;
  }

  .edit-btn:hover {
    background: rgba(201, 169, 110, 0.22);
    border-color: rgba(201, 169, 110, 0.55);
    color: #e8d39a;
    box-shadow: 0 4px 12px -4px rgba(184, 146, 63, 0.35);
  }

  .edit-btn:hover svg {
    opacity: 1;
  }

  .edit-btn:focus-visible {
    outline: none;
    border-color: rgba(201, 169, 110, 0.7);
    box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.22);
  }

  .delete-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    border-radius: 8px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--kcc-text-muted);
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition:
      background 160ms cubic-bezier(0.4, 0, 0.2, 1),
      color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .delete-btn svg {
    flex-shrink: 0;
    opacity: 0.75;
  }

  .delete-btn:hover {
    background: rgba(220, 38, 38, 0.08);
    color: #f87171;
    border-color: rgba(220, 38, 38, 0.32);
  }

  .delete-btn:hover svg {
    opacity: 1;
  }

  /* ── Global card ─────────────────────────────────────────── */

  .global-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    background: var(--kcc-surface);
    border: 1px solid var(--kcc-rim);
    border-radius: 14px;
    padding: 18px 20px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .global-card-info {
    flex: 1;
    min-width: 0;
  }

  .global-card-title {
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--kcc-text);
    margin: 0 0 3px;
  }

  .global-card-desc {
    font-size: 0.8rem;
    color: var(--kcc-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .clean-btn--global {
    margin-top: 0;
    flex-shrink: 0;
  }

  /* ── Toast ──────────────────────────────────────────────── */

  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(20, 20, 24, 0.92);
    color: #fff;
    border: 1px solid var(--kcc-gold-rim);
    padding: 10px 22px;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.5);
    z-index: 9999;
    transition: opacity 0.3s;
  }

  .toast.hidden { display: none; }

  /* ── Modal: dark glass version ──────────────────────────── */

  .modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal.hidden { display: none; }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .modal-content {
    position: relative;
    background: linear-gradient(180deg, #1a1a1f 0%, #131318 100%);
    border: 1px solid var(--kcc-rim-strong);
    border-radius: 16px;
    padding: 28px;
    max-width: 420px;
    width: 90%;
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    text-align: center;
    color: #ececea;
  }

  .modal-content h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: #ececea;
    margin: 0 0 12px;
  }

  .modal-content p {
    font-size: 0.9rem;
    color: #a8a8a4;
    margin: 0 0 8px;
    line-height: 1.55;
  }

  .modal-content strong {
    color: #ececea;
  }

  .modal-warning {
    color: #f87171 !important;
    font-weight: 500;
    font-size: 0.85rem !important;
  }

  .modal-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-top: 22px;
  }

  .modal-btn {
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      background 160ms cubic-bezier(0.2, 0, 0, 1),
      color 160ms cubic-bezier(0.2, 0, 0, 1),
      border-color 160ms cubic-bezier(0.2, 0, 0, 1);
  }

  .modal-btn--cancel {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--kcc-rim);
    color: #ececea;
  }

  .modal-btn--cancel:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--kcc-rim-strong);
  }

  .modal-btn--delete {
    background: rgba(220, 38, 38, 0.92);
    border: 1px solid rgba(220, 38, 38, 0.6);
    color: #fff;
  }

  .modal-btn--delete:hover {
    background: rgb(220, 38, 38);
  }

  .modal-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Series Management ──────────────────────────────────── */

  /* Section header — adds a subtitle row under the existing
     all-caps title so the Series block reads as a deliberate
     management area instead of a generic list. */
  .series-section-head {
    align-items: flex-start;
  }
  .series-section-titles {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .series-section-subtitle {
    margin: 0;
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--kcc-text-secondary);
    letter-spacing: 0;
    text-transform: none;
    max-width: 56ch;
  }

  /* Right cluster of the section header: count meta + "New series" CTA.
     The CTA reads as a primary action in the section's own context —
     gold outline + cream text — so it stands clearly apart from the
     row-level icon-only buttons further below. */
  .series-section-actions {
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .series-new-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--gold-cream, #ffe8a3);
    background: color-mix(in oklab, var(--gold, #c9a96e) 12%, transparent);
    border: 1px solid color-mix(in oklab, var(--gold, #c9a96e) 60%, transparent);
    border-radius: 6px;
    cursor: pointer;
    transition: background 140ms ease, border-color 140ms ease, transform 140ms ease;
  }
  .series-new-btn:hover {
    background: color-mix(in oklab, var(--gold, #c9a96e) 22%, transparent);
    border-color: color-mix(in oklab, var(--gold, #c9a96e) 80%, transparent);
  }
  .series-new-btn:active {
    transform: translateY(1px);
  }

  /* Per-row delete button in the series table. Same visual language
     as the books-table delete button (red-tinted icon button) but
     scoped to the series-actions cell so the two delete buttons
     don't share a class — that way visual changes to one don't
     accidentally touch the other. */
  .series-delete-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    padding: 0;
    margin-inline-start: 8px;
    color: color-mix(in oklab, #f57b6a 75%, currentColor);
    background: transparent;
    border: 1px solid color-mix(in oklab, #f57b6a 30%, transparent);
    border-radius: 6px;
    cursor: pointer;
    transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
  }
  .series-delete-btn:hover {
    background: color-mix(in oklab, #f57b6a 18%, transparent);
    border-color: color-mix(in oklab, #f57b6a 70%, transparent);
    color: #ff8e7d;
  }

  /* ── Series Management table ────────────────────────────────
     Same visual family as the books table (`.kcc-table-wrap`,
     `.kcc-table`, `.kcc-th`, `.kcc-td`). Only the column widths and a
     handful of inline cell visuals (status pill, universe pill, slim
     progress bar, monospace folder code) live here — everything else
     inherits from the existing kcc-table rules above. */

  /* Wrapper override: the books table has `min-width: 1340px` to keep
     its 8 columns legible. The series table needs slightly less and
     gets its own min-width via `.series-table` below. The wrap stays
     identical so the panel chrome (radius, blur, glow) matches. */
  .series-table-wrap {
    margin-block-start: 0;
  }

  .series-table {
    /* 10 columns; min-width keeps every column readable before the
       horizontal scrollbar kicks in on narrow viewports. */
    min-width: 1280px;
  }

  /* Column widths — auto for the description (the only freely-wrapping
     column), explicit for the rest so the row reads as a clean grid.
     `text-align: center` is applied where the cell content is purely
     numeric or pill-shaped so the eye scans down a column without the
     header label drifting to a different alignment than the body. */
  .col-series-name      { width: 200px; }
  .col-series-desc      { width: auto;  min-width: 240px; }
  .col-series-status    { width: 110px; text-align: center; }
  .col-series-universe  { width: 150px; text-align: center; }
  .col-series-actual    { width: 110px; text-align: center; }
  .col-series-planned   { width: 130px; text-align: center; }
  .col-series-progress  { width: 200px; }
  .col-series-folder    { width: 200px; }
  .col-series-order     { width: 100px; text-align: center; }
  .col-series-actions   { width: 150px; text-align: center; }

  /* Title cell — same `.kcc-title-stack` pattern as the books table.
     The slug is intentionally muted so the display title leads. */
  .series-row-title {
    margin: 0;
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.96rem;
    font-weight: 500;
    color: var(--kcc-text);
    line-height: 1.3;
    letter-spacing: -0.005em;
    overflow-wrap: anywhere;
  }
  .series-row-slug {
    margin: 0;
    font-family: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
    font-size: 0.7rem;
    color: var(--kcc-text-muted);
    letter-spacing: 0.02em;
    overflow-wrap: anywhere;
  }

  /* Status pill — three colour-coded states matching the existing
     `.kcc-vis--on` / `--off` palette. Width is fluid (no fixed) so
     Hebrew "פעילה" / "טיוטה" / "מוסתרת" each sit comfortably without
     padding adjustments per language. */
  .series-status-pill {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 999px;
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    border: 1px solid var(--kcc-rim);
    background: rgba(255, 255, 255, 0.03);
    color: var(--kcc-text-secondary);
    white-space: nowrap;
  }
  .series-status-pill[data-status="active"] {
    background: rgba(120, 200, 130, 0.10);
    border-color: rgba(120, 200, 130, 0.36);
    color: #9ad6a3;
  }
  .series-status-pill[data-status="draft"] {
    background: rgba(218, 165, 32, 0.10);
    border-color: rgba(218, 165, 32, 0.40);
    color: #e8c468;
  }
  .series-status-pill[data-status="hidden"] {
    background: rgba(220, 38, 38, 0.10);
    border-color: rgba(220, 38, 38, 0.36);
    color: #f0a9a9;
  }

  /* Universe pill — "מוצגת במרחב" / "מוסתרת מהמרחב". Two states
     only, both rendered as the same shape so the column reads as a
     single visual rhythm. */
  .series-universe-pill {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 999px;
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border: 1px solid var(--kcc-rim);
    background: rgba(255, 255, 255, 0.03);
    color: var(--kcc-text-secondary);
    white-space: nowrap;
  }
  .series-universe-pill[data-on="true"] {
    background: rgba(120, 200, 130, 0.08);
    border-color: rgba(120, 200, 130, 0.32);
    color: #9ad6a3;
  }
  .series-universe-pill[data-on="false"] {
    background: rgba(220, 38, 38, 0.08);
    border-color: rgba(220, 38, 38, 0.32);
    color: #f0a9a9;
  }

  /* Numeric cells — tabular-nums + center alignment line up the
     digits across rows so a quick scan answers "which series has
     more items?" without the eye recalibrating. */
  .series-cell-num {
    text-align: center;
    font-variant-numeric: tabular-nums;
  }

  /* Progress cell — counter on top, slim bar below. Bar fill picks
     up the per-series colour from `--series-color` set on the row. */
  .series-progress-cell {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .series-progress-counter {
    font-size: 0.78rem;
    color: var(--kcc-text-secondary);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.01em;
  }
  .series-progress-bar {
    position: relative;
    width: 100%;
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }
  .series-progress-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(
      90deg,
      var(--series-color, var(--kcc-gold)),
      color-mix(in srgb, var(--series-color, var(--kcc-gold)) 60%, transparent)
    );
    box-shadow: 0 0 8px -2px var(--series-color, var(--kcc-gold));
    transition: width 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Asset folder cell — monospace pill matching the visual rhythm
     of `<code>` inline elements but boxed so the column reads as
     filesystem identifier. */
  .series-folder-code {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--kcc-rim);
    color: var(--kcc-text);
    font-family: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
    font-size: 0.74rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
    overflow: hidden;
    max-width: 100%;
    text-overflow: ellipsis;
  }

  /* Empty state — single full-width row with muted text. Mirrors
     the books table's empty handling and keeps the table chrome
     intact so the section still reads as a "data area" rather than
     a placeholder card. */
  .series-empty-row .series-empty-cell {
    text-align: center;
    color: var(--kcc-text-muted);
    font-size: 0.85rem;
    padding: 26px 16px;
    background: rgba(255, 255, 255, 0.012);
    border-bottom: none;
  }

  /* Hover affordance — same gentle row tint as the books table so
     the two tables behave identically when the cursor moves over
     them. */
  .series-row.kcc-tr:hover .kcc-td {
    background: rgba(255, 255, 255, 0.02);
  }
  .series-row.kcc-tr:last-child .kcc-td {
    border-bottom: none;
  }

  /* The series-edit-btn shares its visual treatment with the per-item
     .edit-btn (gold-tinted primary action) but has its own selector so
     class-list changes on items don't accidentally tweak the series row. */
  .series-edit-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border-radius: 8px;
    border: 1px solid var(--kcc-gold-rim);
    background: rgba(201, 169, 110, 0.14);
    color: var(--kcc-gold);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition:
      background 160ms cubic-bezier(0.4, 0, 0.2, 1),
      color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .series-edit-btn svg {
    flex-shrink: 0;
    opacity: 0.9;
  }

  .series-edit-btn:hover {
    background: rgba(201, 169, 110, 0.22);
    border-color: rgba(201, 169, 110, 0.55);
    color: #e8d39a;
    box-shadow: 0 4px 12px -4px rgba(184, 146, 63, 0.35);
  }

  .series-edit-btn:focus-visible {
    outline: none;
    border-color: rgba(201, 169, 110, 0.7);
    box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.22);
  }

  /* Color-picker row inside the Series Edit drawer. The native color
     input is hidden and triggered by the swatch button so the visual
     stays in the dark premium palette. */
  .meta-color-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .meta-color-swatch {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    padding: 0;
    border-radius: 999px;
    border: 1px solid var(--kcc-rim);
    background: rgba(255, 255, 255, 0.02);
    display: grid;
    place-items: center;
    cursor: pointer;
    transition: border-color 160ms, transform 160ms;
  }

  .meta-color-swatch:hover {
    border-color: var(--kcc-gold-rim);
    transform: scale(1.04);
  }

  .meta-color-swatch:focus-visible {
    outline: none;
    border-color: var(--kcc-gold-rim);
    box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.18);
  }

  .meta-color-dot {
    display: block;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--meta-color-current, var(--kcc-gold));
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.4) inset;
  }

  .meta-color-input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }

  .meta-color-clear {
    padding: 6px 12px;
    border-radius: 8px;
    border: 1px solid var(--kcc-rim);
    background: rgba(255, 255, 255, 0.02);
    color: var(--kcc-text-secondary);
    font-size: 0.78rem;
    cursor: pointer;
    transition: background 160ms, color 160ms, border-color 160ms;
  }

  .meta-color-clear:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--kcc-rim-strong);
    color: var(--kcc-text);
  }

  .meta-color-clear:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* ── Edit Metadata drawer ───────────────────────────────── */

  .meta-drawer {
    position: fixed;
    /* Start BELOW the global Yuval header (sticky, ~72px — matches
       --library-header-offset elsewhere in the app). Both the panel
       and the backdrop are children of this container, so shifting
       the top here keeps the header fully visible above the drawer
       and stops the eyebrow / title from being clipped. */
    inset-block-start: 72px;
    inset-inline: 0;
    inset-block-end: 0;
    z-index: 10001;
    display: flex;
    justify-content: flex-end;
    pointer-events: none;
  }

  /* Hebrew SOURCE_LANGUAGE makes /admin RTL by default. Flip the
     drawer to slide from the inline-end edge in both directions. */
  [dir="rtl"] .meta-drawer {
    justify-content: flex-start;
  }

  .meta-drawer.hidden { display: none; }

  .meta-drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    transition: background 240ms cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: auto;
  }

  .meta-drawer.is-open .meta-drawer-backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .meta-drawer-panel {
    position: relative;
    width: min(440px, 100%);
    height: 100%;
    background: linear-gradient(180deg, #1a1a1f 0%, #131318 100%);
    border-inline-start: 1px solid var(--kcc-rim-strong);
    box-shadow: -30px 0 80px rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
    pointer-events: auto;
    transform: translateX(100%);
    transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  [dir="rtl"] .meta-drawer-panel {
    transform: translateX(-100%);
    box-shadow: 30px 0 80px rgba(0, 0, 0, 0.5);
  }

  .meta-drawer.is-open .meta-drawer-panel {
    transform: translateX(0);
  }

  .meta-drawer-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 24px 24px 18px;
    border-bottom: 1px solid var(--kcc-rim);
  }

  .meta-drawer-heading {
    flex: 1;
    min-width: 0;
  }

  .meta-drawer-eyebrow {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--kcc-gold);
    margin: 0 0 6px;
  }

  .meta-drawer-title {
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--kcc-text);
    margin: 0 0 4px;
    overflow-wrap: break-word;
  }

  .meta-drawer-slug {
    font-family: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
    font-size: 0.72rem;
    color: var(--kcc-text-muted);
    margin: 0;
    letter-spacing: 0.02em;
    overflow-wrap: anywhere;
  }

  .meta-drawer-close {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid var(--kcc-rim);
    background: rgba(255, 255, 255, 0.02);
    color: var(--kcc-text-secondary);
    cursor: pointer;
    transition: background 160ms, color 160ms, border-color 160ms;
  }

  .meta-drawer-close:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--kcc-text);
    border-color: var(--kcc-rim-strong);
  }

  .meta-form {
    flex: 1;
    overflow-y: auto;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .meta-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .meta-field--toggle {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 14px;
    border: 1px solid var(--kcc-rim);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
  }

  .meta-field-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .meta-label {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--kcc-text);
    letter-spacing: 0.01em;
  }

  .meta-hint {
    font-size: 0.72rem;
    color: var(--kcc-text-muted);
    line-height: 1.45;
  }

  .meta-input,
  .meta-select {
    width: 100%;
    padding: 9px 12px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--kcc-rim);
    border-radius: 8px;
    color: var(--kcc-text);
    font-family: inherit;
    font-size: 0.9rem;
    line-height: 1.4;
    transition: border-color 160ms, background 160ms, box-shadow 160ms;
  }

  .meta-input::placeholder {
    color: var(--kcc-text-muted);
  }

  .meta-input:focus,
  .meta-select:focus {
    outline: none;
    border-color: var(--kcc-gold-rim);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.12);
  }

  /* Read-only slug — visually muted so the user can scan it but
     understands it isn't editable. Cursor stays as text so the
     value can still be selected and copied. */
  .meta-input--readonly {
    background: rgba(255, 255, 255, 0.02);
    color: var(--kcc-text-muted);
    cursor: text;
  }
  .meta-input--readonly:focus {
    border-color: var(--kcc-rim);
    background: rgba(255, 255, 255, 0.02);
    box-shadow: none;
  }

  /* Monospace input for filesystem-shaped values (asset folder). */
  .meta-input--mono {
    font-family: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
    font-size: 0.84rem;
    letter-spacing: 0.01em;
  }

  /* Textarea — same look as .meta-input, just with a comfortable
     resize handle and a min-height that fits ~4 lines. */
  .meta-textarea {
    min-height: 96px;
    resize: vertical;
    line-height: 1.5;
  }

  /* Read-only computed summary inside the drawer. Renders just like
     a meta-field but without an input — the label is the value, the
     hint explains why it's read-only. The hidden mirror input keeps
     the value programmatically accessible for tests/screenshots. */
  .meta-field--readonly-summary {
    padding: 10px 12px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px dashed var(--kcc-rim);
  }
  .meta-field--readonly-summary .meta-label {
    color: var(--kcc-text);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .meta-field--readonly-summary .meta-hint {
    color: var(--kcc-text-muted);
  }

  .meta-select {
    appearance: none;
    -webkit-appearance: none;
    background-image:
      linear-gradient(45deg, transparent 50%, var(--kcc-text-secondary) 50%),
      linear-gradient(-45deg, transparent 50%, var(--kcc-text-secondary) 50%);
    background-position:
      calc(100% - 18px) 50%,
      calc(100% - 13px) 50%;
    background-size: 5px 5px, 5px 5px;
    background-repeat: no-repeat;
    padding-inline-end: 30px;
  }

  [dir="rtl"] .meta-select {
    background-position:
      18px 50%,
      13px 50%;
    padding-inline-end: 12px;
    padding-inline-start: 30px;
  }

  /* Dropdown options — keep them readable when the OS popup opens.
     The closed select already inherits the dark drawer background;
     the OPEN list is what browsers paint with native colors (light
     grey on most platforms), so we override it explicitly here.
     Browser support note: Chrome/Edge/Firefox on Windows and Linux
     honor `option { background, color }`. Safari on macOS uses the
     system picker and ignores these rules — there is no reliable CSS
     fix for that without replacing <select> with a custom widget,
     which the spec for this fix explicitly excludes. The duplicate
     `background` + `background-color` declarations are intentional:
     some engines respect one but not the other depending on the
     widget pipeline. */
  .meta-select option {
    background: #16161c;
    background-color: #16161c;
    color: var(--kcc-text);
    padding: 6px 8px;
  }

  .meta-select option:checked {
    background: rgba(201, 169, 110, 0.22);
    background-color: rgba(201, 169, 110, 0.22);
    color: var(--kcc-gold);
    font-weight: 600;
  }

  /* Hover styling on <option> is honored on Firefox; Chrome/Edge
     paint hover via the native highlight color, but a CSS attempt
     here is harmless when ignored and helps where supported. */
  .meta-select option:hover,
  .meta-select option:focus {
    background: rgba(201, 169, 110, 0.16);
    background-color: rgba(201, 169, 110, 0.16);
    color: var(--kcc-gold);
  }

  .meta-select option:disabled {
    color: var(--kcc-text-muted);
  }

  /* Toggle switch */
  .meta-toggle {
    position: relative;
    display: inline-block;
    width: 40px;
    height: 22px;
    flex-shrink: 0;
    cursor: pointer;
  }

  .meta-toggle input {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    opacity: 0;
    cursor: pointer;
  }

  .meta-toggle-track {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid var(--kcc-rim);
    position: relative;
    transition: background 180ms, border-color 180ms;
  }

  .meta-toggle-track::after {
    content: "";
    position: absolute;
    inset-inline-start: 2px;
    top: 2px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #d6d6d2;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
    transition: inset-inline-start 200ms cubic-bezier(0.4, 0, 0.2, 1), background 180ms;
  }

  .meta-toggle input:checked + .meta-toggle-track {
    background: rgba(201, 169, 110, 0.32);
    border-color: var(--kcc-gold-rim);
  }

  .meta-toggle input:checked + .meta-toggle-track::after {
    inset-inline-start: calc(100% - 18px);
    background: var(--kcc-gold);
  }

  .meta-toggle input:focus-visible + .meta-toggle-track {
    box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.24);
  }

  .meta-drawer-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    padding: 18px 24px 22px;
    border-top: 1px solid var(--kcc-rim);
  }

  .meta-btn {
    padding: 9px 18px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition:
      background 160ms cubic-bezier(0.4, 0, 0.2, 1),
      color 160ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .meta-btn--ghost {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--kcc-rim);
    color: var(--kcc-text-secondary);
  }

  .meta-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--kcc-rim-strong);
    color: var(--kcc-text);
  }

  .meta-btn--primary {
    background: linear-gradient(180deg, #d4ba74 0%, #b8923f 100%);
    border: 1px solid rgba(184, 146, 63, 0.6);
    color: #1d1305;
    font-weight: 600;
    box-shadow: 0 4px 14px rgba(184, 146, 63, 0.25);
  }

  .meta-btn--primary:hover {
    background: linear-gradient(180deg, #e2cf95 0%, #c9a96e 100%);
    box-shadow: 0 6px 18px rgba(184, 146, 63, 0.35);
  }

  .meta-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Responsive ─────────────────────────────────────────── */

  /* On narrow viewports the table keeps its column layout but the
     wrapper scrolls horizontally — this is a management surface, not a
     phone-first reading experience, so a clean horizontal scroll is the
     right tradeoff. We only trim the global page chrome and tighten
     paddings inside cells. */
  @media (max-width: 880px) {
    .kcc-th,
    .kcc-td {
      padding: 12px 12px;
    }

    .delete-btn-label,
    .edit-btn-label {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .kcc-wrap {
      padding: 36px 18px 64px;
    }

    .kcc-title {
      font-size: 1.75rem;
    }

    .global-card {
      flex-direction: column;
      align-items: stretch;
    }

    .clean-btn--global {
      align-self: flex-start;
    }

    .meta-drawer-panel {
      width: 100%;
    }

    .meta-drawer-footer {
      padding: 16px 18px 20px;
    }

    .meta-form {
      padding: 18px;
    }
  }
</style>

<script>
  import {
    getMetadata,
    setMetadata,
    getSeriesMetadata,
    setSeriesMetadata,
    getAllMetadata,
    getAllSeriesMetadata,
    deleteSeriesMetadata,
    replaceAllMetadata,
    replaceAllSeriesMetadata,
  } from '../utils/content-metadata';
  import { slugifySeriesName } from '../types/content-metadata';
  import { getKnowledgeCardAssets } from '../utils/library/knowledge-cards';
  import type {
    ContentMetadata,
    SeriesMetadata,
    SeriesStatus,
  } from '../types/content-metadata';

  // ── i18n bundle ──────────────────────────────────────────────
  // The single source of admin runtime strings is the i18n table at
  // src/i18n/translations.ts. The .astro frontmatter resolves the
  // active language, calls t() per key, and emits the bundle as a
  // JSON blob on `.kcc-shell[data-i18n-bundle]`. This script reads
  // it once and substitutes placeholders at runtime — no parallel
  // string source, no hardcoded user-facing copy in the script.
  type AdminI18nBundle = {
    statNoData: string;
    statItemsOne: string;
    statItemsManyTpl: string;
    toastCleanedBook: string;
    toastNoBookData: string;
    toastCleanedGlobal: string;
    toastNoGlobalData: string;
    toastBookDeleted: string;
    toastDeleteError: string;
    toastDeleteFailed: string;
    toastNetworkError: string;
    toastMetadataSaved: string;
    toastEditorialExportedTpl: string;
    toastEditorialImportedTpl: string;
    toastEditorialImportInvalidTpl: string;
    importConfirmTpl: string;
    modalDeleting: string;
    modalConfirmText: string;
    modalHeadingBook: string;
    modalBodyBook: string;
    modalWarningBook: string;
    modalHeadingSeries: string;
    modalBodySeries: string;
    modalWarningSeries: string;
    // Series Management
    seriesEmpty: string;
    seriesCountTpl: string;
    seriesItemsTpl: string;
    seriesAvailableTpl: string;
    seriesEditAriaTpl: string;
    seriesEditTitle: string;
    seriesTagCapsule: string;
    toastSeriesSaved: string;
    // Rich-card redesign
    seriesCardItemsOfTpl: string;
    seriesCardItemsOnlyTpl: string;
    seriesCardActualLabelTpl: string;
    seriesCardAssetFolderLabel: string;
    seriesCardAssetFolderEmpty: string;
    seriesCardEditButton: string;
    seriesCardNoDescription: string;
    seriesCardProgressAriaTpl: string;
    seriesStatusActive: string;
    seriesStatusDraft: string;
    seriesStatusHidden: string;
    seriesBadgeVisible: string;
    seriesBadgeHiddenFromUni: string;
    seriesOptionCapsule: string;
    seriesOptionCard: string;
    seriesOptionOrbitNode: string;
    seriesActualReadOnlyTpl: string;
    seriesActionNew: string;
    seriesActionDelete: string;
    seriesActionDeleteAriaTpl: string;
    seriesActionDeleteTitle: string;
    seriesDrawerEyebrowNew: string;
    seriesFieldName: string;
    seriesFieldNameHint: string;
    seriesToastDeleted: string;
    seriesToastCreated: string;
    seriesToastRenamed: string;
    seriesToastAlreadyExists: string;
    seriesToastNameRequired: string;
    seriesCellNotSet: string;
    seriesCellNoFolder: string;
    seriesCellDash: string;
    cellEmpty: string;
    cellVisible: string;
    cellHidden: string;
    cellNoSeries: string;
    cellNoCategory: string;
    optionBook: string;
    optionCourse: string;
    optionArticle: string;
    // Cover upload
    coverPlaceholder: string;
    coverUpload: string;
    coverUploadAria: string;
    coverReplace: string;
    coverUploading: string;
    toastCoverUploaded: string;
    toastCoverUploadFailed: string;
    toastCoverInvalidType: string;
    toastCoverTooLarge: string;
  };

  const i18nRoot = document.querySelector<HTMLElement>('.kcc-shell');
  const i18n: AdminI18nBundle = (() => {
    try {
      const raw = i18nRoot?.dataset.i18nBundle;
      return raw ? (JSON.parse(raw) as AdminI18nBundle) : ({} as AdminI18nBundle);
    } catch {
      return {} as AdminI18nBundle;
    }
  })();

  function fmt(tpl: string | undefined, params: Record<string, string | number>): string {
    if (!tpl) return '';
    return tpl.replace(/\{\{(\w+)\}\}/g, (_, name) =>
      params[name] !== undefined ? String(params[name]) : `{{${name}}}`,
    );
  }

  const BOOK_PREFIXES = (slug: string) => [
    `yuval_bookmarks_${slug}`,
    `yuval_highlights_${slug}`,   // prefix - will match all chapters
    `yuval_reading_progress_${slug}`,
    `yuval_reading_stats_${slug}`,
    `yuval_reading_goals_${slug}`,
  ];

  const GLOBAL_KEYS = [
    'yuval_language',
    'yuval-theme',
    'yuval-typography',
    'yuval_tts_voice_he',
    'yuval_tts_voice_en',
    'yuval_tts_voice_es',
    'yuval_tts_speed',
    'yuval_onboarded_v1',
    'yuval_reading_goal',
  ];

  function countBookKeys(slug: string): number {
    let count = 0;
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i) || '';
      if (key.includes(`_${slug}`)) count++;
    }
    return count;
  }

  function cleanBook(slug: string): number {
    const toDelete: string[] = [];
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i) || '';
      if (key.includes(`_${slug}`)) toDelete.push(key);
    }
    toDelete.forEach(k => localStorage.removeItem(k));
    return toDelete.length;
  }

  function cleanGlobal(): number {
    let count = 0;
    GLOBAL_KEYS.forEach(k => {
      if (localStorage.getItem(k) !== null) {
        localStorage.removeItem(k);
        count++;
      }
    });
    return count;
  }

  function showToast(msg: string) {
    const toast = document.getElementById('toast')!;
    toast.textContent = msg;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 2800);
  }

  function updateStats() {
    document.querySelectorAll<HTMLElement>('.book-card').forEach(card => {
      const slug = card.dataset.slug!;
      const count = countBookKeys(slug);
      const el = document.getElementById(`stat-${slug}`);
      if (el) {
        el.textContent = count === 0
          ? i18n.statNoData
          : (count === 1 ? i18n.statItemsOne : fmt(i18n.statItemsManyTpl, { n: count }));
      }
    });
  }

  // Attach clean buttons
  document.querySelectorAll<HTMLButtonElement>('.clean-btn[data-slug]').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.slug!;
      const removed = cleanBook(slug);
      updateStats();
      showToast(
        removed > 0
          ? fmt(i18n.toastCleanedBook, { n: removed, slug })
          : fmt(i18n.toastNoBookData, { slug }),
      );
    });
  });

  document.getElementById('clean-global-btn')?.addEventListener('click', () => {
    const removed = cleanGlobal();
    showToast(
      removed > 0
        ? fmt(i18n.toastCleanedGlobal, { n: removed })
        : i18n.toastNoGlobalData,
    );
  });

  // ─────────────────────────────────────────────────────────────
  // Editorial import — post-reload toast handoff
  // The import handler reloads the page after replacing localStorage
  // so every renderer reads fresh state. The success toast would die
  // with the old page, so we hand it off via sessionStorage and
  // surface it on the next paint.
  // ─────────────────────────────────────────────────────────────
  try {
    const raw = sessionStorage.getItem('yuval_admin_import_toast');
    if (raw) {
      sessionStorage.removeItem('yuval_admin_import_toast');
      const { items, series } = JSON.parse(raw) as { items: number; series: number };
      // Defer to next microtask so showToast (defined just below) is in
      // scope and the #toast element is reachable.
      queueMicrotask(() => {
        showToast(fmt(i18n.toastEditorialImportedTpl, { items, series }));
      });
    }
  } catch {
    // Malformed handoff blob — ignore silently. The import already
    // succeeded; the only thing missing is the toast.
  }

  // ─────────────────────────────────────────────────────────────
  // Editorial export
  // Reads `yuval_content_metadata` + `yuval_series_metadata` from
  // localStorage (via the same utilities the rest of admin uses) and
  // downloads them as a single `_editorial.json` shaped for output/.
  // Pure read — never mutates storage. No backend; the download is a
  // client-side Blob → object URL → <a download> trick.
  // ─────────────────────────────────────────────────────────────
  document.getElementById('export-editorial-btn')?.addEventListener('click', () => {
    const items = getAllMetadata();
    const series = getAllSeriesMetadata();
    // JSON.stringify already omits keys whose value is `undefined`, so
    // optional fields the user never set don't leak into the export.
    // Pretty-print with 2-space indent so the file is hand-editable.
    const payload = JSON.stringify(
      { version: 1, items, series },
      null,
      2,
    );

    const blob = new Blob([payload + '\n'], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = '_editorial.json';
    document.body.appendChild(a);
    a.click();
    a.remove();
    // Defer revoke so the click has a chance to flush the download in
    // every browser (Safari historically races otherwise).
    setTimeout(() => URL.revokeObjectURL(url), 0);

    showToast(
      fmt(i18n.toastEditorialExportedTpl, {
        items: Object.keys(items).length,
        series: Object.keys(series).length,
      }),
    );
  });

  // ─────────────────────────────────────────────────────────────
  // Editorial import
  // Replace-mode only. Validates the file shape strictly (version=1,
  // items and series are plain objects), shows native confirm() with
  // the incoming counts, then replaces both localStorage stores and
  // reloads so every admin renderer sees the new state. No backend
  // call; no disk write. Records are written as-is — the validator
  // gates the file SHAPE; field-level integrity is the user's
  // responsibility (they exported it).
  // ─────────────────────────────────────────────────────────────
  const importBtn = document.getElementById('import-editorial-btn');
  const importInput = document.getElementById('import-editorial-input') as HTMLInputElement | null;

  function validateEditorialShape(v: unknown): string | null {
    if (v === null || typeof v !== 'object' || Array.isArray(v)) {
      return 'not a JSON object';
    }
    const obj = v as Record<string, unknown>;
    if (obj.version !== 1) {
      return `version must be 1 (got ${JSON.stringify(obj.version)})`;
    }
    if (obj.items === null || typeof obj.items !== 'object' || Array.isArray(obj.items)) {
      return 'items must be an object';
    }
    if (obj.series === null || typeof obj.series !== 'object' || Array.isArray(obj.series)) {
      return 'series must be an object';
    }
    return null;
  }

  if (importBtn && importInput) {
    importBtn.addEventListener('click', () => {
      // Reset so re-picking the same file path still fires `change`.
      importInput.value = '';
      importInput.click();
    });

    importInput.addEventListener('change', async () => {
      const file = importInput.files?.[0];
      if (!file) return;

      let parsed: unknown;
      try {
        const text = await file.text();
        parsed = JSON.parse(text);
      } catch (err) {
        showToast(fmt(i18n.toastEditorialImportInvalidTpl, {
          reason: err instanceof Error ? err.message : 'parse error',
        }));
        return;
      }

      const shapeError = validateEditorialShape(parsed);
      if (shapeError) {
        showToast(fmt(i18n.toastEditorialImportInvalidTpl, { reason: shapeError }));
        return;
      }

      const payload = parsed as {
        version: 1;
        items: Record<string, ContentMetadata>;
        series: Record<string, SeriesMetadata>;
      };
      const itemCount = Object.keys(payload.items).length;
      const seriesCount = Object.keys(payload.series).length;

      const ok = window.confirm(
        fmt(i18n.importConfirmTpl, { items: itemCount, series: seriesCount }),
      );
      if (!ok) return;

      replaceAllMetadata(payload.items);
      replaceAllSeriesMetadata(payload.series);

      // Stash the success toast for the next page, then reload so the
      // book/series tables and stats repaint from the new stores.
      try {
        sessionStorage.setItem(
          'yuval_admin_import_toast',
          JSON.stringify({ items: itemCount, series: seriesCount }),
        );
      } catch {
        // Quota / disabled — losing the toast is acceptable; the data
        // was already written and the reload will still happen.
      }
      location.reload();
    });
  }

  // ─────────────────────────────────────────────────────────────
  // Confirmation modal — shared by book delete AND series delete.
  //
  // Each caller supplies a heading, a body template, the title to
  // substitute into the body, a warning line, and an async onConfirm.
  // The modal renders the {{title}} placeholder as a real <strong>
  // with `.textContent` so user-supplied titles cannot inject HTML.
  // While onConfirm runs, the confirm button is disabled and shows
  // the "Deleting…" label; on success or failure the modal closes
  // (errors are surfaced via toasts the caller emits inside
  // onConfirm).
  // ─────────────────────────────────────────────────────────────

  const modal = document.getElementById('delete-modal')!;
  const modalHeadingEl = document.getElementById('modal-heading')!;
  const modalBodyEl = document.getElementById('modal-body')!;
  const modalWarningEl = document.getElementById('modal-warning')!;
  const modalCancel = document.getElementById('modal-cancel') as HTMLButtonElement;
  const modalConfirm = document.getElementById('modal-confirm') as HTMLButtonElement;

  type ConfirmRequest = {
    heading: string;
    /** Body template; may contain a single `{{title}}` placeholder. */
    bodyTpl: string;
    /** Substituted into bodyTpl wrapped in <strong>. */
    title: string;
    /** Plain-text warning line shown below the body. */
    warning: string;
    /** Optional confirm-button label. Defaults to i18n.modalConfirmText. */
    confirmLabel?: string;
    /** Action invoked on confirm. Errors must be handled inside. */
    onConfirm: () => Promise<void> | void;
  };

  let pendingConfirm: ConfirmRequest | null = null;

  /**
   * Build the body paragraph for the confirmation modal. Splits
   * `tpl` on the literal `{{title}}` placeholder and inserts a
   * `<strong>` carrying the title's text — never its HTML — so a
   * user-typed series name like `<img onerror=…>` cannot run.
   */
  function buildConfirmBody(tpl: string, title: string): DocumentFragment {
    const frag = document.createDocumentFragment();
    const parts = tpl.split('{{title}}');
    for (let i = 0; i < parts.length; i++) {
      if (i > 0) {
        const strong = document.createElement('strong');
        strong.textContent = title;
        frag.appendChild(strong);
      }
      if (parts[i]) frag.appendChild(document.createTextNode(parts[i]));
    }
    return frag;
  }

  function showConfirmModal(req: ConfirmRequest) {
    pendingConfirm = req;
    modalHeadingEl.textContent = req.heading;
    modalBodyEl.replaceChildren(buildConfirmBody(req.bodyTpl, req.title));
    modalWarningEl.textContent = req.warning;
    modalConfirm.disabled = false;
    modalConfirm.textContent = req.confirmLabel ?? i18n.modalConfirmText;
    modal.classList.remove('hidden');
  }

  function hideModal() {
    modal.classList.add('hidden');
    pendingConfirm = null;
  }

  // Attach book delete buttons. The book delete flow stays in this
  // file (close to the modal) because it's the most-used path.
  // Series delete is wired further below in renderSeries.
  document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.slug!;
      const title = btn.dataset.title || slug;
      showConfirmModal({
        heading: i18n.modalHeadingBook,
        bodyTpl: i18n.modalBodyBook,
        title,
        warning: i18n.modalWarningBook,
        onConfirm: async () => {
          try {
            const response = await fetch('/api/delete-book', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ slug }),
            });
            const result = await response.json();
            if (result.success) {
              const card = document.querySelector(`.book-card[data-slug="${slug}"]`);
              if (card) card.remove();
              showToast(`✅ ${fmt(i18n.toastBookDeleted, { slug })}`);
              // A book delete may have removed the only member of a
              // series, so the series row's count needs a repaint
              // (or the row needs to drop to lonely-only state).
              renderSeries();
            } else {
              showToast(`❌ ${fmt(i18n.toastDeleteError, { msg: result.error || i18n.toastDeleteFailed })}`);
            }
          } catch (error: any) {
            showToast(`❌ ${fmt(i18n.toastNetworkError, { msg: error.message })}`);
          }
        },
      });
    });
  });

  modalCancel.addEventListener('click', hideModal);
  modal.querySelector('.modal-backdrop')?.addEventListener('click', hideModal);

  modalConfirm.addEventListener('click', async () => {
    if (!pendingConfirm) return;
    const req = pendingConfirm;
    modalConfirm.disabled = true;
    modalConfirm.textContent = i18n.modalDeleting;
    try {
      await req.onConfirm();
    } finally {
      hideModal();
    }
  });

  // Close modal with Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      hideModal();
    }
  });

  updateStats();

  // ─────────────────────────────────────────────────────────────
  // Edit Metadata drawer
  // Reads and writes the editorial layer in src/utils/content-metadata.ts.
  // The metadata storage key (yuval_content_metadata) is intentionally
  // NOT matched by cleanBook() or cleanGlobal() above, so editing a
  // book's metadata never affects reader progress or global prefs —
  // those code paths are unchanged.
  // ─────────────────────────────────────────────────────────────

  const metaDrawer = document.getElementById('meta-drawer')!;
  const metaTitleEl = document.getElementById('meta-drawer-title')!;
  const metaSlugEl = document.getElementById('meta-drawer-slug')!;
  const metaForm = document.getElementById('meta-form') as HTMLFormElement;
  const metaSaveBtn = document.getElementById('meta-save') as HTMLButtonElement;

  const metaFields = {
    displayTitle: metaForm.elements.namedItem('displayTitle') as HTMLInputElement,
    contentType: metaForm.elements.namedItem('contentType') as HTMLSelectElement,
    category: metaForm.elements.namedItem('category') as HTMLInputElement,
    seriesName: metaForm.elements.namedItem('seriesName') as HTMLInputElement,
    isVisibleInUniverse: metaForm.elements.namedItem('isVisibleInUniverse') as HTMLInputElement,
    visualMode: metaForm.elements.namedItem('visualMode') as HTMLSelectElement,
  };

  let editingSlug: string | null = null;
  let returnFocusEl: HTMLElement | null = null;

  function contentTypeLabel(t: ContentMetadata['contentType']): string {
    switch (t) {
      case 'course':  return i18n.optionCourse;
      case 'article': return i18n.optionArticle;
      case 'book':
      default:        return i18n.optionBook;
    }
  }

  function paintCardFromMetadata(
    slug: string,
    meta: ContentMetadata,
    opts: { paintTitle?: boolean } = {},
  ) {
    const card = document.querySelector<HTMLElement>(`.book-card[data-slug="${slug}"]`);
    if (!card) return;

    // The SSR-rendered title already reflects the manifest (via
    // pickAdminTitleAndSubtitle, which knows that course_lesson rows
    // surface the lesson-specific name from `subtitles`). Repainting
    // it from localStorage on every boot would let stale or
    // accidentally-saved displayTitle values silently overwrite the
    // correct manifest text — including pinning the slug as the title
    // if a previous session ever saved it. So title repaint is opt-in
    // and only requested by the explicit save flow below.
    if (opts.paintTitle) {
      const titleEl = card.querySelector<HTMLElement>('.book-title');
      if (titleEl) titleEl.textContent = meta.displayTitle;

      const monoEl = card.querySelector<HTMLElement>('.book-monogram');
      if (monoEl) {
        const ch = (meta.displayTitle || slug).trim().charAt(0).toUpperCase();
        monoEl.textContent = ch || '·';
      }
    }

    // Knowledge Catalog table cells — each is identified by its
    // data-cell attribute so the painter doesn't depend on column
    // order. Missing cells (older markup, hypothetical pruning) are
    // simply skipped, never thrown.
    const typeCell = card.querySelector<HTMLElement>('[data-cell="type"]');
    if (typeCell) typeCell.textContent = contentTypeLabel(meta.contentType);

    const seriesCell = card.querySelector<HTMLElement>('[data-cell="series"]');
    if (seriesCell) {
      seriesCell.replaceChildren();
      const trimmed = meta.seriesName.trim();
      if (trimmed) {
        seriesCell.textContent = trimmed;
      } else {
        const muted = document.createElement('span');
        muted.className = 'kcc-muted';
        muted.textContent = i18n.cellNoSeries;
        seriesCell.appendChild(muted);
      }
    }

    const catCell = card.querySelector<HTMLElement>('[data-cell="category"]');
    if (catCell) {
      const stored = meta.category.trim();
      // Only overwrite when the editor has typed something. Otherwise
      // keep the SSR-rendered category from the book-manifest catalog
      // so the cell stays useful before any editorial input.
      if (stored) {
        catCell.replaceChildren();
        catCell.textContent = stored;
      }
    }

    const visCell = card.querySelector<HTMLElement>('[data-cell="visibility"]');
    if (visCell) {
      const on = meta.isVisibleInUniverse;
      visCell.classList.toggle('kcc-vis--on', on);
      visCell.classList.toggle('kcc-vis--off', !on);
      const label = visCell.querySelector<HTMLElement>('.kcc-vis-label');
      if (label) label.textContent = on ? i18n.cellVisible : i18n.cellHidden;
    }
  }

  // On boot, overlay each card with its stored metadata (if any).
  // Cards without stored metadata stay as the SSR rendered them.
  document.querySelectorAll<HTMLElement>('.book-card').forEach(card => {
    const slug = card.dataset.slug;
    if (!slug) return;
    const titleEl = card.querySelector<HTMLElement>('.book-title');
    const ssrTitle = titleEl?.textContent?.trim() || slug;
    const meta = getMetadata(slug, ssrTitle);
    paintCardFromMetadata(slug, meta);
  });

  function openMetaDrawer(slug: string, fallbackTitle: string, trigger: HTMLElement | null) {
    editingSlug = slug;
    returnFocusEl = trigger;
    const meta = getMetadata(slug, fallbackTitle);

    metaTitleEl.textContent = meta.displayTitle;
    metaSlugEl.textContent = slug;

    metaFields.displayTitle.value = meta.displayTitle;
    metaFields.contentType.value = meta.contentType;
    metaFields.category.value = meta.category;
    metaFields.seriesName.value = meta.seriesName;
    metaFields.isVisibleInUniverse.checked = meta.isVisibleInUniverse;
    metaFields.visualMode.value = meta.visualMode;

    metaDrawer.classList.remove('hidden');
    metaDrawer.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(() => {
      metaDrawer.classList.add('is-open');
      metaFields.displayTitle.focus();
      metaFields.displayTitle.select();
    });
    document.body.style.overflow = 'hidden';
  }

  function closeMetaDrawer() {
    if (metaDrawer.classList.contains('hidden')) return;
    editingSlug = null;
    metaDrawer.classList.remove('is-open');
    metaDrawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    window.setTimeout(() => {
      metaDrawer.classList.add('hidden');
      if (returnFocusEl && typeof returnFocusEl.focus === 'function') {
        returnFocusEl.focus();
      }
      returnFocusEl = null;
    }, 280);
  }

  document.querySelectorAll<HTMLButtonElement>('.edit-btn[data-slug]').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.slug!;
      const fallback = btn.dataset.title || slug;
      openMetaDrawer(slug, fallback, btn);
    });
  });

  metaDrawer.querySelectorAll<HTMLElement>('[data-meta-close]').forEach(el => {
    el.addEventListener('click', closeMetaDrawer);
  });

  // Esc closes the metadata drawer. The pre-existing Esc handler for
  // the delete modal guards on its own visibility, so the two
  // handlers do not conflict.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && metaDrawer.classList.contains('is-open')) {
      closeMetaDrawer();
    }
  });

  metaForm.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && (e.target as HTMLElement).tagName === 'INPUT') {
      e.preventDefault();
      metaSaveBtn.click();
    }
  });

  metaSaveBtn.addEventListener('click', () => {
    if (!editingSlug) return;
    const slug = editingSlug;
    const fallback = metaFields.displayTitle.value.trim() || slug;

    const patch: Partial<ContentMetadata> = {
      displayTitle: metaFields.displayTitle.value.trim() || slug,
      contentType: metaFields.contentType.value as ContentMetadata['contentType'],
      category: metaFields.category.value.trim(),
      seriesName: metaFields.seriesName.value.trim(),
      isVisibleInUniverse: metaFields.isVisibleInUniverse.checked,
      visualMode: metaFields.visualMode.value as ContentMetadata['visualMode'],
    };

    const saved = setMetadata(slug, patch, fallback);
    // Save flow is the only place the user explicitly asked for the
    // displayTitle to change, so it's the only place that should
    // overwrite the SSR-rendered manifest title.
    paintCardFromMetadata(slug, saved, { paintTitle: true });
    // A series is implicitly defined by items sharing a non-empty
    // seriesName, so an item save can create / move / drain a series.
    // Re-derive and repaint the Series Management list.
    renderSeries();
    closeMetaDrawer();
    showToast(fmt(i18n.toastMetadataSaved, { title: saved.displayTitle }));
  });

  // ─────────────────────────────────────────────────────────────
  // Series Management
  //
  // A series is detected when one or more visible book cards share the
  // same non-empty `seriesName` in their item metadata. The detection
  // walks the rendered .book-card[data-slug] elements (which are the
  // items the project owner can currently see in /admin) and groups
  // them. Series presentation properties (displayTitle, color, order,
  // visibility, visualMode) live in their own metadata layer accessed
  // via getSeriesMetadata / setSeriesMetadata. Saving a series writes
  // ONLY to yuval_series_metadata — never to item metadata, never to
  // reader progress.
  // ─────────────────────────────────────────────────────────────

  const DEFAULT_SERIES_COLOR = '#c9a96e';

  type SeriesGroup = {
    name: string;
    members: ContentMetadata[];
    available: number;
    seriesMeta: SeriesMetadata;
    /**
     * Every raw `seriesName` string we observed across book metadata
     * that normalized to the same grouping key. Usually a one-element
     * array; multi-element only when the user has whitespace variants
     * of the same series name across books. The series-delete flow
     * uses this list to clear `seriesName` on every book that points
     * at any of the variants in one pass.
     */
    allRawNames: string[];
  };

  /**
   * Build the canonical key used to group items into a single series
   * row. Two seriesName values that differ only in invisible whitespace
   * (trailing space, doubled internal spaces, leading newline) MUST
   * NOT produce two rows — that's the duplicate-row bug we hit when a
   * single series was authored on two books with subtly different
   * whitespace. We collapse internal whitespace to a single space and
   * trim. Casing is intentionally preserved: "AI" and "Ai" remain
   * distinct on purpose so the user can keep deliberate casing splits.
   */
  function normalizeSeriesKey(raw: string): string {
    return raw.trim().replace(/\s+/g, ' ');
  }

  function detectSeriesGroups(): SeriesGroup[] {
    // Bucket -> { displayName (the FIRST raw form encountered, used to
    // render the row), members, allRawNames (every raw seriesName
    // value seen for this normalized key, used by the delete flow to
    // sweep all variants out of book metadata in one pass) }.
    type Bucket = {
      displayName: string;
      members: ContentMetadata[];
      allRawNames: Set<string>;
    };
    const buckets = new Map<string, Bucket>();

    document.querySelectorAll<HTMLElement>('.book-card[data-slug]').forEach(card => {
      const slug = card.dataset.slug;
      if (!slug) return;
      const titleEl = card.querySelector<HTMLElement>('.book-title');
      const fallback = titleEl?.textContent?.trim() || slug;
      const m = getMetadata(slug, fallback);
      const raw = (m.seriesName || '').trim();
      if (!raw) return;
      const key = normalizeSeriesKey(raw);
      if (!key) return;
      const bucket = buckets.get(key);
      if (bucket) {
        bucket.members.push(m);
        bucket.allRawNames.add(raw);
      } else {
        buckets.set(key, {
          displayName: raw,
          members: [m],
          allRawNames: new Set([raw]),
        });
      }
    });

    // Also surface "lonely" series — metadata records that exist but
    // have no books pointing at them. Without this, a series the user
    // creates via the "New series" button would never render until at
    // least one book is attached. The lonely record's name is the
    // displayName for the row.
    const allMeta = getAllSeriesMetadata();
    for (const [name] of Object.entries(allMeta)) {
      const key = normalizeSeriesKey(name);
      if (!key) continue;
      if (buckets.has(key)) continue;
      buckets.set(key, {
        displayName: name,
        members: [],
        allRawNames: new Set([name]),
      });
    }

    const result: SeriesGroup[] = [];
    buckets.forEach(({ displayName, members, allRawNames }) => {
      const available = members.filter(
        m => m.isVisibleInUniverse && m.visualMode !== 'hidden',
      ).length;
      const seriesMeta = getSeriesMetadata(displayName);
      result.push({
        name: displayName,
        members,
        available,
        seriesMeta,
        allRawNames: Array.from(allRawNames),
      });
    });

    // Sort by editorial order if set on EITHER side, then alphabetical
    // by displayTitle as a stable tiebreaker. Series without an order
    // sink to the bottom of the ordered group.
    result.sort((a, b) => {
      const ao = a.seriesMeta.order;
      const bo = b.seriesMeta.order;
      const aHas = typeof ao === 'number';
      const bHas = typeof bo === 'number';
      if (aHas && bHas) {
        if (ao !== bo) return ao - bo;
      } else if (aHas !== bHas) {
        return aHas ? -1 : 1;
      }
      return a.seriesMeta.displayTitle.localeCompare(b.seriesMeta.displayTitle);
    });

    return result;
  }

  function renderSeries(): void {
    const list = document.getElementById('series-list');
    const countEl = document.getElementById('series-count');
    if (!list || !countEl) return;

    const groups = detectSeriesGroups();
    countEl.textContent = fmt(i18n.seriesCountTpl, { n: groups.length });

    // Use DOM APIs (not innerHTML) so series names typed by the user
    // are never interpreted as HTML.
    list.replaceChildren();

    if (groups.length === 0) {
      // Empty-state row spanning the full column count. The hairline
      // border + muted text pattern matches the books table's empty
      // state above so the two sections feel like one panel system.
      const tr = document.createElement('tr');
      tr.className = 'series-empty-row';
      const td = document.createElement('td');
      td.className = 'kcc-td series-empty-cell';
      td.colSpan = 10;
      td.textContent = i18n.seriesEmpty;
      tr.appendChild(td);
      list.appendChild(tr);
      return;
    }

    groups.forEach(group => {
      list.appendChild(buildSeriesRow(group));
    });
  }

  // ─────────────────────────────────────────────────────────────────
  // Series-row builder — emits one <tr> per detected series.
  //
  // Columns (left-to-right in DOM source; visual order under RTL is
  // mirrored automatically by the browser):
  //   1. שם סדרה        — display title (prominent) + slug (muted)
  //   2. תיאור          — shortDescription, or muted "no description"
  //   3. סטטוס          — pill, colored by status
  //   4. מרחב ידע       — pill, colored by isVisibleInUniverse
  //   5. פריטים בפועל   — computed count (members.length)
  //   6. פריטים מתוכננים — plannedBooksCount or "לא הוגדר"
  //   7. התקדמות        — counter + bar, or "לא הוגדר" without bar
  //   8. תיקיית נכסים   — monospace folder name or "ללא תיקייה"
  //   9. סדר תצוגה      — number or "-"
  //  10. פעולות         — gold-outline "עריכת סדרה" button
  //
  // The same `data-series-name` attribute is kept on the row so any
  // existing selector (`[data-series-name="…"]`) continues to work.
  // The legacy `.series-card` class is renamed to `.series-row` to
  // make it obvious the rendering mode changed; `data-series-name`
  // is the stable identity hook either way.
  function buildSeriesRow(group: SeriesGroup): HTMLElement {
    const { name, members, seriesMeta, allRawNames } = group;
    const actualBooksCount = members.length;
    const plannedBooksCount =
      typeof seriesMeta.plannedBooksCount === 'number' && seriesMeta.plannedBooksCount > 0
        ? seriesMeta.plannedBooksCount
        : undefined;
    const color = seriesMeta.color || DEFAULT_SERIES_COLOR;
    const status: SeriesStatus = seriesMeta.status ?? 'active';

    const tr = document.createElement('tr');
    tr.className = 'series-row kcc-tr';
    tr.dataset.seriesName = name;
    tr.dataset.status = status;
    // Series color is exposed on the row so the progress-bar fill
    // (declared in CSS as `var(--series-color, …)`) picks up the
    // per-series accent without extra inline styling per cell.
    tr.style.setProperty('--series-color', color);

    // 0. כריכה — front-image thumbnail + uploader. Same pattern as
    //    the books table; the whole button is the click target and
    //    the delegated handler (matching `[data-cover-upload]`) drives
    //    the file picker / fetch to /api/upload-front. The asset
    //    folder under src/assets/knowledge-cards/ is whatever the
    //    user authored on `seriesMeta.assetFolder`; if blank, we fall
    //    back to slugifySeriesName(name) so the series at least gets
    //    a deterministic folder. The thumbnail itself is read via the
    //    same getKnowledgeCardAssets glob the orbit uses, so what the
    //    admin shows is exactly what /library will show.
    const assetSlug = (seriesMeta.assetFolder?.trim()) || slugifySeriesName(name);
    const coverTd = document.createElement('td');
    coverTd.className = 'kcc-td col-cover';
    const coverBtn = document.createElement('button');
    coverBtn.type = 'button';
    coverBtn.className = 'cover-uploader';
    coverBtn.dataset.coverUpload = 'series';
    coverBtn.dataset.slug = assetSlug;
    coverBtn.title = i18n.coverUpload;
    coverBtn.setAttribute(
      'aria-label',
      fmt(i18n.coverUploadAria, { title: seriesMeta.displayTitle || name }),
    );
    const seriesFrontUrl = assetSlug ? getKnowledgeCardAssets(assetSlug)?.front : undefined;
    if (seriesFrontUrl) {
      const img = document.createElement('img');
      img.className = 'cover-thumb';
      img.src = seriesFrontUrl;
      img.alt = '';
      img.loading = 'lazy';
      img.decoding = 'async';
      coverBtn.appendChild(img);
    } else {
      const empty = document.createElement('span');
      empty.className = 'cover-thumb cover-thumb--empty';
      empty.setAttribute('aria-hidden', 'true');
      empty.innerHTML =
        '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">' +
        '<rect x="3" y="3" width="18" height="18" rx="2"></rect>' +
        '<circle cx="9" cy="9" r="2"></circle>' +
        '<path d="M21 15l-5-5L5 21"></path>' +
        '</svg>';
      coverBtn.appendChild(empty);
    }
    const overlay = document.createElement('span');
    overlay.className = 'cover-uploader-overlay';
    overlay.setAttribute('aria-hidden', 'true');
    overlay.innerHTML =
      '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">' +
      '<path d="M12 5v14"></path><path d="M5 12h14"></path>' +
      '</svg>';
    coverBtn.appendChild(overlay);
    coverTd.appendChild(coverBtn);
    tr.appendChild(coverTd);

    // 1. שם סדרה — title + slug stack mirrors `.kcc-title-stack`
    //    used by the books table so the visual rhythm matches.
    const nameTd = document.createElement('td');
    nameTd.className = 'kcc-td col-series-name';
    const stack = document.createElement('div');
    stack.className = 'kcc-title-stack';
    const title = document.createElement('p');
    title.className = 'series-row-title';
    title.textContent = seriesMeta.displayTitle || name;
    stack.appendChild(title);
    if (seriesMeta.displayTitle && seriesMeta.displayTitle !== name) {
      const slug = document.createElement('p');
      slug.className = 'series-row-slug';
      slug.textContent = name;
      stack.appendChild(slug);
    }
    nameTd.appendChild(stack);
    tr.appendChild(nameTd);

    // 2. תיאור — shortDescription or muted placeholder.
    const descTd = document.createElement('td');
    descTd.className = 'kcc-td col-series-desc';
    const summaryText = (seriesMeta.shortDescription ?? '').trim();
    if (summaryText.length > 0) {
      descTd.textContent = summaryText;
    } else {
      descTd.classList.add('kcc-muted');
      descTd.textContent = i18n.seriesCardNoDescription;
    }
    tr.appendChild(descTd);

    // 3. סטטוס — colored pill driven by data-status.
    const statusTd = document.createElement('td');
    statusTd.className = 'kcc-td col-series-status';
    const statusPill = document.createElement('span');
    statusPill.className = 'series-status-pill';
    statusPill.dataset.status = status;
    statusPill.textContent =
      status === 'draft'  ? i18n.seriesStatusDraft  :
      status === 'hidden' ? i18n.seriesStatusHidden :
                            i18n.seriesStatusActive;
    statusTd.appendChild(statusPill);
    tr.appendChild(statusTd);

    // 4. מרחב ידע — green / red pill driven by data-on.
    const universeTd = document.createElement('td');
    universeTd.className = 'kcc-td col-series-universe';
    const universePill = document.createElement('span');
    universePill.className = 'series-universe-pill';
    if (seriesMeta.isVisibleInUniverse) {
      universePill.dataset.on = 'true';
      universePill.textContent = i18n.seriesBadgeVisible;
    } else {
      universePill.dataset.on = 'false';
      universePill.textContent = i18n.seriesBadgeHiddenFromUni;
    }
    universeTd.appendChild(universePill);
    tr.appendChild(universeTd);

    // 5. פריטים בפועל — computed count. Read-only: never editable.
    const actualTd = document.createElement('td');
    actualTd.className = 'kcc-td col-series-actual series-cell-num';
    actualTd.textContent = String(actualBooksCount);
    tr.appendChild(actualTd);

    // 6. פריטים מתוכננים — number or "לא הוגדר".
    const plannedTd = document.createElement('td');
    plannedTd.className = 'kcc-td col-series-planned series-cell-num';
    if (plannedBooksCount !== undefined) {
      plannedTd.textContent = String(plannedBooksCount);
    } else {
      plannedTd.classList.add('kcc-muted');
      plannedTd.textContent = i18n.seriesCellNotSet;
    }
    tr.appendChild(plannedTd);

    // 7. התקדמות — counter + bar when planned set; "לא הוגדר" otherwise.
    const progressTd = document.createElement('td');
    progressTd.className = 'kcc-td col-series-progress';
    if (plannedBooksCount !== undefined) {
      const pct = Math.max(0, Math.min(100,
        Math.round((actualBooksCount / plannedBooksCount) * 100)));
      const wrap = document.createElement('div');
      wrap.className = 'series-progress-cell';

      const counter = document.createElement('span');
      counter.className = 'series-progress-counter';
      counter.textContent = fmt(i18n.seriesCardItemsOfTpl, {
        actual: actualBooksCount,
        planned: plannedBooksCount,
      });
      wrap.appendChild(counter);

      const bar = document.createElement('div');
      bar.className = 'series-progress-bar';
      bar.setAttribute('role', 'progressbar');
      bar.setAttribute('aria-valuemin', '0');
      bar.setAttribute('aria-valuemax', String(plannedBooksCount));
      bar.setAttribute('aria-valuenow', String(actualBooksCount));
      bar.setAttribute('aria-label', fmt(i18n.seriesCardProgressAriaTpl, {
        actual: actualBooksCount,
        planned: plannedBooksCount,
      }));
      const fill = document.createElement('span');
      fill.className = 'series-progress-fill';
      fill.style.width = pct + '%';
      bar.appendChild(fill);
      wrap.appendChild(bar);

      progressTd.appendChild(wrap);
    } else {
      progressTd.classList.add('kcc-muted');
      progressTd.textContent = i18n.seriesCellNotSet;
    }
    tr.appendChild(progressTd);

    // 8. תיקיית נכסים — monospace folder name or "ללא תיקייה".
    const folderTd = document.createElement('td');
    folderTd.className = 'kcc-td col-series-folder';
    const folder = (seriesMeta.assetFolder ?? '').trim();
    if (folder.length > 0) {
      const code = document.createElement('code');
      code.className = 'series-folder-code';
      code.textContent = folder;
      folderTd.appendChild(code);
    } else {
      folderTd.classList.add('kcc-muted');
      folderTd.textContent = i18n.seriesCellNoFolder;
    }
    tr.appendChild(folderTd);

    // 9. סדר תצוגה — number or "-".
    const orderTd = document.createElement('td');
    orderTd.className = 'kcc-td col-series-order series-cell-num';
    if (typeof seriesMeta.order === 'number') {
      orderTd.textContent = String(seriesMeta.order);
    } else {
      orderTd.classList.add('kcc-muted');
      orderTd.textContent = i18n.seriesCellDash;
    }
    tr.appendChild(orderTd);

    // 10. פעולות — primary "עריכת סדרה" button + small delete icon.
    //     The delete button never deletes immediately; it pops the
    //     shared confirmation modal (same flow used for book delete)
    //     and only on confirm does it (a) clear `seriesName` on every
    //     book attached to any whitespace variant of this group, and
    //     (b) remove the SeriesMetadata record. Both steps run
    //     locally in localStorage — no API call.
    const actionsTd = document.createElement('td');
    actionsTd.className = 'kcc-td col-series-actions';
    const editBtn = document.createElement('button');
    editBtn.type = 'button';
    editBtn.className = 'series-edit-btn';
    editBtn.title = i18n.seriesCardEditButton;
    editBtn.setAttribute('aria-label', fmt(i18n.seriesEditAriaTpl, { name }));
    editBtn.dataset.seriesName = name;
    const svgNs = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(svgNs, 'svg');
    svg.setAttribute('width', '14');
    svg.setAttribute('height', '14');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('fill', 'none');
    svg.setAttribute('stroke', 'currentColor');
    svg.setAttribute('stroke-width', '1.8');
    svg.setAttribute('stroke-linecap', 'round');
    svg.setAttribute('stroke-linejoin', 'round');
    svg.setAttribute('aria-hidden', 'true');
    const p1 = document.createElementNS(svgNs, 'path');
    p1.setAttribute('d', 'M12 20h9');
    const p2 = document.createElementNS(svgNs, 'path');
    p2.setAttribute('d', 'M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z');
    svg.append(p1, p2);
    editBtn.appendChild(svg);
    const editLabel = document.createElement('span');
    editLabel.textContent = i18n.seriesCardEditButton;
    editBtn.appendChild(editLabel);
    editBtn.addEventListener('click', () => openSeriesDrawer(name, editBtn));
    actionsTd.appendChild(editBtn);

    const deleteBtn = document.createElement('button');
    deleteBtn.type = 'button';
    deleteBtn.className = 'series-delete-btn';
    deleteBtn.title = i18n.seriesActionDeleteTitle;
    deleteBtn.setAttribute(
      'aria-label',
      fmt(i18n.seriesActionDeleteAriaTpl, {
        name: seriesMeta.displayTitle || name,
      }),
    );
    const dsvg = document.createElementNS(svgNs, 'svg');
    dsvg.setAttribute('width', '14');
    dsvg.setAttribute('height', '14');
    dsvg.setAttribute('viewBox', '0 0 24 24');
    dsvg.setAttribute('fill', 'none');
    dsvg.setAttribute('stroke', 'currentColor');
    dsvg.setAttribute('stroke-width', '1.8');
    dsvg.setAttribute('stroke-linecap', 'round');
    dsvg.setAttribute('stroke-linejoin', 'round');
    dsvg.setAttribute('aria-hidden', 'true');
    [
      'polyline:3 6 5 6 21 6',
      'path:M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6',
      'path:M10 11v6',
      'path:M14 11v6',
      'path:M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2',
    ].forEach((spec) => {
      const [tag, d] = spec.split(':');
      const el = document.createElementNS(svgNs, tag);
      if (tag === 'polyline') el.setAttribute('points', d);
      else el.setAttribute('d', d);
      dsvg.appendChild(el);
    });
    deleteBtn.appendChild(dsvg);
    deleteBtn.addEventListener('click', () => {
      const displayTitle = seriesMeta.displayTitle || name;
      showConfirmModal({
        heading: i18n.modalHeadingSeries,
        bodyTpl: i18n.modalBodySeries,
        title: displayTitle,
        warning: i18n.modalWarningSeries,
        onConfirm: () => {
          // Detach: clear seriesName on every book whose seriesName
          // normalized to this group (covers whitespace variants).
          for (const member of members) {
            setMetadata(member.slug, { seriesName: '' }, member.displayTitle);
          }
          // Remove the metadata record under every raw-name variant
          // so a single dangling record can never resurrect the row.
          for (const raw of allRawNames) {
            deleteSeriesMetadata(raw);
          }
          renderSeries();
          showToast(fmt(i18n.seriesToastDeleted, { name: displayTitle }));
        },
      });
    });
    actionsTd.appendChild(deleteBtn);

    tr.appendChild(actionsTd);

    return tr;
  }

  // Series drawer — reuses the .meta-drawer slide animation/CSS class
  // structure but is a separate aside (#series-drawer) with its own
  // open/close/save flow that writes only to yuval_series_metadata.

  const seriesDrawer = document.getElementById('series-drawer')!;
  const seriesTitleEl = document.getElementById('series-drawer-title')!;
  const seriesNameEl = document.getElementById('series-drawer-name')!;
  const seriesForm = document.getElementById('series-form') as HTMLFormElement;
  const seriesSaveBtn = document.getElementById('series-save') as HTMLButtonElement;
  const seriesColorSwatch = document.getElementById('series-color-swatch') as HTMLButtonElement;
  const seriesColorInput = document.getElementById('series-color-input') as HTMLInputElement;
  const seriesColorDot = document.getElementById('series-color-dot')!;
  const seriesColorClear = document.getElementById('series-color-clear') as HTMLButtonElement;

  const seriesFields = {
    displayTitle: seriesForm.elements.namedItem('displayTitle') as HTMLInputElement,
    slug: seriesForm.elements.namedItem('slug') as HTMLInputElement,
    shortDescription: seriesForm.elements.namedItem('shortDescription') as HTMLInputElement,
    fullDescription: seriesForm.elements.namedItem('fullDescription') as HTMLTextAreaElement,
    plannedBooksCount: seriesForm.elements.namedItem('plannedBooksCount') as HTMLInputElement,
    assetFolder: seriesForm.elements.namedItem('assetFolder') as HTMLInputElement,
    order: seriesForm.elements.namedItem('order') as HTMLInputElement,
    isVisibleInUniverse: seriesForm.elements.namedItem('isVisibleInUniverse') as HTMLInputElement,
    visualMode: seriesForm.elements.namedItem('visualMode') as HTMLSelectElement,
    status: seriesForm.elements.namedItem('status') as HTMLSelectElement,
  };

  // Live label that surfaces the read-only computed `actualBooksCount`
  // inside the drawer. The value is derived from `members.length` when
  // the drawer is opened — never editable.
  const seriesActualLabel = seriesForm.querySelector<HTMLElement>(
    '.meta-field--readonly-summary .meta-label',
  );

  // Local form state for the optional `color` field. Tracked outside
  // the form because <input type="color"> always produces a value;
  // setting it back to "no override" requires our own tri-state.
  let editingSeriesName: string | null = null;
  let editingColorOverride: string | undefined = undefined;
  let returnFocusElForSeries: HTMLElement | null = null;
  // Create vs edit mode. In create mode the slug field is editable
  // (the user is naming a brand-new series) and the eyebrow swaps to
  // "Create series". Save reads the name from the slug field and
  // refuses to overwrite an existing record.
  let isCreatingSeries = false;
  const seriesEyebrowEl = document.getElementById('series-drawer-eyebrow')!;
  const seriesEyebrowDefault = seriesEyebrowEl.textContent || '';

  function paintColorSwatch(color: string | undefined): void {
    const applied = color || DEFAULT_SERIES_COLOR;
    seriesColorDot.style.setProperty('--meta-color-current', applied);
    seriesColorInput.value = applied;
    seriesColorClear.disabled = !color;
  }

  function openSeriesDrawer(name: string, trigger: HTMLElement | null): void {
    isCreatingSeries = false;
    editingSeriesName = name;
    returnFocusElForSeries = trigger;
    const meta = getSeriesMetadata(name);

    // Compute the read-only `actualBooksCount` from the live group so
    // the drawer always shows the same number as the card. The series
    // card list is the authoritative count source for the admin.
    const group = detectSeriesGroups().find(g => g.name === name);
    const actualBooksCount = group?.members.length ?? 0;

    seriesEyebrowEl.textContent = seriesEyebrowDefault;
    seriesTitleEl.textContent = meta.displayTitle || name;
    seriesNameEl.textContent = name;

    seriesFields.displayTitle.value = meta.displayTitle || name;
    seriesFields.slug.value = name;
    // The slug is editable both in create mode AND in edit mode.
    // In edit mode, changing it triggers a rename in the save flow:
    // every book whose `seriesName` matches any whitespace variant of
    // the current group is retagged, and the SeriesMetadata record is
    // moved from the old key to the new one. See seriesSaveBtn handler.
    seriesFields.slug.readOnly = false;
    seriesFields.slug.classList.remove('meta-input--readonly');
    seriesFields.shortDescription.value = meta.shortDescription ?? '';
    seriesFields.fullDescription.value = meta.fullDescription ?? '';
    seriesFields.plannedBooksCount.value =
      typeof meta.plannedBooksCount === 'number' ? String(meta.plannedBooksCount) : '';
    seriesFields.assetFolder.value = meta.assetFolder ?? '';
    seriesFields.order.value = typeof meta.order === 'number' ? String(meta.order) : '';
    seriesFields.isVisibleInUniverse.checked = meta.isVisibleInUniverse;
    seriesFields.visualMode.value = meta.visualMode;
    seriesFields.status.value = meta.status ?? 'active';
    editingColorOverride = meta.color;
    paintColorSwatch(editingColorOverride);

    // Read-only computed summary — text + the hidden `actualBooksCount`
    // mirror so any test or screenshot capture can read the value
    // straight off the form without relying on the label's content.
    if (seriesActualLabel) {
      seriesActualLabel.textContent = fmt(i18n.seriesActualReadOnlyTpl, { n: actualBooksCount });
    }
    const actualMirror = seriesForm.querySelector<HTMLInputElement>(
      'input[data-actual-books-count]',
    );
    if (actualMirror) actualMirror.value = String(actualBooksCount);

    seriesDrawer.classList.remove('hidden');
    seriesDrawer.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(() => {
      seriesDrawer.classList.add('is-open');
      seriesFields.displayTitle.focus();
      seriesFields.displayTitle.select();
    });
    document.body.style.overflow = 'hidden';
  }

  /**
   * Open the series drawer in "create" mode. The slug input becomes
   * editable and acts as the new series's identifier; saving validates
   * that the chosen name does not collide with an existing series
   * (whitespace-insensitive, the same normalization the row grouping
   * uses) before writing.
   */
  function openSeriesDrawerForNew(trigger: HTMLElement | null): void {
    isCreatingSeries = true;
    editingSeriesName = null;
    returnFocusElForSeries = trigger;

    seriesEyebrowEl.textContent = i18n.seriesDrawerEyebrowNew;
    seriesTitleEl.textContent = i18n.seriesDrawerEyebrowNew;
    seriesNameEl.textContent = '—';

    seriesFields.displayTitle.value = '';
    seriesFields.slug.value = '';
    seriesFields.slug.readOnly = false;
    seriesFields.slug.classList.remove('meta-input--readonly');
    seriesFields.shortDescription.value = '';
    seriesFields.fullDescription.value = '';
    seriesFields.plannedBooksCount.value = '';
    seriesFields.assetFolder.value = '';
    seriesFields.order.value = '';
    seriesFields.isVisibleInUniverse.checked = true;
    seriesFields.visualMode.value = 'capsule';
    seriesFields.status.value = 'active';
    editingColorOverride = undefined;
    paintColorSwatch(undefined);

    if (seriesActualLabel) {
      seriesActualLabel.textContent = fmt(i18n.seriesActualReadOnlyTpl, { n: 0 });
    }
    const actualMirror = seriesForm.querySelector<HTMLInputElement>(
      'input[data-actual-books-count]',
    );
    if (actualMirror) actualMirror.value = '0';

    seriesDrawer.classList.remove('hidden');
    seriesDrawer.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(() => {
      seriesDrawer.classList.add('is-open');
      seriesFields.slug.focus();
    });
    document.body.style.overflow = 'hidden';
  }

  function closeSeriesDrawer(): void {
    if (seriesDrawer.classList.contains('hidden')) return;
    editingSeriesName = null;
    seriesDrawer.classList.remove('is-open');
    seriesDrawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    window.setTimeout(() => {
      seriesDrawer.classList.add('hidden');
      if (returnFocusElForSeries && typeof returnFocusElForSeries.focus === 'function') {
        returnFocusElForSeries.focus();
      }
      returnFocusElForSeries = null;
    }, 280);
  }

  seriesDrawer.querySelectorAll<HTMLElement>('[data-series-close]').forEach(el => {
    el.addEventListener('click', closeSeriesDrawer);
  });

  // Esc — only when the series drawer is the active one. The other
  // Esc handlers (item drawer, delete modal) already guard on their
  // own visibility.
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && seriesDrawer.classList.contains('is-open')) {
      closeSeriesDrawer();
    }
  });

  seriesForm.addEventListener('keydown', e => {
    if (e.key === 'Enter' && (e.target as HTMLElement).tagName === 'INPUT') {
      e.preventDefault();
      seriesSaveBtn.click();
    }
  });

  // Color picker wiring — clicking the swatch opens the native picker;
  // committing a new color updates both the override and the swatch
  // preview. Reset clears the override back to "use default".
  seriesColorSwatch.addEventListener('click', () => seriesColorInput.click());
  seriesColorInput.addEventListener('change', () => {
    editingColorOverride = seriesColorInput.value;
    paintColorSwatch(editingColorOverride);
  });
  seriesColorClear.addEventListener('click', () => {
    editingColorOverride = undefined;
    paintColorSwatch(undefined);
  });

  seriesSaveBtn.addEventListener('click', () => {
    // Resolve the target name AND any rename action.
    //
    // Three flows enter this handler:
    //   1. Create — the slug field is the new series's identifier.
    //      Validate non-empty + no collision with an existing series
    //      under the same normalized key.
    //   2. Edit, no rename — typed slug normalizes to the same key as
    //      the row being edited. Just write the patch.
    //   3. Edit, rename — typed slug normalizes to a NEW key. We need
    //      to (a) move the SeriesMetadata record under the new key,
    //      (b) retag every book that points at any whitespace variant
    //      of the old name to use the new name, (c) delete the old
    //      SeriesMetadata record. The collision check excludes the
    //      current series's own variants.
    //
    // After the handler decides which flow applies, the rest of the
    // save logic just builds the patch and writes the metadata under
    // `name`.
    let name: string;
    let renameFromName: string | null = null;
    let renameRawVariants: string[] = [];

    if (isCreatingSeries) {
      const typed = seriesFields.slug.value.trim();
      if (!typed) {
        showToast(i18n.seriesToastNameRequired);
        seriesFields.slug.focus();
        return;
      }
      const newKey = normalizeSeriesKey(typed);
      const existingNames = Object.keys(getAllSeriesMetadata());
      const collision = existingNames.some(
        (n) => normalizeSeriesKey(n) === newKey,
      );
      if (collision) {
        showToast(fmt(i18n.seriesToastAlreadyExists, { name: typed }));
        seriesFields.slug.focus();
        seriesFields.slug.select();
        return;
      }
      name = typed;
    } else {
      if (!editingSeriesName) return;
      const typed = seriesFields.slug.value.trim();
      if (!typed) {
        showToast(i18n.seriesToastNameRequired);
        seriesFields.slug.focus();
        return;
      }
      const oldKey = normalizeSeriesKey(editingSeriesName);
      const newKey = normalizeSeriesKey(typed);

      if (newKey !== oldKey) {
        // True rename. Reject if the new name collides with ANOTHER
        // existing series (excluding the current group's own raw
        // variants — those are about to be removed).
        const currentGroup = detectSeriesGroups().find(
          (g) => normalizeSeriesKey(g.name) === oldKey,
        );
        renameRawVariants = currentGroup?.allRawNames ?? [editingSeriesName];
        const ownVariantKeys = new Set(
          renameRawVariants.map(normalizeSeriesKey),
        );
        const existingNames = Object.keys(getAllSeriesMetadata());
        const collision = existingNames.some((n) => {
          const k = normalizeSeriesKey(n);
          return k === newKey && !ownVariantKeys.has(k);
        });
        if (collision) {
          showToast(fmt(i18n.seriesToastAlreadyExists, { name: typed }));
          seriesFields.slug.focus();
          seriesFields.slug.select();
          return;
        }
        renameFromName = editingSeriesName;
      }
      name = typed;
    }

    const orderRaw = seriesFields.order.value.trim();
    const orderNum = orderRaw === '' ? undefined : Number(orderRaw);
    const orderValid = orderNum === undefined || Number.isFinite(orderNum);

    // plannedBooksCount: integer ≥ 0 only. Empty / NaN / negative all
    // collapse to undefined so an unset field never poisons the
    // progress bar with a zero-divisor.
    const plannedRaw = seriesFields.plannedBooksCount.value.trim();
    const plannedNum = plannedRaw === '' ? undefined : Number(plannedRaw);
    const plannedClean =
      typeof plannedNum === 'number' && Number.isFinite(plannedNum) && plannedNum > 0
        ? Math.floor(plannedNum)
        : undefined;

    // Optional text fields: trim and fall back to undefined when empty
    // so the stored shape stays free of empty strings (so consumers can
    // use simple `?? defaults` without `''` weirdness).
    const trimOrUndef = (v: string): string | undefined => {
      const t = v.trim();
      return t.length === 0 ? undefined : t;
    };

    const status = (
      ['active', 'draft', 'hidden'].includes(seriesFields.status.value)
        ? seriesFields.status.value
        : 'active'
    ) as SeriesStatus;

    const patch: Partial<SeriesMetadata> = {
      displayTitle:        seriesFields.displayTitle.value.trim() || name,
      visualMode:          seriesFields.visualMode.value as SeriesMetadata['visualMode'],
      color:               editingColorOverride,
      order:               orderValid ? orderNum : undefined,
      isVisibleInUniverse: seriesFields.isVisibleInUniverse.checked,
      shortDescription:    trimOrUndef(seriesFields.shortDescription.value),
      fullDescription:     trimOrUndef(seriesFields.fullDescription.value),
      plannedBooksCount:   plannedClean,
      assetFolder:         trimOrUndef(seriesFields.assetFolder.value),
      status,
    };

    // If this is a rename: walk every book attached to any raw
    // variant of the OLD name and retag its `seriesName` to the NEW
    // name. We do this BEFORE writing the new SeriesMetadata so the
    // re-render after save reflects a single coherent state. After
    // retagging, drop every old-name SeriesMetadata record so the
    // grouping logic never resurrects the old row.
    if (renameFromName) {
      // Build a set of normalized keys we treat as "the same group"
      // for the purpose of retagging — covers whitespace variants.
      const oldVariantKeys = new Set(
        renameRawVariants.map(normalizeSeriesKey),
      );
      document.querySelectorAll<HTMLElement>('.book-card[data-slug]').forEach((card) => {
        const slug = card.dataset.slug;
        if (!slug) return;
        const m = getMetadata(slug);
        const cur = (m.seriesName || '').trim();
        if (!cur) return;
        if (oldVariantKeys.has(normalizeSeriesKey(cur))) {
          setMetadata(slug, { seriesName: name }, m.displayTitle);
        }
      });
      for (const raw of renameRawVariants) {
        if (raw !== name) deleteSeriesMetadata(raw);
      }
    }

    const saved = setSeriesMetadata(name, patch);
    const wasCreating = isCreatingSeries;
    const wasRenamed = renameFromName !== null;
    renderSeries();
    closeSeriesDrawer();
    showToast(
      fmt(
        wasCreating
          ? i18n.seriesToastCreated
          : wasRenamed
            ? i18n.seriesToastRenamed
            : i18n.toastSeriesSaved,
        { name: saved.displayTitle },
      ),
    );
  });

  // Wire the section-header "New series" CTA. The button opens the
  // drawer in create mode; one delegated listener covers the case
  // where the button is later re-rendered.
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement | null)?.closest<HTMLButtonElement>(
      'button[data-new-series]',
    );
    if (!btn) return;
    openSeriesDrawerForNew(btn);
  });

  // Boot — paint the section once item-metadata overlay has run.
  renderSeries();

  // ─────────────────────────────────────────────────────────────
  // Front-image upload (books + series tables)
  //
  // One delegated click handler covers both tables: each trigger
  // carries `data-cover-upload="book|series"` and `data-slug` (the
  // asset-folder slug under src/assets/knowledge-cards/<slug>/).
  // On click we open a transient file picker, validate locally for
  // fast feedback, POST to /api/upload-front, and swap the thumb
  // for an object URL of the just-uploaded file so the user sees
  // the change immediately. The on-disk file is the source of
  // truth for the next SSR pass — Vite's import.meta.glob in
  // knowledge-cards.ts re-resolves on HMR, so a refresh shows the
  // properly-hashed bundled URL.
  // ─────────────────────────────────────────────────────────────

  const FRONT_MAX_BYTES = 5 * 1024 * 1024;
  // PNG only, because the discovery globs `front.png` exclusively.
  // Saving a JPG with a .png extension would render but plant a
  // hidden format mismatch in the bundle.
  const FRONT_ACCEPTED = ['image/png'];

  function pickFrontFile(): Promise<File | null> {
    return new Promise((resolve) => {
      const input = document.createElement('input');
      input.type = 'file';
      input.accept = FRONT_ACCEPTED.join(',');
      input.style.position = 'fixed';
      input.style.left = '-9999px';
      input.addEventListener(
        'change',
        () => {
          const f = input.files && input.files[0] ? input.files[0] : null;
          input.remove();
          resolve(f);
        },
        { once: true },
      );
      // Some browsers fire `cancel` if the user dismisses the dialog;
      // covering both keeps the promise from leaking.
      input.addEventListener(
        'cancel',
        () => { input.remove(); resolve(null); },
        { once: true },
      );
      document.body.appendChild(input);
      input.click();
    });
  }

  function paintFront(button: HTMLButtonElement, url: string) {
    const existingImg = button.querySelector<HTMLImageElement>('.cover-thumb:not(.cover-thumb--empty)');
    if (existingImg) {
      existingImg.src = url;
      return;
    }
    const empty = button.querySelector('.cover-thumb--empty');
    if (empty) empty.remove();
    const img = document.createElement('img');
    img.className = 'cover-thumb';
    img.src = url;
    img.alt = '';
    img.loading = 'lazy';
    img.decoding = 'async';
    // Insert before the overlay so the overlay stays on top.
    const overlay = button.querySelector('.cover-uploader-overlay');
    if (overlay) {
      button.insertBefore(img, overlay);
    } else {
      button.appendChild(img);
    }
  }

  async function uploadFront(
    kind: 'book' | 'series',
    slug: string,
    file: File,
  ): Promise<{ ok: true } | { error: string }> {
    const fd = new FormData();
    fd.append('kind', kind);
    fd.append('slug', slug);
    fd.append('file', file);
    try {
      const res = await fetch('/api/upload-front', { method: 'POST', body: fd });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data?.success) {
        return { error: data?.error || `HTTP ${res.status}` };
      }
      return { ok: true };
    } catch (err: any) {
      return { error: err?.message || 'network' };
    }
  }

  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement | null)?.closest<HTMLButtonElement>(
      'button[data-cover-upload]'
    );
    if (!btn) return;

    const kindRaw = btn.dataset.coverUpload;
    const slug = btn.dataset.slug;
    if ((kindRaw !== 'book' && kindRaw !== 'series') || !slug) return;
    const kind = kindRaw;

    const file = await pickFrontFile();
    if (!file) return;

    if (!FRONT_ACCEPTED.includes(file.type)) {
      showToast(i18n.toastCoverInvalidType);
      return;
    }
    if (file.size > FRONT_MAX_BYTES) {
      showToast(i18n.toastCoverTooLarge);
      return;
    }

    btn.dataset.uploading = 'true';
    const result = await uploadFront(kind, slug, file);
    delete btn.dataset.uploading;

    if ('error' in result) {
      showToast(fmt(i18n.toastCoverUploadFailed, { msg: result.error }));
      return;
    }

    // Instant preview: swap the thumb to a blob URL of the file the
    // user just selected. The on-disk file IS persisted by the
    // server; the proper Vite-hashed URL will surface on the next
    // page load. Object URLs are scoped to the document, so we don't
    // bother revoking — the next paint reuses or replaces them.
    paintFront(btn, URL.createObjectURL(file));

    // Resolve a human title for the toast.
    let title = slug;
    if (kind === 'book') {
      const row = btn.closest<HTMLElement>('.book-card');
      const t = row?.querySelector<HTMLElement>('.book-title');
      if (t?.textContent?.trim()) title = t.textContent.trim();
    } else {
      const card = btn.closest<HTMLElement>('[data-series-name]');
      title = card?.dataset.seriesName || slug;
    }
    showToast(fmt(i18n.toastCoverUploaded, { title }));
  });
</script>
