---
import BaseLayout from '../layouts/BaseLayout.astro';
import { discoverAllBooks } from '../utils/book-discovery';

const books = discoverAllBooks();
---

<BaseLayout title="Admin - Yuval" showLanguageToggle={false}>
  <div class="admin-wrap">
    <h1 class="admin-title">Admin Panel</h1>
    <p class="admin-subtitle">Manage local reader data stored in the browser.</p>

    <div class="books-grid" id="books-grid">
      {books.map(book => (
        <div class="book-card" data-slug={book.slug}>
          <div class="book-info">
            <span class="book-title">{book.title_en}</span>
            <span class="book-slug">{book.slug}</span>
          </div>
          <div class="book-stats">
            <span class="stat" id={`stat-${book.slug}`}>...</span>
          </div>
          <div class="book-actions">
            <button class="clean-btn" data-slug={book.slug}>
              Clean data
            </button>
            <button class="delete-btn" data-slug={book.slug} data-title={book.title_en}>
              🗑️ Delete book
            </button>
          </div>
        </div>
      ))}
    </div>

    <div class="global-section">
      <h2>Global settings</h2>
      <p>Language, theme, typography, TTS voice & speed, onboarding state.</p>
      <button class="clean-btn clean-btn--global" id="clean-global-btn">
        Clean global settings
      </button>
    </div>

    <div id="toast" class="toast hidden"></div>

    <!-- Delete Confirmation Modal -->
    <div id="delete-modal" class="modal hidden">
      <div class="modal-backdrop"></div>
      <div class="modal-content">
        <h3>⚠️ מחיקת ספר</h3>
        <p>האם אתה בטוח שברצונך למחוק את הספר <strong id="modal-book-title"></strong>?</p>
        <p class="modal-warning">פעולה זו תמחק את כל הקבצים בכל השפות ולא ניתנת לביטול!</p>
        <div class="modal-actions">
          <button class="modal-btn modal-btn--cancel" id="modal-cancel">ביטול</button>
          <button class="modal-btn modal-btn--delete" id="modal-confirm">מחק לצמיתות</button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .admin-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .admin-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--yuval-text);
    margin: 0 0 6px;
  }

  .admin-subtitle {
    color: var(--yuval-text-secondary);
    font-size: 0.9rem;
    margin: 0 0 32px;
  }

  .books-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 40px;
  }

  .book-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--yuval-surface);
    border: 1px solid var(--yuval-border);
    border-radius: 12px;
    padding: 16px 20px;
  }

  .book-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .book-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--yuval-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .book-slug {
    font-size: 0.75rem;
    color: var(--yuval-text-muted);
    font-family: monospace;
  }

  .book-stats .stat {
    font-size: 0.8rem;
    color: var(--yuval-text-secondary);
    white-space: nowrap;
  }

  .clean-btn {
    padding: 7px 16px;
    border-radius: 8px;
    border: 1px solid var(--yuval-border);
    background: var(--yuval-bg-secondary);
    color: var(--yuval-text-secondary);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .clean-btn:hover {
    background: #fee2e2;
    color: #b91c1c;
    border-color: #fca5a5;
  }

  .clean-btn--global {
    margin-top: 12px;
  }

  .global-section {
    border-top: 1px solid var(--yuval-border);
    padding-top: 28px;
  }

  .global-section h2 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--yuval-text);
    margin: 0 0 4px;
  }

  .global-section p {
    font-size: 0.85rem;
    color: var(--yuval-text-secondary);
    margin: 0 0 8px;
  }

  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    background: #1a1a1a;
    color: #fff;
    padding: 10px 20px;
    border-radius: 99px;
    font-size: 0.85rem;
    font-weight: 500;
    z-index: 9999;
    transition: opacity 0.3s;
  }

  .toast.hidden { display: none; }

  /* Book actions container */
  .book-actions {
    display: flex;
    gap: 8px;
  }

  /* Delete button */
  .delete-btn {
    padding: 7px 12px;
    border-radius: 8px;
    border: 1px solid #dc2626;
    background: transparent;
    color: #dc2626;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }

  .delete-btn:hover {
    background: #dc2626;
    color: #fff;
  }

  /* Modal */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal.hidden { display: none; }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
  }

  .modal-content {
    position: relative;
    background: var(--yuval-surface, #fff);
    border-radius: 16px;
    padding: 28px;
    max-width: 400px;
    width: 90%;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    text-align: center;
  }

  .modal-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--yuval-text);
    margin: 0 0 12px;
  }

  .modal-content p {
    font-size: 0.9rem;
    color: var(--yuval-text-secondary);
    margin: 0 0 8px;
    line-height: 1.5;
  }

  .modal-warning {
    color: #dc2626 !important;
    font-weight: 500;
    font-size: 0.85rem !important;
  }

  .modal-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 20px;
  }

  .modal-btn {
    padding: 10px 24px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      background 150ms cubic-bezier(0.2, 0, 0, 1),
      color 150ms cubic-bezier(0.2, 0, 0, 1),
      border-color 150ms cubic-bezier(0.2, 0, 0, 1);
  }

  .modal-btn--cancel {
    background: var(--yuval-bg-secondary, #f3f3f3);
    border: 1px solid var(--yuval-border, #ddd);
    color: var(--yuval-text-secondary);
  }

  .modal-btn--cancel:hover {
    background: var(--yuval-border, #ddd);
  }

  .modal-btn--delete {
    background: #dc2626;
    border: none;
    color: #fff;
  }

  .modal-btn--delete:hover {
    background: #b91c1c;
  }

  .modal-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

<script>
  const BOOK_PREFIXES = (slug: string) => [
    `yuval_bookmarks_${slug}`,
    `yuval_highlights_${slug}`,   // prefix - will match all chapters
    `yuval_reading_progress_${slug}`,
    `yuval_reading_stats_${slug}`,
    `yuval_reading_goals_${slug}`,
  ];

  const GLOBAL_KEYS = [
    'yuval_language',
    'yuval-theme',
    'yuval-typography',
    'yuval_tts_voice_he',
    'yuval_tts_voice_en',
    'yuval_tts_voice_es',
    'yuval_tts_speed',
    'yuval_onboarded_v1',
    'yuval_reading_goal',
  ];

  function countBookKeys(slug: string): number {
    let count = 0;
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i) || '';
      if (key.includes(`_${slug}`)) count++;
    }
    return count;
  }

  function cleanBook(slug: string): number {
    const toDelete: string[] = [];
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i) || '';
      if (key.includes(`_${slug}`)) toDelete.push(key);
    }
    toDelete.forEach(k => localStorage.removeItem(k));
    return toDelete.length;
  }

  function cleanGlobal(): number {
    let count = 0;
    GLOBAL_KEYS.forEach(k => {
      if (localStorage.getItem(k) !== null) {
        localStorage.removeItem(k);
        count++;
      }
    });
    return count;
  }

  function showToast(msg: string) {
    const toast = document.getElementById('toast')!;
    toast.textContent = msg;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 2800);
  }

  function updateStats() {
    document.querySelectorAll<HTMLElement>('.book-card').forEach(card => {
      const slug = card.dataset.slug!;
      const count = countBookKeys(slug);
      const el = document.getElementById(`stat-${slug}`);
      if (el) el.textContent = count === 0 ? 'No data' : `${count} item${count !== 1 ? 's' : ''}`;
    });
  }

  // Attach clean buttons
  document.querySelectorAll<HTMLButtonElement>('.clean-btn[data-slug]').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.slug!;
      const removed = cleanBook(slug);
      updateStats();
      showToast(removed > 0 ? `Cleaned ${removed} items for "${slug}"` : `No data found for "${slug}"`);
    });
  });

  document.getElementById('clean-global-btn')?.addEventListener('click', () => {
    const removed = cleanGlobal();
    showToast(removed > 0 ? `Cleaned ${removed} global settings` : 'No global settings found');
  });

  // Delete book functionality
  const modal = document.getElementById('delete-modal')!;
  const modalTitle = document.getElementById('modal-book-title')!;
  const modalCancel = document.getElementById('modal-cancel')!;
  const modalConfirm = document.getElementById('modal-confirm')!;
  let pendingDeleteSlug: string | null = null;

  function showModal(slug: string, title: string) {
    pendingDeleteSlug = slug;
    modalTitle.textContent = title;
    modal.classList.remove('hidden');
    modalConfirm.disabled = false;
    modalConfirm.textContent = 'מחק לצמיתות';
  }

  function hideModal() {
    modal.classList.add('hidden');
    pendingDeleteSlug = null;
  }

  // Attach delete buttons
  document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.slug!;
      const title = btn.dataset.title || slug;
      showModal(slug, title);
    });
  });

  modalCancel.addEventListener('click', hideModal);
  modal.querySelector('.modal-backdrop')?.addEventListener('click', hideModal);

  modalConfirm.addEventListener('click', async () => {
    if (!pendingDeleteSlug) return;
    
    const slug = pendingDeleteSlug;
    modalConfirm.disabled = true;
    modalConfirm.textContent = 'מוחק...';

    try {
      const response = await fetch('/api/delete-book', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug })
      });

      const result = await response.json();

      if (result.success) {
        // Remove the book card from the page
        const card = document.querySelector(`.book-card[data-slug="${slug}"]`);
        if (card) {
          card.remove();
        }
        hideModal();
        showToast(`✅ הספר "${slug}" נמחק בהצלחה`);
      } else {
        showToast(`❌ שגיאה: ${result.error || 'לא ניתן למחוק'}`);
        hideModal();
      }
    } catch (error: any) {
      showToast(`❌ שגיאת רשת: ${error.message}`);
      hideModal();
    }
  });

  // Close modal with Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      hideModal();
    }
  });

  updateStats();
</script>
