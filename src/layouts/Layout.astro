---
/**
 * Layout.astro
 * Base layout for all Yuval/BookForge pages.
 * Props:
 *   title — page <title>
 *   lang  — "he" | "en" — sets dir attribute and language toggle
 */
import ReadingProgress from '../components/ReadingProgress.astro';

export interface Props {
  title: string;
  lang: 'he' | 'en';
}

const { title, lang = 'he' } = Astro.props as Props;
const dir = lang === 'he' ? 'rtl' : 'ltr';
const toggleLang = lang === 'he' ? 'en' : 'he';
const toggleLabel = lang === 'he' ? 'English' : 'עברית';
const toggleHref = `${Astro.url.pathname}?lang=${toggleLang}`;
---

<!doctype html>
<html lang={lang} dir={dir} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@300;400;700;900&family=Heebo:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-[#fafaf8] text-[#1a1a1a] antialiased">

    <!-- Header -->
    <header
      class="sticky top-0 z-[100] flex h-[68px] items-center justify-between border-b border-[#f0ede8] bg-white/95 px-6 backdrop-blur-md md:px-16"
      role="banner"
    >
      <a
        href="/"
        class="font-['Frank_Ruhl_Libre'] text-xl font-bold tracking-wide text-[#1a1a1a] transition-opacity hover:opacity-70"
      >
        BookForge
      </a>

      <nav aria-label={lang === 'he' ? 'בחירת שפה' : 'Language selection'}>
        <a
          href={toggleHref}
          class="rounded-full border border-[#e0ddd8] px-4 py-1.5 font-['Heebo'] text-xs font-medium tracking-[0.08em] text-[#888888] transition-colors hover:border-[#1a1a1a] hover:text-[#1a1a1a]"
        >
          {toggleLabel}
        </a>
      </nav>
    </header>

    <!-- Reading progress bar -->
    <ReadingProgress />

    <!-- Main content -->
    <main
      id="main-content"
      class="mx-auto max-w-4xl px-6 pb-24 pt-12 md:px-16"
      tabindex="-1"
    >
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[#f0ede8] py-8 text-center" role="contentinfo">
      <p class="font-['Heebo'] text-sm text-[#bbbbbb]">
        {lang === 'he' ? 'נוצר עם BookForge' : 'Built with BookForge'}
      </p>
    </footer>

  </body>
</html>
