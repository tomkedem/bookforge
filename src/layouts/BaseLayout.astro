---
import { ClientRouter } from 'astro:transitions';
import '../styles/theme.css';
import '../styles/chapter-lists.css';
import '../styles/tts.css';
import type { Language } from '../types/index';
import Header from '../components/Header.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import { SOURCE_LANGUAGE, getLanguageDirection } from '../utils/language';

interface Props {
  title: string;
  description?: string;
  language?: Language;
  availableLanguages?: Language[];
  allowClientLanguageOverride?: boolean;
  showHeader?: boolean;
  showProgress?: boolean;
  showLanguageToggle?: boolean;
  class?: string;
}

const {
  title,
  description = 'Yuval - A digital reading platform',
  language = SOURCE_LANGUAGE,
  availableLanguages,
  allowClientLanguageOverride = false,
  showHeader = true,
  showProgress = false,
  showLanguageToggle = true,
  class: className,
} = Astro.props;

const isRtl = getLanguageDirection(language) === 'rtl';
---

<!doctype html>
<html lang={language} dir={isRtl ? 'rtl' : 'ltr'} class="scroll-smooth" translate="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta name="google" content="notranslate" />
    <title>{title} | Yuval</title>

    <!-- Preload fonts.
         Split into three Google Fonts requests instead of one giant URL:
         - Hebrew families (the primary reading language)
         - Latin / display serifs (for English chapters and decorative text)
         - Variable fonts (Fraunces) — separate request because the
           variable-axis syntax is the most likely culprit when one
           family in a combined URL silently fails and produces the
           "Verify stylesheet URLs" issue. Each link is independent;
           a failure in one no longer breaks the whole load. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;600;700&family=IBM+Plex+Sans+Hebrew:wght@300;400;500;600;700&family=Heebo:wght@100;300;400;500;600;700;900&family=David+Libre:wght@400;500;700&family=Frank+Ruhl+Libre:wght@400;500;700&family=Noto+Rashi+Hebrew:wght@400;500;700&family=Noto+Serif+Hebrew:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Bellefair&family=Spectral:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=IM+Fell+English:ital@0;1&family=Old+Standard+TT:ital,wght@0,400;0,700;1,400&family=Cardo:ital,wght@0,400;0,700;1,400&family=Cinzel:wght@400;500;600&family=UnifrakturMaguntia&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1a1a1a" />
    <!-- `mobile-web-app-capable` is the modern cross-browser tag; the
         apple-prefixed one is kept alongside it for older iOS Safari
         (it's the one that takes effect there) but is now reported as
         deprecated by Chrome. -->
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <!-- View Transitions -->
    <ClientRouter />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Schema.org -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Yuval",
        "url": "https://yuval.example.com"
      }
    </script>

    <!-- Service Worker registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>

    <!-- Prevent FOUC: apply dark mode before paint -->
    <script is:inline>
      (function() {
        try {
          var theme = localStorage.getItem('yuval-theme');
          if (!theme) theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          if (theme === 'dark') document.documentElement.classList.add('dark');
        } catch(e) {}
      })();
    </script>

    <!-- Sync language between URL ?lang= and localStorage before the page renders.
         If user has a saved language preference but the URL doesn't reflect it,
         redirect so the server re-renders in the correct language. -->
    <script is:inline define:vars={{ serverLang: language, availableLangs: availableLanguages ?? [language], allowClientLanguageOverride }}>
      (function() {
        try {
          var params = new URLSearchParams(window.location.search);
          var urlLang = params.get('lang');
          var storedLang = localStorage.getItem('yuval_language');
          var valid = ['he','en','es'];
          var allowed = Array.isArray(availableLangs) && availableLangs.length > 0 ? availableLangs : [serverLang];

          if (urlLang && valid.indexOf(urlLang) !== -1) {
            if (allowed.indexOf(urlLang) !== -1 && (urlLang === serverLang || allowClientLanguageOverride)) {
              if (storedLang !== urlLang) localStorage.setItem('yuval_language', urlLang);
            } else {
              params.set('lang', serverLang);
              localStorage.setItem('yuval_language', serverLang);
              window.location.replace(window.location.pathname + '?' + params.toString() + window.location.hash);
            }
          } else if (!allowClientLanguageOverride && storedLang && valid.indexOf(storedLang) !== -1 && storedLang !== serverLang && allowed.indexOf(storedLang) !== -1) {
            // No URL override, but stored preference differs from what server rendered - redirect
            params.set('lang', storedLang);
            window.location.replace(window.location.pathname + '?' + params.toString() + window.location.hash);
          } else if (storedLang && valid.indexOf(storedLang) !== -1 && allowed.indexOf(storedLang) === -1) {
            localStorage.setItem('yuval_language', serverLang);
          }
        } catch(e) {}
      })();
    </script>
  </head>

  <body
    class:list={[
      'bg-yuval-bg',
      'text-yuval-text',
      'font-body',
      'antialiased',
      'transition-colors',
      'duration-300',
      className,
    ]}
  >
    {showProgress && <ReadingProgress language={language} />}

    {showHeader && (
      <Header
        language={language}
        availableLanguages={availableLanguages}
        showLanguageToggle={showLanguageToggle}
      />
    )}

    <!-- Sidebars outside main - not affected by View Transitions -->
    <slot name="sidebars" />

    <main id="main-content" class="w-full" transition:animate="none">
      <slot />
    </main>

    <BackToTop />
    {/* Language bootstrap — extracted to a stand-alone .ts file so
        Astro's bundler resolves the ../utils/language import correctly.
        When the body lived inside a `<script type="module">` here it
        was occasionally served raw, which exploded on the browser. */}
    <script>
      import '../scripts/language-bootstrap';
    </script>
    
    </body>
</html>