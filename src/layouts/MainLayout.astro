---
import Header from '../components/Header.astro';

const { title = 'BookForge' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@400;700&family=Heebo:wght@400;500;700&display=swap" rel="stylesheet">
    <style is:global>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Heebo', sans-serif;
            color: #000;
            background: #fff;
            line-height: 1.6;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Frank Ruhl Libre', serif;
            font-weight: 700;
        }

        html[dir="rtl"] {
            direction: rtl;
            text-align: right;
        }

        html[dir="ltr"] {
            direction: ltr;
            text-align: left;
        }
    </style>
</head>
<body>
    <Header />
    <div class="container">
        <slot />
    </div>
</body>
</html>

<style>
    .container {
        min-height: 100vh;
    }
</style>
