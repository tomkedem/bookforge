---
import type { Language } from '../types/index';
import BaseLayout from './BaseLayout.astro';
import ReadingControls from '../components/ReadingControls.astro';
import LeftSidebar from '../components/LeftSidebar.astro';
import '../styles/reading-typography.css';
import '../styles/bash-block.css';
import '../styles/code-runner.css';
import { SOURCE_LANGUAGE, getLanguageDirection } from '../utils/language';

interface Props {
  title: string;
  language?: Language;
  availableLanguages?: Language[];
  class?: string;
}

const { title, language = SOURCE_LANGUAGE, availableLanguages, class: className } = Astro.props;
const isRtl = getLanguageDirection(language) === 'rtl';
const COPY_SUCCESS_MESSAGE = 'Code copied!';
---

<BaseLayout
  title={title}
  language={language}
  availableLanguages={availableLanguages}
  allowClientLanguageOverride={true}
  showHeader={true}
  showProgress={false}
  showLanguageToggle={true}
>
  <!-- Sidebars passed through to body level. The left activity bar
       renders alongside the page-provided right sidebar so both sit
       at the BaseLayout root, outside <main>'s view-transition scope. -->
  <Fragment slot="sidebars">
    <slot name="sidebars" />
    <LeftSidebar />
  </Fragment>

  <article
    class:list={[
      'reading-article',
      'px-4',
      'sm:px-6',
      'lg:px-8',
      'pt-0',
      'pb-4',
      'sm:pb-6',
      'lg:pb-8',
      isRtl && 'text-right',
      className,
    ]}
    style="background-color: var(--yuval-reading-bg); padding-bottom: calc(2rem + var(--platform-status-bar-height, 0px));"
  >
    <!-- Global SVG symbol defs — referenced by <use href="#cr-sun|cr-moon"/>
         in every CodeRunner/CodeBlock theme toggle button. -->
    <svg width="0" height="0" style="position:absolute;overflow:hidden" aria-hidden="true">
      <defs>
        <radialGradient id="cr-sun-core" cx="50%" cy="40%" r="60%">
          <stop offset="0%" stop-color="#fff8b0"/>
          <stop offset="40%" stop-color="#ffdd55"/>
          <stop offset="100%" stop-color="#ff9500"/>
        </radialGradient>
        <radialGradient id="cr-sun-glow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#ffdd55" stop-opacity="0.55"/>
          <stop offset="100%" stop-color="#ffdd55" stop-opacity="0"/>
        </radialGradient>
        <!-- Night-sky background: full black with a hint of midnight blue -->
        <radialGradient id="cr-moon-sky" cx="30%" cy="30%" r="95%">
          <stop offset="0%" stop-color="#0b1128"/>
          <stop offset="55%" stop-color="#04060f"/>
          <stop offset="100%" stop-color="#000000"/>
        </radialGradient>
        <!-- Glowing crescent: warm ivory fading to amber -->
        <radialGradient id="cr-moon-body" cx="40%" cy="35%" r="80%">
          <stop offset="0%" stop-color="#fffbe0"/>
          <stop offset="55%" stop-color="#f6dc8a"/>
          <stop offset="100%" stop-color="#d9a84a"/>
        </radialGradient>
        <!-- Soft halo around the crescent -->
        <radialGradient id="cr-moon-halo" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#ffe79a" stop-opacity="0.55"/>
          <stop offset="55%" stop-color="#ffe79a" stop-opacity="0.12"/>
          <stop offset="100%" stop-color="#ffe79a" stop-opacity="0"/>
        </radialGradient>
        <!-- Gold progress-ring gradient (used by the per-chapter
             minutes-remaining ring in the sticky top strip). Shared
             across all three language rows so SVG refs don't duplicate. -->
        <linearGradient id="ring-gold-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#e8c547"/>
          <stop offset="55%" stop-color="#c9a227"/>
          <stop offset="100%" stop-color="#a8852a"/>
        </linearGradient>
        <linearGradient id="ring-gold-gradient-dark" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#d4c098"/>
          <stop offset="55%" stop-color="#a8956d"/>
          <stop offset="100%" stop-color="#7a6b56"/>
        </linearGradient>
        <!-- Mask that bites a circular chunk out of the moon to form a
             fat-banana crescent. The bite is fully offset so a thick C
             remains visible. -->
        <mask id="cr-crescent-mask">
          <rect width="24" height="24" fill="black"/>
          <circle cx="10" cy="12" r="9" fill="white"/>
          <circle cx="14.8" cy="10.5" r="8" fill="black"/>
        </mask>
        <symbol id="cr-sun" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="11" fill="url(#cr-sun-glow)"/>
          <g stroke="#ffcc33" stroke-width="1.5" stroke-linecap="round">
            <line x1="12" y1="2" x2="12" y2="4.5"/>
            <line x1="12" y1="19.5" x2="12" y2="22"/>
            <line x1="2" y1="12" x2="4.5" y2="12"/>
            <line x1="19.5" y1="12" x2="22" y2="12"/>
            <line x1="4.93" y1="4.93" x2="6.7" y2="6.7"/>
            <line x1="17.3" y1="17.3" x2="19.07" y2="19.07"/>
            <line x1="4.93" y1="19.07" x2="6.7" y2="17.3"/>
            <line x1="17.3" y1="6.7" x2="19.07" y2="4.93"/>
          </g>
          <circle cx="12" cy="12" r="5" fill="url(#cr-sun-core)"/>
          <circle cx="10.5" cy="10.5" r="1.2" fill="#fff8b0" opacity="0.8"/>
        </symbol>
        <symbol id="cr-moon" viewBox="0 0 24 24">
          <!-- Pitch-black night-sky disc (full button background) -->
          <circle cx="12" cy="12" r="12" fill="url(#cr-moon-sky)"/>
          <!-- Tiny stars scattered across the sky -->
          <circle cx="4.5" cy="6" r="0.35" fill="#ffffff" opacity="0.9"/>
          <circle cx="19.5" cy="5.5" r="0.45" fill="#ffffff" opacity="0.95"/>
          <circle cx="20.5" cy="15" r="0.3" fill="#ffffff" opacity="0.8"/>
          <circle cx="3.5" cy="17" r="0.3" fill="#ffffff" opacity="0.8"/>
          <circle cx="7" cy="3.2" r="0.25" fill="#ffffff" opacity="0.75"/>
          <circle cx="17" cy="20.5" r="0.25" fill="#ffffff" opacity="0.75"/>
          <circle cx="22" cy="9" r="0.22" fill="#ffffff" opacity="0.7"/>
          <!-- Halo glow around the crescent -->
          <circle cx="10" cy="12" r="10.5" fill="url(#cr-moon-halo)"/>
          <!-- Crescent moon — a bright disc with a circular bite taken out
               of it. Body radius 9, bite radius 8, offset ~5 → visible
               banana-shaped C opening to the right. -->
          <circle cx="10" cy="12" r="9" fill="url(#cr-moon-body)" mask="url(#cr-crescent-mask)"/>
        </symbol>
      </defs>
    </svg>

    <!-- Chapter content -->
    <div
      class="reading-content prose prose-invert max-w-none space-y-6"
      data-language={language}
    >
      <slot />
    </div>
    <!-- Typography mode persistence and toggle logic -->
    <script is:inline>
      // Wrap in IIFE so our `const STORAGE_KEY` doesn't collide with
      // the one declared by ReadingControls.astro (both run on the
      // same page; top-level `const` is global for inline scripts).
      (function initReadingPrefs() {
        // Typography mode: 'modern' (Assistant) or 'clean' (Heebo)
        const STORAGE_KEY = 'typography-mode';
        const root = document.documentElement;
        function applyTypographyMode(mode) {
          if (mode === 'clean') {
            root.setAttribute('data-typography', 'clean');
          } else {
            root.setAttribute('data-typography', 'modern');
          }
        }
        const saved = localStorage.getItem(STORAGE_KEY);
        applyTypographyMode(saved === 'clean' ? 'clean' : 'modern');
        window.addEventListener('typography-mode-change', (e) => {
          const mode = e.detail?.mode;
          if (mode === 'clean' || mode === 'modern') {
            applyTypographyMode(mode);
            localStorage.setItem(STORAGE_KEY, mode);
          }
        });

        // Code theme ('dark' / 'light') — applied inline to avoid a flash
        // of the wrong icon before the module script runs. Default = dark.
        try {
          const savedCodeTheme = localStorage.getItem('code-theme');
          root.setAttribute('data-code-theme', savedCodeTheme === 'light' ? 'light' : 'dark');
        } catch {
          root.setAttribute('data-code-theme', 'dark');
        }
      })();
    </script>

    <!-- Custom prose styles for reading -->
    <style>
      /* ── Syntax highlighting (highlight.js GitHub Dark theme) ── */
      :global(.hljs) {
        color: #c9d1d9;
        background: #0d1117;
      }
      :global(.hljs-doctag, .hljs-keyword, .hljs-meta .hljs-keyword,
              .hljs-template-tag, .hljs-template-variable, .hljs-type,
              .hljs-variable.language_) { color: #ff7b72; }
      :global(.hljs-title, .hljs-title.class_, .hljs-title.class_.inherited__,
              .hljs-title.function_) { color: #d2a8ff; }
      :global(.hljs-attr, .hljs-attribute, .hljs-literal, .hljs-meta,
              .hljs-number, .hljs-operator, .hljs-selector-attr,
              .hljs-selector-class, .hljs-selector-id, .hljs-variable) { color: #79c0ff; }
      :global(.hljs-meta .hljs-string, .hljs-regexp, .hljs-string) { color: #a5d6ff; }
      :global(.hljs-built_in, .hljs-symbol) { color: #ffa657; }
      :global(.hljs-comment, .hljs-code, .hljs-formula) { color: #8b949e; }
      :global(.hljs-name, .hljs-quote, .hljs-selector-pseudo,
              .hljs-selector-tag) { color: #7ee787; }
      :global(.hljs-subst) { color: #c9d1d9; }
      :global(.hljs-section) { color: #1f6feb; font-weight: bold; }
      :global(.hljs-bullet) { color: #f2cc60; }
      :global(.hljs-emphasis) { color: #c9d1d9; font-style: italic; }
      :global(.hljs-strong) { color: #c9d1d9; font-weight: bold; }
      :global(.hljs-addition) { color: #aff5b4; background-color: #033a16; }
      :global(.hljs-deletion) { color: #ffdcd7; background-color: #67060c; }

      /* Code always LTR regardless of page language */
      :global(article pre),
      :global(article code) {
        direction: ltr !important;
        text-align: left !important;
        unicode-bidi: isolate;
      }

      /* Code block wrapper */
      :global(article pre) {
        position: relative;
        background: #0d1117;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 0;
        overflow: hidden;
        margin: 1.75rem 0;
        box-shadow: 0 4px 16px rgba(0,0,0,0.25);
      }

      /* Language badge */
      :global(article pre[data-lang]::before) {
        content: attr(data-lang);
        display: block;
        background: #161b22;
        border-bottom: 1px solid #30363d;
        padding: 6px 16px;
        font-size: 11px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: #8b949e;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      :global(article pre code.hljs) {
        display: block;
        padding: 12px;
        overflow-x: auto;
        font-size: 0.75rem;
        line-height: 1.6;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        background: transparent;
      }

      @media (min-width: 640px) {
        :global(article pre code.hljs) {
          padding: 20px;
          font-size: 0.85rem;
          line-height: 1.7;
        }
      }

      /* Inline code */
      :global(article :not(pre) > code) {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.85em;
        background: rgba(110, 118, 129, 0.15);
        border: 1px solid rgba(110, 118, 129, 0.25);
        border-radius: 4px;
        padding: 0.15em 0.45em;
        color: #e6edf3;
      }
      :global(article h1) {
        @apply font-heading font-bold text-2xl sm:text-4xl lg:text-5xl leading-tight mt-10 sm:mt-16 mb-5 sm:mb-8 text-yuval-text;
        color: var(--yuval-chapter-title);
        letter-spacing: -0.01em;
      }

      :global(article h2) {
        @apply font-heading font-bold text-lg sm:text-2xl lg:text-3xl leading-snug mt-8 sm:mt-10 mb-3 sm:mb-4 text-yuval-text;
      }

      :global(article h3) {
        @apply font-heading font-semibold text-base sm:text-xl lg:text-2xl leading-snug mt-6 sm:mt-8 mb-2 sm:mb-3 text-yuval-text-secondary;
      }

      :global(article p) {
        @apply text-base sm:text-lg lg:text-xl leading-relaxed sm:leading-loose text-yuval-text-secondary mb-4 sm:mb-6 font-light;
      }

      :global(article blockquote) {
        @apply relative pl-4 sm:pl-6 py-3 sm:py-4 my-6 sm:my-8 text-base sm:text-xl leading-relaxed text-yuval-text-secondary bg-yuval-bg-secondary;
        border-left: 4px solid var(--yuval-blockquote-border);
      }

      :global(article [dir="rtl"] blockquote) {
        @apply pl-0 pr-6 border-l-0 border-r-4;
      }

      :global(article strong) {
        @apply font-semibold text-yuval-text;
      }

      :global(article em) {
        @apply italic;
      }

      :global(article ul,
      article ol) {
        @apply ml-6 space-y-2 my-6;
      }

      :global(article ul) {
        list-style-type: disc;
      }

      :global(article ol) {
        list-style-type: decimal;
      }

      :global(article [dir="rtl"] ul,
      article [dir="rtl"] ol) {
        @apply ml-0 mr-6;
      }

      :global(article li) {
        @apply text-base sm:text-lg leading-relaxed text-yuval-text-secondary font-light;
      }

      :global(article a) {
        @apply underline transition-colors duration-200;
        color: var(--yuval-link);
      }

      :global(article a:hover) {
        color: var(--yuval-link-hover);
      }

      :global(article img) {
        @apply max-w-full h-auto rounded-lg my-8 mx-auto block;
        background-color: #fff;
        image-rendering: -webkit-optimize-contrast;
        image-rendering: crisp-edges;
        backface-visibility: hidden;
        transform: translateZ(0);
      }

      /* Code block copy button */
      :global(article pre) {
        position: relative;
      }

      :global(.code-copy-btn) {
        position: absolute;
        top: 8px;
        right: 8px;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 6px;
        border: 1px solid #30363d;
        background: #21262d;
        color: #8b949e;
        cursor: pointer;
        opacity: 0;
        transition: opacity 200ms var(--ease-standard), color 150ms var(--ease-standard), background 150ms var(--ease-standard);
      }

      :global(article pre:hover .code-copy-btn),
      :global(.code-copy-btn:focus-visible) {
        opacity: 1;
      }

      :global(.code-copy-btn:hover) {
        color: #e6edf3;
        background: #30363d;
      }

      :global(.code-copy-btn.copied) {
        color: #3fb950;
      }

      :global(article hr) {
        @apply my-12 border-yuval-border;
      }

      /* ── Markdown Preview: tab bar replaces ::before label ── */
      :global(article pre[data-has-preview]::before) {
        display: none;
      }

      :global(article .md-tab-bar) {
        display: flex;
        align-items: center;
        background: #161b22;
        border-bottom: 1px solid #30363d;
        padding: 0 8px;
        gap: 0;
        flex-shrink: 0;
      }

      :global(article .md-lang-label) {
        font-size: 11px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: #8b949e;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 6px 12px 6px 8px;
        margin-right: 8px;
        border-right: 1px solid #30363d;
        flex-shrink: 0;
      }

      :global(article .md-tab) {
        padding: 6px 14px;
        font-size: 12px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: #8b949e;
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        transition: color 0.15s, border-color 0.15s;
        margin-bottom: -1px;
      }

      :global(article .md-tab:hover) {
        color: #c9d1d9;
      }

      :global(article .md-tab-active) {
        color: #e6edf3;
        border-bottom-color: #58a6ff;
      }

      /* Preview rendered area */
      :global(article .md-preview) {
        padding: 20px 24px;
        color: #c9d1d9;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 14px;
        line-height: 1.7;
      }
      :global(article .md-preview[dir="ltr"]) {
        direction: ltr;
        text-align: left;
      }
      :global(article .md-preview[dir="rtl"]) {
        direction: rtl;
        text-align: right;
        font-family: 'Heebo', 'Frank Ruhl Libre', -apple-system, sans-serif;
      }
      :global(article .md-preview[dir="rtl"] ul,
              article .md-preview[dir="rtl"] ol) {
        padding-left: 0;
        padding-right: 1.4em;
      }
      :global(article .md-preview[dir="rtl"] blockquote) {
        border-left: none;
        border-right: 3px solid #58a6ff;
        padding: 4px 16px 4px 0;
      }
      :global(article .md-preview[dir="rtl"] pre) {
        direction: ltr;
        text-align: left;
      }

      :global(article .md-preview h1) {
        font-size: 2.25rem;
        font-weight: 700;
        color: var(--yuval-chapter-title);
        margin: 2.5rem 0 1.5rem;
        border-bottom: none;
        padding-bottom: 0;
        letter-spacing: -0.01em;
      }
      :global(article .md-preview h2) {
        font-size: 1.2em; font-weight: 600;
        color: #e6edf3; margin: 1em 0 0.4em;
        border-bottom: 1px solid #21262d; padding-bottom: 0.2em;
      }
      :global(article .md-preview h3) {
        font-size: 1.05em; font-weight: 600;
        color: #e6edf3; margin: 0.9em 0 0.3em;
      }
      :global(article .md-preview p) { margin: 0.5em 0; }
      :global(article .md-preview ul, article .md-preview ol) {
        margin: 0.5em 0; padding-left: 1.4em;
      }
      :global(article .md-preview ul) {
        list-style-type: disc;
      }
      :global(article .md-preview ol) {
        list-style-type: decimal;
      }
      :global(article .md-preview li) { margin: 0.2em 0; }
      :global(article .md-preview code) {
        background: rgba(110,118,129,0.2);
        border: 1px solid rgba(110,118,129,0.25);
        padding: 0.1em 0.4em; border-radius: 4px;
        font-family: ui-monospace, Menlo, monospace; font-size: 0.88em;
        color: #e6edf3;
      }
      :global(article .md-preview pre) {
        background: #0d1117; border: 1px solid #30363d;
        border-radius: 6px; padding: 12px 16px;
        overflow-x: auto; margin: 0.8em 0;
      }
      :global(article .md-preview pre code) {
        background: none; border: none; padding: 0; font-size: 0.85em;
      }
      :global(article .md-preview blockquote) {
        border-left: 3px solid #58a6ff;
        margin: 0.8em 0; padding: 4px 0 4px 16px;
        color: #8b949e;
      }
      :global(article .md-preview hr) {
        border: none; border-top: 1px solid #30363d; margin: 1em 0;
      }
      :global(article .md-preview strong) { font-weight: 600; color: #e6edf3; }
      :global(article .md-preview em) { font-style: italic; color: #c9d1d9; }
      :global(article .md-preview a) { color: #58a6ff; text-decoration: none; }
      :global(article .md-preview a:hover) { text-decoration: underline; }

      /* YAML frontmatter block in preview */
      :global(article .md-preview .md-frontmatter) {
        background: #0d1117; border: 1px solid #30363d;
        border-radius: 6px; padding: 12px 16px;
        margin-bottom: 1em;
        font-family: ui-monospace, Menlo, monospace;
        font-size: 12px; color: #8b949e;
      }
      :global(article .md-preview .md-frontmatter-key) { color: #79c0ff; }
      :global(article .md-preview .md-frontmatter-value) { color: #a5d6ff; }
      :global(article .md-preview .md-frontmatter-title) {
        font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
        color: #484f58; margin-bottom: 8px;
      }

      /* ── Quiet data-grid tables: neutral translucent palette ──
         Gold is gone; the table now uses translucent slate-gray tints
         that adapt automatically to light and dark backgrounds (since
         rgba over a white surface reads as cool gray, and over a near-
         black surface reads as soft slate). The chrome stays out of
         the way so the data leads. */
      :global(article .table-wrapper),
      :global(article table) {
        @apply my-6;
      }

      :global(article table) {
        width: 100%;
        display: block;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        max-width: 100%;
        border-collapse: collapse;
        border: 1px solid rgba(127, 127, 140, 0.18);
        border-radius: 6px;
        font-size: 0.95rem;
        line-height: 1.55;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
      }

      @media (min-width: 768px) {
        :global(article table) {
          display: table;
          overflow: hidden;
          overflow-x: visible;
        }
      }

      /* Every cell gets a faint grid border. Vertical-align: middle so
         single-line cells read as centered, and multi-line cells still
         baseline-align across the row. */
      :global(article th),
      :global(article td) {
        border: 1px solid rgba(127, 127, 140, 0.12);
        padding: 0.7rem 1rem;
        text-align: start;
        vertical-align: middle;
      }

      /* Header row — same row height as body (matched padding), text
         vertically centered inside its cell. Tone is a barely-there
         slate wash; only weight + a 2px under-rule signal hierarchy. */
      :global(article thead th) {
        background: rgba(127, 127, 140, 0.06);
        color: var(--yuval-chapter-title);
        font-weight: 700;
        letter-spacing: 0.03em;
        font-size: 0.95rem;
        text-transform: uppercase;
        padding: 0.7rem 1rem;
        border-color: rgba(127, 127, 140, 0.16);
        border-bottom: 2px solid rgba(127, 127, 140, 0.32);
        position: relative;
      }

      /* Vertical dividers inside header — same neutral tone, slightly
         stronger than body cell borders so the header reads as a unit. */
      :global(article thead th + th) {
        border-inline-start: 1px solid rgba(127, 127, 140, 0.16);
      }

      /* Row-header cells (th inside tbody) — quiet emphasis without
         pulling color attention. */
      :global(article tbody th) {
        background: rgba(127, 127, 140, 0.04);
        font-weight: 700;
        color: var(--yuval-chapter-title);
      }

      /* Zebra striping for scan rhythm — translucent so it tints both
         light and dark backgrounds without picking a side. */
      :global(article tbody tr:nth-child(even) td) {
        background: rgba(127, 127, 140, 0.025);
      }

      :global(article tbody tr:hover td) {
        background: rgba(127, 127, 140, 0.06);
      }

      /* RTL */
      :global(article [dir="rtl"] table) {
        direction: rtl;
      }

      /* Mobile: same grid, tighter cells, sticky first column */
      @media (max-width: 767px) {
        :global(article th),
        :global(article td) {
          white-space: nowrap;
          padding: 0.6rem 0.8rem;
          font-size: 0.88rem;
        }

        :global(article thead th) {
          font-size: 0.82rem;
          /* Match body cell padding so header row height = body row height on mobile too. */
          padding: 0.6rem 0.8rem;
          letter-spacing: 0.025em;
        }

        :global(article th:first-child),
        :global(article td:first-child) {
          position: sticky;
          inset-inline-start: 0;
          background: var(--yuval-bg);
          z-index: 1;
          box-shadow: 1px 0 0 rgba(127, 127, 140, 0.18);
        }

        :global(article [dir="rtl"] th:first-child),
        :global(article [dir="rtl"] td:first-child) {
