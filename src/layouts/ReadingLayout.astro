      }

      /* Phone: remove cap so the full viewport is used (minus px-4 padding) */
      @media (max-width: 639px) {
        .reading-article {
          max-width: none;
        }
      }

      /* Tablet (sm–md): both desktop sidebars are hidden in this range,
         so the reading column should fill the viewport instead of
         sitting in a centered 760px well with empty gutters. The lg
         block below takes over once the sidebars reappear. */
      @media (min-width: 640px) and (max-width: 1023px) {
        .reading-article {
          max-width: none;
        }
      }

      /* Force content text to follow the container's direction.
         Uses high-specificity selector + !important to defeat any inherited
         text-align: center from legacy Word-ingest wrappers. */
      :global([data-lang][dir="ltr"] .chapter-content),
      :global([data-lang][dir="ltr"] .chapter-content *) {
        text-align: start !important;
        direction: ltr;
      }
      :global([data-lang][dir="rtl"] .chapter-content),
      :global([data-lang][dir="rtl"] .chapter-content *) {
        text-align: start !important;
        direction: rtl;
      }
      /* Preserve intentional center/right in code, tables, figures */
      :global([data-lang] .chapter-content pre),
      :global([data-lang] .chapter-content code),
      :global([data-lang] .chapter-content figure),
      :global([data-lang] .chapter-content table),
      :global([data-lang] .chapter-content .coderunner),
      :global([data-lang] .chapter-content .bash-block) {
        text-align: initial !important;
      }

      /* Code components must always render LTR, even inside an RTL page.
         We exclude the gutter from the left-align rule so line numbers
         stay right-aligned (flush with the code column). */
      :global([data-lang][dir="rtl"] .chapter-content .coderunner),
      :global([data-lang][dir="rtl"] .chapter-content .coderunner *:not(.cr-gutter):not(.cr-gutter span)),
      :global([data-lang][dir="rtl"] .chapter-content .bash-block),
      :global([data-lang][dir="rtl"] .chapter-content .bash-block *) {
        direction: ltr !important;
        text-align: left !important;
        unicode-bidi: isolate;
      }
      :global([data-lang][dir="rtl"] .chapter-content .coderunner .cr-gutter),
      :global([data-lang][dir="rtl"] .chapter-content .coderunner .cr-gutter span) {
        direction: ltr !important;
        text-align: right !important;
        unicode-bidi: isolate;
      }

      /* Desktop: reading column fills the full horizontal space between
         the two fixed sidebars. Asymmetric reservations using logical
         properties — 320px for the unified sidebar on inline-start,
         76px for the LeftSidebar activity rail on inline-end. The
         lg:px-8 utility (2rem) supplies inner breathing room on both
         sides. The strip header above the column has its own geometry
         and is unaffected. */
      @media (min-width: 1024px) {
        .reading-article {
          max-width: none;
          /* TOC stays on the inline-START edge (logical) — right in
             RTL, left in LTR. The left dock is anchored to the visual
             LEFT in every language (physical), so its reservation
             uses an explicit margin-left instead of inline-end.
             We do NOT set `margin-right: 0` here — in RTL,
             `margin-inline-start` resolves to margin-right (320px
             for the TOC), and a later `margin-right: 0` would
             cancel it, dropping content under the right sidebar. */
          margin-inline-start: 320px;
          margin-left: 128px;
          /* Sync with the chromatic-shift collapse animations: same
             500ms cubic-out the SVG matrices run on. Both edges
             transition independently. */
          transition:
            margin-inline-start 500ms cubic-bezier(0.33, 1, 0.68, 1),
            margin-left         500ms cubic-bezier(0.33, 1, 0.68, 1);
        }

        /* Immersive: hides the unified sidebar, so we drop the
           inline-start reservation and only keep the LeftSidebar gap. */
        :global(body.reading-immersive) .reading-article {
          margin-inline-start: 0;
          margin-left: 128px;
        }

        /* Sidebar-collapsed: same reservation drop, but driven by
           the explicit collapse toggle (independent of immersive). */
        :global(body.sidebar-collapsed) .reading-article {
          margin-inline-start: 0;
        }

        /* Left-sidebar collapsed: drop the visual-left dock
           reservation. Stacks with sidebar-collapsed when both are
           collapsed (full-width reading column). */
        :global(body.left-sidebar-collapsed) .reading-article {
          margin-left: 0;
        }
      }


      /* Zen mode: large centered text, no distractions */
      :global(body.reading-zen) .reading-article {
        margin-left: 0 !important;
        margin-right: 0 !important;
      }
      :global(body.reading-zen) .chapter-content {
        font-size: clamp(18px, 2.2vw, 24px) !important;
        line-height: 1.9 !important;
        max-width: 640px;
        margin: 0 auto;
      }

      /* Reading-mode body bg = shell surface.
         The page body's default bg (--yuval-bg) is the area around
         the LeftSidebar dock and outside the chapter strip — it
         shows in the gutters left of the article (and right of it
         where the unified sidebar doesn't extend). For the
         "single shell" frame to read as one continuous surface, the
         gutters must match the strip + TOC + dock. We paint them
         with --yuval-surface (#1A1A1A dark / #FFFFFF light, but the
         shell uses #F5F4EF in light via the strip rules — so we
         set it to the same #F5F4EF in light here too).
         The reading article itself paints its own --yuval-reading-bg
         on top, so the centered content column stays distinct. */
      :global(body.reading-mode) {
        background-color: var(--yuval-surface, #1a1a1a) !important;
      }
      :global(:root:not(.dark) body.reading-mode) {
        background-color: #F5F4EF !important;
      }

      /* Header stays visible in immersive mode */
      :global(body.reading-immersive) #site-header {
        opacity: 1;
      }
      :global(#site-header) {
        transition: background-color 0.3s, border-color 0.3s;
      }

      /* CodeRunner styles live in src/styles/code-runner.css.
         They support a global dark/light theme toggle via
         [data-code-theme] on <html>, set early by the inline script. */

      /* Copy feedback animation */
      @keyframes fadeInOut {
        0% { opacity: 0; transform: translate(-50%, -50%) scale(0.9); }
        15% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
        85% { opacity: 1; }
        100% { opacity: 0; }
      }

    </style>
  </article>

  <!-- Reading Controls (Focus, Typography, Theme) -->
  <ReadingControls />

  <script type="module">
    // Inject copy buttons into all code blocks
    function addCopyButtons() {
      document.querySelectorAll('article pre').forEach((pre) => {
        // Skip <pre> elements inside styled block wrappers — they already
        // have their own Copy buttons (BashBlock, CodeBlock, CodeRunner).
        // Adding the generic floating Copy button on top would double up
        // and confuse readers.
        if (pre.closest('.bash-block') ||
            pre.closest('.coderunner')) return;
        if (pre.querySelector('.code-copy-btn')) return;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'code-copy-btn';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code');
          if (!code) return;
          try {
            await navigator.clipboard.writeText(code.textContent || '');
            btn.classList.add('copied');
            btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
            setTimeout(() => {
              btn.classList.remove('copied');
              btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
            }, 2000);
          } catch {
            // Fallback: select text
            const range = document.createRange();
            range.selectNodeContents(code);
            const sel = window.getSelection();
            sel?.removeAllRanges();
            sel?.addRange(range);
          }
        });
        pre.appendChild(btn);
      });
    }

    // Lazy-load content images
    function lazyLoadImages() {
      document.querySelectorAll('article img').forEach((img) => {
        if (!img.hasAttribute('loading')) {
          img.loading = 'lazy';
          img.decoding = 'async';
        }
      });
    }

    // ── Markdown Preview tabs ──────────────────────────────────────

    /** Escape HTML special chars */
    function esc(s) {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    /** Inline formatting: bold, italic, code, links */
    function inline(s) {
      return s
        .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
    }

    /** Render YAML frontmatter as a styled block */
    function renderFrontmatter(lines) {
      const rows = lines.map(line => {
        const m = line.match(/^(\s*-?\s*)([^:]+):(.*)/);
        if (!m) return `<div>${esc(line)}</div>`;
        const indent = m[1].includes('-') ? 'margin-left:12px;' : '';
        return `<div style="${indent}"><span class="md-frontmatter-key">${esc(m[2])}</span>:<span class="md-frontmatter-value">${esc(m[3])}</span></div>`;
      }).join('');
      return `<div class="md-frontmatter"><div class="md-frontmatter-title">Frontmatter</div>${rows}</div>`;
    }

    /** Minimal Markdown → HTML renderer */
    function renderMarkdown(raw) {
      const lines = raw.split('\n');
      let html = '';
      let i = 0;

      // Detect and extract YAML frontmatter
      if (lines[0]?.trim() === '---') {
        const endIdx = lines.indexOf('---', 1);
        if (endIdx > 0) {
          html += renderFrontmatter(lines.slice(1, endIdx));
          i = endIdx + 1;
        }
      }

      let inUl = false, inOl = false, inPre = false, preLines = [];

      for (; i < lines.length; i++) {
        const raw_line = lines[i];
        const line = raw_line.trim();

        // Fenced code block
        if (line.startsWith('```')) {
          if (!inPre) {
            if (inUl) { html += '</ul>'; inUl = false; }
            if (inOl) { html += '</ol>'; inOl = false; }
            inPre = true; preLines = [];
          } else {
            html += `<pre><code>${esc(preLines.join('\n'))}</code></pre>`;
            inPre = false;
          }
          continue;
        }
        if (inPre) { preLines.push(raw_line); continue; }

        // Headings
        const hm = line.match(/^(#{1,6})\s+(.*)/);
        if (hm) {
          if (inUl) { html += '</ul>'; inUl = false; }
          if (inOl) { html += '</ol>'; inOl = false; }
          const lvl = hm[1].length;
          html += `<h${lvl}>${inline(esc(hm[2]))}</h${lvl}>`;
          continue;
        }

        // HR
        if (/^---+$/.test(line) || /^\*\*\*+$/.test(line)) {
          if (inUl) { html += '</ul>'; inUl = false; }
          if (inOl) { html += '</ol>'; inOl = false; }
          html += '<hr>';
          continue;
        }

        // Blockquote
        if (line.startsWith('> ')) {
          if (inUl) { html += '</ul>'; inUl = false; }
          if (inOl) { html += '</ol>'; inOl = false; }
          html += `<blockquote>${inline(esc(line.slice(2)))}</blockquote>`;
          continue;
        }

        // Unordered list
        const ulm = line.match(/^[-*+]\s+(.*)/);
        if (ulm) {
          if (inOl) { html += '</ol>'; inOl = false; }
          if (!inUl) { html += '<ul>'; inUl = true; }
          html += `<li>${inline(esc(ulm[1]))}</li>`;
          continue;
        }

        // Ordered list
        const olm = line.match(/^\d+\.\s+(.*)/);
        if (olm) {
          if (inUl) { html += '</ul>'; inUl = false; }
          if (!inOl) { html += '<ol>'; inOl = true; }
          html += `<li>${inline(esc(olm[1]))}</li>`;
          continue;
        }

        // Close open lists on blank line or paragraph
        if (line === '') {
          if (inUl) { html += '</ul>'; inUl = false; }
          if (inOl) { html += '</ol>'; inOl = false; }
          continue;
        }

        // Paragraph
        if (inUl) { html += '</ul>'; inUl = false; }
        if (inOl) { html += '</ol>'; inOl = false; }
        html += `<p>${inline(esc(line))}</p>`;
      }

      if (inUl) html += '</ul>';
      if (inOl) html += '</ol>';
      if (inPre) html += `<pre><code>${esc(preLines.join('\n'))}</code></pre>`;

      return html;
    }

    /** Detect if text is predominantly Hebrew/RTL */
    function detectDir(text) {
      const hebrewChars = (text.match(/[\u0590-\u05FF\uFB1D-\uFB4F]/g) || []).length;
      const latinChars  = (text.match(/[a-zA-Z]/g) || []).length;
      return hebrewChars > latinChars ? 'rtl' : 'ltr';
    }

    /** Add Source/Preview tabs to markdown code blocks */
    function addMarkdownPreview() {
      document.querySelectorAll('article pre[data-lang="markdown"], article pre[data-lang="md"]').forEach((pre) => {
        if (pre.dataset.hasPreview) return;
        const code = pre.querySelector('code');
        if (!code) return;

        pre.dataset.hasPreview = 'true';

        // Tab bar: language label + Source tab + Preview tab
        const tabBar = document.createElement('div');
        tabBar.className = 'md-tab-bar';
        tabBar.innerHTML = `
          <span class="md-lang-label">Markdown</span>
          <button class="md-tab md-tab-active" data-tab="source" type="button">Source</button>
          <button class="md-tab" data-tab="preview" type="button">Preview</button>
        `;

        // Preview container
        const previewDiv = document.createElement('div');
        previewDiv.className = 'md-preview';
        previewDiv.style.display = 'none';

        // Insert tab bar as first child, preview after code
        pre.insertBefore(tabBar, pre.firstChild);
        code.after(previewDiv);

        // Tab switching
        tabBar.addEventListener('click', (e) => {
          const btn = e.target.closest('.md-tab');
          if (!btn) return;
          const tab = btn.dataset.tab;

          tabBar.querySelectorAll('.md-tab').forEach(b => b.classList.remove('md-tab-active'));
          btn.classList.add('md-tab-active');

          if (tab === 'preview') {
            const content = code.textContent || '';
            previewDiv.setAttribute('dir', detectDir(content));
            previewDiv.innerHTML = renderMarkdown(content);
            code.style.display = 'none';
            previewDiv.style.display = 'block';
          } else {
            code.style.display = '';
            previewDiv.style.display = 'none';
          }
        });
      });
    }

    function reinitAll() {
      initCodeThemeToggle();
      addCopyButtons();
      lazyLoadImages();
      addMarkdownPreview();
      if (document.querySelector('.coderunner')) {
        initCodeRunners();
      }
      if (document.querySelector('.bash-block')) {
        initBashBlocks();
      }
    }

    // Wire up ALL code theme toggle buttons — one per code block header.
    // They all read/write the same [data-code-theme] on <html>, so
    // clicking any of them switches the theme for every code block at once.
    function initCodeThemeToggle() {
      document.querySelectorAll('[data-code-theme-toggle]').forEach((btn) => {
        if (btn.dataset.initialized) return;
        btn.dataset.initialized = 'true';

        const syncLabel = () => {
          const current = document.documentElement.getAttribute('data-code-theme') || 'dark';
          btn.setAttribute('aria-pressed', current === 'light' ? 'true' : 'false');
          btn.dataset.theme = current;
        };
        syncLabel();

        btn.addEventListener('click', () => {
          const current = document.documentElement.getAttribute('data-code-theme') || 'dark';
          const next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-code-theme', next);
          try { localStorage.setItem('code-theme', next); } catch {}
          document.querySelectorAll('[data-code-theme-toggle]').forEach((b) => {
            b.setAttribute('aria-pressed', next === 'light' ? 'true' : 'false');
            b.dataset.theme = next;
          });
        });
      });
    }

    function initBashBlocks() {
      document.querySelectorAll('.bash-block').forEach((block) => {
        if (block.dataset.initialized) return;
        block.dataset.initialized = 'true';

        const copyBtn = block.querySelector('.bash-copy-btn');
        const body = block.querySelector('.bash-body');
        if (!copyBtn || !body) return;

        copyBtn.addEventListener('click', async () => {
          // Prefer the encoded code on the button's data-code; fall
          // back to body.dataset.code; last resort use text content.
          const codeData = copyBtn.dataset.code || body.dataset.code;
          const text = codeData ? decodeURIComponent(codeData) : (body.textContent || '');

          try {
            await navigator.clipboard.writeText(text);
            copyBtn.classList.add('copied');
            setTimeout(() => copyBtn.classList.remove('copied'), 1800);
          } catch (err) {
            console.error('Failed to copy bash command:', err);
          }
        });
      });
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Pyodide Python Execution
    // ═══════════════════════════════════════════════════════════════════════

    

    let pyodide = null;
    let pyodideLoading = false;
    let pyodideReady = false;
    
    const PYODIDE_CDN = 'https://cdn.jsdelivr.net/pyodide/v0.25.0/full/';
    
    async function loadPyodide() {
      if (pyodide) return pyodide;
      if (pyodideLoading) {
        while (!pyodideReady) {
          await new Promise(r => setTimeout(r, 100));
        }
        return pyodide;
      }
      
      pyodideLoading = true;
      
      try {
        if (!window.loadPyodide) {
          await new Promise((resolve, reject) => {
            const script = document.createElement('script');
            script.src = PYODIDE_CDN + 'pyodide.js';
            script.onload = () => resolve();
            script.onerror = () => reject(new Error('Failed to load Pyodide'));
            document.head.appendChild(script);
          });
        }
        
        pyodide = await window.loadPyodide({
          indexURL: PYODIDE_CDN
        });
        
        await pyodide.runPython(`
import sys
from io import StringIO

class OutputCapture:
    def __init__(self):
        self.stdout = StringIO()
        self.stderr = StringIO()
        sys.stdout = self.stdout
        sys.stderr = self.stderr
        
    def get_output(self):
        return self.stdout.getvalue(), self.stderr.getvalue()
    
    def clear(self):
        self.stdout = StringIO()
        self.stderr = StringIO()
        sys.stdout = self.stdout
        sys.stderr = self.stderr

_output_capture = OutputCapture()
        `);
        
        pyodideReady = true;
        return pyodide;
        
      } catch (error) {
        pyodideLoading = false;
        throw error;
      }
    }
    
    async function runPythonCode(code) {
      const startTime = performance.now();
      const py = await loadPyodide();
      
      await py.runPython('_output_capture.clear()');
      
      try {
        const result = await py.runPython(code);
        const [stdout, stderr] = py.globals.get('_output_capture').get_output().toJs();
        const endTime = performance.now();
        
        let output = stdout || '';
        if (result !== undefined && result !== null && String(result) !== 'None') {
          output = output ? output + '\n' + String(result) : String(result);
        }
        
        return {
          output: output || 'Execution finished (no output)',
          error: stderr || null,
          time: endTime - startTime
        };
      } catch (error) {
        const endTime = performance.now();
        return {
          output: '',
          error: error.message || String(error),
          time: endTime - startTime
        };
      }
    }

    // Unified init for Python runners + view-only code blocks.
    // Both share .coderunner; the Run button is absent for view-only.
    function initCodeRunners() {
      document.querySelectorAll('.coderunner').forEach((block) => {
        if (block.dataset.initialized) return;
        block.dataset.initialized = 'true';

        const copyBtn = block.querySelector('.cr-copy-btn');
        const runBtn  = block.querySelector('.cr-run-btn');
        const editBtn = block.querySelector('.cr-edit-btn');
        const resetBtn = block.querySelector('.cr-reset-btn');
        const editor = block.querySelector('.cr-editor');
        const gutter  = block.querySelector('.cr-gutter');
        const codeEl  = block.querySelector('.cr-code');
        const status  = block.querySelector('.cr-run-status');
        const outPanel = block.querySelector('.cr-output');
        const outText  = block.querySelector('.cr-output-text');
        const clearBtn = block.querySelector('.cr-output-clear');
        const linesStatus = block.querySelectorAll('.cr-status-item')[1];

        const encodedCode = block.dataset.code || '';
        const originalCode = encodedCode ? decodeURIComponent(encodedCode) : '';

        function getCurrentCode() {
          if (block.dataset.editing === 'true' && editor) return editor.value;
          return originalCode;
        }

        function renderGutter(lineCount) {
          if (!gutter) return;
          let html = '';
          for (let i = 1; i <= Math.max(lineCount, 1); i++) html += `<span>${i}</span>`;
          gutter.innerHTML = html;
        }

        function updateLineStatus(lineCount) {
          if (linesStatus) linesStatus.textContent = `${lineCount} lines`;
        }

        function refreshMetrics(code) {
          const lines = code.split('\n').length;
          renderGutter(lines);
          updateLineStatus(lines);
        }

        if (editor) {
          editor.value = originalCode;

          editor.addEventListener('input', () => {
            const val = editor.value;
            refreshMetrics(val);
            block.dataset.dirty = val !== originalCode ? 'true' : 'false';
            // auto-grow: expand to content height
            editor.style.height = 'auto';
            editor.style.height = editor.scrollHeight + 'px';
          });

          editor.addEventListener('keydown', (e) => {
            if (e.key === 'Tab') {
              e.preventDefault();
              const start = editor.selectionStart;
              const end = editor.selectionEnd;
              const insert = '    ';
              editor.value = editor.value.substring(0, start) + insert + editor.value.substring(end);
              editor.selectionStart = editor.selectionEnd = start + insert.length;
              editor.dispatchEvent(new Event('input'));
            } else if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
              e.preventDefault();
              runBtn?.click();
            }
          });

          editor.addEventListener('scroll', () => {
            if (gutter) gutter.scrollTop = editor.scrollTop;
          });
        }

        if (codeEl && gutter) {
          codeEl.addEventListener('scroll', () => {
            gutter.scrollTop = codeEl.scrollTop;
          });
        }

        copyBtn?.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(getCurrentCode());
            copyBtn.classList.add('copied');
            setTimeout(() => copyBtn.classList.remove('copied'), 1800);
          } catch (err) {
            console.error('Failed to copy code:', err);
          }
        });

        editBtn?.addEventListener('click', () => {
          const editing = block.dataset.editing === 'true';
          block.dataset.editing = editing ? 'false' : 'true';
          if (!editing && editor) {
            // entering edit mode — size textarea to content
            editor.style.height = 'auto';
            editor.style.height = editor.scrollHeight + 'px';
            editor.focus();
            // place caret at end
            const len = editor.value.length;
            editor.setSelectionRange(len, len);
          }
        });

        resetBtn?.addEventListener('click', () => {
          if (!editor) return;
          editor.value = originalCode;
          refreshMetrics(originalCode);
          block.dataset.dirty = 'false';
          editor.style.height = 'auto';
          editor.style.height = editor.scrollHeight + 'px';
          editor.focus();
        });

        runBtn?.addEventListener('click', async () => {
          const code = getCurrentCode();
          if (!code || !outPanel || !outText || !status) return;
          runBtn.disabled = true;
          runBtn.classList.add('running');
          status.textContent = 'Running';
          status.className = 'cr-status-item cr-status-right cr-run-status';
          outPanel.hidden = false;
          outText.textContent = 'Loading Python...';
          try {
            const result = await runPythonCode(code);
            if (result.error) {
              outText.innerHTML = `<span class="error">${escapeHtml(result.error)}</span>`;
              status.textContent = 'Error';
              status.className = 'cr-status-item cr-status-right cr-run-status error';
            } else {
              outText.innerHTML = `<span class="success">${escapeHtml(result.output)}</span>`;
              status.textContent = `Done in ${Math.round(result.time)}ms`;
              status.className = 'cr-status-item cr-status-right cr-run-status success';
            }
          } catch (err) {
            outText.innerHTML = `<span class="error">${escapeHtml(err.message || 'Unknown error')}</span>`;
            status.textContent = 'Pyodide error';
            status.className = 'cr-status-item cr-status-right cr-run-status error';
          } finally {
            runBtn.disabled = false;
            runBtn.classList.remove('running');
          }
        });

        clearBtn?.addEventListener('click', () => {
          if (outPanel && outText) {
            outPanel.hidden = true;
            outText.textContent = '';
          }
          if (status) {
            status.textContent = 'Ready';
            status.className = 'cr-status-item cr-status-right cr-run-status';
          }
        });
      });
    }


    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function showCopyFeedback(message) {
      const feedback = document.createElement('div');
      feedback.style.cssText = `
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        padding: 0.75rem 1.5rem;
        background: #a6e3a1;
        color: #11111b;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        z-index: 10000;
        animation: fadeInOut 1500ms var(--ease-standard) forwards;
      `;
      feedback.textContent = message;
      document.body.appendChild(feedback);
      setTimeout(() => feedback.remove(), 1500);
    }

    reinitAll();
    // Astro View Transitions navigation
    document.addEventListener('astro:after-swap', reinitAll);
    // Fetch-based chapter navigation (TOC clicks)
    window.addEventListener('chapter-content-swapped', reinitAll);
  </script>

  <!-- Reading Mode signal — body.reading-mode is consumed by Header.astro
       to dim/compress the global navbar into a quiet contextual layer.
       Removed before navigating away so non-reading pages get the full
       header back; re-added when another ReadingLayout page mounts. -->
  <script is:inline>
    (function () {
      function enable() { document.body.classList.add('reading-mode'); }
      function disable() { document.body.classList.remove('reading-mode'); }
      enable();
      document.addEventListener('astro:page-load', enable);
      document.addEventListener('astro:before-swap', disable);
    })();
  </script>
</BaseLayout>