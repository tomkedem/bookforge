---
import type { Language } from '../types/index';
import BaseLayout from './BaseLayout.astro';
import ReadingControls from '../components/ReadingControls.astro';
import { SOURCE_LANGUAGE, getLanguageDirection } from '../utils/language';

interface Props {
  title: string;
  language?: Language;
  availableLanguages?: Language[];
  class?: string;
}

const { title, language = SOURCE_LANGUAGE, availableLanguages, class: className } = Astro.props;
const isRtl = getLanguageDirection(language) === 'rtl';
const COPY_SUCCESS_MESSAGE = 'Code copied!';
---

<BaseLayout
  title={title}
  language={language}
  availableLanguages={availableLanguages}
  allowClientLanguageOverride={true}
  showHeader={true}
  showProgress={true}
  showLanguageToggle={true}
>
  <!-- Sidebars passed through to body level -->
  <slot name="sidebars" slot="sidebars" />

  <article
    class:list={[
      'reading-article',
      'px-4',
      'sm:px-6',
      'lg:px-8',
      'pt-0',
      'pb-4',
      'sm:pb-6',
      'lg:pb-8',
      isRtl && 'text-right',
      className,
    ]}
    style="background-color: var(--yuval-reading-bg);"
  >
    <!-- Chapter content -->
    <div
      class="prose prose-invert max-w-none space-y-6"
      data-language={language}
    >
      <slot />
    </div>

    <!-- Custom prose styles for reading -->
    <style>
      /* ── Syntax highlighting (highlight.js GitHub Dark theme) ── */
      :global(.hljs) {
        color: #c9d1d9;
        background: #0d1117;
      }
      :global(.hljs-doctag, .hljs-keyword, .hljs-meta .hljs-keyword,
              .hljs-template-tag, .hljs-template-variable, .hljs-type,
              .hljs-variable.language_) { color: #ff7b72; }
      :global(.hljs-title, .hljs-title.class_, .hljs-title.class_.inherited__,
              .hljs-title.function_) { color: #d2a8ff; }
      :global(.hljs-attr, .hljs-attribute, .hljs-literal, .hljs-meta,
              .hljs-number, .hljs-operator, .hljs-selector-attr,
              .hljs-selector-class, .hljs-selector-id, .hljs-variable) { color: #79c0ff; }
      :global(.hljs-meta .hljs-string, .hljs-regexp, .hljs-string) { color: #a5d6ff; }
      :global(.hljs-built_in, .hljs-symbol) { color: #ffa657; }
      :global(.hljs-comment, .hljs-code, .hljs-formula) { color: #8b949e; }
      :global(.hljs-name, .hljs-quote, .hljs-selector-pseudo,
              .hljs-selector-tag) { color: #7ee787; }
      :global(.hljs-subst) { color: #c9d1d9; }
      :global(.hljs-section) { color: #1f6feb; font-weight: bold; }
      :global(.hljs-bullet) { color: #f2cc60; }
      :global(.hljs-emphasis) { color: #c9d1d9; font-style: italic; }
      :global(.hljs-strong) { color: #c9d1d9; font-weight: bold; }
      :global(.hljs-addition) { color: #aff5b4; background-color: #033a16; }
      :global(.hljs-deletion) { color: #ffdcd7; background-color: #67060c; }

      /* Code always LTR regardless of page language */
      :global(article pre),
      :global(article code) {
        direction: ltr !important;
        text-align: left !important;
        unicode-bidi: isolate;
      }

      /* Code block wrapper */
      :global(article pre) {
        position: relative;
        background: #0d1117;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 0;
        overflow: hidden;
        margin: 1.75rem 0;
        box-shadow: 0 4px 16px rgba(0,0,0,0.25);
      }

      /* Language badge */
      :global(article pre[data-lang]::before) {
        content: attr(data-lang);
        display: block;
        background: #161b22;
        border-bottom: 1px solid #30363d;
        padding: 6px 16px;
        font-size: 11px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: #8b949e;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      :global(article pre code.hljs) {
        display: block;
        padding: 12px;
        overflow-x: auto;
        font-size: 0.75rem;
        line-height: 1.6;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        background: transparent;
      }

      @media (min-width: 640px) {
        :global(article pre code.hljs) {
          padding: 20px;
          font-size: 0.85rem;
          line-height: 1.7;
        }
      }

      /* Inline code */
      :global(article :not(pre) > code) {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.85em;
        background: rgba(110, 118, 129, 0.15);
        border: 1px solid rgba(110, 118, 129, 0.25);
        border-radius: 4px;
        padding: 0.15em 0.45em;
        color: #e6edf3;
      }
      :global(article h1) {
        @apply font-heading font-bold text-xl sm:text-3xl lg:text-4xl leading-tight mt-8 sm:mt-12 mb-4 sm:mb-6 text-yuval-text;
      }

      :global(article h2) {
        @apply font-heading font-bold text-lg sm:text-2xl lg:text-3xl leading-snug mt-8 sm:mt-10 mb-3 sm:mb-4 text-yuval-text;
      }

      :global(article h3) {
        @apply font-heading font-semibold text-base sm:text-xl lg:text-2xl leading-snug mt-6 sm:mt-8 mb-2 sm:mb-3 text-yuval-text-secondary;
      }

      :global(article p) {
        @apply text-base sm:text-lg lg:text-xl leading-relaxed sm:leading-loose text-yuval-text-secondary mb-4 sm:mb-6 font-light;
      }

      :global(article blockquote) {
        @apply relative pl-4 sm:pl-6 py-3 sm:py-4 my-6 sm:my-8 text-base sm:text-xl leading-relaxed text-yuval-text-secondary bg-yuval-bg-secondary;
        border-left: 4px solid var(--yuval-blockquote-border);
      }

      :global(article [dir="rtl"] blockquote) {
        @apply pl-0 pr-6 border-l-0 border-r-4;
      }

      :global(article strong) {
        @apply font-semibold text-yuval-text;
      }

      :global(article em) {
        @apply italic;
      }

      :global(article ul,
      article ol) {
        @apply ml-6 space-y-2 my-6;
      }

      :global(article ul) {
        list-style-type: disc;
      }

      :global(article ol) {
        list-style-type: decimal;
      }

      :global(article [dir="rtl"] ul,
      article [dir="rtl"] ol) {
        @apply ml-0 mr-6;
      }

      :global(article li) {
        @apply text-base sm:text-lg leading-relaxed text-yuval-text-secondary font-light;
      }

      :global(article a) {
        @apply underline transition-colors duration-200;
        color: var(--yuval-link);
      }

      :global(article a:hover) {
        color: var(--yuval-link-hover);
      }

      :global(article img) {
        @apply max-w-full h-auto rounded-lg my-8 mx-auto block;
        background-color: #fff;
        image-rendering: -webkit-optimize-contrast;
        image-rendering: crisp-edges;
        backface-visibility: hidden;
        transform: translateZ(0);
      }

      /* Code block copy button */
      :global(article pre) {
        position: relative;
      }

      :global(.code-copy-btn) {
        position: absolute;
        top: 8px;
        right: 8px;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 6px;
        border: 1px solid #30363d;
        background: #21262d;
        color: #8b949e;
        cursor: pointer;
        opacity: 0;
        transition: opacity 200ms var(--ease-standard), color 150ms var(--ease-standard), background 150ms var(--ease-standard);
      }

      :global(article pre:hover .code-copy-btn),
      :global(.code-copy-btn:focus-visible) {
        opacity: 1;
      }

      :global(.code-copy-btn:hover) {
        color: #e6edf3;
        background: #30363d;
      }

      :global(.code-copy-btn.copied) {
        color: #3fb950;
      }

      :global(article hr) {
        @apply my-12 border-yuval-border;
      }

      /* ── Markdown Preview: tab bar replaces ::before label ── */
      :global(article pre[data-has-preview]::before) {
        display: none;
      }

      :global(article .md-tab-bar) {
        display: flex;
        align-items: center;
        background: #161b22;
        border-bottom: 1px solid #30363d;
        padding: 0 8px;
        gap: 0;
        flex-shrink: 0;
      }

      :global(article .md-lang-label) {
        font-size: 11px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: #8b949e;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 6px 12px 6px 8px;
        margin-right: 8px;
        border-right: 1px solid #30363d;
        flex-shrink: 0;
      }

      :global(article .md-tab) {
        padding: 6px 14px;
        font-size: 12px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: #8b949e;
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        transition: color 0.15s, border-color 0.15s;
        margin-bottom: -1px;
      }

      :global(article .md-tab:hover) {
        color: #c9d1d9;
      }

      :global(article .md-tab-active) {
        color: #e6edf3;
        border-bottom-color: #58a6ff;
      }

      /* Preview rendered area */
      :global(article .md-preview) {
        padding: 20px 24px;
        color: #c9d1d9;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 14px;
        line-height: 1.7;
      }
      :global(article .md-preview[dir="ltr"]) {
        direction: ltr;
        text-align: left;
      }
      :global(article .md-preview[dir="rtl"]) {
        direction: rtl;
        text-align: right;
        font-family: 'Heebo', 'Frank Ruhl Libre', -apple-system, sans-serif;
      }
      :global(article .md-preview[dir="rtl"] ul,
              article .md-preview[dir="rtl"] ol) {
        padding-left: 0;
        padding-right: 1.4em;
      }
      :global(article .md-preview[dir="rtl"] blockquote) {
        border-left: none;
        border-right: 3px solid #58a6ff;
        padding: 4px 16px 4px 0;
      }
      :global(article .md-preview[dir="rtl"] pre) {
        direction: ltr;
        text-align: left;
      }

      :global(article .md-preview h1) {
        font-size: 1.4em; font-weight: 700;
        color: #e6edf3; margin: 0.2em 0 0.6em;
        border-bottom: 1px solid #30363d; padding-bottom: 0.3em;
      }
      :global(article .md-preview h2) {
        font-size: 1.2em; font-weight: 600;
        color: #e6edf3; margin: 1em 0 0.4em;
        border-bottom: 1px solid #21262d; padding-bottom: 0.2em;
      }
      :global(article .md-preview h3) {
        font-size: 1.05em; font-weight: 600;
        color: #e6edf3; margin: 0.9em 0 0.3em;
      }
      :global(article .md-preview p) { margin: 0.5em 0; }
      :global(article .md-preview ul, article .md-preview ol) {
        margin: 0.5em 0; padding-left: 1.4em;
      }
      :global(article .md-preview ul) {
        list-style-type: disc;
      }
      :global(article .md-preview ol) {
        list-style-type: decimal;
      }
      :global(article .md-preview li) { margin: 0.2em 0; }
      :global(article .md-preview code) {
        background: rgba(110,118,129,0.2);
        border: 1px solid rgba(110,118,129,0.25);
        padding: 0.1em 0.4em; border-radius: 4px;
        font-family: ui-monospace, Menlo, monospace; font-size: 0.88em;
        color: #e6edf3;
      }
      :global(article .md-preview pre) {
        background: #0d1117; border: 1px solid #30363d;
        border-radius: 6px; padding: 12px 16px;
        overflow-x: auto; margin: 0.8em 0;
      }
      :global(article .md-preview pre code) {
        background: none; border: none; padding: 0; font-size: 0.85em;
      }
      :global(article .md-preview blockquote) {
        border-left: 3px solid #58a6ff;
        margin: 0.8em 0; padding: 4px 0 4px 16px;
        color: #8b949e;
      }
      :global(article .md-preview hr) {
        border: none; border-top: 1px solid #30363d; margin: 1em 0;
      }
      :global(article .md-preview strong) { font-weight: 600; color: #e6edf3; }
      :global(article .md-preview em) { font-style: italic; color: #c9d1d9; }
      :global(article .md-preview a) { color: #58a6ff; text-decoration: none; }
      :global(article .md-preview a:hover) { text-decoration: underline; }

      /* YAML frontmatter block in preview */
      :global(article .md-preview .md-frontmatter) {
        background: #0d1117; border: 1px solid #30363d;
        border-radius: 6px; padding: 12px 16px;
        margin-bottom: 1em;
        font-family: ui-monospace, Menlo, monospace;
        font-size: 12px; color: #8b949e;
      }
      :global(article .md-preview .md-frontmatter-key) { color: #79c0ff; }
      :global(article .md-preview .md-frontmatter-value) { color: #a5d6ff; }
      :global(article .md-preview .md-frontmatter-title) {
        font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
        color: #484f58; margin-bottom: 8px;
      }

      /* ── Premium data-grid tables: visible grid + gold header ── */
      :global(article .table-wrapper),
      :global(article table) {
        @apply my-6;
      }

      :global(article table) {
        width: 100%;
        display: block;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        max-width: 100%;
        border-collapse: collapse;
        border: 1px solid color-mix(in srgb, var(--gold-500) 28%, var(--yuval-border-secondary));
        border-radius: 3px;
        font-size: 0.95rem;
        line-height: 1.55;
        box-shadow:
          0 1px 0 var(--gold-tint-18) inset,
          0 10px 24px rgba(15, 23, 42, 0.05);
      }

      @media (min-width: 768px) {
        :global(article table) {
          display: table;
          overflow: hidden;
          overflow-x: visible;
        }
      }

      /* Every cell gets a visible grid border */
      :global(article th),
      :global(article td) {
        border: 1px solid color-mix(in srgb, var(--gold-500) 16%, var(--yuval-border-secondary));
        padding: 0.7rem 1rem;
        text-align: start;
        vertical-align: top;
      }

      /* Header row — refined gold tone, stronger hierarchy */
      :global(article thead th) {
        background:
          linear-gradient(180deg,
            color-mix(in srgb, var(--gold-500) 14%, var(--yuval-bg)) 0%,
            color-mix(in srgb, var(--gold-500) 8%, var(--yuval-bg)) 100%);
        color: var(--yuval-chapter-title);
        font-weight: 700;
        letter-spacing: 0.04em;
        font-size: 0.95rem;
        text-transform: uppercase;
        padding: 1rem 1.1rem;
        border-color: var(--gold-tint-35);
        border-bottom: 2px solid color-mix(in srgb, var(--gold-600) 85%, var(--gold-500));
        box-shadow: inset 0 1px 0 color-mix(in srgb, var(--gold-300) 28%, transparent);
        position: relative;
      }

      /* Vertical dividers inside header — keep gold, slightly stronger */
      :global(article thead th + th) {
        border-inline-start: 1px solid var(--gold-tint-35);
      }

      /* Row-header cells (th inside tbody) — slightly emphasised */
      :global(article tbody th) {
        background: color-mix(in srgb, var(--gold-500) 6%, var(--yuval-bg));
        font-weight: 700;
        color: var(--yuval-chapter-title);
      }

      /* Subtle zebra for scanning, kept under the grid */
      :global(article tbody tr:nth-child(even) td) {
        background: color-mix(in srgb, var(--yuval-bg-secondary, var(--yuval-bg)) 55%, transparent);
      }

      :global(article tbody tr:hover td) {
        background: color-mix(in srgb, var(--gold-500) 7%, var(--yuval-bg));
      }

      /* RTL */
      :global(article [dir="rtl"] table) {
        direction: rtl;
      }

      /* Mobile: same grid, tighter cells, sticky first column */
      @media (max-width: 767px) {
        :global(article th),
        :global(article td) {
          white-space: nowrap;
          padding: 0.6rem 0.8rem;
          font-size: 0.88rem;
        }

        :global(article thead th) {
          font-size: 0.82rem;
          padding: 0.8rem 0.85rem;
          letter-spacing: 0.03em;
        }

        :global(article th:first-child),
        :global(article td:first-child) {
          position: sticky;
          inset-inline-start: 0;
          background: var(--yuval-bg);
          z-index: 1;
          box-shadow: 1px 0 0 var(--gold-tint-25);
        }

        :global(article [dir="rtl"] th:first-child),
        :global(article [dir="rtl"] td:first-child) {
          box-shadow: -1px 0 0 var(--gold-tint-25);
        }

        :global(article thead th:first-child) {
          background:
            linear-gradient(180deg,
              color-mix(in srgb, var(--gold-500) 18%, var(--yuval-bg)) 0%,
              color-mix(in srgb, var(--gold-500) 10%, var(--yuval-bg)) 100%);
        }
      }

      /* Prevent long content from causing page overflow */
      :global(.chapter-content) {
        overflow-wrap: anywhere;
      }
      :global(.chapter-content > *) {
        max-width: 100%;
      }

      /* Reading article fills space between sidebars */
      .reading-article {
        margin-left: 0;
        margin-right: 0;
      }

      /* Force content text to follow the container's direction.
         Uses high-specificity selector + !important to defeat any inherited
         text-align: center from legacy Word-ingest wrappers. */
      :global([data-lang][dir="ltr"] .chapter-content),
      :global([data-lang][dir="ltr"] .chapter-content *) {
        text-align: start !important;
        direction: ltr;
      }
      :global([data-lang][dir="rtl"] .chapter-content),
      :global([data-lang][dir="rtl"] .chapter-content *) {
        text-align: start !important;
        direction: rtl;
      }
      /* Preserve intentional center/right in code, tables, figures */
      :global([data-lang] .chapter-content pre),
      :global([data-lang] .chapter-content code),
      :global([data-lang] .chapter-content figure),
      :global([data-lang] .chapter-content table),
      :global([data-lang] .chapter-content .code-runner-wrapper),
      :global([data-lang] .chapter-content .code-block-wrapper) {
        text-align: initial !important;
      }

      /* Code components must always render LTR, even inside an RTL page.
         Overrides the wildcard direction:rtl rule above for code wrappers
         and every descendant (gutter, toolbar, buttons, line numbers, pre, code). */
      :global([data-lang][dir="rtl"] .chapter-content .code-block-pro),
      :global([data-lang][dir="rtl"] .chapter-content .code-block-pro *),
      :global([data-lang][dir="rtl"] .chapter-content .code-runner-wrapper),
      :global([data-lang][dir="rtl"] .chapter-content .code-runner-wrapper *),
      :global([data-lang][dir="rtl"] .chapter-content .code-block-wrapper),
      :global([data-lang][dir="rtl"] .chapter-content .code-block-wrapper *) {
        direction: ltr !important;
        text-align: left !important;
        unicode-bidi: isolate;
      }
      /* Keep line-number gutter right-aligned (numbers flush to code) */
      :global([data-lang][dir="rtl"] .chapter-content .code-block-pro .line-number),
      :global([data-lang][dir="rtl"] .chapter-content .code-runner-wrapper .line-num) {
        text-align: right !important;
      }

      @media (min-width: 1024px) {
        .reading-article {
          margin-left: 320px;
          margin-right: 320px;
          transition: margin 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                      max-width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Immersive: article expands to full width */
        :global(body.reading-immersive) .reading-article {
          margin-left: 0;
          margin-right: 0;
        }
      }


      /* Zen mode: large centered text, no distractions */
      :global(body.reading-zen) .reading-article {
        margin-left: 0 !important;
        margin-right: 0 !important;
      }
      :global(body.reading-zen) .chapter-content {
        font-size: clamp(18px, 2.2vw, 24px) !important;
        line-height: 1.9 !important;
        max-width: 640px;
        margin: 0 auto;
      }

      /* Header stays visible in immersive mode */
      :global(body.reading-immersive) #site-header {
        opacity: 1;
      }
      :global(#site-header) {
        transition: background-color 0.3s, border-color 0.3s;
      }

      /* ═══════════════════════════════════════════════════════════════════════
         CodeRunner & CodeBlock styles (VS Code dark theme)
         ═══════════════════════════════════════════════════════════════════════ */

      /* Shared CSS variables */
      :global(.code-runner-wrapper),
      :global(.code-block-wrapper) {
        --cr-bg-primary: #1e1e2e;
        --cr-bg-secondary: #181825;
        --cr-bg-tertiary: #11111b;
        --cr-border-color: #313244;
        --cr-bg-hover: rgba(69, 71, 90, 0.5);
        --cr-text-primary: #cdd6f4;
        --cr-text-secondary: #a6adc8;
        --cr-text-muted: #6c7086;
        --cr-accent-green: #a6e3a1;
        --cr-accent-blue: #89b4fa;
        --cr-accent-red: #f38ba8;
        --cr-accent-yellow: #f9e2af;
        --cr-accent-purple: #cba6f7;
        
        margin: 1.5rem 0;
        border-radius: 12px;
        overflow: hidden;
        background: var(--cr-bg-primary);
        border: 1px solid var(--cr-border-color);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
        direction: ltr;
        text-align: left;
      }

      /* Runner Header (Python) */
      :global(.code-runner-wrapper .runner-header),
      :global(.code-block-wrapper .block-header) {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.625rem 1rem;
        background: var(--cr-bg-tertiary);
        border-bottom: 1px solid var(--cr-border-color);
      }

      :global(.code-runner-wrapper .header-left),
      :global(.code-block-wrapper .header-left) {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      :global(.code-runner-wrapper .window-controls),
      :global(.code-block-wrapper .window-controls) {
        display: flex;
        gap: 6px;
      }

      :global(.code-runner-wrapper .control),
      :global(.code-block-wrapper .control) {
        width: 12px;
        height: 12px;
        border-radius: 50%;
      }

      :global(.code-runner-wrapper .control.red),
      :global(.code-block-wrapper .control.red) { background: #ff5f57; }
      :global(.code-runner-wrapper .control.yellow),
      :global(.code-block-wrapper .control.yellow) { background: #febc2e; }
      :global(.code-runner-wrapper .control.green),
      :global(.code-block-wrapper .control.green) { background: #28c840; }

      :global(.code-runner-wrapper .file-name) {
        font-size: 0.8rem;
        color: var(--cr-text-secondary);
      }

