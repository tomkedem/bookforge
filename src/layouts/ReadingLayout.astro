      }

      /* Responsive reading column — fixed width, centered at every breakpoint.
         Mobile: fills viewport. Tablet+: capped at --reading-content-width. */
      .reading-article {
        max-width: var(--reading-content-width, 760px);
        margin-left: auto;
        margin-right: auto;
        transition: margin 0.35s cubic-bezier(0.4, 0, 0.2, 1),
